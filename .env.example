# Analytics option 1: Google Analytics 4
# Example: G-XXXXXXXXXX
PUBLIC_GA4_ID=

# Google Ads conversion tracking
# Example: AW-123456789
PUBLIC_GOOGLE_ADS_CONVERSION_ID=
# Example: AbCdEfGhIjKlMnOpQrSt
PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_LABEL=

# Google Search Console verification meta tag content
# Example: abcdefghijklmnopqrstuvwxyz1234567890
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Analytics option 2: Matomo
# Example: https://analytics.example.com
PUBLIC_MATOMO_URL=
# Example: 1
PUBLIC_MATOMO_SITE_ID=

# Booking link
# Example: https://calendly.com/contact-sunelys/30min
PUBLIC_BOOKING_URL=https://calendly.com/contact-sunelys/30min

# Airtable leads
# Create a personal access token with data.records:write on the base.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Leads
LEAD_ALERT_WEBHOOK_URL=
# Optional reporting controls for npm run marketing:audit.
# AIRTABLE_LEADS_VIEW can point to a filtered Airtable view, for example "Leads qualifiés".
AIRTABLE_LEADS_VIEW=
MARKETING_LEADS_MAX_RECORDS=5000

# Defaults match the current Airtable table visible in "Leads Sunelys".
AIRTABLE_FIELD_FIRST_NAME=Prénom
AIRTABLE_FIELD_LAST_NAME=Nom
AIRTABLE_FIELD_EMAIL=Email

# Optional: only set these after adding matching editable columns in Airtable.
# Leave AIRTABLE_FIELD_DATE empty if "Date entrée" is an automatic Airtable field.
AIRTABLE_FIELD_DATE=
AIRTABLE_FIELD_FULL_NAME=
AIRTABLE_FIELD_COMPANY=Société
AIRTABLE_FIELD_PHONE=Téléphone
AIRTABLE_FIELD_VOLUME=Volume dossiers/mois
AIRTABLE_FIELD_NEED=Besoin principal
AIRTABLE_FIELD_MESSAGE=Commentaire
AIRTABLE_FIELD_CONVERSION_TYPE=
AIRTABLE_FIELD_LEAD_STAGE=
AIRTABLE_FIELD_BLOCKED_STAGE=
AIRTABLE_FIELD_SERVICE_INTEREST=
AIRTABLE_FIELD_LEAD_SOURCE_DETAIL=
AIRTABLE_FIELD_QUALIFICATION_HINT=
AIRTABLE_FIELD_STATUS=Statut
AIRTABLE_FIELD_PIPELINE=
AIRTABLE_FIELD_OWNER=
AIRTABLE_FIELD_FOLLOW_UP_SLA=
AIRTABLE_FIELD_SOURCE=Source
AIRTABLE_FIELD_FIRST_REFERRER=
AIRTABLE_FIELD_UTM_SOURCE=UTM source
AIRTABLE_FIELD_UTM_MEDIUM=UTM medium
AIRTABLE_FIELD_UTM_CAMPAIGN=UTM campaign
AIRTABLE_FIELD_UTM_TERM=
AIRTABLE_FIELD_UTM_CONTENT=
AIRTABLE_FIELD_GCLID=
AIRTABLE_FIELD_FBCLID=
AIRTABLE_FIELD_MSCLKID=
AIRTABLE_FIELD_LANDING_PAGE=Landing page

# Marketing AI agent
# Run with: npm run marketing:audit
# Test Google connection with: npm run marketing:google:test
# Optional OpenAI synthesis. Without this key, the agent still creates a rule-based audit.
OPENAI_API_KEY=
# Latest model default used by the agent; override only if needed.
MARKETING_AGENT_MODEL=gpt-5.5
MARKETING_AGENT_REASONING_EFFORT=low
MARKETING_AGENT_VERBOSITY=medium
MARKETING_AGENT_LOOKBACK_DAYS=90
MARKETING_AGENT_LIVE_URL=https://sunelys.fr
MARKETING_PULSE_INTERVAL_MINUTES=1440
MARKETING_PULSE_MAX_P0=0
MARKETING_PULSE_WEBHOOK=

# Optional Google data connectors for the marketing agent.
# Use either a service account JSON file path or the full/base64 JSON payload.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
# OAuth fallback when service account key creation is blocked by organization policy.
GOOGLE_OAUTH_CLIENT_CREDENTIALS=./secrets/google-oauth-client.json
GOOGLE_OAUTH_TOKEN=./secrets/google-oauth-token.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_JSON=
GA4_PROPERTY_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://sunelys.fr/
SEARCH_CONSOLE_ROW_LIMIT=5000

# Optional PageSpeed Insights collection.
# Enable with MARKETING_AGENT_PAGESPEED=1 or with CLI flag --pagespeed.
MARKETING_AGENT_PAGESPEED=0
PAGESPEED_API_KEY=
