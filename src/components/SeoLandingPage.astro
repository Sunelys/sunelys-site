  .seo-hero .hero-copy {
    gap: 0;
  }

  .seo-hero .hero-copy > .kicker {
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
  }

  .seo-hero h1 {
    max-width: 14ch;
    margin-top: 0.7rem;
