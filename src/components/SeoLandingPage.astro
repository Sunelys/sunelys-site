    color: var(--text-muted);
    font-size: 0.63rem;
    text-align: center;
  }

  .seo-context {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 0.7rem;
    padding: 0.7rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .seo-context .hero-fit-card,
  .seo-context .hero-proof-card {
    min-height: 25rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.2rem, 3vw, 2.5rem);
    border-radius: 16px;
    box-shadow: none;
  }

  .seo-context .hero-fit-card {
    border-color: transparent;
    background: transparent;
  }

  .seo-context .hero-fit-card h2 {
    margin-top: 0.65rem;
  }

  .seo-context .hero-fit-card > p:not(.kicker) {
    max-width: 56ch;
    margin-top: 0.8rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .seo-context .hero-fit-card ul {
    display: grid;
    gap: 0.55rem;
    margin: auto 0 0;
    padding: 1.2rem 0 0;
    list-style: none;
  }

  .seo-context .hero-fit-card li,
  .seo-context .proof-highlights li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .seo-context .hero-fit-card li::before,
  .seo-context .proof-highlights li::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    flex: 0 0 auto;
    margin-top: 0.3rem;
    border-radius: 50%;
    background: var(--system);
  }

  .seo-context .hero-proof-card {
    border-color: var(--ink);
    background:
      radial-gradient(90% 80% at 100% 0%, rgba(54, 98, 227, 0.24), transparent 62%),
      var(--ink);
  }

  .seo-context .hero-proof-card .kicker {
    color: var(--accent);
  }

  .seo-context .hero-proof-card blockquote {
    margin-top: clamp(1.5rem, 4vw, 3rem);
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 650;
    line-height: 1.65;
  }

  .seo-context .proof-signature {
    margin-top: auto;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    font-size: 0.7rem;
    text-transform: none;
  }

  .seo-context .proof-highlights {
    gap: 0.35rem;
    margin-top: 0.8rem;
    padding: 0;
    list-style: none;
  }

  .seo-context .proof-highlights li {
    color: rgba(255, 255, 255, 0.52);
  }

  .seo-context .proof-highlights li::before {
    background: var(--accent);
  }

  .service-pricing-strip {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    background: var(--surface);
  }

  .service-pricing-strip > div {
    display: grid;
    gap: 0.22rem;
  }

  .service-pricing-strip strong {
    color: var(--text);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .service-pricing-strip > a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex: 0 0 auto;
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 760;
    text-underline-offset: 0.25rem;
  }

  .service-pricing-strip > a span {
    color: var(--system);
  }

  .service-decision-recap {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.34fr);
    gap: clamp(1rem, 2vw, 1.35rem);
    overflow: hidden;
    padding: clamp(1.1rem, 3vw, 1.65rem);
    border-color: color-mix(in srgb, var(--system) 13%, var(--line));
    background:
      linear-gradient(90deg, rgba(54, 98, 227, 0.045) 1px, transparent 1px) 0 0 / 38px 38px,
      radial-gradient(90% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 54%, transparent), transparent 62%),
      color-mix(in srgb, var(--surface) 96%, white);
    box-shadow: var(--shadow-sm);
  }

  .service-decision-recap::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--system), var(--accent));
  }

  .decision-recap-head {
    display: grid;
    align-content: center;
    gap: 0.65rem;
  }

  .decision-recap-head h2 {
    max-width: 18ch;
    margin: 0;
    color: var(--ink);
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .decision-recap-head > p:not(.kicker) {
    max-width: 58ch;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .decision-recap-price {
    display: grid;
    align-content: space-between;
    gap: 0.8rem;
    min-height: 13.4rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    border-radius: 18px;
    background:
      radial-gradient(70% 110% at 100% 0%, color-mix(in srgb, var(--accent-soft) 70%, transparent), transparent 68%),
      rgba(255, 255, 255, 0.82);
  }

  .decision-recap-price > span {
    color: var(--accent-strong);
    font-size: 0.66rem;
    font-weight: 820;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .decision-recap-price strong {
    color: var(--ink);
    font-size: clamp(2.1rem, 4vw, 3rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .decision-recap-price small {
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 720;
  }

  .decision-recap-price a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.78rem 0.9rem;
    border-radius: 999px;
    background: var(--ink);
    color: #fff;
    font-size: 0.74rem;
    font-weight: 790;
    text-decoration: none;
  }

  .decision-recap-price a span {
    color: var(--accent);
    transition: transform 160ms ease;
  }

  .decision-recap-price a:hover span {
    transform: translateX(3px);
  }

  .decision-recap-grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .decision-recap-card {
    display: grid;
    align-content: start;
    gap: 0.7rem;
    min-height: 12rem;
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.76);
  }

  .decision-recap-card > span {
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 820;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .decision-recap-card strong {
    max-width: 20ch;
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.18;
  }

  .decision-recap-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .seo-transformation {
    position: relative;
    overflow: hidden;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border-color: color-mix(in srgb, var(--system) 12%, var(--line));
    background:
      radial-gradient(75% 90% at 100% 0%, rgba(54, 98, 227, 0.12), transparent 64%),
      var(--system-soft);
  }

  .transformation-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.64fr);
    gap: clamp(1.2rem, 4vw, 4rem);
    align-items: end;
  }

  .transformation-head h2 {
    max-width: 17ch;
    margin-top: 0.65rem;
    font-size: clamp(2rem, 3.8vw, 3.8rem);
    line-height: 0.98;
  }

  .transformation-head > p {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--accent);
  }

  .transformation-head > p strong {
    color: var(--text);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .transformation-head > p span {
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.55;
  }

  .transformation-stage {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) 6.2rem minmax(0, 1.08fr);
    gap: 0.55rem;
    align-items: stretch;
    margin-top: clamp(1.4rem, 3vw, 2.2rem);
  }

  .workflow-panel {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: #ffffff;
  }

  .workflow-panel header {
    min-height: 6.4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }

  .workflow-panel header > div {
    display: grid;
    gap: 0.2rem;
  }

  .workflow-panel header span,
  .workflow-panel header em {
    color: var(--text-muted);
    font-size: 0.58rem;
    font-style: normal;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .workflow-panel header strong {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .workflow-panel header em {
    flex: 0 0 auto;
    padding: 0.32rem 0.5rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-deep);
    letter-spacing: 0.03em;
  }

  .workflow-panel ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .workflow-panel li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr) auto;
    gap: 0.72rem;
    align-items: center;
    min-height: 5.35rem;
    padding: 0.82rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .workflow-panel li:last-child {
    border-bottom: 0;
  }

  .workflow-panel li > span {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9px;
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.61rem;
    font-weight: 800;
  }

  .workflow-panel li h3,
  .workflow-panel li p {
    margin: 0;
  }

  .workflow-panel li h3 {
    color: var(--text);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .workflow-panel li div p {
    margin-top: 0.16rem;
    color: var(--text-muted);
    font-size: 0.66rem;
    line-height: 1.46;
  }

  .workflow-panel li > i {
    padding: 0.26rem 0.42rem;
    border-radius: 999px;
    background: var(--bg-soft);
    color: var(--text-muted);
    font-size: 0.54rem;
    font-style: normal;
    font-weight: 750;
    white-space: nowrap;
  }

  .workflow-after {
    border-color: var(--ink);
    background:
      radial-gradient(90% 80% at 100% 0%, rgba(54, 98, 227, 0.28), transparent 62%),
      var(--ink);
  }

  .workflow-after header,
  .workflow-after li {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .workflow-after header span {
    color: var(--accent);
  }

  .workflow-after header strong {
    color: #ffffff;
  }

  .workflow-after header em {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.7);
  }

  .workflow-after header em i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 4px rgba(29, 155, 117, 0.16);
    animation: workflow-live 2.4s ease-out infinite;
  }

  .workflow-after li > span {
    background: rgba(212, 130, 42, 0.14);
    color: var(--accent);
  }

  .workflow-after li > p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.72rem;
    font-weight: 620;
    line-height: 1.48;
  }

  .workflow-after li > i {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.48);
  }

  .workflow-handoff {
    position: relative;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .workflow-handoff::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0 50%;
    width: 1px;
    background: linear-gradient(transparent, color-mix(in srgb, var(--accent) 46%, var(--line)), transparent);
  }

  .workflow-handoff span,
  .workflow-handoff strong {
    position: relative;
    z-index: 1;
  }

  .workflow-handoff span {
    padding: 0.3rem 0.45rem;
    border-radius: 999px;
    background: var(--system-soft);
    color: var(--text-muted);
    font-size: 0.53rem;
    font-weight: 800;
    text-align: center;
    text-transform: uppercase;
  }

  .workflow-handoff strong {
    display: inline-grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 14px;
    background: var(--accent);
    color: #ffffff;
    font-size: 1.15rem;
    box-shadow: 0 14px 30px rgba(212, 130, 42, 0.26);
    animation: workflow-transfer 2.2s ease-in-out infinite;
  }

  .transformation-outcomes {
    display: grid;
    grid-template-columns: minmax(130px, 0.35fr) minmax(0, 1fr) auto;
    gap: clamp(1rem, 2.5vw, 2rem);
    align-items: center;
    margin-top: 0.7rem;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 16px;
    background: #ffffff;
  }

  .transformation-outcomes > p {
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.4;
  }

  .transformation-outcomes ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .transformation-outcomes li {
    display: flex;
    gap: 0.45rem;
    color: var(--text-muted);
    font-size: 0.63rem;
    line-height: 1.4;
  }

  .transformation-outcomes li::before {
    content: "";
    flex: 0 0 auto;
    width: 0.36rem;
    height: 0.36rem;
    margin-top: 0.25rem;
    border-radius: 50%;
    background: var(--success);
  }

  .transformation-outcomes .btn {
    min-height: 2.8rem;
    white-space: nowrap;
  }

  .seo-final[id] {
    scroll-margin-top: 6rem;
  }

  @keyframes workflow-transfer {
    0%,
    20% {
      transform: translateX(-0.14rem);
    }

    70%,
    100% {
      transform: translateX(0.14rem);
    }
  }

  @keyframes workflow-live {
    0%,
    55% {
      box-shadow: 0 0 0 4px rgba(29, 155, 117, 0.16);
    }

    85%,
    100% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  .split-head {
    gap: clamp(1.2rem, 4vw, 4rem);
  }

  .split-head > p {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .problem-intro {
    max-width: 70ch;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .problem-grid,
  .details-grid,
  .use-case-grid,
  .signal-grid {
    gap: 0;
    margin-top: 1.5rem;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .problem-card,
  .detail-card,
  .use-case-card,
  .signal-grid p {
    min-height: 11rem;
    align-content: end;
    padding: 1rem;
    border: 0;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
  }

  .problem-card h3,
  .detail-card h3,
  .use-case-card h3 {
    font-size: 0.9rem;
  }

  .problem-card p,
  .detail-card p,
  .use-case-card p,
  .signal-grid p {
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.52;
  }

  .seo-problem {
    background: var(--system-soft);
  }

  .seo-use-cases,
  .seo-details {
    background: var(--surface);
  }

  .scope-layout {
    gap: 0.65rem;
    margin-top: 1.5rem;
  }

  .scope-panel {
    min-height: 24rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.1rem, 2.5vw, 1.8rem);
    border-color: var(--line);
    border-radius: 16px;
    background: var(--system-soft);
  }

  .scope-panel h3 {
    font-size: 1.1rem;
  }

  .scope-panel ul {
    display: grid;
    gap: 0.6rem;
    margin-top: auto;
    padding: 1.2rem 0 0;
    list-style: none;
  }

  .scope-panel li {
    display: flex;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  .scope-panel li::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    flex: 0 0 auto;
    margin-top: 0.3rem;
    border-radius: 50%;
    background: var(--system);
  }

  .scope-panel-dark {
    border-color: var(--ink);
    background:
      radial-gradient(90% 80% at 100% 0%, rgba(54, 98, 227, 0.24), transparent 62%),
      var(--ink);
  }

  .scope-panel-dark li {
    color: rgba(255, 255, 255, 0.6);
  }

  .scope-panel-dark li::before {
    background: var(--accent);
  }

  .seo-process {
    background: var(--system-soft);
  }

  .seo-process ol {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
    border-left: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .seo-process li {
    min-height: 12rem;
    display: flex;
    align-items: end;
    padding: 3.2rem 1rem 1rem;
    border: 0;
    border-right: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
    border-bottom: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font-size: 0.74rem;
    line-height: 1.5;
  }

  .seo-process li::before {
    left: 1rem;
    top: 1rem;
    width: auto;
    height: auto;
    border: 0;
    background: transparent;
    color: var(--system);
    font-size: 0.65rem;
    transform: none;
  }

  .seo-delegation {
    background: var(--surface);
  }

  .seo-delegation .signal-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .seo-delegation .btn {
    margin-top: 1rem;
  }

  .seo-case {
    border-color: var(--ink);
    background:
      radial-gradient(80% 100% at 100% 0%, rgba(54, 98, 227, 0.25), transparent 62%),
      var(--ink);
  }

  .seo-case .kicker {
    color: var(--accent);
  }

  .seo-case h2 {
    color: #ffffff;
  }

  .seo-case .volume {
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.75rem;
  }

  .seo-case ul {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .seo-case li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
  }

  .faq-grid {
    display: block;
    margin-top: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .faq-card {
    padding: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
  }

  .faq-card summary {
    cursor: pointer;
    list-style: none;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem 0;
  }

  .faq-card summary::-webkit-details-marker {
    display: none;
  }

  .faq-card summary > span {
    color: var(--system);
    font-size: 0.63rem;
    font-weight: 800;
  }

  .faq-card summary strong {
    color: var(--text);
    font-size: 0.82rem;
    line-height: 1.4;
  }

  .faq-card summary i {
    position: relative;
    width: 1.7rem;
    height: 1.7rem;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .faq-card summary i::before,
  .faq-card summary i::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.6rem;
    height: 1px;
    background: var(--text);
    transform: translate(-50%, -50%);
  }

  .faq-card summary i::after {
