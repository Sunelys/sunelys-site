---
import { filterVisibleLinks, publicBlogSlugs } from "../lib/blogPublication";
import BrandSignature from "./BrandSignature.astro";
import FormPrivacyNote from "./FormPrivacyNote.astro";

interface ProblemItem {
  title: string;
  text: string;
}

interface CaseStudyData {
  title: string;
  volume: string;
  results: string[];
}

interface FaqItem {
  question: string;
  answer: string;
}

interface InternalLink {
  href: string;
  label: string;
}

interface GuideLink {
  href: string;
  label: string;
  description: string;
}

interface DetailBlock {
  title: string;
  text: string;
}

interface UseCaseItem {
  title: string;
  text: string;
}

interface DecisionRecapItem {
  label: string;
  title: string;
  text: string;
}

interface SeoPageContent {
  slug: string;
  heroTitle: string;
  heroSubtitle: string;
  heroPrimaryLabel?: string;
  heroSecondaryCta?: {
    label: string;
    href: string;
  };
  conversionOffer?: {
    eyebrow: string;
    label: string;
    price: string;
    priceNote: string;
    scope: string;
    terms: string[];
  };
  heroCheckpoint?: {
    eyebrow: string;
    title: string;
    items: Array<{ label: string; status: string }>;
  };
  decisionRecap?: {
    eyebrow: string;
    title: string;
    text: string;
    priceLabel: string;
    price: string;
    priceNote: string;
    cta: {
      label: string;
      href: string;
      track: string;
    };
    items: DecisionRecapItem[];
  };
  quickFormTitle?: string;
  quickFormSubmitLabel?: string;
  quickFormNote?: string;
  diagnosticLabel?: string;
  diagnosticOptions?: Array<{ value: string; label: string }>;
  fitTitle: string;
  fitIntro: string;
  fitItems: string[];
  proof: {
    quote: string;
    author: string;
    role: string;
    highlights: string[];
  };
  problemTitle: string;
  problemIntro: string;
  problemItems: ProblemItem[];
  useCaseItems?: UseCaseItem[];
  scopeItems: string[];
  detailBlocks?: DetailBlock[];
  processSteps: string[];
  signalTitle: string;
  signalIntro: string;
  signalItems: string[];
  caseStudy: CaseStudyData;
  faqItems: FaqItem[];
  finalTitle: string;
  finalText: string;
  guideLinks?: GuideLink[];
  internalLinks: InternalLink[];
}

interface Props {
  data: SeoPageContent;
}

const { data } = Astro.props;
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const successUrl = `https://sunelys.fr/merci?source=${data.slug}_service_form`;

const heroBadges = [
  "Pour installateurs photovoltaïques",
  "Dossier ponctuel accepté",
  "Diagnostic gratuit sous 24h",
];

const heroBadgesBySlug: Record<string, string[]> = {
  gestion_administrative: [
    "Pilotage opérationnel du flux dossier",
    "Pilotage sous 48h sur dossier complet",
    "Moins de points de friction manuels",
  ],
  consuel_photovoltaique: [
    "Préparation de dossier en phase de chantier",
    "Contrôle documentaire avant envoi",
    "Relances structurées jusqu'à validation",
  ],
  raccordement_enedis: [
    "Dossier raccordement Enedis clarifié",
    "Statuts centralisés, relances suivies",
    "Diminution des allers-retours",
  ],
  declaration_prealable: [
    "DP propre dès la première soumission",
    "Check-list pièces techniques + administratives",
    "Moins d'aller-retour en mairie",
  ],
  sous_traitance_declaration_prealable: [
    "Externalisation encadrée DP",
    "Responsable Sunelys dédié au suivi",
    "Pilotage humain au-delà du formulaire",
  ],
  tarif_declaration_prealable: [
    "Tarification simple par dossier",
    "Sans engagement caché",
    "Transparence sur le périmètre",
  ],
};

const decisionBySlug: Record<string, string[]> = {
  gestion_administrative: [
    "Quel flux vous coûte le plus de temps ?",
    "Quel est votre volume de dossiers mensuel ?",
    "Quels blocages vous coûtent le plus en production ?",
  ],
  consuel_photovoltaique: [
    "La mise en service bloque vos chantiers ?",
    "Vos pièces sont-elles validées avant envoi ?",
    "Qui suit les demandes de complément ?",
  ],
  raccordement_enedis: [
    "Vos demandes Enedis restent-elles sans réponse ?",
    "Le dossier de raccordement manque-t-il de pièces ?",
    "Vos statuts sont-ils visibles pour vos équipes ?",
  ],
  declaration_prealable: [
    "Votre première DP a été refusée récemment ?",
    "Vos pièces ont-elles été standardisées ?",
    "Quelle étape bloque la signature client ?",
  ],
  sous_traitance_declaration_prealable: [
    "Votre équipe peut-elle continuer à vendre sereinement ?",
    "Quel délai de reprise voulez-vous gagner ?",
    "Quels risques acceptez-vous de porter encore ?",
  ],
  tarif_declaration_prealable: [
    "Vous cherchez une visibilité budgétaire simple ?",
    "Quel volume avez-vous par mois ?",
    "Vous préférez un coût par dossier stable ?",
  ],
};

const serviceInterestBySlug: Record<string, string> = {
  gestion_administrative: "Pilotage complet DP, Consuel et raccordement",
  consuel_photovoltaique: "Dossier Consuel photovoltaïque",
  raccordement_enedis: "Raccordement Enedis photovoltaïque",
  declaration_prealable: "Déclaration préalable panneaux solaires",
  sous_traitance_declaration_prealable: "Sous-traitance déclaration préalable solaire",
  tarif_declaration_prealable: "Tarif déclaration préalable photovoltaïque",
};

const serviceInterest = serviceInterestBySlug[data.slug] || data.heroTitle;
const isGestionLanding = data.slug === "gestion_administrative";
const signatureVariant = data.slug.includes("tarif")
  ? "pricing"
  : isGestionLanding
    ? "flow"
    : "editorial";
const heroSecondaryCta =
  data.heroSecondaryCta ??
  (isGestionLanding
    ? { label: "Voir les tarifs du pilotage complet", href: "/tarifs" }
    : { label: "Voir les services", href: "/services" });
const heroPrimaryLabel = data.heroPrimaryLabel ?? "Décrire mon dossier";
const quickSubmitLabel = data.quickFormSubmitLabel ?? (isGestionLanding ? "Recevoir mon plan d'action" : "Décrire mon dossier");
const delegationLabel = isGestionLanding ? "Diagnostiquer mon flux administratif" : "Faire le point sur mes blocages";
const finalSubmitLabel = isGestionLanding ? "Recevoir mon plan d'action" : "Recevoir mon diagnostic";
const diagnosticLabel = data.diagnosticLabel ?? "Étape bloquée";
const serviceBadges = heroBadgesBySlug[data.slug] || heroBadges;
const decisionStrip = decisionBySlug[data.slug] || [
  "Votre point de friction principal aujourd'hui",
  "Le volume de dossiers à traiter",
  "Le délai où ça coince le plus",
];
const quickFormPrompt =
  isGestionLanding
    ? "Choisissez la première étape et on vous renvoie un plan de priorisation par ordre de valeur."
    : "En 2 minutes, on situe votre point de friction et on trace votre prochaine action.";
const diagnosticOptions =
  data.diagnosticOptions ?? [
    { value: "Avant dépôt", label: "Avant dépôt" },
    { value: "Complément mairie", label: "Complément mairie" },
    { value: "Consuel à préparer", label: "Consuel à préparer" },
    { value: "Raccordement en attente", label: "Raccordement en attente" },
    { value: "Dossier d'aide à déposer", label: "Dossier d'aide à déposer" },
    { value: "Prime à suivre", label: "Prime à suivre" },
    { value: "Mise en service bloquée", label: "Mise en service bloquée" },
    { value: "Pilotage global", label: "Pilotage global" },
    { value: "Je ne sais pas encore", label: "Je ne sais pas encore" },
  ];

const outcomeItems = [
  "Moins de charge administrative pour vos équipes",
  "Moins de retours liés aux pièces incomplètes",
  "Plus de visibilité sur les jalons et les blocages",
  "Une expérience client plus fluide côté installateur",
];

const portalProofItems = [
  "Statuts, pièces attendues et prochaines actions visibles au même endroit",
  "DP, raccordement, Consuel et aides suivis dans une logique de dossier",
  "Un outil de suivi, mais surtout un pilotage humain pour relancer et sécuriser",
];

const attributionFields = [
  "landing_page",
  "first_referrer",
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "fbclid",
  "msclkid",
];

const salesContact = {
  name: "Myriam Zaoui",
  email: "contact@sunelys.fr",
  phone: "06 95 90 79 19",
  emailHref: "mailto:contact@sunelys.fr",
  phoneHref: "tel:+33695907919",
};

const visibleInternalLinks = filterVisibleLinks(data.internalLinks, publicBlogSlugs);
const visibleGuideLinks = filterVisibleLinks(data.guideLinks, publicBlogSlugs);
---

<section class="seo-section seo-hero section-shell reveal">
  <BrandSignature variant={signatureVariant} compact />
  <div class="hero-layout">
    <div class="hero-copy" data-reveal-item>
      <p class="kicker">Service administratif photovoltaïque</p>
      <h1>{data.heroTitle}</h1>
      <p>{data.heroSubtitle}</p>
      <p class="expert-line">
        Un pilotage administratif solaire exigeant, pensé pour les installateurs qui veulent grandir sans perdre le contrôle.
      </p>

      {
        data.conversionOffer && (
          <div
        class="hero-conversion-offer"
        aria-label={`${data.conversionOffer.label} à ${data.conversionOffer.price} HT par dossier`}
        data-track-view="service_offer_view"
        data-track-label={data.slug}
      >
            <div class="conversion-offer-head">
              <div>
                <span>{data.conversionOffer.eyebrow}</span>
                <strong>{data.conversionOffer.label}</strong>
              </div>
              <p>
                <strong>{data.conversionOffer.price}</strong>
                <span>{data.conversionOffer.priceNote}</span>
              </p>
            </div>
            <p class="conversion-offer-scope">{data.conversionOffer.scope}</p>
            <ul>
              {data.conversionOffer.terms.map((term) => <li>{term}</li>)}
            </ul>
          </div>
        )
      }

      {
        data.heroCheckpoint && (
          <div
            class="hero-checkpoint"
            aria-label={data.heroCheckpoint.title}
            data-track-view="service_checkpoint_view"
            data-track-label={data.slug}
          >
            <div>
              <span>{data.heroCheckpoint.eyebrow}</span>
              <strong>{data.heroCheckpoint.title}</strong>
            </div>
            <ol>
              {data.heroCheckpoint.items.map((item) => (
                <li>
                  <span>{item.label}</span>
                  <em>{item.status}</em>
                </li>
              ))}
            </ol>
          </div>
        )
      }

      <ul class="hero-badges" aria-label="Informations clés Sunelys">
        {serviceBadges.map((badge) => <li>{badge}</li>)}
      </ul>

      <div class="hero-fit-card" data-track-view="service_decision_view" aria-label="Point de départ du diagnostic">
        <p class="kicker">Décision rapide</p>
        <p>{quickFormPrompt}</p>
        <ul class="hero-badges" aria-label="Questions de cadrage">
          {decisionStrip.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      {
        isGestionLanding && (
          <ul class="hero-price-pills" aria-label="Tarifs principaux Sunelys">
            <li>
              <span>DP complète</span>
              <strong>119 € HT</strong>
            </li>
            <li>
              <span>Raccordement + Consuel</span>
              <strong>89 € HT</strong>
            </li>
            <li>
              <span>Pilotage complet</span>
              <strong>199 € HT</strong>
            </li>
          </ul>
        )
      }

      <div class="hero-actions">
        <a class="btn btn-accent" href={`#service-quick-${data.slug}`} data-track={`cta_${data.slug}_hero`}>
          {heroPrimaryLabel}
        </a>
        <a class="btn btn-secondary" href={heroSecondaryCta.href} data-track={`cta_${data.slug}_hero_services`}>
          {heroSecondaryCta.label}
        </a>
      </div>
    </div>

    <aside class="hero-aside" data-reveal-item>
      <article
        id={`service-quick-${data.slug}`}
        class="hero-lead-card"
        aria-label="Demande de cadrage rapide"
        data-track-view="service_quick_form_view"
        data-track-label={data.slug}
      >
        <p class="kicker">Réponse personnalisée sous 24h</p>
        <h2>{data.quickFormTitle ?? "Identifiez le premier flux administratif à déléguer."}</h2>
        <form
          class="hero-service-form"
          action={leadFormAction}
          method="POST"
          data-lead-form
          data-conversion-type="form_contact"
        >
          <input type="hidden" name="_subject" value={`Nouveau cadrage service hero - ${data.heroTitle}`} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_next" value={successUrl} />
          <input type="hidden" name="source_page" value={`${data.slug}_hero`} />
          <input type="hidden" name="conversion_type" value="form_contact" />
          <input type="hidden" name="lead_stage" value="service_hero_form_submitted" />
          <input type="hidden" name="service_interest" value={serviceInterest} />
          <input type="hidden" name="lead_source_detail" value={`${data.slug}_hero_form`} />
          <input type="hidden" name="qualification_hint" value="email professionnel, téléphone optionnel, volume mensuel et étape bloquée" />
          <input type="hidden" name="lead_status" value="Nouveau lead" />
          <input type="hidden" name="lead_pipeline" value="Site web - Page service hero" />
          <input type="hidden" name="lead_owner" value="Sunelys commercial" />
          <input type="hidden" name="follow_up_sla" value="24h" />
          <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
          {attributionFields.map((fieldName) => (
            <input type="hidden" name={fieldName} data-service-attribution={fieldName} />
          ))}

          <label>
            <span>Email professionnel</span>
            <input type="email" name="email" autocomplete="email" inputmode="email" required />
          </label>
          <label>
            <span>Téléphone pour rappel <em>optionnel</em></span>
            <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
          </label>
          <label>
            <span>Volume mensuel</span>
            <select name="volume" required>
              <option value="">Sélectionner</option>
              <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
              <option value="10-30 dossiers">10-30 dossiers</option>
              <option value="+30 dossiers">+30 dossiers</option>
            </select>
          </label>
          <label>
            <span>{diagnosticLabel}</span>
            <select name="blocked_stage" required>
              <option value="">Sélectionner</option>
              {diagnosticOptions.map((option) => <option value={option.value}>{option.label}</option>)}
            </select>
          </label>
        <button class="btn btn-primary btn-accent" type="submit" data-track={`cta_${data.slug}_hero_form`}>
            {quickSubmitLabel}
          </button>
          <small>{data.quickFormNote ?? "Email requis. Volume et blocage obligatoires. Téléphone optionnel."}</small>
          <FormPrivacyNote />
        </form>

        <div class="hero-contact-identity">
          <p>Mon interlocutrice</p>
          <strong>{salesContact.name}</strong>
          <a href={salesContact.emailHref} data-track={`cta_${data.slug}_hero_email`}>
            {salesContact.email}
          </a>
          <a href={salesContact.phoneHref} data-track={`cta_${data.slug}_hero_phone`}>
            {salesContact.phone}
          </a>
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="seo-context section-shell reveal" aria-label="Contexte et preuve">
  <article class="hero-fit-card" data-reveal-item>
    <p class="kicker">Quand ce service vous concerne</p>
    <h2>{data.fitTitle}</h2>
    <p>{data.fitIntro}</p>
    <ul>
      {data.fitItems.map((item) => <li>{item}</li>)}
    </ul>
  </article>

  <article class="hero-proof-card" data-reveal-item>
    <p class="kicker">Retour terrain</p>
    <blockquote>{data.proof.quote}</blockquote>
    <p class="proof-signature">
      {data.proof.author}
      <span>{data.proof.role}</span>
    </p>
    <ul class="proof-highlights">
      {data.proof.highlights.map((highlight) => <li>{highlight}</li>)}
    </ul>
  </article>
</section>

<section class="service-pricing-strip section-shell reveal" aria-label="Tarification Sunelys">
  <div data-reveal-item>
    <p class="kicker">Tarifs fixes</p>
    <strong>Dossier ponctuel accepté · aucun abonnement · facturation au réel</strong>
  </div>
  <a href="/tarifs" data-track={`cta_${data.slug}_pricing_strip`}>
    Consulter tous les tarifs
    <span aria-hidden="true">→</span>
  </a>
</section>

{
  data.decisionRecap && (
    <section
      class="service-decision-recap section-shell reveal"
      aria-labelledby={`service-decision-${data.slug}`}
      data-track-view="service_decision_recap_view"
      data-track-label={data.slug}
    >
      <div class="decision-recap-head" data-reveal-item>
        <p class="kicker">{data.decisionRecap.eyebrow}</p>
        <h2 id={`service-decision-${data.slug}`}>{data.decisionRecap.title}</h2>
        <p>{data.decisionRecap.text}</p>
      </div>

      <aside class="decision-recap-price" aria-label="Repère tarifaire" data-reveal-item>
        <span>{data.decisionRecap.priceLabel}</span>
        <strong>{data.decisionRecap.price}</strong>
        <small>{data.decisionRecap.priceNote}</small>
        <a href={data.decisionRecap.cta.href} data-track={data.decisionRecap.cta.track}>
          {data.decisionRecap.cta.label}
          <span aria-hidden="true">→</span>
        </a>
      </aside>

      <div class="decision-recap-grid">
        {data.decisionRecap.items.map((item, index) => (
          <article class="decision-recap-card" data-reveal-item>
            <span>0{index + 1} · {item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

{
  isGestionLanding && (
    <section class="seo-section seo-portal-proof section-shell reveal">
      <div class="split-head">
        <div>
          <p class="kicker">Portail client inclus</p>
          <h2>Une vision claire des dossiers, sans perdre le pilotage humain.</h2>
        </div>
        <p>
          Le portail ne remplace pas Sunelys. Il rend le suivi lisible: vos dossiers, leurs statuts,
          les pièces attendues et les prochaines actions restent visibles pour éviter les relances à l'aveugle.
        </p>
      </div>

      <div class="portal-proof-layout">
        <figure class="portal-proof-cover">
          <img
            src="/google-business-profile/sunelys-gbp-cover-portail-2026-07-21.jpg"
            alt="Aperçu du portail client Sunelys pour le suivi administratif photovoltaïque"
            width="1254"
            height="705"
            loading="lazy"
            decoding="async"
          />
        </figure>

        <div class="portal-proof-stack">
          <figure>
            <img
              src="/google-business-profile/sunelys-gbp-portail-dashboard-propre-2026-07-21.jpg"
              alt="Vue d'ensemble anonymisée du portail client Sunelys"
              width="1600"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <figure>
            <img
              src="/google-business-profile/sunelys-gbp-portail-dossiers-propre-2026-07-21.jpg"
              alt="Liste anonymisée de dossiers dans le portail client Sunelys"
              width="1600"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <div class="portal-proof-copy">
          <ul>
            {portalProofItems.map((item) => <li>{item}</li>)}
          </ul>
          <a
            class="btn btn-primary btn-accent"
            href={`/contact?source=${data.slug}_portal_proof#contact-form`}
            data-track={`cta_${data.slug}_portal_proof`}
          >
            Voir comment reprendre vos dossiers
          </a>
        </div>
      </div>
    </section>
  )
}

<section
  class="seo-section seo-transformation section-shell reveal"
  aria-labelledby={`transformation-${data.slug}`}
  data-track-view="service_transformation_view"
  data-track-label={data.slug}
>
  <div class="transformation-head" data-reveal-item>
    <div>
      <p class="kicker">Avant / Avec Sunelys</p>
      <h2 id={`transformation-${data.slug}`}>Le même dossier. Pas la même charge administrative.</h2>
    </div>
    <p>
      <strong>{data.problemTitle}</strong>
      <span>{data.problemIntro}</span>
    </p>
  </div>

  <div class="transformation-stage">
    <article class="workflow-panel workflow-before" data-reveal-item>
      <header>
        <div>
          <span>Dans votre équipe</span>
          <strong>Le flux se disperse</strong>
        </div>
        <em>Sans relais dédié</em>
      </header>
      <ol>
        {
          data.problemItems.map((item, index) => (
            <li>
              <span>0{index + 1}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
              <i>À traiter</i>
            </li>
          ))
        }
      </ol>
    </article>

    <div class="workflow-handoff" aria-hidden="true" data-reveal-item>
      <span>Sunelys reprend</span>
      <strong>→</strong>
    </div>

    <article class="workflow-panel workflow-after" data-reveal-item>
      <header>
        <div>
          <span>Avec Sunelys</span>
          <strong>Le flux devient piloté</strong>
        </div>
        <em><i></i> Suivi actif</em>
      </header>
      <ol>
        {
          data.scopeItems.map((item, index) => (
            <li>
              <span aria-hidden="true">✓</span>
              <p>{item}</p>
              <i>{index === data.scopeItems.length - 1 ? "Visible" : "Suivi"}</i>
            </li>
          ))
        }
      </ol>
    </article>
  </div>

  <div class="transformation-outcomes" data-reveal-item>
    <p>Ce que vos équipes récupèrent</p>
    <ul>
      {outcomeItems.map((item) => <li>{item}</li>)}
    </ul>
    <a
      class="btn btn-accent"
      href={`#service-final-${data.slug}`}
      data-track={`cta_${data.slug}_transformation`}
    >
      Faire reprendre ce flux
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

{
  data.useCaseItems && data.useCaseItems.length > 0 && (
    <section class="seo-section seo-use-cases section-shell reveal">
      <div class="split-head">
        <div>
          <p class="kicker">Cas d'usage</p>
          <h2>Les situations où Sunelys accélère vos DP</h2>
        </div>
        <p>
          Chaque installateur n'a pas le même volume ni les mêmes blocages. La prise en charge
          s'adapte au flux réel: dossiers récurrents, reprises après complément ou coordination
          entre plusieurs interlocuteurs.
        </p>
      </div>
