---
import { filterVisibleLinks, publicBlogSlugs } from "../lib/blogPublication";
import BrandSignature from "./BrandSignature.astro";

interface ProblemItem {
  title: string;
  text: string;
}

interface CaseStudyData {
  title: string;
  volume: string;
  results: string[];
}

interface FaqItem {
  question: string;
  answer: string;
}

interface InternalLink {
  href: string;
  label: string;
}

interface GuideLink {
  href: string;
  label: string;
  description: string;
}

interface DetailBlock {
  title: string;
  text: string;
}

interface UseCaseItem {
  title: string;
  text: string;
}

interface SeoPageContent {
  slug: string;
  heroTitle: string;
  heroSubtitle: string;
  fitTitle: string;
  fitIntro: string;
  fitItems: string[];
  proof: {
    quote: string;
    author: string;
    role: string;
    highlights: string[];
  };
  problemTitle: string;
  problemIntro: string;
  problemItems: ProblemItem[];
  useCaseItems?: UseCaseItem[];
  scopeItems: string[];
  detailBlocks?: DetailBlock[];
  processSteps: string[];
  signalTitle: string;
  signalIntro: string;
  signalItems: string[];
  caseStudy: CaseStudyData;
  faqItems: FaqItem[];
  finalTitle: string;
  finalText: string;
  guideLinks?: GuideLink[];
  internalLinks: InternalLink[];
}

interface Props {
  data: SeoPageContent;
}

const { data } = Astro.props;
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const successUrl = `https://sunelys.fr/merci?source=${data.slug}_service_form`;

const heroBadges = [
  "Pour installateurs photovoltaïques",
  "Dossier ponctuel accepté",
  "Diagnostic gratuit sous 24h",
];

const serviceInterestBySlug: Record<string, string> = {
  gestion_administrative: "Pilotage complet DP, Consuel et raccordement",
  consuel_photovoltaique: "Dossier Consuel photovoltaïque",
  raccordement_enedis: "Raccordement Enedis photovoltaïque",
  declaration_prealable: "Déclaration préalable panneaux solaires",
  sous_traitance_declaration_prealable: "Sous-traitance déclaration préalable solaire",
  tarif_declaration_prealable: "Tarif déclaration préalable photovoltaïque",
};

const serviceInterest = serviceInterestBySlug[data.slug] || data.heroTitle;
const isGestionLanding = data.slug === "gestion_administrative";
const signatureVariant = data.slug.includes("tarif")
  ? "pricing"
  : isGestionLanding
    ? "flow"
    : "editorial";
const heroSecondaryCta = isGestionLanding
  ? { label: "Voir les tarifs du pilotage complet", href: "/tarifs" }
  : { label: "Voir les services", href: "/services" };
const heroPrimaryLabel = "Recevoir mon diagnostic gratuit";
const delegationLabel = isGestionLanding ? "Diagnostiquer mon flux administratif" : "Faire le point sur mes blocages";
const finalSubmitLabel = isGestionLanding ? "Recevoir mon plan d'action" : "Recevoir mon diagnostic";

const outcomeItems = [
  "Moins de charge administrative pour vos équipes",
  "Moins de retours liés aux pièces incomplètes",
  "Plus de visibilité sur les jalons et les blocages",
  "Une expérience client plus fluide côté installateur",
];

const portalProofItems = [
  "Statuts, pièces attendues et prochaines actions visibles au même endroit",
  "DP, raccordement, Consuel et aides suivis dans une logique de dossier",
  "Un outil de suivi, mais surtout un pilotage humain pour relancer et sécuriser",
];

const attributionFields = [
  "landing_page",
  "first_referrer",
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "fbclid",
  "msclkid",
];

const visibleInternalLinks = filterVisibleLinks(data.internalLinks, publicBlogSlugs);
const visibleGuideLinks = filterVisibleLinks(data.guideLinks, publicBlogSlugs);
---

<section class="seo-section seo-hero section-shell reveal">
  <BrandSignature variant={signatureVariant} compact />
  <div class="hero-layout">
    <div class="hero-copy" data-reveal-item>
      <p class="kicker">Service administratif photovoltaïque</p>
      <h1>{data.heroTitle}</h1>
      <p>{data.heroSubtitle}</p>
      <p class="expert-line">
        Un pilotage administratif solaire exigeant, pensé pour les installateurs qui veulent grandir sans perdre le contrôle.
      </p>

      <ul class="hero-badges" aria-label="Informations clés Sunelys">
        {heroBadges.map((badge) => <li>{badge}</li>)}
      </ul>

      {
        isGestionLanding && (
          <ul class="hero-price-pills" aria-label="Tarifs principaux Sunelys">
            <li>
              <span>DP complète</span>
              <strong>119 € HT</strong>
            </li>
            <li>
              <span>Raccordement + Consuel</span>
              <strong>89 € HT</strong>
            </li>
            <li>
              <span>Pilotage complet</span>
              <strong>199 € HT</strong>
            </li>
          </ul>
        )
      }

      <div class="hero-actions">
        <a class="btn btn-accent" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_hero`}>
          {heroPrimaryLabel}
        </a>
        <a class="btn btn-secondary" href={heroSecondaryCta.href} data-track={`cta_${data.slug}_hero_services`}>
          {heroSecondaryCta.label}
        </a>
      </div>
    </div>

    <aside class="hero-aside" data-reveal-item>
      <article class="hero-lead-card" aria-label="Demande de cadrage rapide">
        <p class="kicker">Diagnostic sous 24h</p>
        <h2>Identifiez le premier flux administratif à déléguer.</h2>
        <form
          class="hero-service-form"
          action={leadFormAction}
          method="POST"
          data-lead-form
          data-conversion-type="form_contact"
        >
          <input type="hidden" name="_subject" value={`Nouveau cadrage service hero - ${data.heroTitle}`} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_next" value={successUrl} />
          <input type="hidden" name="source_page" value={`${data.slug}_hero`} />
          <input type="hidden" name="conversion_type" value="form_contact" />
          <input type="hidden" name="lead_stage" value="service_hero_form_submitted" />
          <input type="hidden" name="service_interest" value={serviceInterest} />
          <input type="hidden" name="lead_source_detail" value={`${data.slug}_hero_form`} />
          <input type="hidden" name="qualification_hint" value="email professionnel, téléphone optionnel, volume mensuel et étape bloquée" />
          <input type="hidden" name="lead_status" value="Nouveau lead" />
          <input type="hidden" name="lead_pipeline" value="Site web - Page service hero" />
          <input type="hidden" name="lead_owner" value="Sunelys commercial" />
          <input type="hidden" name="follow_up_sla" value="24h" />
          <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
          {attributionFields.map((fieldName) => (
            <input type="hidden" name={fieldName} data-service-attribution={fieldName} />
          ))}

          <label>
            <span>Email professionnel</span>
            <input type="email" name="email" autocomplete="email" inputmode="email" required />
          </label>
          <label>
            <span>Téléphone pour rappel <em>optionnel</em></span>
            <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
          </label>
          <label>
            <span>Volume mensuel</span>
            <select name="volume" required>
              <option value="">Sélectionner</option>
              <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
              <option value="10-30 dossiers">10-30 dossiers</option>
              <option value="+30 dossiers">+30 dossiers</option>
            </select>
          </label>
          <label>
            <span>Étape bloquée</span>
            <select name="blocked_stage" required>
              <option value="">Sélectionner</option>
              <option value="Avant dépôt">Avant dépôt</option>
              <option value="Complément mairie">Complément mairie</option>
              <option value="Consuel à préparer">Consuel à préparer</option>
              <option value="Raccordement en attente">Raccordement en attente</option>
              <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
              <option value="Prime à suivre">Prime à suivre</option>
              <option value="Mise en service bloquée">Mise en service bloquée</option>
              <option value="Pilotage global">Pilotage global</option>
              <option value="Je ne sais pas encore">Je ne sais pas encore</option>
            </select>
          </label>
          <button class="btn btn-primary btn-accent" type="submit" data-track={`cta_${data.slug}_hero_form`}>
            Recevoir mon plan d'action
          </button>
          <small>Email, volume et blocage. Téléphone optionnel.</small>
        </form>
      </article>
    </aside>
  </div>
</section>

<section class="seo-context section-shell reveal" aria-label="Contexte et preuve">
  <article class="hero-fit-card" data-reveal-item>
    <p class="kicker">Quand ce service vous concerne</p>
    <h2>{data.fitTitle}</h2>
    <p>{data.fitIntro}</p>
    <ul>
      {data.fitItems.map((item) => <li>{item}</li>)}
    </ul>
  </article>

  <article class="hero-proof-card" data-reveal-item>
    <p class="kicker">Retour terrain</p>
    <blockquote>{data.proof.quote}</blockquote>
    <p class="proof-signature">
      {data.proof.author}
      <span>{data.proof.role}</span>
    </p>
    <ul class="proof-highlights">
      {data.proof.highlights.map((highlight) => <li>{highlight}</li>)}
    </ul>
  </article>
</section>

<section class="service-pricing-strip section-shell reveal" aria-label="Tarification Sunelys">
  <div data-reveal-item>
    <p class="kicker">Tarifs fixes</p>
    <strong>Dossier ponctuel accepté · aucun abonnement · facturation au réel</strong>
  </div>
  <a href="/tarifs" data-track={`cta_${data.slug}_pricing_strip`}>
    Consulter tous les tarifs
    <span aria-hidden="true">→</span>
  </a>
</section>

{
  isGestionLanding && (
    <section class="seo-section seo-portal-proof section-shell reveal">
      <div class="split-head">
        <div>
          <p class="kicker">Portail client inclus</p>
          <h2>Une vision claire des dossiers, sans perdre le pilotage humain.</h2>
        </div>
        <p>
          Le portail ne remplace pas Sunelys. Il rend le suivi lisible: vos dossiers, leurs statuts,
          les pièces attendues et les prochaines actions restent visibles pour éviter les relances à l'aveugle.
        </p>
      </div>

      <div class="portal-proof-layout">
        <figure class="portal-proof-cover">
          <img
            src="/google-business-profile/sunelys-gbp-cover-portail-2026-07-21.jpg"
            alt="Aperçu du portail client Sunelys pour le suivi administratif photovoltaïque"
            width="1254"
            height="705"
            loading="lazy"
            decoding="async"
          />
        </figure>

        <div class="portal-proof-stack">
          <figure>
            <img
              src="/google-business-profile/sunelys-gbp-portail-dashboard-propre-2026-07-21.jpg"
              alt="Vue d'ensemble anonymisée du portail client Sunelys"
              width="1600"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <figure>
            <img
              src="/google-business-profile/sunelys-gbp-portail-dossiers-propre-2026-07-21.jpg"
              alt="Liste anonymisée de dossiers dans le portail client Sunelys"
              width="1600"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <div class="portal-proof-copy">
          <ul>
            {portalProofItems.map((item) => <li>{item}</li>)}
          </ul>
          <a
            class="btn btn-primary btn-accent"
            href={`/contact?source=${data.slug}_portal_proof#contact-form`}
            data-track={`cta_${data.slug}_portal_proof`}
          >
            Voir comment reprendre vos dossiers
          </a>
        </div>
      </div>
    </section>
  )
}

<section class="seo-section seo-problem section-shell reveal">
  <p class="kicker">Le problème</p>
  <h2>{data.problemTitle}</h2>
  <p class="problem-intro">{data.problemIntro}</p>
  <div class="problem-grid">
    {
      data.problemItems.map((item) => (
        <article class="problem-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>
</section>

{
  data.useCaseItems && data.useCaseItems.length > 0 && (
    <section class="seo-section seo-use-cases section-shell reveal">
      <div class="split-head">
        <div>
          <p class="kicker">Cas d'usage</p>
          <h2>Les situations où Sunelys accélère vos DP</h2>
        </div>
        <p>
          Chaque installateur n'a pas le même volume ni les mêmes blocages. La prise en charge
          s'adapte au flux réel: dossiers récurrents, reprises après complément ou coordination
          entre plusieurs interlocuteurs.
        </p>
      </div>
      <div class="use-case-grid">
        {data.useCaseItems.map((item) => (
          <article class="use-case-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-scope section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Ce que Sunelys prend en charge</p>
      <h2>Pilotage administratif de bout en bout</h2>
    </div>
    <p>
      L'objectif n'est pas seulement de déposer un dossier. C'est de rendre le flux plus fiable,
      plus lisible et moins consommateur de temps pour vos équipes.
    </p>
  </div>

  <div class="scope-layout">
    <article class="scope-panel">
      <h3>Prise en charge opérationnelle</h3>
      <ul>
        {data.scopeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="scope-panel scope-panel-dark">
      <h3>Résultats attendus</h3>
      <ul>
        {outcomeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

{
  data.detailBlocks && data.detailBlocks.length > 0 && (
    <section class="seo-section seo-details section-shell reveal">
      <p class="kicker">À prévoir</p>
      <h2>Documents, délais et erreurs à éviter</h2>
      <div class="details-grid">
        {data.detailBlocks.map((block) => (
          <article class="detail-card">
            <h3>{block.title}</h3>
            <p>{block.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-process section-shell reveal">
  <p class="kicker">Process</p>
  <h2>Une exécution claire en 4 étapes</h2>
  <ol>
    {data.processSteps.map((step) => <li>{step}</li>)}
  </ol>
</section>

<section class="seo-section seo-delegation section-shell reveal">
  <p class="kicker">Quand déléguer</p>
  <h2>{data.signalTitle}</h2>
  <p class="problem-intro">{data.signalIntro}</p>
  <div class="signal-grid">
    {data.signalItems.map((signal) => <p>{signal}</p>)}
  </div>
      <a class="btn btn-secondary" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_delegation`}>
        {delegationLabel}
      </a>
</section>

<section class="seo-section seo-case section-shell reveal">
  <p class="kicker">Exemple de flux</p>
  <div class="case-layout">
    <div>
      <h2>{data.caseStudy.title}</h2>
      <p class="volume">{data.caseStudy.volume}</p>
    </div>
    <ul>
      {data.caseStudy.results.map((result) => <li>{result}</li>)}
    </ul>
  </div>
</section>

<section class="seo-section seo-faq section-shell reveal">
  <p class="kicker">FAQ</p>
  <h2>Questions fréquentes</h2>
  <div class="faq-grid">
    {
      data.faqItems.map((item, index) => (
        <details class="faq-card">
          <summary>
            <span>0{index + 1}</span>
            <strong>{item.question}</strong>
            <i aria-hidden="true"></i>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<section class="seo-section seo-links section-shell reveal">
  <p class="kicker">À lire aussi</p>
  <h2>Explorer les autres démarches</h2>
      <div class="links-grid">
    {
      visibleInternalLinks.map((link) => (
        <a class="link-pill" href={link.href} data-track={`link_${data.slug}_${link.href}`}>
          {link.label}
        </a>
      ))
    }
  </div>
</section>

{
  visibleGuideLinks.length > 0 && (
    <section class="seo-section seo-guides section-shell reveal">
      <p class="kicker">Guides associés</p>
      <h2>Approfondir ce sujet</h2>
      <div class="guide-grid">
        {visibleGuideLinks.map((link) => (
          <a class="guide-link" href={link.href} data-track={`guide_${data.slug}_${link.href}`}>
            <span>{link.label}</span>
            <small>{link.description}</small>
          </a>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-final section-shell reveal">
  <h2>{data.finalTitle}</h2>
  <p>{data.finalText}</p>
  <form
    class="service-lead-form"
    action={leadFormAction}
    method="POST"
    data-lead-form
    data-conversion-type="form_contact"
  >
    <input type="hidden" name="_subject" value={`Nouveau cadrage service - ${data.heroTitle}`} />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_next" value={successUrl} />
    <input type="hidden" name="source_page" value={data.slug} />
    <input type="hidden" name="conversion_type" value="form_contact" />
    <input type="hidden" name="lead_stage" value="service_final_form_submitted" />
    <input type="hidden" name="service_interest" value={serviceInterest} />
    <input type="hidden" name="lead_source_detail" value={`${data.slug}_final_form`} />
    <input type="hidden" name="qualification_hint" value="prenom, email professionnel, téléphone optionnel, volume mensuel, urgence et étape bloquée" />
    <input type="hidden" name="lead_status" value="Nouveau lead" />
    <input type="hidden" name="lead_pipeline" value="Site web - Page service" />
    <input type="hidden" name="lead_owner" value="Sunelys commercial" />
    <input type="hidden" name="follow_up_sla" value="24h" />
    <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
    {attributionFields.map((fieldName) => (
      <input type="hidden" name={fieldName} data-service-attribution={fieldName} />
    ))}

    <label>
      <span>Prénom</span>
      <input type="text" name="first_name" autocomplete="given-name" required />
    </label>
    <label>
      <span>Email professionnel</span>
      <input type="email" name="email" autocomplete="email" inputmode="email" required />
    </label>
    <label>
      <span>Téléphone pour rappel <em>optionnel</em></span>
      <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
    </label>
    <label>
      <span>Volume mensuel</span>
      <select name="volume" required>
        <option value="">Sélectionner</option>
        <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
        <option value="10-30 dossiers">10-30 dossiers</option>
        <option value="+30 dossiers">+30 dossiers</option>
      </select>
    </label>
    <label>
      <span>Étape bloquée</span>
      <select name="blocked_stage" required>
        <option value="">Sélectionner</option>
        <option value="Avant dépôt">Avant dépôt</option>
        <option value="Complément mairie">Complément mairie</option>
        <option value="Consuel à préparer">Consuel à préparer</option>
        <option value="Raccordement en attente">Raccordement en attente</option>
        <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
        <option value="Prime à suivre">Prime à suivre</option>
        <option value="Mise en service bloquée">Mise en service bloquée</option>
        <option value="Pilotage global">Pilotage global</option>
        <option value="Je ne sais pas encore">Je ne sais pas encore</option>
      </select>
    </label>
    <label>
      <span>Urgence</span>
      <select name="urgency" required>
        <option value="">Sélectionner</option>
        <option value="Sous 48h">Sous 48h</option>
        <option value="Cette semaine">Cette semaine</option>
        <option value="Ce mois-ci">Ce mois-ci</option>
        <option value="Pas urgent">Pas urgent</option>
      </select>
    </label>
    <button class="btn btn-accent" type="submit" data-track={`cta_${data.slug}_final_form`}>
      {finalSubmitLabel}
    </button>
    <small>Réponse sous 24h • Sans engagement</small>
  </form>
</section>

<script>
  const serviceAttribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
  document.querySelectorAll("[data-service-attribution]").forEach((field) => {
    if (!(field instanceof HTMLInputElement)) return;
    const key = field.dataset.serviceAttribution || "";
    field.value = serviceAttribution[key] || "";
  });
</script>

<style>
  .seo-section {
    border: 1px solid color-mix(in srgb, var(--line) 88%, white);
    border-radius: var(--radius-xl);
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 92%, white),
      var(--surface)
    );
    box-shadow: 0 18px 48px rgba(20, 16, 10, 0.055);
    padding: clamp(1.2rem, 2.8vw, 2.2rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.62rem 0 0;
    max-width: 20ch;
    font-size: clamp(2rem, 4vw, 3.9rem);
    line-height: 0.95;
    letter-spacing: 0;
    text-wrap: balance;
  }

  h2 {
    margin: 0.62rem 0 0;
    font-size: clamp(1.45rem, 2.5vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  h3 {
    margin: 0;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    line-height: 1.2;
  }

  p,
  li {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .seo-hero {
    position: relative;
    isolation: isolate;
    background:
      radial-gradient(
        110% 130% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--surface-elevated) 94%, white),
        var(--surface)
      );
  }

  .hero-copy {
    display: grid;
    gap: 0.9rem;
  }

  .expert-line {
    max-width: 54ch;
    border-left: 3px solid var(--accent-strong);
    padding: 0.08rem 0 0.08rem 0.82rem;
    color: var(--text);
    font-size: clamp(0.98rem, 0.28vw + 0.92rem, 1.08rem);
    font-weight: 650;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.82fr);
    gap: clamp(1rem, 2vw, 1.35rem);
    align-items: start;
  }

  .hero-aside {
    display: grid;
    gap: 0.72rem;
  }

  .hero-badges {
    margin: 0.1rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-badges li,
  .link-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    border-radius: 11px;
    border: 1px solid color-mix(in srgb, var(--line) 78%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 84%, white);
    padding: 0.38rem 0.74rem;
    font-size: 0.73rem;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .hero-price-pills {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-price-pills li {
    display: grid;
    gap: 0.18rem;
    min-height: 4.4rem;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: 13px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.66rem 0.72rem;
    box-shadow: 0 12px 26px rgba(20, 16, 10, 0.055);
  }

  .hero-price-pills span {
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .hero-price-pills strong {
    color: var(--accent-deep);
    font-size: clamp(1.05rem, 1vw, 1.28rem);
    line-height: 1.05;
  }

  .hero-fit-card,
  .hero-lead-card,
  .hero-proof-card {
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: 16px;
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    padding: 1rem;
    display: grid;
    gap: 0.58rem;
  }

  .hero-lead-card {
    position: relative;
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 34%, transparent), transparent 58%),
      color-mix(in srgb, var(--surface-elevated) 94%, white);
    border-color: color-mix(in srgb, var(--line) 64%, var(--accent));
    box-shadow: 0 20px 44px rgba(20, 16, 10, 0.075);
  }

  .hero-lead-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: 16px 0 0 16px;
    background: linear-gradient(180deg, #c59455, var(--accent-strong));
  }

  .hero-lead-card h2 {
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    max-width: 16ch;
  }

  .hero-service-form {
    display: grid;
    gap: 0.58rem;
  }

  .hero-service-form label {
    display: grid;
    gap: 0.32rem;
    color: var(--text);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-service-form input,
  .hero-service-form select {
    width: 100%;
    min-height: 2.65rem;
    border: 1px solid color-mix(in srgb, var(--line) 78%, var(--accent));
    border-radius: 11px;
    background: #fffdfa;
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.66rem 0.74rem;
  }

  .hero-service-form .btn {
    width: 100%;
  }

  .hero-service-form small {
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .hero-fit-card h2 {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    max-width: 16ch;
  }

  .hero-fit-card ul,
  .proof-highlights {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.42rem;
  }

  .hero-proof-card {
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 34%, transparent), transparent 58%),
      linear-gradient(165deg, #17130f, #11100d);
    border-color: color-mix(in srgb, var(--line) 45%, var(--accent));
  }

  .hero-proof-card .kicker,
  .hero-proof-card blockquote,
  .hero-proof-card li,
  .proof-signature {
    color: #f6f0e4;
  }

  .hero-proof-card blockquote {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.6;
    font-weight: 500;
    text-wrap: balance;
  }

  .proof-signature {
    display: grid;
    gap: 0.16rem;
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 700;
  }

  .proof-signature span {
    color: #d5c7b4;
    font-size: 0.74rem;
  }

  .problem-intro {
    margin-top: 0.74rem;
    max-width: 72ch;
  }

  .problem-grid,
  .details-grid,
  .faq-grid,
  .signal-grid,
  .use-case-grid,
  .diagnostic-grid,
  .fast-diagnostic-grid,
  .handover-grid,
  .concern-grid {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .problem-card,
  .detail-card,
  .faq-card,
  .diagnostic-card,
  .fast-diagnostic-card,
  .handover-card,
  .scope-panel,
  .use-case-card,
  .concern-grid p,
  .signal-grid p {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    border-radius: 15px;
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    padding: 0.85rem;
    display: grid;
    gap: 0.45rem;
  }

  .seo-details h2 {
    max-width: 22ch;
  }

  .seo-use-cases {
    background: color-mix(in srgb, var(--surface-elevated) 82%, white);
  }

  .seo-fast-diagnostic {
    background:
      radial-gradient(
        100% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 38%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
  }

  .seo-offer-snapshot {
    background:
      radial-gradient(
        100% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 40%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
  }

  .offer-snapshot-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .offer-snapshot-item {
    min-height: 9.2rem;
    border: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent));
    border-radius: 15px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.9rem;
    display: grid;
    gap: 0.4rem;
    align-content: start;
  }

  .offer-snapshot-item span {
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .offer-snapshot-item strong {
    color: var(--text);
    font-size: clamp(1.5rem, 2.3vw, 2.45rem);
    line-height: 1;
  }

  .offer-snapshot-actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .fast-diagnostic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .seo-portal-proof {
    background:
      radial-gradient(
        95% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 44%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
  }

  .portal-proof-layout {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(260px, 0.72fr);
    gap: 0.8rem;
    align-items: stretch;
  }

  .portal-proof-cover,
  .portal-proof-stack figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: 16px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: 0 20px 50px rgba(20, 16, 10, 0.08);
  }

  .portal-proof-cover {
    min-height: 100%;
  }

  .portal-proof-cover img,
  .portal-proof-stack img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .portal-proof-cover img,
  .portal-proof-stack img {
    object-fit: cover;
  }

  .portal-proof-stack {
    display: grid;
    gap: 0.72rem;
  }

  .portal-proof-stack figure {
    aspect-ratio: 16 / 9;
  }

  .portal-proof-copy {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.72rem;
    border: 1px solid color-mix(in srgb, var(--line) 76%, white);
    border-radius: 16px;
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    padding: 0.85rem;
  }

  .portal-proof-copy ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.28rem;
  }

  .portal-proof-copy li {
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .fast-diagnostic-card {
    align-content: start;
  }

  .seo-handover {
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
  }

  .handover-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .handover-card {
    align-content: start;
  }

  .handover-card span {
    width: fit-content;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 58%, white);
    color: var(--text);
    padding: 0.22rem 0.52rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .handover-card strong {
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .seo-concerned {
    background: color-mix(in srgb, var(--surface-elevated) 84%, white);
  }

  .concern-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .concern-grid p {
    color: var(--text);
    font-weight: 700;
  }

  .use-case-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .use-case-card {
    align-content: start;
  }

  .details-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .detail-card {
    align-content: start;
  }

  .split-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.72fr);
    gap: 1rem;
    align-items: end;
  }

  .scope-layout,
  .case-layout {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.8rem;
  }

  .scope-panel ul,
  .seo-case ul {
    margin: 0.72rem 0 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.42rem;
  }

  .scope-panel-dark {
    background:
      radial-gradient(100% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 38%, transparent), transparent 58%),
      #17130f;
    border-color: color-mix(in srgb, var(--line) 45%, var(--accent));
  }

  .scope-panel-dark h3,
  .scope-panel-dark li {
    color: #f8f2e7;
  }

  .scope-panel-dark li {
    color: #dfd4c6;
  }

  .seo-process ol {
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.58rem;
    counter-reset: process;
  }

  .seo-process li {
    counter-increment: process;
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.78rem 0.82rem 0.78rem 3rem;
    position: relative;
    color: var(--text);
    font-weight: 600;
  }

  .seo-process li::before {
    content: counter(process);
    position: absolute;
    left: 0.82rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 65%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 70%, white);
    color: var(--text);
    display: grid;
    place-items: center;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .seo-delegation .btn {
    margin-top: 1rem;
  }

  .seo-diagnostic {
    background:
      radial-gradient(
        100% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 36%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 94%, white),
        var(--surface)
      );
  }

  .diagnostic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .diagnostic-card {
    align-content: start;
  }

  .diagnostic-actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .volume {
    margin-top: 0.74rem;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .links-grid {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .link-pill {
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .link-pill:hover,
  .link-pill:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .guide-grid {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .guide-link {
    min-height: 7.2rem;
    display: grid;
    align-content: start;
    gap: 0.34rem;
    padding: 0.92rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    color: var(--text);
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .guide-link:hover,
  .guide-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .guide-link span {
    font-weight: 800;
    line-height: 1.24;
  }

  .guide-link small {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .seo-final {
    text-align: center;
    background:
      radial-gradient(
        100% 120% at 0% 0%,
        color-mix(in srgb, var(--accent-soft) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(165deg, #1b1712, #11100d);
    border-color: color-mix(in srgb, var(--line) 54%, var(--accent));
  }

  .seo-final h2,
  .seo-final p {
    color: #f7f2e8;
    max-width: 55ch;
    margin-inline: auto;
  }

  .seo-final p {
    margin-top: 0.8rem;
    color: #d9cfbf;
  }

  .seo-final .btn {
    margin-top: 1rem;
  }

  .service-lead-form {
    margin: 1rem auto 0;
    max-width: 1040px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.62rem;
    align-items: end;
  }

  .service-lead-form label {
    display: grid;
    gap: 0.34rem;
    text-align: left;
    color: #f7f2e8;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .service-lead-form input,
  .service-lead-form select {
    width: 100%;
    min-height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: 11px;
    background: #fffdfa;
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.7rem 0.78rem;
  }

  .service-lead-form .btn {
    grid-column: 1 / -1;
    width: 100%;
    margin-top: 0;
    white-space: nowrap;
  }

  .service-lead-form small {
    grid-column: 1 / -1;
    color: #d9cfbf;
    font-size: 0.78rem;
  }

  @media (max-width: 900px) {
    .problem-grid,
    .details-grid,
    .faq-grid,
    .signal-grid,
    .use-case-grid,
    .diagnostic-grid,
    .fast-diagnostic-grid,
    .offer-snapshot-grid,
    .handover-grid,
    .concern-grid,
    .scope-layout,
    .case-layout,
    .split-head,
    .guide-grid,
    .hero-layout {
      grid-template-columns: 1fr;
    }

    .portal-proof-layout {
      grid-template-columns: 1fr;
    }

    .hero-price-pills {
      grid-template-columns: 1fr;
    }

    .portal-proof-cover {
      aspect-ratio: 16 / 9;
    }

    .portal-proof-copy .btn {
      width: 100%;
    }

    .expert-line {
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      padding: 0.72rem 0;
    }

    .hero-actions .btn,
    .diagnostic-actions .btn,
    .offer-snapshot-actions .btn,
    .seo-delegation .btn,
    .seo-final .btn {
      width: 100%;
    }

    .service-lead-form {
      grid-template-columns: 1fr;
    }
  }

  /* Direction visuelle 2026 */
  .seo-section {
    border-color: var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    padding: clamp(1.3rem, 3vw, 2.6rem);
  }

  .seo-section > .kicker,
  .split-head .kicker,
  .seo-context .kicker,
  .service-pricing-strip .kicker {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
  }

  .seo-section h2,
  .seo-context h2 {
    max-width: 18ch;
    margin-top: 0.6rem;
    font-size: clamp(2rem, 3.6vw, 3.6rem);
    letter-spacing: -0.035em;
  }

  .seo-hero {
    overflow: hidden;
    border-color: var(--ink);
    background:
      radial-gradient(70% 100% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 62%),
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
    box-shadow: var(--shadow-md);
    padding: clamp(1.5rem, 3.8vw, 4rem);
  }

  .hero-layout {
    position: relative;
    z-index: 1;
    grid-template-columns: minmax(0, 1.06fr) minmax(350px, 0.74fr);
    gap: clamp(1.5rem, 4vw, 4.2rem);
    align-items: center;
  }

  .seo-hero .hero-copy {
    gap: 0;
  }

  .seo-hero .hero-copy > .kicker {
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
  }

  .seo-hero h1 {
    max-width: 14ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 5.1rem);
    letter-spacing: -0.045em;
    line-height: 0.94;
  }

  .seo-hero .hero-copy > p:not(.kicker):not(.expert-line) {
    max-width: 62ch;
    margin-top: 1.05rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.92rem;
    line-height: 1.64;
  }

  .seo-hero .expert-line {
    max-width: 59ch;
    margin-top: 1rem;
    padding: 0.1rem 0 0.1rem 0.8rem;
    border-left-color: var(--accent);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.8rem;
    font-weight: 680;
  }

  .seo-hero .hero-badges {
    gap: 0.55rem 1rem;
    margin-top: 1.15rem;
  }

  .seo-hero .hero-badges li {
    min-height: 0;
    gap: 0.42rem;
    padding: 0;
