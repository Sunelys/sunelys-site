---
import LeadMagnetChecklist from "./LeadMagnetChecklist.astro";
import { filterVisibleLinks, publicBlogSlugs } from "../lib/blogPublication";

interface ProblemItem {
  title: string;
  text: string;
}

interface CaseStudyData {
  title: string;
  volume: string;
  results: string[];
}

interface FaqItem {
  question: string;
  answer: string;
}

interface InternalLink {
  href: string;
  label: string;
}

interface GuideLink {
  href: string;
  label: string;
  description: string;
}

interface DetailBlock {
  title: string;
  text: string;
}

interface UseCaseItem {
  title: string;
  text: string;
}

interface SeoPageContent {
  slug: string;
  heroTitle: string;
  heroSubtitle: string;
  fitTitle: string;
  fitIntro: string;
  fitItems: string[];
  proof: {
    quote: string;
    author: string;
    role: string;
    highlights: string[];
  };
  problemTitle: string;
  problemIntro: string;
  problemItems: ProblemItem[];
  useCaseItems?: UseCaseItem[];
  scopeItems: string[];
  detailBlocks?: DetailBlock[];
  processSteps: string[];
  signalTitle: string;
  signalIntro: string;
  signalItems: string[];
  caseStudy: CaseStudyData;
  faqItems: FaqItem[];
  finalTitle: string;
  finalText: string;
  guideLinks?: GuideLink[];
  internalLinks: InternalLink[];
}

interface Props {
  data: SeoPageContent;
}

const { data } = Astro.props;
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const successUrl = `https://sunelys.fr/merci?source=${data.slug}_service_form`;

const heroBadges = [
  "Pour installateurs photovoltaïques",
  "Dossier ponctuel accepté",
  "Diagnostic gratuit sous 24h",
];

const serviceInterestBySlug: Record<string, string> = {
  gestion_administrative: "Pilotage complet DP, Consuel et raccordement",
  consuel_photovoltaique: "Dossier Consuel photovoltaïque",
  raccordement_enedis: "Raccordement Enedis photovoltaïque",
  declaration_prealable: "Déclaration préalable panneaux solaires",
  sous_traitance_declaration_prealable: "Sous-traitance déclaration préalable solaire",
  tarif_declaration_prealable: "Tarif déclaration préalable photovoltaïque",
};

const serviceInterest = serviceInterestBySlug[data.slug] || data.heroTitle;
const isGestionLanding = data.slug === "gestion_administrative";
const heroSecondaryCta = isGestionLanding
  ? { label: "Voir les tarifs du pilotage complet", href: "/tarifs" }
  : { label: "Voir les services", href: "/services" };
const heroPrimaryLabel = "Recevoir mon diagnostic gratuit";
const delegationLabel = isGestionLanding ? "Diagnostiquer mon flux administratif" : "Faire le point sur mes blocages";
const diagnosticPrimaryLabel = "Recevoir un diagnostic sous 24h";
const diagnosticSecondaryLabel = isGestionLanding ? "Voir les offres pilotage complet" : "Voir les offres";
const finalSubmitLabel = isGestionLanding ? "Recevoir mon plan d'action" : "Recevoir mon diagnostic";

const pricingHighlights = [
  {
    service: "DP complète",
    price: "119 € HT",
    text: "Pièces, dépôt mairie et suivi jusqu'à validation.",
  },
  {
    service: "Raccordement + Consuel",
    price: "89 € HT",
    text: "Dossier suivi, relances et mise en service plus lisible.",
  },
  {
    service: "MaPrimeRénov'",
    price: "129 € HT",
    text: "Montage, dépôt ANAH et suivi administratif.",
  },
  {
    service: "CEE",
    price: "99 € HT",
    text: "Contrôle des pièces et suivi jusqu'à validation.",
  },
];

const adminChecklistItems = [
  "Pièces à réunir selon le blocage: DP, Consuel, Enedis ou aides",
  "Signaux qui indiquent quoi déléguer en premier",
  "Réponse Sunelys sous 24h pour cadrer le prochain dossier",
];

const fastDiagnosticItems = [
  {
    title: "Dossier ponctuel",
    text: "Pour reprendre une DP, un Consuel, un raccordement ou une aide qui consomme déjà trop de temps.",
  },
  {
    title: "Pic de charge",
    text: "Pour absorber une période dense sans mobiliser vos commerciaux ou conducteurs de travaux sur chaque relance.",
  },
  {
    title: "Flux récurrent",
    text: "Pour structurer un pilotage clair quand les dossiers reviennent tous les mois et que les statuts se dispersent.",
  },
];

const concernSignals = [
  "Un dossier client avance, mais personne ne sait exactement quelle action bloque.",
  "Vos équipes relancent plusieurs interlocuteurs au lieu de vendre, poser ou suivre les chantiers.",
  "Une pièce manquante, un retour mairie, Consuel ou Enedis décale la mise en service.",
  "Vous voulez déléguer une brique précise avant de confier tout le flux administratif.",
];

const handoverItems = [
  {
    label: "DP",
    title: "Déclarations préalables",
    text: "Contrôle des pièces, cohérence des informations, dépôt et suivi mairie jusqu'au retour.",
    result: "Moins de compléments et une lecture claire de chaque statut.",
  },
  {
    label: "Mise en service",
    title: "Consuel et raccordement",
    text: "Préparation administrative, suivi des portails, relances et demandes de complément.",
    result: "Les dossiers proches mise en service ne restent plus sans pilote.",
  },
  {
    label: "Aides",
    title: "MaPrimeRénov' et CEE",
    text: "Montage, pièces attendues, jalons et suivi pour éviter les dossiers qui dorment.",
    result: "Un flux d'aides plus lisible pour vos équipes et vos clients.",
  },
  {
    label: "Pilotage",
    title: "Vision par dossier",
    text: "Centralisation des actions, priorisation des urgences et point d'avancement exploitable.",
    result: "Vous savez quoi relancer, quoi déléguer et quoi traiter en premier.",
  },
];

const diagnosticItems = [
  {
    title: "Volume et sources",
    text: "Identifier d'où viennent les demandes, combien de dossiers arrivent chaque mois et quelles pages génèrent les leads utiles.",
  },
  {
    title: "Blocages réels",
    text: "Séparer les irritants DP, Consuel, raccordement, relances client et suivi interne pour prioriser sans tout déléguer d'un coup.",
  },
  {
    title: "Plan d'action",
    text: "Définir le premier périmètre à confier, les statuts à suivre et les indicateurs qui diront si la délégation crée vraiment du revenu.",
  },
];

const outcomeItems = [
  "Moins de charge administrative pour vos équipes",
  "Moins de retours liés aux pièces incomplètes",
  "Plus de visibilité sur les jalons et les blocages",
  "Une expérience client plus fluide côté installateur",
];

const attributionFields = [
  "landing_page",
  "first_referrer",
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "fbclid",
  "msclkid",
];

const visibleInternalLinks = filterVisibleLinks(data.internalLinks, publicBlogSlugs);
const visibleGuideLinks = filterVisibleLinks(data.guideLinks, publicBlogSlugs);
---

<section class="seo-section seo-hero section-shell reveal">
  <div class="hero-layout">
    <div class="hero-copy">
      <p class="kicker">Service administratif photovoltaïque</p>
      <h1>{data.heroTitle}</h1>
      <p>{data.heroSubtitle}</p>
      <p class="expert-line">
        Un pilotage administratif solaire exigeant, pensé pour les installateurs qui veulent grandir sans perdre le contrôle.
      </p>

      <ul class="hero-badges" aria-label="Informations clés Sunelys">
        {heroBadges.map((badge) => <li>{badge}</li>)}
      </ul>

      <div class="hero-actions">
        <a class="btn btn-primary" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_hero`}>
          {heroPrimaryLabel}
        </a>
        <a class="btn btn-secondary" href={heroSecondaryCta.href} data-track={`cta_${data.slug}_hero_services`}>
          {heroSecondaryCta.label}
        </a>
      </div>
    </div>

    <aside class="hero-aside">
      <article class="hero-lead-card" aria-label="Demande de cadrage rapide">
        <p class="kicker">Diagnostic sous 24h</p>
        <h2>Identifiez le premier flux administratif à déléguer.</h2>
        <form
          class="hero-service-form"
          action={leadFormAction}
          method="POST"
          data-lead-form
          data-conversion-type="form_contact"
        >
          <input type="hidden" name="_subject" value={`Nouveau cadrage service hero - ${data.heroTitle}`} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_next" value={successUrl} />
          <input type="hidden" name="source_page" value={`${data.slug}_hero`} />
          <input type="hidden" name="conversion_type" value="form_contact" />
          <input type="hidden" name="lead_stage" value="service_hero_form_submitted" />
          <input type="hidden" name="service_interest" value={serviceInterest} />
          <input type="hidden" name="lead_source_detail" value={`${data.slug}_hero_form`} />
          <input type="hidden" name="qualification_hint" value="email professionnel, téléphone, volume mensuel, urgence et étape bloquée" />
          <input type="hidden" name="lead_status" value="Nouveau lead" />
          <input type="hidden" name="lead_pipeline" value="Site web - Page service hero" />
          <input type="hidden" name="lead_owner" value="Sunelys commercial" />
          <input type="hidden" name="follow_up_sla" value="24h" />
          <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
          {attributionFields.map((fieldName) => (
            <input type="hidden" name={fieldName} data-service-attribution={fieldName} />
          ))}

          <label>
            <span>Email professionnel</span>
            <input type="email" name="email" autocomplete="email" inputmode="email" required />
          </label>
          <label>
            <span>Téléphone pour rappel</span>
            <input type="tel" name="phone" autocomplete="tel" inputmode="tel" required />
          </label>
          <label>
            <span>Volume mensuel</span>
            <select name="volume" required>
              <option value="">Sélectionner</option>
              <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
              <option value="10-30 dossiers">10-30 dossiers</option>
              <option value="+30 dossiers">+30 dossiers</option>
            </select>
          </label>
          <label>
            <span>Étape bloquée</span>
            <select name="blocked_stage" required>
              <option value="">Sélectionner</option>
              <option value="Avant dépôt">Avant dépôt</option>
              <option value="Complément mairie">Complément mairie</option>
              <option value="Consuel à préparer">Consuel à préparer</option>
              <option value="Raccordement en attente">Raccordement en attente</option>
              <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
              <option value="Prime à suivre">Prime à suivre</option>
              <option value="Mise en service bloquée">Mise en service bloquée</option>
              <option value="Pilotage global">Pilotage global</option>
              <option value="Je ne sais pas encore">Je ne sais pas encore</option>
            </select>
          </label>
          <label>
            <span>Urgence</span>
            <select name="urgency" required>
              <option value="">Sélectionner</option>
              <option value="Sous 48h">Sous 48h</option>
              <option value="Cette semaine">Cette semaine</option>
              <option value="Ce mois-ci">Ce mois-ci</option>
              <option value="Pas urgent">Pas urgent</option>
            </select>
          </label>
          <button class="btn btn-primary btn-accent" type="submit" data-track={`cta_${data.slug}_hero_form`}>
            Recevoir mon plan d'action
          </button>
          <small>Diagnostic gratuit sous 24h. Dossier ponctuel accepté, sans engagement.</small>
        </form>
      </article>

      <article class="hero-fit-card">
        <p class="kicker">Quand cette page vous concerne</p>
        <h2>{data.fitTitle}</h2>
        <p>{data.fitIntro}</p>
        <ul>
          {data.fitItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="hero-proof-card">
        <p class="kicker">Retour terrain</p>
        <blockquote>{data.proof.quote}</blockquote>
        <p class="proof-signature">
          {data.proof.author}
          <span>{data.proof.role}</span>
        </p>
        <ul class="proof-highlights">
          {data.proof.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="seo-section seo-offer-snapshot section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Offre claire</p>
      <h2>Tarifs visibles, diagnostic gratuit, pas de minimum bloquant.</h2>
    </div>
    <p>
      Vous pouvez commencer par un dossier ponctuel, un blocage urgent ou un flux récurrent.
      Le diagnostic sert à choisir le premier périmètre rentable à déléguer.
    </p>
  </div>

  <div class="offer-snapshot-grid" aria-label="Tarifs Sunelys principaux">
    {pricingHighlights.map((item) => (
      <article class="offer-snapshot-item">
        <span>{item.service}</span>
        <strong>{item.price}</strong>
        <p>{item.text}</p>
      </article>
    ))}
  </div>

  <div class="offer-snapshot-actions">
    <a class="btn btn-primary btn-accent" href={`/contact?source=${data.slug}_pricing_snapshot#contact-form`} data-track={`cta_${data.slug}_pricing_snapshot`}>
      Recevoir mon diagnostic gratuit
    </a>
    <a class="btn btn-secondary" href="/tarifs" data-track={`cta_${data.slug}_pricing_snapshot_tarifs`}>
      Voir tous les tarifs
    </a>
  </div>
</section>

<LeadMagnetChecklist
  source={`${data.slug}_checklist_admin_inline`}
  kicker="Checklist de reprise"
  title="Recevez la checklist des pièces à fournir selon votre blocage."
  text="Une ressource courte pour savoir quoi préparer avant de confier une DP, un Consuel, un raccordement Enedis, MaPrimeRénov' ou CEE."
  items={adminChecklistItems}
  need={serviceInterest}
  blockedStage="Pilotage global"
  message="Demande de checklist administrative selon blocage"
  serviceInterest={serviceInterest}
  qualificationHint="email professionnel demandeur checklist administrative DP Consuel Enedis aides"
  submitLabel="Recevoir la checklist"
/>

<section class="seo-section seo-fast-diagnostic section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Offre d'entrée</p>
      <h2>Diagnostic gratuit sous 24h de vos dossiers administratifs bloqués.</h2>
    </div>
    <p>
      Sunelys identifie le premier périmètre à déléguer pour récupérer du temps et de la visibilité:
      DP, Consuel, raccordement Enedis, MaPrimeRénov' ou CEE.
    </p>
  </div>

  <div class="fast-diagnostic-grid">
    {fastDiagnosticItems.map((item) => (
      <article class="fast-diagnostic-card">
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </article>
    ))}
  </div>

  <div class="diagnostic-actions">
    <a
      class="btn btn-primary btn-accent"
      href={`/contact?source=${data.slug}_diagnostic_24h#contact-form`}
      data-track={`cta_${data.slug}_fast_diagnostic`}
    >
      Recevoir un diagnostic sous 24h
    </a>
    <a class="btn btn-secondary" href="/tarifs" data-track={`cta_${data.slug}_fast_diagnostic_tarifs`}>
      Voir les tarifs fixes
    </a>
  </div>
</section>

<section class="seo-section seo-problem section-shell reveal">
  <p class="kicker">Le problème</p>
  <h2>{data.problemTitle}</h2>
  <p class="problem-intro">{data.problemIntro}</p>
  <div class="problem-grid">
    {
      data.problemItems.map((item) => (
        <article class="problem-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="seo-section seo-handover section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Reprise opérationnelle</p>
      <h2>Ce que Sunelys peut reprendre dès le premier échange.</h2>
    </div>
    <p>
      Pas besoin d'attendre 10 dossiers par mois pour être aidé. On peut traiter un blocage ponctuel,
      absorber un pic de charge ou structurer un flux récurrent quand le volume augmente.
    </p>
  </div>

  <div class="handover-grid">
    {handoverItems.map((item) => (
      <article class="handover-card">
        <span>{item.label}</span>
        <h3>{item.title}</h3>
        <p>{item.text}</p>
        <strong>{item.result}</strong>
      </article>
    ))}
  </div>
</section>

<section class="seo-section seo-concerned section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Vous êtes concerné si</p>
      <h2>Le volume n'est pas le seul signal. Le vrai sujet, c'est la friction.</h2>
    </div>
    <p>
      On ne ferme pas la porte aux petits installateurs. Le diagnostic sert justement à savoir
      s'il faut traiter un dossier ponctuel, un pic de charge ou un flux récurrent.
    </p>
  </div>
  <div class="concern-grid">
    {concernSignals.map((signal) => <p>{signal}</p>)}
  </div>
</section>

{
  data.useCaseItems && data.useCaseItems.length > 0 && (
    <section class="seo-section seo-use-cases section-shell reveal">
      <div class="split-head">
        <div>
          <p class="kicker">Cas d'usage</p>
          <h2>Les situations où Sunelys accélère vos DP</h2>
        </div>
        <p>
          Chaque installateur n'a pas le même volume ni les mêmes blocages. La prise en charge
          s'adapte au flux réel: dossiers récurrents, reprises après complément ou coordination
          entre plusieurs interlocuteurs.
        </p>
      </div>
      <div class="use-case-grid">
        {data.useCaseItems.map((item) => (
          <article class="use-case-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-scope section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Ce que Sunelys prend en charge</p>
      <h2>Pilotage administratif de bout en bout</h2>
    </div>
    <p>
      L'objectif n'est pas seulement de déposer un dossier. C'est de rendre le flux plus fiable,
      plus lisible et moins consommateur de temps pour vos équipes.
    </p>
  </div>

  <div class="scope-layout">
    <article class="scope-panel">
      <h3>Prise en charge opérationnelle</h3>
      <ul>
        {data.scopeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="scope-panel scope-panel-dark">
      <h3>Résultats attendus</h3>
      <ul>
        {outcomeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

{
  data.detailBlocks && data.detailBlocks.length > 0 && (
    <section class="seo-section seo-details section-shell reveal">
      <p class="kicker">À prévoir</p>
      <h2>Documents, délais et erreurs à éviter</h2>
      <div class="details-grid">
        {data.detailBlocks.map((block) => (
          <article class="detail-card">
            <h3>{block.title}</h3>
            <p>{block.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-process section-shell reveal">
  <p class="kicker">Process</p>
  <h2>Une exécution claire en 4 étapes</h2>
  <ol>
    {data.processSteps.map((step) => <li>{step}</li>)}
  </ol>
</section>

<section class="seo-section seo-delegation section-shell reveal">
  <p class="kicker">Quand déléguer</p>
  <h2>{data.signalTitle}</h2>
  <p class="problem-intro">{data.signalIntro}</p>
  <div class="signal-grid">
    {data.signalItems.map((signal) => <p>{signal}</p>)}
  </div>
      <a class="btn btn-secondary" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_delegation`}>
        {delegationLabel}
      </a>
</section>

<section class="seo-section seo-case section-shell reveal">
  <p class="kicker">Exemple de flux</p>
  <div class="case-layout">
    <div>
      <h2>{data.caseStudy.title}</h2>
      <p class="volume">{data.caseStudy.volume}</p>
    </div>
    <ul>
      {data.caseStudy.results.map((result) => <li>{result}</li>)}
    </ul>
  </div>
</section>

<section class="seo-section seo-diagnostic section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Diagnostic installateur</p>
      <h2>Savoir quoi déléguer avant de changer votre organisation</h2>
    </div>
    <p>
      Le premier échange sert à relier vos pages d'entrée, vos demandes commerciales et vos dossiers signés.
      L'objectif est de repérer le périmètre le plus rentable à traiter en premier.
    </p>
  </div>

  <div class="diagnostic-grid">
    {diagnosticItems.map((item) => (
      <article class="diagnostic-card">
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </article>
    ))}
  </div>

  <div class="diagnostic-actions">
      <a
        class="btn btn-primary btn-accent"
        href={`/contact?source=${data.slug}_diagnostic#contact-form`}
        data-track={`cta_${data.slug}_diagnostic`}
      >
        {diagnosticPrimaryLabel}
      </a>
      <a class="btn btn-secondary" href="/tarifs" data-track={`cta_${data.slug}_diagnostic_tarifs`}>
        {diagnosticSecondaryLabel}
      </a>
  </div>
</section>

<section class="seo-section seo-faq section-shell reveal">
  <p class="kicker">FAQ</p>
  <h2>Questions fréquentes</h2>
  <div class="faq-grid">
    {
      data.faqItems.map((item) => (
        <article class="faq-card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="seo-section seo-links section-shell reveal">
  <p class="kicker">À lire aussi</p>
  <h2>Explorer les autres démarches</h2>
      <div class="links-grid">
    {
      visibleInternalLinks.map((link) => (
        <a class="link-pill" href={link.href} data-track={`link_${data.slug}_${link.href}`}>
          {link.label}
        </a>
      ))
    }
  </div>
</section>

{
  visibleGuideLinks.length > 0 && (
    <section class="seo-section seo-guides section-shell reveal">
      <p class="kicker">Guides associés</p>
      <h2>Approfondir ce sujet</h2>
      <div class="guide-grid">
        {visibleGuideLinks.map((link) => (
          <a class="guide-link" href={link.href} data-track={`guide_${data.slug}_${link.href}`}>
            <span>{link.label}</span>
            <small>{link.description}</small>
          </a>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-final section-shell reveal">
  <h2>{data.finalTitle}</h2>
  <p>{data.finalText}</p>
  <form
    class="service-lead-form"
    action={leadFormAction}
    method="POST"
    data-lead-form
    data-conversion-type="form_contact"
