---
interface ProblemItem {
  title: string;
  text: string;
}

interface CaseStudyData {
  title: string;
  volume: string;
  results: string[];
}

interface FaqItem {
  question: string;
  answer: string;
}

interface InternalLink {
  href: string;
  label: string;
}

interface DetailBlock {
  title: string;
  text: string;
}

interface SeoPageContent {
  slug: string;
  heroTitle: string;
  heroSubtitle: string;
  fitTitle: string;
  fitIntro: string;
  fitItems: string[];
  proof: {
    quote: string;
    author: string;
    role: string;
    highlights: string[];
  };
  problemTitle: string;
  problemIntro: string;
  problemItems: ProblemItem[];
  scopeItems: string[];
  detailBlocks?: DetailBlock[];
  processSteps: string[];
  signalTitle: string;
  signalIntro: string;
  signalItems: string[];
  caseStudy: CaseStudyData;
  faqItems: FaqItem[];
  finalTitle: string;
  finalText: string;
  internalLinks: InternalLink[];
}

interface Props {
  data: SeoPageContent;
}

const { data } = Astro.props;
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "https://formsubmit.co/contact@sunelys.fr";
const successUrl = `https://sunelys.fr/merci?source=${data.slug}_service_form`;

const heroBadges = [
  "Pour installateurs photovoltaïques",
  "DP · Consuel · Raccordement",
  "Cadrage de flux en 15 minutes",
];

const outcomeItems = [
  "Moins de charge administrative pour vos équipes",
  "Moins de retours liés aux pièces incomplètes",
  "Plus de visibilité sur les jalons et les blocages",
  "Une expérience client plus fluide côté installateur",
];
---

<section class="seo-section seo-hero section-shell reveal">
  <div class="hero-layout">
    <div class="hero-copy">
      <p class="kicker">Service administratif photovoltaïque</p>
      <h1>{data.heroTitle}</h1>
      <p>{data.heroSubtitle}</p>

      <ul class="hero-badges" aria-label="Informations clés Sunelys">
        {heroBadges.map((badge) => <li>{badge}</li>)}
      </ul>

      <div class="hero-actions">
        <a class="btn btn-primary" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_hero`}>
          Recevoir un cadrage
        </a>
        <a class="btn btn-secondary" href="/services" data-track={`cta_${data.slug}_hero_services`}>
          Voir les services
        </a>
      </div>
    </div>

    <aside class="hero-aside">
      <article class="hero-fit-card">
        <p class="kicker">Quand cette page vous concerne</p>
        <h2>{data.fitTitle}</h2>
        <p>{data.fitIntro}</p>
        <ul>
          {data.fitItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="hero-proof-card">
        <p class="kicker">Retour terrain</p>
        <blockquote>{data.proof.quote}</blockquote>
        <p class="proof-signature">
          {data.proof.author}
          <span>{data.proof.role}</span>
        </p>
        <ul class="proof-highlights">
          {data.proof.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="seo-section seo-problem section-shell reveal">
  <p class="kicker">Le problème</p>
  <h2>{data.problemTitle}</h2>
  <p class="problem-intro">{data.problemIntro}</p>
  <div class="problem-grid">
    {
      data.problemItems.map((item) => (
        <article class="problem-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="seo-section seo-scope section-shell reveal">
  <div class="split-head">
    <div>
      <p class="kicker">Ce que Sunelys prend en charge</p>
      <h2>Pilotage administratif de bout en bout</h2>
    </div>
    <p>
      L'objectif n'est pas seulement de déposer un dossier. C'est de rendre le flux plus fiable,
      plus lisible et moins consommateur de temps pour vos équipes.
    </p>
  </div>

  <div class="scope-layout">
    <article class="scope-panel">
      <h3>Prise en charge opérationnelle</h3>
      <ul>
        {data.scopeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="scope-panel scope-panel-dark">
      <h3>Résultats attendus</h3>
      <ul>
        {outcomeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

{
  data.detailBlocks && data.detailBlocks.length > 0 && (
    <section class="seo-section seo-details section-shell reveal">
      <p class="kicker">À prévoir</p>
      <h2>Documents, délais et erreurs à éviter</h2>
      <div class="details-grid">
        {data.detailBlocks.map((block) => (
          <article class="detail-card">
            <h3>{block.title}</h3>
            <p>{block.text}</p>
          </article>
        ))}
      </div>
    </section>
  )
}

<section class="seo-section seo-process section-shell reveal">
  <p class="kicker">Process</p>
  <h2>Une exécution claire en 4 étapes</h2>
  <ol>
    {data.processSteps.map((step) => <li>{step}</li>)}
  </ol>
</section>

<section class="seo-section seo-delegation section-shell reveal">
  <p class="kicker">Quand déléguer</p>
  <h2>{data.signalTitle}</h2>
  <p class="problem-intro">{data.signalIntro}</p>
  <div class="signal-grid">
    {data.signalItems.map((signal) => <p>{signal}</p>)}
  </div>
  <a class="btn btn-secondary" href={`/contact?source=${data.slug}`} data-track={`cta_${data.slug}_delegation`}>
    Faire le point sur mes flux
  </a>
</section>

<section class="seo-section seo-case section-shell reveal">
  <p class="kicker">Exemple de flux</p>
  <div class="case-layout">
    <div>
      <h2>{data.caseStudy.title}</h2>
      <p class="volume">{data.caseStudy.volume}</p>
    </div>
    <ul>
      {data.caseStudy.results.map((result) => <li>{result}</li>)}
    </ul>
  </div>
</section>

<section class="seo-section seo-faq section-shell reveal">
  <p class="kicker">FAQ</p>
  <h2>Questions fréquentes</h2>
  <div class="faq-grid">
    {
      data.faqItems.map((item) => (
        <article class="faq-card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="seo-section seo-links section-shell reveal">
  <p class="kicker">À lire aussi</p>
  <h2>Explorer les autres démarches</h2>
  <div class="links-grid">
    {
      data.internalLinks.map((link) => (
        <a class="link-pill" href={link.href} data-track={`link_${data.slug}_${link.href}`}>
          {link.label}
        </a>
      ))
    }
  </div>
</section>

<section class="seo-section seo-final section-shell reveal">
  <h2>{data.finalTitle}</h2>
  <p>{data.finalText}</p>
  <form class="service-lead-form" action={leadFormAction} method="POST">
    <input type="hidden" name="_subject" value={`Nouveau cadrage service - ${data.heroTitle}`} />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_next" value={successUrl} />
    <input type="hidden" name="source_page" value={data.slug} />
    <input type="hidden" name="lead_status" value="Nouveau lead" />
    <input type="hidden" name="lead_pipeline" value="Site web - Page service" />
    <input type="hidden" name="lead_owner" value="Sunelys commercial" />
    <input type="hidden" name="follow_up_sla" value="24h" />

    <label>
      <span>Prénom</span>
      <input type="text" name="first_name" autocomplete="given-name" required />
    </label>
    <label>
      <span>Email professionnel</span>
      <input type="email" name="email" autocomplete="email" inputmode="email" required />
    </label>
    <label>
      <span>Volume mensuel</span>
      <select name="volume" required>
        <option value="">Sélectionner</option>
        <option value="1-10 dossiers">1-10 dossiers</option>
        <option value="10-30 dossiers">10-30 dossiers</option>
        <option value="+30 dossiers">+30 dossiers</option>
      </select>
    </label>
    <button class="btn btn-primary btn-accent" type="submit" data-track={`cta_${data.slug}_final_form`}>
      Recevoir un cadrage
    </button>
    <small>Réponse sous 24h • Sans engagement</small>
  </form>
</section>

<style>
  .seo-section {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 92%, white),
      var(--surface)
    );
    box-shadow: var(--shadow-sm);
    padding: clamp(1.2rem, 2.8vw, 2.2rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.62rem 0 0;
    max-width: 20ch;
    font-size: clamp(2rem, 4vw, 3.9rem);
    line-height: 0.95;
    text-wrap: balance;
  }

  h2 {
    margin: 0.62rem 0 0;
    font-size: clamp(1.45rem, 2.5vw, 2.4rem);
    line-height: 1.05;
    text-wrap: balance;
  }

  h3 {
    margin: 0;
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    line-height: 1.2;
  }

  p,
  li {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .seo-hero {
    background:
      radial-gradient(
        110% 130% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 60%, transparent),
        transparent 58%
      ),
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--surface-elevated) 94%, white),
        var(--surface)
      );
  }

  .hero-copy {
    display: grid;
    gap: 0.9rem;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 1rem;
    align-items: start;
  }

  .hero-aside {
    display: grid;
    gap: 0.8rem;
  }

  .hero-badges {
    margin: 0.1rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-badges li,
  .link-pill {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
    padding: 0.38rem 0.74rem;
    font-size: 0.73rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .hero-fit-card,
  .hero-proof-card {
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: calc(var(--radius-md) - 2px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    padding: 1rem;
    display: grid;
    gap: 0.58rem;
  }

  .hero-fit-card h2 {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    max-width: 16ch;
  }

  .hero-fit-card ul,
  .proof-highlights {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.42rem;
  }

  .hero-proof-card {
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 34%, transparent), transparent 58%),
      linear-gradient(165deg, #17130f, #11100d);
    border-color: color-mix(in srgb, var(--line) 45%, var(--accent));
  }

  .hero-proof-card .kicker,
  .hero-proof-card blockquote,
  .hero-proof-card li,
  .proof-signature {
    color: #f6f0e4;
  }

  .hero-proof-card blockquote {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.6;
    font-weight: 500;
    text-wrap: balance;
  }

  .proof-signature {
    display: grid;
    gap: 0.16rem;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .proof-signature span {
    color: #d5c7b4;
    font-size: 0.74rem;
  }

  .problem-intro {
    margin-top: 0.74rem;
    max-width: 72ch;
  }

  .problem-grid,
  .details-grid,
  .faq-grid,
  .signal-grid {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .problem-card,
  .detail-card,
  .faq-card,
  .scope-panel,
  .signal-grid p {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    padding: 0.85rem;
    display: grid;
    gap: 0.45rem;
  }

  .seo-details h2 {
    max-width: 22ch;
  }

  .details-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .detail-card {
    align-content: start;
  }

  .split-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.72fr);
    gap: 1rem;
    align-items: end;
  }

  .scope-layout,
  .case-layout {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.8rem;
  }

  .scope-panel ul,
  .seo-case ul {
    margin: 0.72rem 0 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.42rem;
  }

  .scope-panel-dark {
    background:
      radial-gradient(100% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 38%, transparent), transparent 58%),
      #17130f;
    border-color: color-mix(in srgb, var(--line) 45%, var(--accent));
  }

  .scope-panel-dark h3,
  .scope-panel-dark li {
    color: #f8f2e7;
  }

  .scope-panel-dark li {
    color: #dfd4c6;
  }

  .seo-process ol {
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.58rem;
    counter-reset: process;
  }

  .seo-process li {
    counter-increment: process;
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.78rem 0.82rem 0.78rem 3rem;
    position: relative;
    color: var(--text);
    font-weight: 600;
  }

  .seo-process li::before {
    content: counter(process);
    position: absolute;
    left: 0.82rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 65%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 70%, white);
    color: var(--text);
    display: grid;
    place-items: center;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .seo-delegation .btn {
    margin-top: 1rem;
  }

  .volume {
    margin-top: 0.74rem;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .links-grid {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .link-pill {
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .link-pill:hover,
  .link-pill:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .seo-final {
    text-align: center;
    background:
      radial-gradient(
        100% 120% at 0% 0%,
        color-mix(in srgb, var(--accent-soft) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(165deg, #1b1712, #11100d);
    border-color: color-mix(in srgb, var(--line) 54%, var(--accent));
  }

  .seo-final h2,
  .seo-final p {
    color: #f7f2e8;
    max-width: 55ch;
    margin-inline: auto;
  }

  .seo-final p {
    margin-top: 0.8rem;
    color: #d9cfbf;
  }

  .seo-final .btn {
    margin-top: 1rem;
  }

  .service-lead-form {
    margin: 1rem auto 0;
    max-width: 860px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr)) auto;
    gap: 0.62rem;
    align-items: end;
  }

  .service-lead-form label {
    display: grid;
    gap: 0.34rem;
    text-align: left;
    color: #f7f2e8;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .service-lead-form input,
  .service-lead-form select {
    width: 100%;
    min-height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: 14px;
    background: #fffdfa;
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.7rem 0.78rem;
  }

  .service-lead-form .btn {
    margin-top: 0;
    white-space: nowrap;
  }

  .service-lead-form small {
    grid-column: 1 / -1;
    color: #d9cfbf;
    font-size: 0.78rem;
  }

  @media (max-width: 900px) {
    .problem-grid,
    .details-grid,
    .faq-grid,
    .signal-grid,
    .scope-layout,
    .case-layout,
    .split-head,
    .hero-layout {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn,
    .seo-delegation .btn,
    .seo-final .btn {
      width: 100%;
    }

    .service-lead-form {
      grid-template-columns: 1fr;
    }
  }
</style>
