    border-radius: 15px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.9rem;
    display: grid;
    gap: 0.4rem;
    align-content: start;
  }

  .offer-snapshot-item span {
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .offer-snapshot-item strong {
    color: var(--text);
    font-size: clamp(1.5rem, 2.3vw, 2.45rem);
    line-height: 1;
  }

  .offer-snapshot-actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .fast-diagnostic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .seo-portal-proof {
    background:
      radial-gradient(
        95% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 44%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
  }

  .portal-proof-layout {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(260px, 0.72fr);
    gap: 0.8rem;
    align-items: stretch;
  }

  .portal-proof-cover,
  .portal-proof-stack figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: 16px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: 0 20px 50px rgba(20, 16, 10, 0.08);
  }

  .portal-proof-cover {
    min-height: 100%;
  }

  .portal-proof-cover img,
  .portal-proof-stack img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .portal-proof-cover img,
  .portal-proof-stack img {
    object-fit: cover;
  }

  .portal-proof-stack {
    display: grid;
    gap: 0.72rem;
  }

  .portal-proof-stack figure {
    aspect-ratio: 16 / 9;
  }

  .portal-proof-copy {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.72rem;
    border: 1px solid color-mix(in srgb, var(--line) 76%, white);
    border-radius: 16px;
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    padding: 0.85rem;
  }

  .portal-proof-copy ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.28rem;
  }

  .portal-proof-copy li {
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .fast-diagnostic-card {
    align-content: start;
  }

  .seo-handover {
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
  }

  .handover-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .handover-card {
    align-content: start;
  }

  .handover-card span {
    width: fit-content;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 58%, white);
    color: var(--text);
    padding: 0.22rem 0.52rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .handover-card strong {
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .seo-concerned {
    background: color-mix(in srgb, var(--surface-elevated) 84%, white);
  }

  .concern-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .concern-grid p {
    color: var(--text);
    font-weight: 700;
  }

  .use-case-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .use-case-card {
    align-content: start;
  }

  .details-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .detail-card {
    align-content: start;
  }

  .split-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.72fr);
    gap: 1rem;
    align-items: end;
  }

  .scope-layout,
  .case-layout {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.8rem;
  }

  .scope-panel ul,
  .seo-case ul {
    margin: 0.72rem 0 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.42rem;
  }

  .scope-panel-dark {
    background:
      radial-gradient(100% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 38%, transparent), transparent 58%),
      #17130f;
    border-color: color-mix(in srgb, var(--line) 45%, var(--accent));
  }

  .scope-panel-dark h3,
  .scope-panel-dark li {
    color: #f8f2e7;
  }

  .scope-panel-dark li {
    color: #dfd4c6;
  }

  .seo-process ol {
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.58rem;
    counter-reset: process;
  }

  .seo-process li {
    counter-increment: process;
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.78rem 0.82rem 0.78rem 3rem;
    position: relative;
    color: var(--text);
    font-weight: 600;
  }

  .seo-process li::before {
    content: counter(process);
    position: absolute;
    left: 0.82rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 65%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 70%, white);
    color: var(--text);
    display: grid;
    place-items: center;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .seo-delegation .btn {
    margin-top: 1rem;
  }

  .seo-diagnostic {
    background:
      radial-gradient(
        100% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 36%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 94%, white),
        var(--surface)
      );
  }

  .diagnostic-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .diagnostic-card {
    align-content: start;
  }

  .diagnostic-actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .volume {
    margin-top: 0.74rem;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .links-grid {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .link-pill {
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .link-pill:hover,
  .link-pill:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .guide-grid {
    margin-top: 0.9rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .guide-link {
    min-height: 7.2rem;
    display: grid;
    align-content: start;
    gap: 0.34rem;
    padding: 0.92rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    color: var(--text);
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .guide-link:hover,
  .guide-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .guide-link span {
    font-weight: 800;
    line-height: 1.24;
  }

  .guide-link small {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .seo-final {
    text-align: center;
    background:
      radial-gradient(
        100% 120% at 0% 0%,
        color-mix(in srgb, var(--accent-soft) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(165deg, #1b1712, #11100d);
    border-color: color-mix(in srgb, var(--line) 54%, var(--accent));
  }

  .seo-final h2,
  .seo-final p {
    color: #f7f2e8;
    max-width: 55ch;
    margin-inline: auto;
  }

  .seo-final p {
    margin-top: 0.8rem;
    color: #d9cfbf;
  }

  .seo-final .btn {
    margin-top: 1rem;
  }

  .service-lead-form {
    margin: 1rem auto 0;
    max-width: 1040px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.62rem;
    align-items: end;
  }

  .service-lead-form label {
    display: grid;
    gap: 0.34rem;
    text-align: left;
    color: #f7f2e8;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .service-lead-form input,
  .service-lead-form select {
    width: 100%;
    min-height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: 11px;
    background: #fffdfa;
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.7rem 0.78rem;
  }

  .service-lead-form .btn {
    grid-column: 1 / -1;
    width: 100%;
    margin-top: 0;
    white-space: nowrap;
  }

  .service-lead-form small {
    grid-column: 1 / -1;
    color: #d9cfbf;
    font-size: 0.78rem;
  }

  @media (max-width: 900px) {
    .problem-grid,
    .details-grid,
    .faq-grid,
    .signal-grid,
    .use-case-grid,
    .diagnostic-grid,
    .fast-diagnostic-grid,
    .offer-snapshot-grid,
    .handover-grid,
    .concern-grid,
    .scope-layout,
    .case-layout,
    .split-head,
    .guide-grid,
    .hero-layout {
      grid-template-columns: 1fr;
    }

    .portal-proof-layout {
      grid-template-columns: 1fr;
    }

    .hero-price-pills {
      grid-template-columns: 1fr;
    }

    .portal-proof-cover {
      aspect-ratio: 16 / 9;
    }

    .portal-proof-copy .btn {
      width: 100%;
    }

    .expert-line {
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      padding: 0.72rem 0;
    }

    .hero-actions .btn,
    .diagnostic-actions .btn,
    .offer-snapshot-actions .btn,
    .seo-delegation .btn,
    .seo-final .btn {
      width: 100%;
    }

    .service-lead-form {
      grid-template-columns: 1fr;
    }
  }

  /* Direction visuelle 2026 */
  .seo-section {
    border-color: var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    padding: clamp(1.3rem, 3vw, 2.6rem);
