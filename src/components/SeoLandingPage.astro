<script>
  const serviceAttribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
  document.querySelectorAll("[data-service-attribution]").forEach((field) => {
    if (!(field instanceof HTMLInputElement)) return;
    const key = field.dataset.serviceAttribution || "";
    field.value = serviceAttribution[key] || "";
  });

  document.querySelectorAll(".knowledge-accordion").forEach((accordion) => {
    const items = Array.from(accordion.querySelectorAll(".knowledge-item"));

    items.forEach((item) => {
      item.addEventListener("toggle", () => {
        if (!(item instanceof HTMLDetailsElement) || !item.open) return;

        items.forEach((sibling) => {
          if (sibling instanceof HTMLDetailsElement && sibling !== item) {
            sibling.open = false;
          }
        });
      });
    });
  });

  document.querySelectorAll(".support-faq").forEach((faq) => {
    const items = Array.from(faq.querySelectorAll(".support-faq-item"));

    items.forEach((item) => {
      item.addEventListener("toggle", () => {
        if (!(item instanceof HTMLDetailsElement) || !item.open) return;

        items.forEach((sibling) => {
          if (sibling instanceof HTMLDetailsElement && sibling !== item) {
            sibling.open = false;
          }
        });
      });
    });
  });
</script>

