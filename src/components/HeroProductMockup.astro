---
type Variant = "minimal" | "full";

interface ProjectItem {
  name: string;
  progress: string;
  status: string;
}

interface MockupData {
  label: string;
  title: string;
  projects: ProjectItem[];
  timeline?: string[];
  documents?: string[];
  footer?: string;
  variant?: Variant;
}

interface Props {
  data: MockupData;
  variant?: Variant;
}

const { data, variant = data.variant ?? "full" } = Astro.props;
const timelineLabel = (data.timeline ?? []).join(" → ");
---

<aside class="mockup reveal" data-variant={variant} aria-label="Aperçu du portail Sunelys">
  <div class="mockup-shell">
    <header class="mockup-head">
      <span class="mockup-label">{data.label}</span>
      <span class="mockup-live">
        <span class="live-dot" aria-hidden="true"></span>
        LIVE
      </span>
    </header>

    <h2>{data.title}</h2>

    <div class="mockup-layout">
      <section class="panel panel-main">
        <p class="panel-label">Liste dossiers</p>
        <ul class="dossiers-list">
          {
            data.projects.map((project, index) => (
              <li class="dossier-row" style={`--row-delay:${index * 80}ms`}>
                <div class="row-main">
                  <span class="status-dot" aria-hidden="true"></span>
                  <div class="row-copy">
                    <strong>{project.name}</strong>
                    <small class:list={["progress", index === 1 && variant === "full" && "progress-switch"]}>
                      <span class="state state-a">{project.progress}</span>
                      <span class="state state-b">Consuel en cours</span>
                    </small>
                  </div>
                </div>
                <span class="row-pill">{project.status}</span>
              </li>
            ))
          }
        </ul>
        {
          variant === "full" && timelineLabel && (
            <p class="workflow-inline">{timelineLabel}</p>
          )
        }
      </section>

      <div class="side-stack">
        <section class="panel panel-status">
          <p class="panel-label">Statuts en cours</p>
          <ul>
            <li class="status-badge status-green">DP validée</li>
            <li class="status-badge status-sand">Consuel en cours</li>
            <li class="status-badge status-blue">Raccordement planifié</li>
          </ul>
        </section>

        {
          variant === "full" && (
            <section class="panel panel-documents">
              <p class="panel-label">Documents</p>
              <ul>
                {(data.documents ?? []).slice(0, 3).map((document) => (
                  <li>{document}</li>
                ))}
              </ul>
            </section>
          )
        }
      </div>
    </div>

    {
      variant === "full" && data.footer && <p class="mockup-footer">{data.footer}</p>
    }
  </div>
</aside>

<style>
  .mockup {
    --border-subtle: color-mix(in srgb, var(--line) 82%, white);
    --text-primary: var(--text);
    --text-muted-soft: color-mix(in srgb, var(--text-muted) 92%, #6e675b);
    --radius-lg: 16px;
    --radius-xl-local: 18px;
    --shadow-lg:
      0 40px 120px rgba(0, 0, 0, 0.18),
      0 10px 40px rgba(0, 0, 0, 0.08);

    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background:
      radial-gradient(
        120% 100% at 92% -8%,
        color-mix(in srgb, var(--accent-soft) 52%, transparent),
        transparent 58%
      ),
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--surface-elevated) 96%, white),
        var(--surface)
      );
    padding: clamp(0.95rem, 2vw, 1.3rem);
  }

  .mockup-shell {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl-local);
    background: color-mix(in srgb, var(--surface-elevated) 95%, white);
    box-shadow: var(--shadow-lg);
    padding: 0.92rem;
    position: relative;
    overflow: hidden;
    transform: perspective(1400px) rotateY(-5deg) rotateX(2deg);
    transform-origin: right center;
    animation:
      mockup-enter 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both,
      floating 6s ease-in-out infinite 760ms;
  }

  .mockup-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      103deg,
      transparent 18%,
      rgba(255, 255, 255, 0.36) 42%,
      transparent 62%
    );
    transform: translateX(-100%);
    animation: shimmer 12s ease-in-out infinite;
    pointer-events: none;
  }

  .mockup-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.45rem;
  }

  .mockup-label,
  .mockup-live {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    background: color-mix(in srgb, var(--surface) 88%, white);
    padding: 0.34rem 0.56rem;
    font-size: 0.62rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-primary);
  }

  .mockup-live {
    gap: 0.34rem;
    background: color-mix(in srgb, var(--accent-soft) 72%, white);
    transform-origin: center;
    animation: live-pill 2.5s ease-in-out infinite;
  }

  .live-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: #3a7556;
  }

  h2 {
    margin: 0.76rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.02rem, 1vw + 0.86rem, 1.35rem);
    letter-spacing: 0.01em;
    line-height: 1.2;
    font-weight: 650;
    color: var(--text-primary);
    max-width: 30ch;
  }

  .mockup-layout {
    margin-top: 0.82rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.54rem;
  }

  .panel {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface-elevated) 93%, white);
    box-shadow: 0 8px 24px rgba(20, 16, 10, 0.08);
    padding: 0.62rem;
    position: relative;
  }

  .panel-main {
    background:
      radial-gradient(
        110% 100% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 40%, transparent),
        transparent 60%
      ),
      color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: 0.7rem;
  }

  .side-stack {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.54rem;
  }

  .panel-label {
    margin: 0;
    color: var(--text-muted-soft);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .panel ul {
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.34rem;
  }

  .dossier-row {
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: 12px;
    background: color-mix(in srgb, var(--surface) 88%, white);
    padding: 0.45rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.35rem;
    transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
    animation: row-enter 520ms ease both;
    animation-delay: var(--row-delay);
  }

  .dossier-row:hover {
    background: color-mix(in srgb, var(--accent-soft) 44%, white);
    border-color: color-mix(in srgb, var(--line) 56%, var(--accent));
    transform: translateY(-1px);
  }

  .row-main {
    display: flex;
    align-items: flex-start;
    gap: 0.42rem;
    min-width: 0;
  }

  .row-copy {
    min-width: 0;
  }

  .status-dot {
    width: 0.44rem;
    height: 0.44rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 70%, #fff3d8);
    margin-top: 0.25rem;
    flex-shrink: 0;
  }

  strong {
    display: block;
    font-size: 0.74rem;
    line-height: 1.2;
    color: var(--text-primary);
    font-weight: 650;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 18ch;
  }

  .progress {
    display: block;
    margin-top: 0.1rem;
    color: var(--text-muted-soft);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    position: relative;
    min-height: 0.95rem;
  }

  .progress .state {
    display: inline-flex;
    align-items: center;
  }

  .progress-switch .state-b {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    animation: progress-switch 8s ease-in-out infinite;
  }

  .progress-switch .state-a {
    animation: progress-hide 8s ease-in-out infinite;
  }

  .row-pill {
    flex-shrink: 0;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 62%, white);
    padding: 0.2rem 0.42rem;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-primary);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.86rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, white);
    padding: 0.32rem 0.55rem;
    font-size: 0.61rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-primary);
  }

  .status-green {
    background: color-mix(in srgb, #dff3e7 72%, white);
    border-color: color-mix(in srgb, #7faf93 42%, var(--line));
  }

  .status-sand {
    background: color-mix(in srgb, #f6eed8 78%, white);
    border-color: color-mix(in srgb, #d0b87b 40%, var(--line));
  }

  .status-blue {
    background: color-mix(in srgb, #e6eef8 78%, white);
    border-color: color-mix(in srgb, #8aa3c4 40%, var(--line));
  }

  .panel-documents li {
    border-bottom: 1px solid color-mix(in srgb, var(--line) 66%, white);
    padding: 0.22rem 0;
    font-size: 0.67rem;
    color: var(--text-muted-soft);
    line-height: 1.35;
  }

  .panel-documents li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .workflow-inline {
    margin: 0.58rem 0 0;
    border-top: 1px solid color-mix(in srgb, var(--line) 65%, white);
    padding-top: 0.45rem;
    color: var(--text-muted-soft);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.32;
  }

  .mockup-footer {
    margin: 0.62rem 0 0;
    color: var(--text-muted-soft);
    font-size: 0.66rem;
    line-height: 1.5;
  }

  .mockup[data-variant="minimal"] .panel-documents,
  .mockup[data-variant="minimal"] .workflow-inline,
  .mockup[data-variant="minimal"] .mockup-footer {
    display: none;
  }

  @keyframes mockup-enter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes floating {
    0%,
    100% {
      transform: perspective(1400px) rotateY(-5deg) rotateX(2deg) translateY(0);
    }
    50% {
      transform: perspective(1400px) rotateY(-5deg) rotateX(2deg) translateY(-6px);
    }
  }

  @keyframes row-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes live-pill {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  @keyframes shimmer {
    0%,
    78% {
      transform: translateX(-105%);
      opacity: 0;
    }
    82% {
      opacity: 1;
    }
    100% {
      transform: translateX(110%);
      opacity: 0;
    }
  }

  @keyframes progress-switch {
    0%,
    36% {
      opacity: 0;
    }
    44%,
    84% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @keyframes progress-hide {
    0%,
    36% {
      opacity: 1;
    }
    44%,
    84% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  @media (max-width: 980px) {
    .mockup-shell {
      transform: none;
      animation:
        mockup-enter 650ms ease both,
        floating-mobile 6s ease-in-out infinite 700ms;
    }
  }

  @media (max-width: 760px) {
    .side-stack {
      grid-template-columns: 1fr;
    }

    .panel-documents {
      display: none;
    }
  }

  @keyframes floating-mobile {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mockup-shell,
    .dossier-row,
    .mockup-live,
    .mockup-shell::before,
    .progress-switch .state-a,
    .progress-switch .state-b {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }
</style>
