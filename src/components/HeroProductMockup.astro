---
type Variant = "minimal" | "full";

interface ProjectItem {
  name: string;
  progress: string;
  status: string;
}

interface MockupData {
  label: string;
  title: string;
  projects: ProjectItem[];
  timeline?: string[];
  documents?: string[];
  footer?: string;
  variant?: Variant;
}

interface Props {
  data: MockupData;
  variant?: Variant;
}

const { data, variant = data.variant ?? "full" } = Astro.props;
---

<aside class="mockup" data-variant={variant} aria-label="Aperçu du portail Sunelys">
  <div class="mockup-shell">
    <header class="mockup-head">
      <span class="mockup-label">{data.label}</span>
      <span class="mockup-live">
        <span class="live-dot" aria-hidden="true"></span>
        LIVE
      </span>
    </header>

    <h2>{data.title}</h2>

    <div class="mockup-grid">
      <section class="panel panel-dossiers">
        <p class="panel-label">Liste dossiers</p>
        <ul>
          {
            data.projects.map((project, index) => (
              <li class="dossier-row" style={`--row-delay:${index * 120}ms`}>
                <div class="row-main">
                  <span class="status-dot" aria-hidden="true"></span>
                  <div>
                    <strong>{project.name}</strong>
                    <small class:list={["progress", index === 1 && variant === "full" && "progress-switch"]}>
                      <span class="state state-a">{project.progress}</span>
                      <span class="state state-b">Consuel en cours</span>
                    </small>
                  </div>
                </div>
                <span class="row-pill">{project.status}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="panel panel-status">
        <p class="panel-label">Statuts en cours</p>
        <ul>
          <li class="status-badge status-green">DP validée</li>
          <li class="status-badge status-sand">Consuel en cours</li>
          <li class="status-badge status-blue">Raccordement planifié</li>
        </ul>
      </section>

      {
        variant === "full" && (
          <section class="panel panel-timeline">
            <p class="panel-label">Workflow</p>
            <ol>
              {(data.timeline ?? []).map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </section>
        )
      }
    </div>

    {
      variant === "full" && data.footer && <p class="mockup-footer">{data.footer}</p>
    }
  </div>
</aside>

<style>
  .mockup {
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background:
      radial-gradient(120% 100% at 90% -8%, color-mix(in srgb, var(--accent-soft) 52%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(0.95rem, 2vw, 1.3rem);
    animation: mockup-enter 650ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .mockup-shell {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    border-radius: calc(var(--radius-xl) - 8px);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: 0 24px 52px rgba(18, 14, 10, 0.13);
    padding: 0.86rem;
    transform: perspective(1200px) rotateY(-6deg) rotateX(2deg);
    transform-origin: right center;
    transition: transform 320ms ease, box-shadow 320ms ease;
    position: relative;
    overflow: hidden;
  }

  .mockup-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      102deg,
      transparent 12%,
      rgba(255, 255, 255, 0.42) 38%,
      transparent 60%
    );
    transform: translateX(-100%);
    animation: shimmer 10s ease-in-out infinite;
    pointer-events: none;
  }

  .mockup:hover .mockup-shell {
    transform: perspective(1200px) rotateY(-3deg) rotateX(1deg) translateY(-2px);
    box-shadow: 0 30px 64px rgba(18, 14, 10, 0.16);
  }

  .mockup-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.45rem;
  }

  .mockup-label,
  .mockup-live {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    background: color-mix(in srgb, var(--surface) 88%, white);
    padding: 0.34rem 0.56rem;
    font-size: 0.62rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
  }

  .mockup-live {
    gap: 0.34rem;
    background: color-mix(in srgb, var(--accent-soft) 72%, white);
  }

  .live-dot {
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 999px;
    background: #3a7556;
    animation: live-pulse 2.8s ease-in-out infinite;
  }

  h2 {
    margin: 0.7rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.02rem, 1vw + 0.86rem, 1.36rem);
    letter-spacing: 0.01em;
    line-height: 1.2;
    font-weight: 650;
    max-width: 30ch;
  }

  .mockup-grid {
    margin-top: 0.78rem;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    gap: 0.5rem;
  }

  .panel {
    border: 1px solid color-mix(in srgb, var(--line) 86%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
    padding: 0.56rem;
    position: relative;
  }

  .panel-label {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .panel ul,
  .panel ol {
    margin: 0.46rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.34rem;
  }

  .dossier-row {
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: calc(var(--radius-sm) - 2px);
    background: color-mix(in srgb, var(--surface) 86%, white);
    padding: 0.42rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.34rem;
    animation: row-enter 520ms ease both;
    animation-delay: var(--row-delay);
  }

  .row-main {
    display: flex;
    align-items: flex-start;
    gap: 0.42rem;
    min-width: 0;
  }

  .status-dot {
    width: 0.44rem;
    height: 0.44rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 70%, #fff3d8);
    margin-top: 0.25rem;
    flex-shrink: 0;
  }

  strong {
    display: block;
    font-size: 0.73rem;
    line-height: 1.2;
    color: var(--text);
    font-weight: 650;
  }

  .progress {
    display: block;
    margin-top: 0.08rem;
    color: var(--text-muted);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    position: relative;
    min-height: 0.95rem;
  }

  .progress .state {
    display: inline-flex;
    align-items: center;
  }

  .progress-switch .state-b {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    animation: progress-switch 7.6s ease-in-out infinite;
  }

  .progress-switch .state-a {
    animation: progress-hide 7.6s ease-in-out infinite;
  }

  .row-pill {
    flex-shrink: 0;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 62%, white);
    padding: 0.2rem 0.42rem;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.86rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, white);
    padding: 0.32rem 0.55rem;
    font-size: 0.61rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
  }

  .status-green {
    background: color-mix(in srgb, #dff3e7 70%, white);
    border-color: color-mix(in srgb, #7faf93 44%, var(--line));
  }

  .status-sand {
    background: color-mix(in srgb, #f6eed8 76%, white);
    border-color: color-mix(in srgb, #d0b87b 42%, var(--line));
  }

  .status-blue {
    background: color-mix(in srgb, #e6eef8 76%, white);
    border-color: color-mix(in srgb, #8aa3c4 42%, var(--line));
  }

  .panel-timeline {
    grid-column: 1 / -1;
  }

  .panel-timeline ol {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.22rem;
  }

  .panel-timeline li {
    min-height: 1.62rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 64%, white);
    display: grid;
    place-items: center;
    padding: 0.18rem 0.26rem;
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
    text-align: center;
    line-height: 1.15;
  }

  .mockup-footer {
    margin: 0.58rem 0 0;
    color: var(--text-muted);
    font-size: 0.66rem;
    line-height: 1.5;
  }

  .mockup[data-variant="minimal"] .panel-timeline,
  .mockup[data-variant="minimal"] .mockup-footer {
    display: none;
  }

  @keyframes mockup-enter {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes row-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes live-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(58, 117, 86, 0.3);
    }
    50% {
      box-shadow: 0 0 0 7px rgba(58, 117, 86, 0);
    }
  }

  @keyframes shimmer {
    0%,
    78% {
      transform: translateX(-105%);
      opacity: 0;
    }
    82% {
      opacity: 1;
    }
    100% {
      transform: translateX(110%);
      opacity: 0;
    }
  }

  @keyframes progress-switch {
    0%,
    35% {
      opacity: 0;
    }
    42%,
    82% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @keyframes progress-hide {
    0%,
    35% {
      opacity: 1;
    }
    42%,
    82% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  @media (max-width: 900px) {
    .mockup-shell {
      transform: none;
    }

    .mockup-grid {
      grid-template-columns: 1fr;
    }

    .panel-timeline ol {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mockup,
    .mockup-shell,
    .dossier-row,
    .live-dot,
    .mockup-shell::before,
    .progress-switch .state-a,
    .progress-switch .state-b {
      animation: none !important;
      transition: none !important;
    }

    .mockup-shell {
      transform: none !important;
    }
  }
</style>
