---
import MediaFrame from "./MediaFrame.astro";

interface ResultItem {
  value: string;
  label: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    client?: string;
    context?: string;
    narrative: string;
    results: ResultItem[];
    note?: string;
    secondaryCase?: {
      title: string;
      author: string;
      quote: string;
    };
    cta: {
      label: string;
      href: string;
      track: string;
    };
    image?: {
      src: string;
      alt: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="section-shell case-section reveal">
  <div class="case-copy">
    <div class="case-head">
      <p class="kicker">{data.kicker}</p>
      <h2>{data.title}</h2>
      {data.client && <p class="client">{data.client}</p>}
      {data.context && <p class="context">{data.context}</p>}
    </div>

    <article class="main-quote">
      <span class="quote-mark" aria-hidden="true">“</span>
      <p class="narrative">{data.narrative}</p>
    </article>

    {data.note && <p class="note">{data.note}</p>}

    {
      data.secondaryCase && (
        <article class="secondary-case">
          <p class="secondary-kicker">{data.secondaryCase.title}</p>
          <p class="secondary-quote">"{data.secondaryCase.quote}"</p>
          <p class="secondary-author">{data.secondaryCase.author}</p>
        </article>
      )
    }

    <a class="btn btn-secondary" href={data.cta.href} data-track={data.cta.track}>{data.cta.label}</a>
  </div>

  <div class="case-side">
    {data.image && (
      <div class="case-visual">
        <MediaFrame src={data.image.src} alt={data.image.alt} label="Cas client" variant="landscape" />
      </div>
    )}

    <div class="case-results">
      {
        data.results.map((result, index) => (
          <article class:list={["metric-box", index === 0 && "is-featured"]}>
            <p class="value">{result.value}</p>
            <p class="label">{result.label}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .case-section {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 60%, var(--accent));
    background:
      radial-gradient(90% 110% at -6% 0%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 62%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface));
    box-shadow: 0 30px 78px rgba(20, 16, 10, 0.11);
    padding: clamp(1.3rem, 2.8vw, 2.35rem);
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    gap: clamp(0.9rem, 1.8vw, 1.25rem);
  }

  .case-section::before {
    content: "";
    position: absolute;
    inset: 1rem;
    border: 1px solid color-mix(in srgb, var(--line) 42%, white);
    border-radius: calc(var(--radius-xl) - 14px);
    pointer-events: none;
  }

  .case-copy,
  .case-side {
    position: relative;
    z-index: 1;
  }

  .case-copy {
    display: grid;
    align-content: start;
    gap: 0.9rem;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  h2 {
    margin: 0.48rem 0 0;
    max-width: 18ch;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1;
    text-wrap: balance;
  }

  .client {
    margin: 0.88rem 0 0;
    color: var(--text);
    font-size: 0.97rem;
    font-weight: 650;
  }

  .context {
    margin: 0.22rem 0 0;
    color: var(--text-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
  }

  .main-quote {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 82%, var(--accent));
    border-radius: 28px;
    background:
      radial-gradient(120% 120% at 100% 0%, color-mix(in srgb, var(--accent-soft) 54%, transparent), transparent 58%),
      color-mix(in srgb, var(--surface-elevated) 96%, white);
    box-shadow: 0 18px 42px rgba(20, 16, 10, 0.08);
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .quote-mark {
    display: inline-block;
    color: color-mix(in srgb, var(--accent) 84%, #f1d8b8);
    font-family: var(--font-display);
    font-size: clamp(3rem, 4.8vw, 4.8rem);
    line-height: 0.7;
  }

  .narrative {
    margin: 0.24rem 0 0;
    color: var(--text);
    font-size: clamp(1rem, 0.48vw + 0.92rem, 1.14rem);
    line-height: 1.64;
    text-wrap: pretty;
  }

  .note {
    margin: -0.15rem 0 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.55;
  }

  .secondary-case {
    border: 1px solid color-mix(in srgb, var(--line) 78%, var(--accent));
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.7);
    padding: 1rem;
    box-shadow: 0 14px 34px rgba(22, 16, 10, 0.06);
  }

  .secondary-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .secondary-quote {
    margin: 0.42rem 0 0;
    color: var(--text);
    font-size: 0.87rem;
    line-height: 1.58;
  }

  .secondary-author {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .case-copy .btn {
    margin-top: 0.05rem;
    width: fit-content;
  }

  .case-side {
    display: grid;
    gap: 0.82rem;
    align-content: start;
  }

  .case-results {
    display: grid;
    gap: 0.62rem;
  }

  .metric-box {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    border-radius: 22px;
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: 0 14px 36px rgba(22, 16, 10, 0.07);
    padding: 0.95rem;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .metric-box.is-featured {
    background:
      radial-gradient(110% 120% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      color-mix(in srgb, var(--surface-elevated) 96%, white);
  }

  .metric-box:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 44px rgba(22, 16, 10, 0.11);
    border-color: color-mix(in srgb, var(--line) 66%, var(--accent));
  }

  .value {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.6rem, 2vw, 2.25rem);
    line-height: 0.9;
    font-family: var(--font-display);
  }

  .label {
    margin: 0.34rem 0 0;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.46;
    max-width: 24ch;
  }

  @media (max-width: 980px) {
    .case-section {
      grid-template-columns: 1fr;
    }

    .case-copy .btn {
      width: 100%;
    }
  }
</style>
