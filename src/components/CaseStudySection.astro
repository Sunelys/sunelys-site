---
import MediaFrame from "./MediaFrame.astro";

interface ResultItem {
  value: string;
  label: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    client: string;
    context: string;
    narrative: string;
    results: ResultItem[];
    note: string;
    cta: {
      label: string;
      href: string;
      track: string;
    };
    image?: {
      src: string;
      alt: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="section-shell case-section reveal">
  <div class="case-content">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
    <p class="client">{data.client}</p>
    <p class="context">{data.context}</p>
    <p class="narrative">{data.narrative}</p>
    <p class="note">{data.note}</p>
    <a class="btn btn-secondary" href={data.cta.href} data-track={data.cta.track}>{data.cta.label}</a>
  </div>

  <div class="case-metrics">
    {data.image && (
      <div class="case-visual">
        <MediaFrame src={data.image.src} alt={data.image.alt} label="Cas client" variant="landscape" />
      </div>
    )}
    {
      data.results.map((result) => (
        <article class="metric-box">
          <p class="value">{result.value}</p>
          <p class="label">{result.label}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .case-section {
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    background:
      radial-gradient(110% 120% at -6% 0%, color-mix(in srgb, var(--accent-soft) 40%, transparent), transparent 62%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 92%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.3rem, 2.8vw, 2.2rem);
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 0.76rem;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 24ch;
    font-size: clamp(1.6rem, 2.8vw, 2.7rem);
    line-height: 1.03;
  }

  .client {
    margin: 0.86rem 0 0;
    color: var(--text);
    font-size: 0.96rem;
    font-weight: 600;
  }

  .context {
    margin: 0.24rem 0 0;
    color: var(--text-muted);
    font-size: 0.69rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-weight: 600;
  }

  .narrative {
    margin: 0.68rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.52;
  }

  .note {
    margin: 0.52rem 0 0;
    color: var(--text-muted);
    font-size: 0.69rem;
  }

  .case-content .btn {
    margin-top: 0.86rem;
    width: fit-content;
  }

  .case-metrics {
    display: grid;
    gap: 0.52rem;
    align-content: start;
  }

  .case-visual {
    margin-bottom: 0.1rem;
  }

  .metric-box {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: 0 10px 24px rgba(22, 16, 10, 0.07);
    padding: 0.78rem;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .metric-box:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--line) 65%, var(--accent));
  }

  .value {
    margin: 0;
    font-size: clamp(1.45rem, 1.9vw, 2.1rem);
    line-height: 0.9;
    font-family: var(--font-display);
  }

  .label {
    margin: 0.32rem 0 0;
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.42;
  }

  @media (max-width: 980px) {
    .case-section {
      grid-template-columns: 1fr;
    }

    .case-content .btn {
      width: 100%;
    }
  }
</style>
