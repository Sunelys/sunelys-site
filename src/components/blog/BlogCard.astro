---
import MediaFrame from "../MediaFrame.astro";

interface Props {
  post: {
    frontmatter: {
      slug: string;
      title: string;
      description: string;
      pubDate: string;
      category: string;
      readingTime: string;
      coverImage?: string;
      coverAlt?: string;
    };
  };
}

const { post } = Astro.props;
const date = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(post.frontmatter.pubDate));
---

<article class="blog-card">
  <MediaFrame
    src={post.frontmatter.coverImage}
    alt={post.frontmatter.coverAlt || post.frontmatter.title}
    label="Visuel article à remplacer"
    variant="landscape"
  />

  <div class="blog-card-meta">
    <span>{post.frontmatter.category}</span>
    <span>{date}</span>
    <span>{post.frontmatter.readingTime}</span>
  </div>
  <h2>
    <a href={`/blog/${post.frontmatter.slug}`} data-track="cta_blog_card" data-track-label={post.frontmatter.title}>
      {post.frontmatter.title}
    </a>
  </h2>
  <p>{post.frontmatter.description}</p>
  <a class="blog-card-link" href={`/blog/${post.frontmatter.slug}`} data-track="cta_blog_read" data-track-label={post.frontmatter.title}>
    Lire l'article
  </a>
</article>

<style>
  .blog-card {
    min-height: 100%;
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: clamp(1.1rem, 2vw, 1.55rem);
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: var(--radius-md);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 92%, white));
    box-shadow: var(--shadow-sm);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--line) 64%, var(--accent));
  }

  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.7rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-card h2 {
    font-size: clamp(1.55rem, 2.3vw, 2.25rem);
    line-height: 1.02;
  }

  .blog-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .blog-card p {
    color: var(--text-muted);
    font-size: var(--step-0);
    line-height: 1.65;
  }

  .blog-card-link {
    width: fit-content;
    margin-top: 0.2rem;
    color: var(--text);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .blog-card-link:hover,
  .blog-card-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }
</style>
