---
import ResponsiveImage from "../ResponsiveImage.astro";

interface Props {
  post: {
    frontmatter: {
      slug: string;
      title: string;
      description: string;
      pubDate: string;
      category: string;
      readingTime: string;
      coverImage?: string;
      coverAlt?: string;
    };
  };
  index?: number;
}

const { post, index = 0 } = Astro.props;
const articleHref = `/blog/${post.frontmatter.slug}`;
const date = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "short",
  year: "numeric",
}).format(new Date(post.frontmatter.pubDate));
---

<article class="blog-card">
  <a
    class="blog-visual"
    href={articleHref}
    data-track="cta_blog_card_visual"
    data-track-label={post.frontmatter.title}
    aria-label={`Lire : ${post.frontmatter.title}`}
  >
    {
      post.frontmatter.coverImage ? (
        <ResponsiveImage
          src={post.frontmatter.coverImage}
          alt={post.frontmatter.coverAlt || post.frontmatter.title}
          loading="lazy"
          decoding="async"
          width="1280"
          height="720"
          sizes="(max-width: 700px) 88vw, (max-width: 1100px) 44vw, 30vw"
        />
      ) : (
        <span aria-hidden="true">SUNELYS</span>
      )
    }
    <i aria-hidden="true">0{index + 1}</i>
  </a>

  <div class="blog-card-body">
    <div class="blog-card-meta">
      <span>{post.frontmatter.category}</span>
      <span>{post.frontmatter.readingTime}</span>
    </div>

    <h2>
      <a href={articleHref} data-track="cta_blog_card" data-track-label={post.frontmatter.title}>
        {post.frontmatter.title}
      </a>
    </h2>

    <p>{post.frontmatter.description}</p>

    <footer>
      <time datetime={post.frontmatter.pubDate}>{date}</time>
      <a href={articleHref} data-track="cta_blog_read" data-track-label={post.frontmatter.title}>
        Lire le guide
        <span aria-hidden="true">→</span>
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-card {
    min-height: 100%;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface);
    transition: border-color 170ms ease, box-shadow 170ms ease, transform 170ms ease;
  }

  .blog-card:hover {
    border-color: color-mix(in srgb, var(--system) 28%, var(--line));
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .blog-visual {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      radial-gradient(80% 100% at 100% 0%, rgba(54, 98, 227, 0.25), transparent 62%),
      var(--ink);
  }

  .blog-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .blog-visual :global(.responsive-picture) {
    height: 100%;
  }

  .blog-card:hover .blog-visual img {
    transform: scale(1.025);
  }

  .blog-visual > span {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .blog-visual i {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(14, 23, 38, 0.68);
    color: var(--accent);
    font-size: 0.62rem;
    font-style: normal;
    font-weight: 800;
    backdrop-filter: blur(10px);
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    min-height: 21rem;
    padding: 1.05rem;
  }

  .blog-card-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    color: var(--system);
    font-size: 0.61rem;
    font-weight: 780;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .blog-card-meta span:last-child {
    color: var(--text-muted);
  }

  h2 {
    margin-top: 1.35rem;
    font-size: clamp(1.45rem, 2.1vw, 2.05rem);
    line-height: 1.04;
  }

  h2 a {
    color: inherit;
    text-decoration: none;
  }

  .blog-card-body > p {
    margin-top: 0.75rem;
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.58;
  }

  footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-top: auto;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }

  time {
    color: var(--text-muted);
    font-size: 0.62rem;
  }

  footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 760;
    text-decoration: none;
  }

  footer a span {
    color: var(--accent);
    font-size: 0.9rem;
    transition: transform 160ms ease;
  }

  footer a:hover span {
    transform: translateX(3px);
  }

  @media (max-width: 620px) {
    .blog-card-body {
      min-height: 18rem;
    }
  }
</style>
