---
interface Testimonial {
  quote: string;
  author: string;
  note: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    testimonials: Testimonial[];
  };
}

const { data } = Astro.props;
const getInitials = (name: string) =>
  name
    .split(/\s+/)
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
---

<section class="section-shell proof-section reveal" aria-labelledby="proof-title">
  <div class="proof-head" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="proof-title">{data.title}</h2>
    <p class="intro">
      Moins de relances, des dossiers plus lisibles et une équipe qui sait exactement où en est chaque démarche.
    </p>
    <div class="proof-signal">
      <span aria-hidden="true"></span>
      Retours de professionnels accompagnés
    </div>
  </div>

  <div class="testimonial-grid">
    {
      data.testimonials.map((item, index) => (
        <article class:list={["testimonial-card", index === 0 && "is-primary"]} data-reveal-item>
          <div class="testimonial-top">
            <span>Retour terrain</span>
            <strong aria-hidden="true">0{index + 1}</strong>
          </div>

          <blockquote>{item.quote}</blockquote>

          <footer>
            <span class="avatar" aria-hidden="true">{getInitials(item.author)}</span>
            <div>
              <strong>{item.author}</strong>
              <p>{item.note}</p>
            </div>
          </footer>
        </article>
      ))
    }
  </div>
</section>

<style>
  .proof-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1.2rem, 3vw, 2.5rem);
    align-items: stretch;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .proof-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(0.25rem, 1vw, 0.8rem);
  }

  .kicker {
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 14ch;
    margin-top: 0.65rem;
    font-size: clamp(2rem, 3.5vw, 3.45rem);
  }

  .intro {
    max-width: 49ch;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.62;
  }

  .proof-signal {
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    margin-top: auto;
    padding-top: 1.5rem;
    color: var(--text-muted);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .proof-signal span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 4px var(--success-soft);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .testimonial-card {
    min-height: 27rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.1rem, 2.2vw, 1.75rem);
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: 16px;
    background: #ffffff;
  }

  .testimonial-card.is-primary {
    border-color: var(--ink);
    background:
      radial-gradient(100% 75% at 100% 0%, rgba(54, 98, 227, 0.24), transparent 58%),
      var(--ink);
    color: #ffffff;
  }

  .testimonial-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .testimonial-top > span {
    color: var(--system);
    font-size: 0.66rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .testimonial-top > strong {
    color: color-mix(in srgb, var(--system) 65%, var(--text-muted));
    font-size: 0.68rem;
  }

  .is-primary .testimonial-top > span,
  .is-primary .testimonial-top > strong {
    color: var(--accent);
  }

  blockquote {
    margin: clamp(2.2rem, 5vw, 4.5rem) 0 1.5rem;
    color: var(--text);
    font-size: clamp(1rem, 0.4vw + 0.94rem, 1.16rem);
    font-weight: 650;
    line-height: 1.66;
  }

  .is-primary blockquote {
    color: rgba(255, 255, 255, 0.92);
  }

  footer {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.72rem;
    align-items: center;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .is-primary footer {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .avatar {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .is-primary .avatar {
    background: rgba(255, 255, 255, 0.1);
    color: var(--accent);
  }

  footer strong {
    display: block;
    color: var(--text);
    font-size: 0.8rem;
  }

  .is-primary footer strong {
    color: #ffffff;
  }

  footer p {
    margin-top: 0.16rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    line-height: 1.45;
  }

  .is-primary footer p {
    color: rgba(255, 255, 255, 0.52);
  }

  @media (max-width: 980px) {
    .proof-section {
      grid-template-columns: 1fr;
    }

    .proof-signal {
      margin-top: 0;
    }
  }

  @media (max-width: 700px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }

    .testimonial-card {
      min-height: 22rem;
    }
  }
</style>
