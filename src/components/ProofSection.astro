---
interface Props {
  data: {
    kicker: string;
    title: string;
    testimonials: Array<{
      quote: string;
      author: string;
      note: string;
    }>;
  };
}

const { data } = Astro.props;
---

<section class="section-shell proof-section reveal" aria-labelledby="proof-title">
  <div class="proof-head" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="proof-title">{data.title}</h2>
    <p class="intro">
      Des retours terrain nominatifs, placés après le parcours, les services et le produit pour rassurer sans alourdir
      le haut de page.
    </p>
  </div>

  <div class="testimonial-grid">
    {
      data.testimonials.map((item, index) => (
        <article class:list={["testimonial-card", index === 0 && "is-primary"]} data-reveal-item>
          <span class="quote-mark" aria-hidden="true">“</span>
          <p class="testimonial-quote">{item.quote}</p>
          <div class="testimonial-footer">
            <strong>{item.author}</strong>
            <span>{item.note}</span>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .proof-section {
    display: grid;
    gap: 0.9rem;
    padding: clamp(1.2rem, 2.6vw, 2.1rem);
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(90% 120% at 0% 0%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 58%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 16ch;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1.02;
  }

  .intro {
    margin: 0.72rem 0 0;
    max-width: 60ch;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.78rem;
  }

  .testimonial-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 0.62rem;
    padding: 1.05rem;
    border: 1px solid color-mix(in srgb, var(--line) 78%, var(--accent));
    border-radius: 26px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 95%, white), rgba(255, 255, 255, 0.78));
    box-shadow: 0 16px 38px rgba(20, 16, 10, 0.07);
  }

  .testimonial-card.is-primary {
    background:
      radial-gradient(110% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 54%, transparent), transparent 56%),
      color-mix(in srgb, var(--surface-elevated) 96%, white);
  }

  .quote-mark {
    display: inline-block;
    color: color-mix(in srgb, var(--accent) 84%, #f1d8b8);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    line-height: 0.7;
  }

  .testimonial-quote {
    margin: 0;
    color: var(--text);
    font-size: clamp(0.98rem, 0.4vw + 0.92rem, 1.08rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .testimonial-footer {
    display: grid;
    gap: 0.18rem;
    padding-top: 0.15rem;
  }

  .testimonial-footer strong {
    font-size: 0.86rem;
    line-height: 1.4;
  }

  .testimonial-footer span {
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.48;
  }

  @media (max-width: 900px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
