---
interface LogoItem {
  name: string;
  src: string;
}

interface MetricItem {
  value: string;
  label: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    logos: LogoItem[];
    metrics: MetricItem[];
    trustNote?: string;
    testimonials: Array<{
      quote: string;
      author: string;
      note: string;
    }>;
  };
}

const { data } = Astro.props;
const visibleLogos = data.logos.filter((logo) => logo.src);
---

<section class="section-shell proof-section reveal">
  <div class="proof-head">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
  </div>

  {
    visibleLogos.length > 0 ? (
      <div class="logo-row" aria-label="Partenaires Sunelys">
        {
          visibleLogos.map((logo) => (
            <article class="logo-slot" aria-label={logo.name}>
              <img src={logo.src} alt={logo.name} loading="lazy" />
            </article>
          ))
        }
      </div>
    ) : (
      <div class="trust-note" aria-label="Références clients">
        <p>{data.trustNote ?? "Références et cas détaillés communiqués sur demande."}</p>
      </div>
    )
  }

  <div class="proof-layout">
    <div class="metrics-panel">
      {
        data.metrics.map((metric) => (
          <article class="metric-card">
            <p class="metric-value">{metric.value}</p>
            <p class="metric-label">{metric.label}</p>
          </article>
        ))
      }
    </div>

    <div class="cred-panel">
      {
        data.testimonials.map((testimonial) => (
          <blockquote class="quote-box">
            <p>"{testimonial.quote}"</p>
            <cite>{testimonial.author}</cite>
            <small>{testimonial.note}</small>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>

<style>
  .proof-section {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 92%, white), color-mix(in srgb, var(--bg-soft) 65%, white));
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: clamp(1.2rem, 2.8vw, 2.2rem);
  }

  .proof-head h2 {
    margin: 0.52rem 0 0;
    max-width: 26ch;
    font-size: clamp(1.65rem, 2.85vw, 2.7rem);
    line-height: 1.03;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.13em;
  }

  .logo-row {
    margin-top: 0.95rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .logo-slot,
  .trust-note {
    min-height: 3.05rem;
    border: 1px solid color-mix(in srgb, var(--line) 74%, var(--accent));
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    display: grid;
    place-items: center;
    text-align: center;
    padding: 0.5rem 0.8rem;
  }

  .trust-note {
    margin-top: 0.95rem;
    justify-items: start;
    border-radius: calc(var(--radius-md) - 6px);
    min-height: auto;
  }

  .trust-note p {
    margin: 0;
    color: var(--text);
    font-size: 0.8rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .logo-slot img {
    max-width: 100%;
    max-height: 24px;
    object-fit: contain;
  }

  .proof-layout {
    margin-top: 0.7rem;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
    gap: 0.65rem;
  }

  .metrics-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .metric-card {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-sm);
    padding: 0.8rem;
  }

  .metric-value {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.6vw, 2.8rem);
    line-height: 0.88;
  }

  .metric-label {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1.35;
  }

  .cred-panel {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: linear-gradient(160deg, color-mix(in srgb, var(--surface-elevated) 88%, white), var(--surface));
    display: grid;
    gap: 0.55rem;
    padding: 0.7rem;
  }

  .quote-box {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--line) 85%, white);
    border-radius: calc(var(--radius-md) - 8px);
    background: color-mix(in srgb, var(--surface-elevated) 93%, white);
    padding: 0.72rem;
  }

  .quote-box p {
    margin: 0;
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .quote-box cite {
    display: inline-block;
    margin-top: 0.46rem;
    color: var(--text-muted);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-style: normal;
    font-weight: 600;
  }

  .quote-box small {
    display: block;
    margin-top: 0.2rem;
    color: var(--text-muted);
    font-size: 0.68rem;
  }

  @media (max-width: 960px) {
    .logo-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .proof-layout {
      grid-template-columns: 1fr;
    }

    .metrics-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
