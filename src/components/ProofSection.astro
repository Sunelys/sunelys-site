---
interface Testimonial {
  tabLabel: string;
  quote: string;
  author: string;
  note: string;
  service?: string;
  outcome?: string;
  logo?: string;
  logoAlt?: string;
  logoWidth?: number;
  logoHeight?: number;
  journey?: {
    label: string;
    text: string;
  }[];
}

interface Props {
  data: {
    kicker: string;
    title: string;
    testimonials: Testimonial[];
  };
}

const { data } = Astro.props;
const getInitials = (name: string) =>
  name
    .split(/\s+/)
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
---

<section class="section-shell proof-section reveal" aria-labelledby="proof-title">
  <header class="proof-head" data-reveal-item>
    <div>
      <p class="kicker">{data.kicker}</p>
      <h2 id="proof-title">{data.title}</h2>
    </div>
    <div class="proof-intro">
      <p>
        Deux retours nominatifs publiés avec accord : le besoin, le relais Sunelys et l’effet décrit par chaque
        installateur, sans extrapolation.
      </p>
      <span><i aria-hidden="true"></i> Paroles de professionnels accompagnés</span>
    </div>
  </header>

  <div class="case-experience" data-client-proof data-reveal-item>
    <div class="case-tabs" role="tablist" aria-label="Choisir un retour client Sunelys">
      {
        data.testimonials.map((item, index) => (
          <button
            type="button"
            id={`client-proof-tab-${index + 1}`}
            class:list={["case-tab", index === 0 && "is-active"]}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`client-proof-panel-${index + 1}`}
            tabindex={index === 0 ? 0 : -1}
            data-client-proof-tab={String(index + 1)}
          >
            <span>0{index + 1}</span>
            <strong>{item.tabLabel}</strong>
            <i aria-hidden="true"></i>
          </button>
        ))
      }
    </div>

    <div class="case-panels">
      {
        data.testimonials.map((item, index) => (
          <article
            id={`client-proof-panel-${index + 1}`}
            class="case-panel"
            role="tabpanel"
            aria-labelledby={`client-proof-tab-${index + 1}`}
            tabindex="0"
            hidden={index !== 0}
            data-client-proof-panel={String(index + 1)}
          >
            <div class="case-context">
              <div class="case-label">
                <span>{index === 0 ? "Cas client publié" : "Retour terrain"}</span>
                <strong>Avec accord</strong>
              </div>

              <div class="company-mark">
                {
                  item.logo ? (
                    <img
                      src={item.logo}
                      alt={item.logoAlt || ""}
                      width={item.logoWidth}
                      height={item.logoHeight}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span aria-hidden="true">{getInitials(item.author)}</span>
                  )
                }
              </div>

              <div class="case-outcome">
                {item.service && <p>{item.service}</p>}
                {item.outcome && <h3>{item.outcome}</h3>}
              </div>

              {
                item.journey && (
                  <ol class="case-journey" aria-label={`Parcours décrit par ${item.tabLabel}`}>
                    {item.journey.map((step, stepIndex) => (
                      <li>
                        <span>0{stepIndex + 1}</span>
                        <div>
                          <p>{step.label}</p>
                          <strong>{step.text}</strong>
                        </div>
                      </li>
                    ))}
                  </ol>
                )
              }
            </div>

            <div class="case-voice">
              <div class="quote-mark" aria-hidden="true">“</div>
              <blockquote>{item.quote}</blockquote>

              <footer>
                <div class="author">
                  <span aria-hidden="true">{getInitials(item.author)}</span>
                  <div>
                    <strong>{item.author}</strong>
                    <p>{item.note}</p>
                  </div>
                </div>
                <div class="verified">
                  <i aria-hidden="true">✓</i>
                  Accord de publication
                </div>
              </footer>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-client-proof]").forEach((experience) => {
    if (!(experience instanceof HTMLElement)) return;

    const tabs = Array.from(experience.querySelectorAll("[data-client-proof-tab]")).filter(
      (tab): tab is HTMLButtonElement => tab instanceof HTMLButtonElement,
    );
    const panels = Array.from(experience.querySelectorAll("[data-client-proof-panel]")).filter(
      (panel): panel is HTMLElement => panel instanceof HTMLElement,
    );

    const activate = (activeTab: HTMLButtonElement, track = true) => {
      const activeId = activeTab.dataset.clientProofTab;
      if (!activeId) return;

      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.clientProofPanel !== activeId;
      });

      if (track) {
        window.trackEvent?.("client_proof_view", {
          category: "engagement",
          label: activeTab.textContent?.trim() || activeId,
          source: "homepage_proof",
        });
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();

        let nextIndex = index;
        if (event.key === "ArrowRight") nextIndex = (index + 1) % tabs.length;
        if (event.key === "ArrowLeft") nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;

        const nextTab = tabs[nextIndex];
        if (!nextTab) return;
        activate(nextTab);
        nextTab.focus();
      });
    });
  });
</script>

<style>
  .proof-section {
    position: relative;
    overflow: hidden;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: var(--radius-xl);
    background:
      linear-gradient(rgba(54, 98, 227, 0.035) 1px, transparent 1px) 0 0 / 34px 34px,
      linear-gradient(90deg, rgba(54, 98, 227, 0.035) 1px, transparent 1px) 0 0 / 34px 34px,
      var(--system-soft);
  }

  .proof-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.55fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
    margin-bottom: clamp(1.4rem, 2.6vw, 2.2rem);
  }

  .kicker {
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 18ch;
    margin-top: 0.65rem;
    font-size: clamp(2.1rem, 4vw, 4rem);
  }

  .proof-intro {
    display: grid;
    gap: 1rem;
  }

  .proof-intro > p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.62;
  }

  .proof-intro > span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.67rem;
    font-weight: 700;
  }

  .proof-intro > span i {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 4px var(--success-soft);
  }

  .case-experience {
    overflow: hidden;
    border: 1px solid rgba(14, 23, 38, 0.12);
    border-radius: 20px;
    background: var(--ink);
    box-shadow: 0 28px 70px rgba(14, 23, 38, 0.16);
  }

  .case-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.4rem;
    padding: 0.55rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: #ffffff;
  }

  .case-tab {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.7rem;
    align-items: center;
    min-height: 3.1rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid transparent;
    border-radius: 12px;
    background: transparent;
    color: var(--text-muted);
    font: inherit;
    text-align: left;
    cursor: pointer;
    transition:
      color 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease;
  }

  .case-tab > span {
    color: var(--system);
    font-size: 0.6rem;
    font-weight: 800;
  }

  .case-tab strong {
    font-size: 0.72rem;
    font-weight: 760;
  }

  .case-tab i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--line);
  }

  .case-tab:hover,
  .case-tab:focus-visible {
    border-color: var(--line);
    background: var(--bg-soft);
    color: var(--text);
  }

  .case-tab.is-active {
    border-color: var(--ink);
    background: var(--ink);
    color: #ffffff;
  }

  .case-tab.is-active > span {
    color: var(--accent);
  }

  .case-tab.is-active i {
    background: var(--success);
    box-shadow: 0 0 0 4px rgba(29, 155, 117, 0.12);
  }

  .case-panel {
    display: grid;
    grid-template-columns: minmax(270px, 0.78fr) minmax(0, 1.22fr);
    min-height: 34rem;
    outline: none;
  }

  .case-context,
  .case-voice {
    min-width: 0;
    padding: clamp(1.25rem, 3vw, 2.7rem);
  }

  .case-context {
    display: flex;
    flex-direction: column;
    background: #ffffff;
  }

  .case-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .case-label > span {
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-label > strong {
    padding: 0.28rem 0.5rem;
    border-radius: 999px;
    background: var(--success-soft);
    color: var(--success);
    font-size: 0.56rem;
    font-weight: 760;
  }

  .company-mark {
    display: grid;
    width: clamp(7.5rem, 14vw, 10.5rem);
    height: 6.3rem;
    place-items: center;
    margin-top: clamp(1.5rem, 3vw, 2.6rem);
    padding: 0.7rem;
    border: 1px solid var(--line);
    border-radius: 15px;
    background: var(--bg-soft);
  }

  .company-mark img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .company-mark > span {
    color: var(--system);
    font-size: 1.2rem;
    font-weight: 800;
  }

  .case-outcome {
    margin-top: 1.5rem;
  }

  .case-outcome p {
    color: var(--accent-deep);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-outcome h3 {
    max-width: 27ch;
    margin-top: 0.45rem;
    color: var(--ink);
    font-size: clamp(1.15rem, 1.8vw, 1.55rem);
    line-height: 1.24;
  }

  .case-journey {
    position: relative;
    display: grid;
    gap: 0;
    margin: auto 0 0;
    padding: 1.2rem 0 0;
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .case-journey li {
    position: relative;
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.6rem;
    min-height: 3.35rem;
    padding: 0.5rem 0;
  }

  .case-journey li > span {
    z-index: 1;
    display: grid;
    width: 1.5rem;
    height: 1.5rem;
    place-items: center;
    border: 1px solid var(--system);
    border-radius: 0.4rem;
    background: #ffffff;
    color: var(--system);
    font-size: 0.52rem;
    font-weight: 800;
  }

  .case-journey li:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 2rem;
    bottom: -0.5rem;
    left: 0.74rem;
    width: 1px;
    background: var(--line);
  }

  .case-journey p {
    color: var(--text-muted);
    font-size: 0.55rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-journey strong {
    display: block;
    margin-top: 0.16rem;
    color: var(--text);
    font-size: 0.71rem;
  }

  .case-voice {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(90% 80% at 100% 0%, rgba(54, 98, 227, 0.27), transparent 62%),
      radial-gradient(75% 90% at 0% 100%, rgba(212, 130, 42, 0.16), transparent 62%),
      var(--ink);
  }

  .quote-mark {
    color: var(--accent);
    font-size: clamp(4rem, 8vw, 7rem);
    font-weight: 800;
    line-height: 0.72;
  }

  blockquote {
    max-width: 34ch;
    margin: clamp(1.4rem, 3vw, 2.5rem) 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: clamp(1.22rem, 2vw, 1.78rem);
    font-weight: 620;
    letter-spacing: -0.025em;
    line-height: 1.45;
  }

  footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.2rem;
    margin-top: auto;
    padding-top: 1.3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .author {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: center;
  }

  .author > span {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.07);
    color: var(--accent);
    font-size: 0.64rem;
    font-weight: 800;
  }

  .author strong {
    color: #ffffff;
    font-size: 0.76rem;
  }

  .author p {
    max-width: 36ch;
    margin-top: 0.18rem;
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.62rem;
    line-height: 1.45;
  }

  .verified {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex: 0 0 auto;
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.6rem;
    font-weight: 700;
  }

  .verified i {
    display: grid;
    width: 1.15rem;
    height: 1.15rem;
    place-items: center;
    border-radius: 50%;
    background: var(--success);
    color: #ffffff;
    font-size: 0.55rem;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .proof-head,
    .case-panel {
      grid-template-columns: 1fr;
    }

    .case-panel {
      min-height: 0;
    }

    .case-context {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0 1.3rem;
    }

    .case-label {
      grid-column: 1 / -1;
    }

    .company-mark {
      grid-row: 2 / span 2;
    }

    .case-journey {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 1.4rem;
    }

    .case-journey li {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding-right: 0.7rem;
    }

    .case-journey li:not(:last-child)::after {
      inset: 0.75rem -0.1rem auto 2rem;
      width: auto;
      height: 1px;
    }
  }

  @media (max-width: 620px) {
    .proof-section {
      padding: 1.1rem;
    }

    .case-tabs {
      gap: 0.3rem;
      padding: 0.4rem;
    }

    .case-tab {
      grid-template-columns: 1fr auto;
      gap: 0.4rem;
      min-width: 0;
      padding: 0.6rem;
    }

    .case-tab > span {
      display: none;
    }

    .case-tab strong {
      overflow: hidden;
      font-size: 0.66rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .case-context,
    .case-voice {
      padding: 1.15rem;
    }

    .case-context {
      display: flex;
    }

    .company-mark {
      width: 7.5rem;
      height: 5.2rem;
      margin-top: 1.3rem;
    }

    .case-journey {
      width: 100%;
      grid-template-columns: 1fr;
      margin-top: 1.4rem;
    }

    .case-journey li {
      grid-template-columns: 2rem 1fr;
      padding-right: 0;
    }

    .case-journey li:not(:last-child)::after {
      inset: 2rem auto -0.5rem 0.74rem;
      width: 1px;
      height: auto;
    }

    blockquote {
      font-size: clamp(1.12rem, 5.4vw, 1.42rem);
    }

    footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .case-panel:not([hidden]) .case-context {
      animation: proof-context-in 220ms ease-out both;
    }

    .case-panel:not([hidden]) .case-voice {
      animation: proof-voice-in 260ms 35ms ease-out both;
    }
  }

  @keyframes proof-context-in {
    from {
      opacity: 0;
      transform: translateX(-5px);
    }
  }

  @keyframes proof-voice-in {
    from {
      opacity: 0;
      transform: translateX(5px);
    }
  }
</style>
