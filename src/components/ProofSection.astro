---
interface LogoItem {
  name: string;
  src: string;
}

interface MetricItem {
  value: string;
  label: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    logos: LogoItem[];
    metrics: MetricItem[];
    trustNote?: string;
    testimonials: Array<{
      quote: string;
      author: string;
      note: string;
    }>;
  };
}

const { data } = Astro.props;
const visibleLogos = data.logos.filter((logo) => logo.src);
const spotlight = data.testimonials[0];
---

<section class="section-shell proof-section reveal">
  <div class="proof-shell">
    <div class="proof-top">
      <div class="proof-head">
        <p class="kicker">{data.kicker}</p>
        <h2>{data.title}</h2>
      </div>

      <div class="trust-note" aria-label="Positionnement de confiance">
        <span class="trust-tag">Structures déjà accompagnées</span>
        <p>{data.trustNote ?? "Références et cas détaillés communiqués sur demande."}</p>
      </div>
    </div>

    <div class="proof-stage">
      {
        spotlight && (
          <article class="proof-spotlight" aria-label="Témoignage client">
            <p class="spotlight-kicker">Témoignage nominatif</p>
            <span class="quote-mark" aria-hidden="true">“</span>
            <p class="spotlight-quote">{spotlight.quote}</p>
            <div class="spotlight-footer">
              <strong>{spotlight.author}</strong>
              <span>{spotlight.note}</span>
            </div>
          </article>
        )
      }

      <div class="proof-side">
        <div class="metric-grid">
          {
            data.metrics.map((metric, index) => (
              <article class:list={["metric-card", index === 0 && "is-featured"]}>
                <p class="metric-value">{metric.value}</p>
                <p class="metric-label">{metric.label}</p>
              </article>
            ))
          }
        </div>

        {
          visibleLogos.length > 0 && (
            <div class="logo-wall" aria-label="Clients Sunelys">
              <div class="logo-wall-head">
                <p class="logo-eyebrow">Ils nous font déjà confiance</p>
                <p class="logo-caption">Des marques déjà visibles, pas des promesses théoriques.</p>
              </div>

              <div class="logo-row">
                {
                  visibleLogos.map((logo) => (
                    <article class="logo-slot" aria-label={logo.name}>
                      <img src={logo.src} alt={logo.name} loading="lazy" />
                    </article>
                  ))
                }
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .proof-section {
    position: relative;
    overflow: hidden;
    padding: 0;
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 38%, var(--accent));
    background:
      radial-gradient(85% 115% at 0% 0%, rgba(239, 227, 201, 0.18), transparent 56%),
      radial-gradient(82% 110% at 100% 8%, rgba(197, 165, 111, 0.16), transparent 58%),
      linear-gradient(154deg, #191510, #100d09 74%);
    box-shadow: 0 38px 120px rgba(20, 16, 10, 0.22);
  }

  .proof-section::before {
    content: "";
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(255, 253, 247, 0.08);
    border-radius: calc(var(--radius-xl) - 14px);
    pointer-events: none;
  }

  .proof-shell {
    position: relative;
    z-index: 1;
    padding: clamp(1.4rem, 3vw, 2.4rem);
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .proof-top {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.95fr);
    gap: clamp(0.9rem, 2vw, 1.6rem);
    align-items: end;
  }

  .kicker {
    margin: 0;
    color: color-mix(in srgb, #f5e8d0 82%, var(--accent));
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .proof-head h2 {
    margin: 0.56rem 0 0;
    max-width: 11ch;
    color: #fffdf7;
    font-size: clamp(2.15rem, 3.8vw, 4.1rem);
    line-height: 0.94;
    text-wrap: balance;
  }

  .trust-note {
    justify-self: end;
    width: min(100%, 34rem);
    border: 1px solid rgba(255, 253, 247, 0.14);
    border-radius: 24px;
    background: rgba(255, 253, 247, 0.06);
    backdrop-filter: blur(16px);
    padding: clamp(1rem, 2vw, 1.3rem);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .trust-tag {
    display: inline-flex;
    min-height: 1.9rem;
    align-items: center;
    padding: 0.24rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 253, 247, 0.14);
    background: rgba(255, 253, 247, 0.07);
    color: #fff3de;
    font-size: 0.66rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 800;
  }

  .trust-note p {
    margin: 0.72rem 0 0;
    color: #f5edde;
    font-size: clamp(0.98rem, 0.34vw + 0.9rem, 1.1rem);
    line-height: 1.62;
    font-weight: 600;
  }

  .proof-stage {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    gap: clamp(0.95rem, 1.6vw, 1.2rem);
    align-items: stretch;
  }

  .proof-spotlight {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, #ffffff 74%, var(--accent));
    border-radius: 30px;
    background:
      radial-gradient(78% 120% at 100% 0%, rgba(239, 227, 201, 0.28), transparent 58%),
      linear-gradient(180deg, #fffdfa, #fbf6ec);
    padding: clamp(1.25rem, 2.3vw, 1.8rem);
    box-shadow: 0 24px 60px rgba(13, 11, 8, 0.18);
  }

  .proof-spotlight::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(140deg, transparent 58%, rgba(197, 165, 111, 0.08) 100%);
    pointer-events: none;
  }

  .spotlight-kicker {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .quote-mark {
    position: relative;
    z-index: 1;
    display: inline-block;
    margin-top: 0.7rem;
    color: color-mix(in srgb, var(--accent) 86%, #f2dbc0);
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 5vw, 5.2rem);
    line-height: 0.7;
  }

  .spotlight-quote {
    position: relative;
    z-index: 1;
    margin: 0.28rem 0 0;
    color: var(--text);
    font-size: clamp(1.08rem, 0.58vw + 0.96rem, 1.28rem);
    line-height: 1.62;
    text-wrap: pretty;
  }

  .spotlight-footer {
    position: relative;
    z-index: 1;
    margin-top: 1rem;
    padding-top: 0.88rem;
    border-top: 1px solid color-mix(in srgb, var(--line) 84%, white);
    display: grid;
    gap: 0.22rem;
  }

  .spotlight-footer strong {
    color: var(--text);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .spotlight-footer span {
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .proof-side {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.78rem;
  }

  .metric-card {
    min-height: 10rem;
    border: 1px solid rgba(255, 253, 247, 0.14);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 253, 247, 0.11), rgba(255, 253, 247, 0.045));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    padding: 1rem;
    display: grid;
    align-content: end;
    gap: 0.48rem;
  }

  .metric-card.is-featured {
    grid-column: 1 / -1;
    min-height: 11.25rem;
    background:
      radial-gradient(110% 140% at 100% 0%, rgba(239, 227, 201, 0.18), transparent 56%),
      linear-gradient(180deg, rgba(255, 253, 247, 0.14), rgba(255, 253, 247, 0.06));
  }

  .metric-value {
    margin: 0;
    color: #fffdf7;
    font-family: var(--font-display);
    font-size: clamp(2rem, 2.9vw, 3.2rem);
    line-height: 0.9;
  }

  .metric-label {
    margin: 0;
    color: #d5c8b4;
    font-size: 0.84rem;
    line-height: 1.46;
    max-width: 21ch;
  }

  .logo-wall {
    border: 1px solid rgba(255, 253, 247, 0.12);
    border-radius: 24px;
    background: rgba(255, 253, 247, 0.05);
    padding: 1rem;
    display: grid;
    gap: 0.8rem;
  }

  .logo-wall-head {
    display: grid;
    gap: 0.18rem;
  }

  .logo-eyebrow {
    margin: 0;
    color: #f0dfc0;
    font-size: 0.67rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .logo-caption {
    margin: 0;
    color: #cfc1ad;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .logo-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .logo-slot {
    min-height: 4.8rem;
    border: 1px solid color-mix(in srgb, #ffffff 74%, var(--accent));
    border-radius: 18px;
    background:
      radial-gradient(100% 130% at 100% 0%, rgba(239, 227, 201, 0.34), transparent 62%),
      #fffefa;
    display: grid;
    place-items: center;
    padding: 0.82rem 1rem;
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .logo-slot:hover,
  .logo-slot:focus-within {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, #ffffff 40%, var(--accent));
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }

  .logo-slot img {
    display: block;
    width: auto;
    max-width: min(76%, 150px);
    max-height: 40px;
    object-fit: contain;
  }

  .logo-slot img[alt="Be Travaux"] {
    max-width: 118px;
    max-height: 36px;
  }

  @media (max-width: 1080px) {
    .proof-top,
    .proof-stage {
      grid-template-columns: 1fr;
    }

    .trust-note {
      justify-self: stretch;
      width: 100%;
    }
  }

  @media (max-width: 760px) {
    .proof-head h2 {
      max-width: 11ch;
      font-size: clamp(2.3rem, 12vw, 3.25rem);
    }

    .metric-grid,
    .logo-row {
      grid-template-columns: 1fr;
    }

    .metric-card,
    .metric-card.is-featured {
      min-height: auto;
    }

    .spotlight-quote {
      font-size: 1rem;
    }
  }
</style>
