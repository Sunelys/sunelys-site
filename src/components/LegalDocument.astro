---
import BaseLayout from "../layouts/BaseLayout.astro";

interface SectionLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  intro: string;
  updatedAt: string;
  sections: SectionLink[];
}

const { title, description, eyebrow, intro, updatedAt, sections } = Astro.props;
---

<BaseLayout title={`${title} | Sunelys`} description={description}>
  <header class="legal-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="intro">{intro}</p>
    </div>
    <p class="updated"><span>Version en vigueur</span><strong>{updatedAt}</strong></p>
  </header>

  <div class="legal-layout">
    <aside class="legal-index" aria-label={`Sommaire — ${title}`}>
      <p>Dans cette page</p>
      <nav>
        {sections.map((section, index) => (
          <a href={section.href}><span>{String(index + 1).padStart(2, "0")}</span>{section.label}</a>
        ))}
      </nav>
    </aside>

    <article class="legal-content">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .legal-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    overflow: hidden;
    padding: clamp(2rem, 5vw, 4.5rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 90% 0%, rgba(54, 98, 227, 0.42), transparent 34%),
      radial-gradient(circle at 0% 100%, rgba(212, 130, 42, 0.2), transparent 35%),
      var(--ink);
  }

  .legal-hero::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -13rem;
    width: clamp(20rem, 36vw, 35rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 820;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    color: #ffffff;
    font-size: clamp(2.8rem, 6vw, 6rem);
    letter-spacing: -0.06em;
    line-height: 0.92;
  }

  .intro {
    max-width: 56ch;
    margin: 1rem 0 0;
    color: #cbd5e1;
    font-size: clamp(0.98rem, 1.4vw, 1.15rem);
    line-height: 1.65;
  }

  .updated {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.22rem;
    min-width: 13rem;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }

  .updated span {
    color: #9fb0c6;
    font-size: 0.62rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .updated strong {
    color: #ffffff;
    font-size: 0.82rem;
  }

  .legal-layout {
    display: grid;
    grid-template-columns: minmax(13rem, 0.34fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .legal-index {
    position: sticky;
    top: 6rem;
    padding-top: 1rem;
    border-top: 2px solid var(--ink);
  }

  .legal-index > p {
    margin: 0 0 0.85rem;
    color: var(--text-muted);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legal-index nav {
    display: grid;
  }

  .legal-index a {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.65rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--text);
    font-size: 0.76rem;
    line-height: 1.4;
    text-decoration: none;
  }

  .legal-index a span {
    color: var(--system);
    font-size: 0.63rem;
    font-weight: 820;
  }

  .legal-index a:hover,
  .legal-index a:focus-visible {
    color: var(--system);
  }

  .legal-content {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    min-width: 0;
  }

  :global(.legal-content section) {
    display: grid;
    gap: 0.9rem;
    scroll-margin-top: 6rem;
    padding-bottom: clamp(1.8rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
  }

  :global(.legal-content section:last-child) {
    border-bottom: 0;
  }

  :global(.legal-content .section-number) {
    margin: 0;
    color: var(--system);
    font-size: 0.67rem;
    font-weight: 850;
    letter-spacing: 0.08em;
  }

  :global(.legal-content h2) {
    max-width: 22ch;
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.7rem, 3.4vw, 3rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  :global(.legal-content h3) {
    margin: 0.65rem 0 0;
    color: var(--ink);
    font-size: 1rem;
  }

  :global(.legal-content p),
  :global(.legal-content li),
  :global(.legal-content td),
  :global(.legal-content th) {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  :global(.legal-content p),
  :global(.legal-content ul) {
    margin: 0;
  }

  :global(.legal-content ul) {
    display: grid;
    gap: 0.5rem;
    padding-left: 1.2rem;
  }

  :global(.legal-content strong) {
    color: var(--text);
  }

  :global(.legal-content a) {
    color: var(--system);
    font-weight: 700;
    text-underline-offset: 0.2rem;
  }

  :global(.legal-content .legal-card) {
    display: grid;
    gap: 0.5rem;
    padding: clamp(1rem, 2.5vw, 1.4rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  :global(.legal-content .legal-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  :global(.legal-content .data-table) {
    width: 100%;
    border-collapse: collapse;
    border-top: 2px solid var(--ink);
  }

  :global(.legal-content .data-table th),
  :global(.legal-content .data-table td) {
    padding: 0.9rem 0.75rem;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  :global(.legal-content .data-table th) {
    color: var(--ink);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  :global(.legal-content .legal-callout) {
    padding: 1.1rem;
    border-left: 3px solid var(--accent);
    background: var(--accent-soft);
  }

  @media (max-width: 820px) {
    .legal-hero,
    .legal-layout {
      grid-template-columns: 1fr;
    }

    .updated {
      width: min(100%, 20rem);
    }

    .legal-index {
      position: static;
    }
  }

  @media (max-width: 620px) {
    .legal-hero {
      margin-inline: calc(var(--container-padding) * -0.35);
      padding: 1.4rem;
      border-radius: var(--radius-md);
    }

    h1 {
      font-size: clamp(2.5rem, 13vw, 3.8rem);
    }

    :global(.legal-content .legal-grid) {
      grid-template-columns: 1fr;
    }

    :global(.legal-content .data-table),
    :global(.legal-content .data-table tbody),
    :global(.legal-content .data-table tr),
    :global(.legal-content .data-table th),
    :global(.legal-content .data-table td) {
      display: block;
    }

    :global(.legal-content .data-table thead) {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }

    :global(.legal-content .data-table tr) {
      padding: 0.8rem 0;
      border-bottom: 1px solid var(--line);
    }

    :global(.legal-content .data-table td) {
      padding: 0.18rem 0;
      border: 0;
    }

    :global(.legal-content .data-table td:first-child) {
      color: var(--ink);
      font-weight: 800;
    }
  }
</style>
