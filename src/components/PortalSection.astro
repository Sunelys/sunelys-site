---
interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    benefits: string[];
    cta: {
      label: string;
      href: string;
      track: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="section-shell portal-section reveal">
  <div class="portal-copy">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
    <p class="text">{data.text}</p>

    <ul class="benefits">
      {
        data.benefits.map((benefit) => (
          <li>{benefit}</li>
        ))
      }
    </ul>

    <a class="btn btn-primary" href={data.cta.href} data-track={data.cta.track}>{data.cta.label}</a>
  </div>

  <div class="portal-mock" aria-label="Aperçu du portail Sunelys">
    <header>
      <span class="chip">Portail Sunelys</span>
      <span class="status">Live</span>
    </header>

    <div class="mock-body">
      <aside>
        <p>Pipeline</p>
        <ul>
          <li><span></span> DP</li>
          <li><span></span> Consuel</li>
          <li><span></span> Raccordement</li>
        </ul>
      </aside>

      <div class="main">
        <article>
          <h3>Dossiers actifs</h3>
          <p>42</p>
        </article>
        <article>
          <h3>Pièces en attente</h3>
          <p>7</p>
        </article>
        <article>
          <h3>Conformité ce mois</h3>
          <p>97%</p>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .portal-section {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 0.72rem;
    align-items: stretch;
  }

  .portal-copy {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: var(--radius-xl);
    background: linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 90%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.15rem, 2.5vw, 2rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.55rem, 2.8vw, 2.8rem);
    line-height: 1.04;
    max-width: 23ch;
  }

  .text {
    margin: 0.84rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.54;
  }

  .benefits {
    margin: 0.78rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.38rem;
  }

  .benefits li {
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    padding: 0.55rem 0.68rem;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .portal-copy .btn {
    margin-top: 0.86rem;
    width: fit-content;
  }

  .portal-mock {
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 58%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: 0.96rem;
    display: grid;
    gap: 0.72rem;
    position: relative;
    overflow: hidden;
  }

  .portal-mock::after {
    content: "";
    position: absolute;
    right: -14%;
    top: -30%;
    width: clamp(220px, 34vw, 420px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.85);
    filter: blur(calc(var(--shape-blur) * 1.25));
    pointer-events: none;
  }

  .portal-mock header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.7rem;
    position: relative;
    z-index: 1;
  }

  .chip,
  .status {
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.62rem;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--surface);
  }

  .status {
    color: #205f42;
  }

  .mock-body {
    display: grid;
    grid-template-columns: minmax(138px, 0.72fr) minmax(0, 1.28fr);
    gap: 0.6rem;
    position: relative;
    z-index: 1;
  }

  .mock-body aside,
  .mock-body .main {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-elevated);
    padding: 0.6rem;
  }

  .mock-body aside p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .mock-body aside ul {
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.42rem;
  }

  .mock-body aside li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .mock-body aside li span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--accent);
    display: inline-block;
  }

  .mock-body .main {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .mock-body .main article {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    padding: 0.5rem;
  }

  .mock-body .main h3 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
  }

  .mock-body .main p {
    margin: 0.45rem 0 0;
    font-size: 1.05rem;
    color: var(--text);
    font-weight: 700;
  }

  @media (max-width: 1080px) {
    .portal-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .mock-body {
      grid-template-columns: 1fr;
    }

    .mock-body .main {
      grid-template-columns: 1fr;
    }

    .portal-copy .btn {
      width: 100%;
    }
  }
</style>
