---
interface PortalView {
  id: string;
  label: string;
  eyebrow: string;
  title: string;
  text: string;
  src: string;
  avifSrcset?: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  signal: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    benefits: string[];
    cta: {
      label: string;
      href: string;
      track: string;
    };
    clientAccess: {
      label: string;
      href: string;
      track: string;
    };
    views: PortalView[];
  };
}

const { data } = Astro.props;
const firstSignal = data.views[0]?.signal ?? "Priorités visibles";
const secondSignal = data.views[1]?.signal ?? "Flux centralisés";
---

<section
  class="section-shell portal-section reveal"
  aria-labelledby="portal-title"
  data-track-view="homepage_portal_view"
  data-track-label="homepage_portal"
>
  <div class="portal-copy" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="portal-title">{data.title}</h2>
    <p class="text">{data.text}</p>

    <div class="portal-assurance">
      <span aria-hidden="true">
        <i></i>
        <i></i>
        <i></i>
      </span>
      <p><strong>Portail dédié</strong> avec un interlocuteur humain.</p>
    </div>

    <ul class="benefits" aria-label="Ce que le portail rend visible">
      {
        data.benefits.map((benefit, index) => (
          <li>
            <span>0{index + 1}</span>
            <strong>{benefit}</strong>
          </li>
        ))
      }
    </ul>

    <div class="portal-actions">
      <a class="btn btn-accent" href={data.cta.href} data-track={data.cta.track}>
        {data.cta.label}
        <span aria-hidden="true">→</span>
      </a>
      <a class="client-access" href={data.clientAccess.href} data-track={data.clientAccess.track}>
        {data.clientAccess.label}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  <div class="portal-showcase" data-portal-demo data-reveal-item>
    <div class="showcase-topbar">
      <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
      <p>portail.sunelys.fr</p>
      <span class="live-status"><i aria-hidden="true"></i> Suivi actif</span>
    </div>

    <div class="showcase-body">
      <aside class="console-rail" aria-label="Synthèse de pilotage du portail">
        <div>
          <p class="rail-label">Tableau de bord</p>
          <h3>Les priorités sortent du flux.</h3>
        </div>

        <div class="rail-cards">
          <article>
            <span>Priorité</span>
            <strong>{firstSignal}</strong>
          </article>
          <article>
            <span>Vision</span>
            <strong>{secondSignal}</strong>
          </article>
          <article>
            <span>Échanges</span>
            <strong>Pièces et statuts au même endroit</strong>
          </article>
        </div>
      </aside>

      <div class="screen-area">
        <div class="portal-tabs" role="tablist" aria-label="Découvrir les vues du portail Sunelys">
          {
            data.views.map((view, index) => (
              <button
                type="button"
                id={`portal-tab-${view.id}`}
                class:list={["portal-tab", index === 0 && "is-active"]}
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`portal-panel-${view.id}`}
                tabindex={index === 0 ? 0 : -1}
                data-portal-tab={view.id}
              >
                <span>0{index + 1}</span>
                {view.label}
              </button>
            ))
          }
        </div>

        <div class="portal-views">
          {
            data.views.map((view, index) => (
              <div
                id={`portal-panel-${view.id}`}
                class="portal-view"
                role="tabpanel"
                aria-labelledby={`portal-tab-${view.id}`}
                tabindex="0"
                hidden={index !== 0}
                data-portal-panel={view.id}
              >
                <figure class="portal-visual">
                  <picture>
                    {
                      view.avifSrcset && (
                        <source type="image/avif" srcset={view.avifSrcset} sizes={view.sizes} />
                      )
                    }
                    <img
                      src={view.src}
                      alt={view.alt}
                      width={view.width}
                      height={view.height}
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                    />
                  </picture>
                  <figcaption class="visual-signal">
                    <span aria-hidden="true"></span>
                    {view.signal}
                  </figcaption>
                </figure>

                <div class="view-caption">
                  <p>{view.eyebrow}</p>
                  <h3>{view.title}</h3>
                  <span>{view.text}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="demo-footer">
      <p><span aria-hidden="true">✓</span> Exemple anonymisé</p>
      <p>Dossiers · pièces · statuts · relances</p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-portal-demo]").forEach((demo) => {
    if (!(demo instanceof HTMLElement)) return;

    const tabs = Array.from(demo.querySelectorAll("[data-portal-tab]")).filter(
      (tab): tab is HTMLButtonElement => tab instanceof HTMLButtonElement,
    );
    const panels = Array.from(demo.querySelectorAll("[data-portal-panel]")).filter(
      (panel): panel is HTMLElement => panel instanceof HTMLElement,
    );

    const activate = (activeTab: HTMLButtonElement, track = true) => {
      const activeId = activeTab.dataset.portalTab;
      if (!activeId) return;

      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.portalPanel !== activeId;
      });

      if (track) {
        window.trackEvent?.("portal_demo_view", {
          category: "engagement",
          label: activeId,
          source: "homepage_portal",
        });
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();

        let nextIndex = index;
        if (event.key === "ArrowRight") nextIndex = (index + 1) % tabs.length;
        if (event.key === "ArrowLeft") nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;

        const nextTab = tabs[nextIndex];
        if (!nextTab) return;
        activate(nextTab);
        nextTab.focus();
      });
    });
  });
</script>

<style>
  .portal-section {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(300px, 0.62fr) minmax(0, 1.38fr);
    gap: 1.05rem;
    overflow: hidden;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px) 0 0 / 42px 42px,
      linear-gradient(180deg, var(--ink-soft), var(--ink));
    box-shadow: var(--shadow-md);
  }

  .portal-copy {
    display: grid;
    align-content: center;
    min-width: 0;
    padding: 2rem;
  }

  .kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h2 {
    max-width: 14ch;
    margin: 0.7rem 0 0;
    color: #ffffff;
    font-size: 3.38rem;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .text {
    max-width: 52ch;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.96rem;
    line-height: 1.64;
  }

  .portal-assurance {
    display: flex;
    align-items: center;
    gap: 0.68rem;
    width: fit-content;
    margin-top: 1.2rem;
    padding: 0.62rem 0.78rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
  }

  .portal-assurance > span {
    display: inline-flex;
    align-items: center;
    padding-left: 0.18rem;
  }

  .portal-assurance i {
    width: 0.62rem;
    height: 0.62rem;
    margin-left: -0.18rem;
    border: 1px solid var(--ink);
    border-radius: 50%;
    background: var(--accent);
  }

  .portal-assurance i:nth-child(2) {
    background: var(--system);
  }

  .portal-assurance i:nth-child(3) {
    background: var(--success);
  }

  .portal-assurance p {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.72rem;
  }

  .portal-assurance strong {
    color: #ffffff;
  }

  .benefits {
    width: 100%;
    display: grid;
    gap: 0;
    margin: 1.45rem 0 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.11);
    list-style: none;
  }

  .benefits li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.55rem;
    align-items: center;
    min-height: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.11);
  }

  .benefits li > span {
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 800;
  }

  .benefits strong {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    margin-top: 1.5rem;
  }

  .portal-actions .btn {
    width: fit-content;
  }

  .client-access {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.75rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 720;
    text-decoration: none;
  }

  .client-access:hover,
  .client-access:focus-visible {
    color: #ffffff;
  }

  .portal-showcase {
    align-self: center;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 18px;
    background: #eef2f7;
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.36);
  }

  .showcase-topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: 3rem;
    padding: 0 1rem;
    border-bottom: 1px solid #dfe4eb;
    background: #ffffff;
  }

  .showcase-topbar > p {
    color: #687386;
    font-size: 0.68rem;
    font-weight: 650;
  }

  .window-dots {
    display: flex;
    gap: 0.3rem;
  }

  .window-dots span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #dce1e8;
  }

  .live-status {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: #477765;
    font-size: 0.64rem;
    font-weight: 760;
  }

  .live-status i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px var(--success-soft);
  }

  .showcase-body {
    display: grid;
    grid-template-columns: minmax(160px, 0.32fr) minmax(0, 1fr);
    min-width: 0;
    padding: 0.75rem;
    gap: 0.75rem;
  }

  .console-rail {
    display: grid;
    align-content: space-between;
    gap: 1rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid #dfe4eb;
    border-radius: 14px;
    background: #ffffff;
  }

  .rail-label {
    margin: 0;
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .console-rail h3 {
    max-width: 14ch;
    margin: 0.42rem 0 0;
    color: var(--ink);
    font-size: 1.22rem;
    letter-spacing: 0;
    line-height: 1.12;
  }

  .rail-cards {
    display: grid;
    gap: 0.45rem;
  }

  .rail-cards article {
    display: grid;
    gap: 0.22rem;
    min-width: 0;
    padding: 0.68rem;
    border: 1px solid #e2e7ef;
    border-radius: 10px;
    background: #f7f9fc;
  }

  .rail-cards span {
    color: #778296;
    font-size: 0.62rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .rail-cards strong {
    color: var(--ink);
    font-size: 0.74rem;
    line-height: 1.34;
  }

  .screen-area {
    min-width: 0;
  }

  .portal-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.35rem;
    margin-bottom: 0.65rem;
    padding: 0.35rem;
    border: 1px solid #dfe4eb;
    border-radius: 12px;
    background: #ffffff;
  }

  .portal-tab {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.6rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 9px;
    background: transparent;
    color: #667185;
    font: inherit;
    font-size: 0.73rem;
    font-weight: 720;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .portal-tab span {
    color: #8a94a5;
    font-size: 0.6rem;
  }

  .portal-tab:hover,
  .portal-tab:focus-visible {
    color: var(--ink);
    background: #f5f7fa;
  }

  .portal-tab.is-active {
    border-color: #dfe4eb;
    background: var(--ink);
    color: #ffffff;
  }

  .portal-tab.is-active span {
    color: var(--accent);
  }

  .portal-view {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(170px, 0.34fr);
    gap: 0.75rem;
    align-items: stretch;
    outline: none;
  }

  .portal-view[hidden] {
    display: none;
  }

  .portal-visual {
    position: relative;
    min-width: 0;
    margin: 0;
    overflow: hidden;
    border: 1px solid #dde3eb;
    border-radius: 13px;
    background: #ffffff;
    box-shadow: 0 16px 40px rgba(14, 23, 38, 0.1);
  }

  .portal-visual picture {
    display: block;
  }

  .portal-visual img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: #ffffff;
  }

  .visual-signal {
    position: absolute;
    right: 0.72rem;
    bottom: 0.72rem;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    max-width: calc(100% - 1.44rem);
    padding: 0.5rem 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.68);
    border-radius: 999px;
    background: rgba(14, 23, 38, 0.88);
    box-shadow: 0 10px 28px rgba(14, 23, 38, 0.22);
    color: #ffffff;
    font-size: 0.62rem;
    font-weight: 720;
    backdrop-filter: blur(12px);
  }

  .visual-signal span {
    flex: 0 0 auto;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--success);
  }

  .view-caption {
    display: grid;
    align-content: space-between;
    gap: 1rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid #dfe4eb;
    border-radius: 13px;
    background: #ffffff;
  }

  .view-caption p {
    margin: 0;
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .view-caption h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.12rem;
    letter-spacing: 0;
    line-height: 1.16;
  }

  .view-caption > span {
    color: #657084;
    font-size: 0.74rem;
    line-height: 1.5;
  }

  .demo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.6rem;
    padding: 0 1rem;
    border-top: 1px solid #dfe4eb;
    background: #ffffff;
  }

  .demo-footer p {
    color: #7a8495;
    font-size: 0.6rem;
    font-weight: 650;
  }

  .demo-footer p:first-child {
    color: #567466;
  }

  .demo-footer p:first-child span {
    color: var(--success);
  }

  @media (max-width: 1120px) {
    .portal-section {
      grid-template-columns: 1fr;
    }

    .portal-copy {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.75fr);
      gap: 1rem 2rem;
      align-items: end;
      padding: 1.65rem;
    }

    .portal-copy > .kicker,
    .portal-copy > h2,
    .portal-copy > .text {
      grid-column: 1;
    }

    .portal-assurance,
    .portal-actions {
      grid-column: 2;
      margin-top: 0;
    }

    .benefits {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 0.4rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.11);
    }

    .benefits li {
      grid-template-columns: 1.7rem 1fr;
      padding: 0.65rem;
      border-bottom: 0;
    }

    .benefits li + li {
      border-left: 1px solid rgba(255, 255, 255, 0.11);
    }
  }

  @media (max-width: 860px) {
    .showcase-body,
    .portal-view {
      grid-template-columns: 1fr;
    }

    .console-rail {
      align-content: start;
    }

    .rail-cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .portal-section {
      padding: 0.65rem;
      border-radius: 20px;
    }

    .portal-copy {
      display: grid;
      grid-template-columns: 1fr;
      padding: 1.05rem 0.7rem 1.15rem;
    }

    .portal-copy > .kicker,
    .portal-copy > h2,
    .portal-copy > .text,
    .portal-assurance,
    .portal-actions {
      grid-column: auto;
    }

    h2 {
      max-width: 16ch;
      font-size: 2.35rem;
    }

    .portal-assurance {
      margin-top: 1rem;
    }

    .benefits {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: 1.25rem;
      border-bottom: 0;
    }

    .benefits li {
      padding: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.11);
    }

    .benefits li + li {
      border-left: 0;
    }

    .portal-actions {
      margin-top: 1.25rem;
    }

    .portal-actions .btn {
      width: 100%;
    }

    .portal-showcase {
      border-radius: 14px;
    }

    .showcase-topbar {
      grid-template-columns: auto 1fr;
      min-height: 2.7rem;
      padding: 0 0.75rem;
    }

    .showcase-topbar > p {
      display: none;
    }

    .showcase-body {
      padding: 0.5rem;
      gap: 0.5rem;
    }

    .rail-cards {
      grid-template-columns: 1fr;
    }

    .portal-tabs {
      margin-bottom: 0.5rem;
      padding: 0.3rem;
    }

    .portal-tab {
      min-height: 2.55rem;
      padding-inline: 0.45rem;
      font-size: 0.68rem;
    }

    .portal-tab span {
      display: none;
    }

    .visual-signal {
      right: 0.45rem;
      bottom: 0.45rem;
      max-width: calc(100% - 0.9rem);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .view-caption {
      padding: 0.9rem;
    }

    .demo-footer p:last-child {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .portal-view:not([hidden]) .portal-visual {
      animation: portal-view-in 220ms ease-out both;
    }

    .portal-view:not([hidden]) .view-caption {
      animation: portal-caption-in 260ms 40ms ease-out both;
    }

    .live-status i {
      animation: portal-live 2.6s ease-in-out infinite;
    }
  }

  @keyframes portal-view-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  @keyframes portal-caption-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
  }

  @keyframes portal-live {
    50% {
      box-shadow: 0 0 0 6px rgba(29, 155, 117, 0.06);
    }
  }
</style>
