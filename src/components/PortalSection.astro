---
interface PortalView {
  id: string;
  label: string;
  eyebrow: string;
  title: string;
  text: string;
  src: string;
  avifSrcset?: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  signal: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    benefits: string[];
    cta: {
      label: string;
      href: string;
      track: string;
    };
    clientAccess: {
      label: string;
      href: string;
      track: string;
    };
    views: PortalView[];
  };
}

const { data } = Astro.props;
---

<section class="section-shell portal-section reveal" aria-labelledby="portal-title">
  <div class="portal-copy" data-reveal-item>
    <div class="portal-heading">
      <p class="kicker">{data.kicker}</p>
      <h2 id="portal-title">{data.title}</h2>
      <p class="text">{data.text}</p>
    </div>

    <div class="portal-proof">
      <span class="human-signal" aria-hidden="true">
        <i></i>
        <i></i>
        <i></i>
      </span>
      <p><strong>Portail dédié</strong> + interlocuteur humain</p>
    </div>

    <ul class="benefits">
      {
        data.benefits.map((benefit, index) => (
          <li>
            <span>0{index + 1}</span>
            <strong>{benefit}</strong>
          </li>
        ))
      }
    </ul>

    <div class="portal-actions">
      <a class="btn btn-accent" href={data.cta.href} data-track={data.cta.track}>
        {data.cta.label}
        <span aria-hidden="true">→</span>
      </a>
      <a
        class="client-access"
        href={data.clientAccess.href}
        data-track={data.clientAccess.track}
      >
        {data.clientAccess.label}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  <div class="portal-demo" data-portal-demo data-reveal-item>
    <div class="product-bar">
      <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
      <p>portail.sunelys.fr</p>
      <span class="live-status"><i aria-hidden="true"></i> Suivi en temps réel</span>
    </div>

    <div class="portal-tabs" role="tablist" aria-label="Découvrir les vues du portail Sunelys">
      {
        data.views.map((view, index) => (
          <button
            type="button"
            id={`portal-tab-${view.id}`}
            class:list={["portal-tab", index === 0 && "is-active"]}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`portal-panel-${view.id}`}
            tabindex={index === 0 ? 0 : -1}
            data-portal-tab={view.id}
          >
            <span>0{index + 1}</span>
            {view.label}
          </button>
        ))
      }
    </div>

    <div class="portal-views">
      {
        data.views.map((view, index) => (
          <div
            id={`portal-panel-${view.id}`}
            class="portal-view"
            role="tabpanel"
            aria-labelledby={`portal-tab-${view.id}`}
            tabindex="0"
            hidden={index !== 0}
            data-portal-panel={view.id}
          >
            <div class="portal-visual">
              <figure>
                <picture>
                  {
                    view.avifSrcset && (
                      <source
                        type="image/avif"
                        srcset={view.avifSrcset}
                        sizes={view.sizes}
                      />
                    )
                  }
                  <img
                    src={view.src}
                    alt={view.alt}
                    width={view.width}
                    height={view.height}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
                </picture>
              </figure>
              <div class="visual-signal">
                <span aria-hidden="true"></span>
                {view.signal}
              </div>
            </div>

            <div class="view-caption">
              <p>{view.eyebrow}</p>
              <h3>{view.title}</h3>
              <span>{view.text}</span>
            </div>
          </div>
        ))
      }
    </div>

    <div class="demo-footer">
      <p><span aria-hidden="true">✓</span> Exemple anonymisé</p>
      <p>Dossiers · pièces · statuts · relances</p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-portal-demo]").forEach((demo) => {
    if (!(demo instanceof HTMLElement)) return;

    const tabs = Array.from(demo.querySelectorAll("[data-portal-tab]")).filter(
      (tab): tab is HTMLButtonElement => tab instanceof HTMLButtonElement,
    );
    const panels = Array.from(demo.querySelectorAll("[data-portal-panel]")).filter(
      (panel): panel is HTMLElement => panel instanceof HTMLElement,
    );

    const activate = (activeTab: HTMLButtonElement, track = true) => {
      const activeId = activeTab.dataset.portalTab;
      if (!activeId) return;

      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.portalPanel !== activeId;
      });

      if (track) {
        window.trackEvent?.("portal_demo_view", {
          category: "engagement",
          label: activeId,
          source: "homepage_portal",
        });
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();

        let nextIndex = index;
        if (event.key === "ArrowRight") nextIndex = (index + 1) % tabs.length;
        if (event.key === "ArrowLeft") nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;

        const nextTab = tabs[nextIndex];
        if (!nextTab) return;
        activate(nextTab);
        nextTab.focus();
      });
    });
  });
</script>

<style>
  .portal-section {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(300px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1rem, 2.5vw, 2.5rem);
    overflow: hidden;
    padding: clamp(0.75rem, 1.4vw, 1.25rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(85% 105% at 0% 100%, rgba(212, 130, 42, 0.21), transparent 55%),
      radial-gradient(80% 85% at 80% 0%, rgba(54, 98, 227, 0.28), transparent 60%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .portal-section::before {
    content: "";
    position: absolute;
    z-index: -1;
    inset: auto auto -12rem -8rem;
    width: 22rem;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    box-shadow:
      0 0 0 3rem rgba(255, 255, 255, 0.018),
      0 0 0 7rem rgba(255, 255, 255, 0.012);
  }

  .portal-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1rem, 2.6vw, 2.6rem);
  }

  .kicker {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 14ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.15rem, 3.7vw, 3.85rem);
  }

  .text {
    max-width: 52ch;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.94rem;
    line-height: 1.64;
  }

  .portal-proof {
    display: flex;
    align-items: center;
    gap: 0.68rem;
    margin-top: 1.2rem;
    padding: 0.62rem 0.78rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.055);
  }

  .portal-proof p {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.7rem;
  }

  .portal-proof strong {
    color: rgba(255, 255, 255, 0.93);
  }

  .human-signal {
    display: inline-flex;
    align-items: center;
    padding-left: 0.18rem;
  }

  .human-signal i {
    width: 0.62rem;
    height: 0.62rem;
    margin-left: -0.18rem;
    border: 1px solid var(--ink);
    border-radius: 50%;
    background: var(--accent);
  }

  .human-signal i:nth-child(2) {
    background: var(--system);
  }

  .human-signal i:nth-child(3) {
    background: var(--success);
  }

  .benefits {
    width: 100%;
    display: grid;
    gap: 0;
    margin: 1.5rem 0 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    list-style: none;
  }

  .benefits li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.55rem;
    align-items: center;
    min-height: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .benefits li > span {
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .benefits strong {
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem 1rem;
    margin-top: 1.5rem;
  }

  .portal-actions .btn {
    width: fit-content;
  }

  .client-access {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.75rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.74rem;
    font-weight: 720;
    text-decoration: none;
  }

  .client-access:hover,
  .client-access:focus-visible {
    color: #ffffff;
  }

  .portal-demo {
    align-self: center;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 18px;
    background: #f4f6fa;
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.36);
  }

  .product-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: 3rem;
    padding: 0 1rem;
    border-bottom: 1px solid #dfe4eb;
    background: #ffffff;
  }

  .product-bar > p {
    color: #687386;
    font-size: 0.68rem;
    font-weight: 650;
  }

  .window-dots {
    display: flex;
    gap: 0.3rem;
  }

  .window-dots span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #dce1e8;
  }

  .live-status {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: #477765;
    font-size: 0.64rem;
    font-weight: 760;
  }

  .live-status i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px var(--success-soft);
  }

  .portal-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.35rem;
    padding: 0.65rem;
    background: #ffffff;
  }

  .portal-tab {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.7rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 10px;
    background: transparent;
    color: #667185;
    font: inherit;
    font-size: 0.73rem;
    font-weight: 720;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .portal-tab span {
    color: #8a94a5;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }

  .portal-tab:hover,
  .portal-tab:focus-visible {
    color: var(--ink);
    background: #f5f7fa;
  }

  .portal-tab.is-active {
    border-color: #dfe4eb;
    background: var(--ink);
    color: #ffffff;
  }

  .portal-tab.is-active span {
    color: var(--accent);
  }

  .portal-views {
    padding: 0 clamp(0.65rem, 1.25vw, 1rem);
  }

  .portal-view {
    outline: none;
  }

  .portal-visual {
    position: relative;
    overflow: hidden;
    border: 1px solid #dde3eb;
    border-radius: 13px;
    background: #eceff4;
    box-shadow: 0 16px 40px rgba(14, 23, 38, 0.1);
  }

  figure {
    margin: 0;
  }

  .portal-visual img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: #ffffff;
  }

  .portal-visual picture {
    display: block;
  }

  .visual-signal {
    position: absolute;
    right: 0.72rem;
    bottom: 0.72rem;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    background: rgba(14, 23, 38, 0.88);
    box-shadow: 0 10px 28px rgba(14, 23, 38, 0.22);
    color: #ffffff;
    font-size: 0.62rem;
    font-weight: 720;
    backdrop-filter: blur(12px);
  }

  .visual-signal span {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--success);
  }

  .view-caption {
    display: grid;
    grid-template-columns: minmax(90px, 0.5fr) minmax(180px, 0.95fr) minmax(190px, 1.2fr);
    gap: 1rem;
    align-items: center;
    min-height: 6.6rem;
    padding: 1rem 0.35rem;
  }

  .view-caption p {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .view-caption h3 {
    color: var(--ink);
    font-size: clamp(0.98rem, 1.2vw, 1.18rem);
    line-height: 1.18;
  }

  .view-caption > span {
    color: #657084;
    font-size: 0.74rem;
    line-height: 1.5;
  }

  .demo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.5rem;
    padding: 0 1rem;
    border-top: 1px solid #dfe4eb;
    background: #ffffff;
  }

  .demo-footer p {
    color: #7a8495;
    font-size: 0.6rem;
    font-weight: 650;
  }

  .demo-footer p:first-child {
    color: #567466;
  }

  .demo-footer p:first-child span {
    color: var(--success);
  }

  @media (max-width: 1080px) {
    .portal-section {
      grid-template-columns: 1fr;
    }

    .portal-copy {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.75fr);
      gap: 1rem 2rem;
      align-items: end;
    }

    .portal-heading {
      grid-row: span 2;
    }

    .portal-proof {
      width: fit-content;
      margin: 0;
    }

    .benefits {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 0.4rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .benefits li {
      grid-template-columns: 1.7rem 1fr;
      padding: 0.65rem;
      border-bottom: 0;
    }

    .benefits li + li {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .portal-actions {
      margin-top: 0;
    }
  }

  @media (max-width: 720px) {
    .portal-section {
      padding: 0.5rem;
      border-radius: 20px;
    }

    .portal-copy {
      display: flex;
      padding: 1.05rem 0.8rem 1.15rem;
    }

    h2 {
      max-width: 16ch;
      font-size: clamp(2rem, 10.8vw, 3.2rem);
    }

    .portal-proof {
      margin-top: 1rem;
    }

    .benefits {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: 1.25rem;
      border-bottom: 0;
    }

    .benefits li {
      padding: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .benefits li + li {
      border-left: 0;
    }

    .portal-actions {
      margin-top: 1.25rem;
    }

    .portal-demo {
      border-radius: 14px;
    }

    .product-bar {
      grid-template-columns: auto 1fr;
      min-height: 2.7rem;
      padding: 0 0.75rem;
    }

    .product-bar > p {
      display: none;
    }

    .portal-tabs {
      padding: 0.45rem;
    }

    .portal-tab {
      min-height: 2.55rem;
      padding-inline: 0.45rem;
      font-size: 0.68rem;
    }

    .portal-tab span {
      display: none;
    }

    .portal-views {
      padding: 0 0.45rem;
    }

    .visual-signal {
      right: 0.45rem;
      bottom: 0.45rem;
      max-width: calc(100% - 0.9rem);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .view-caption {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      min-height: 0;
      padding: 0.85rem 0.3rem 1rem;
    }

    .view-caption h3 {
      max-width: 30ch;
    }

    .demo-footer p:last-child {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .portal-view:not([hidden]) .portal-visual {
      animation: portal-view-in 220ms ease-out both;
    }

    .portal-view:not([hidden]) .view-caption {
      animation: portal-caption-in 260ms 40ms ease-out both;
    }

    .live-status i {
      animation: portal-live 2.6s ease-in-out infinite;
    }
  }

  @keyframes portal-view-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  @keyframes portal-caption-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
  }

  @keyframes portal-live {
    50% {
      box-shadow: 0 0 0 6px rgba(29, 155, 117, 0.06);
    }
  }
</style>
