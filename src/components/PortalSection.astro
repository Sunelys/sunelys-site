---
interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    benefits: string[];
    cta: {
      label: string;
      href: string;
      track: string;
    };
    image?: {
      src: string;
      alt: string;
    };
    secondaryImage?: {
      src: string;
      alt: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="section-shell portal-section reveal" aria-labelledby="portal-title">
  <div class="portal-copy" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="portal-title">{data.title}</h2>
    <p class="text">{data.text}</p>

    <ul class="benefits">
      {
        data.benefits.map((benefit) => (
          <li>
            <span aria-hidden="true"></span>
            {benefit}
          </li>
        ))
      }
    </ul>

    <div class="portal-actions">
      <a class="btn btn-accent" href={data.cta.href} data-track={data.cta.track}>
        {data.cta.label}
        <span aria-hidden="true">↗</span>
      </a>
      <p><strong>Portail dédié</strong> + interlocuteur humain</p>
    </div>
  </div>

  <div class="product-panel" aria-label="Aperçu du portail Sunelys" data-reveal-item>
    <div class="product-bar">
      <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
      <p>portail.sunelys.fr</p>
      <span class="live-status"><i aria-hidden="true"></i> Suivi en temps réel</span>
    </div>

    {
      data.image && (
        <figure class="product-main">
          <img src={data.image.src} alt={data.image.alt} loading="lazy" decoding="async" />
        </figure>
      )
    }

    <div class="product-detail">
      <div>
        <p class="detail-label">Une lecture opérationnelle</p>
        <h3>Le bon statut, la prochaine action et les pièces au même endroit.</h3>
      </div>

      {
        data.secondaryImage && (
          <figure>
            <img src={data.secondaryImage.src} alt={data.secondaryImage.alt} loading="lazy" decoding="async" />
          </figure>
        )
      }
    </div>
  </div>
</section>

<style>
  .portal-section {
    display: grid;
    grid-template-columns: minmax(320px, 0.78fr) minmax(0, 1.22fr);
    overflow: hidden;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(80% 92% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 58%),
      radial-gradient(75% 80% at 75% 0%, rgba(54, 98, 227, 0.25), transparent 60%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .portal-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.5rem, 3.5vw, 3.6rem);
  }

  .kicker {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 16ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.1rem, 3.9vw, 4rem);
  }

  .text {
    max-width: 54ch;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.94rem;
    line-height: 1.64;
  }

  .benefits {
    display: grid;
    gap: 0.6rem;
    margin: 1.35rem 0 0;
    padding: 0;
    list-style: none;
  }

  .benefits li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.82rem;
    font-weight: 680;
  }

  .benefits li > span {
    width: 0.52rem;
    height: 0.52rem;
    flex: 0 0 auto;
    border: 2px solid var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(212, 130, 42, 0.12);
  }

  .portal-actions {
    display: grid;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .portal-actions .btn {
    width: fit-content;
  }

  .portal-actions p {
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.72rem;
  }

  .portal-actions strong {
    color: rgba(255, 255, 255, 0.8);
  }

  .product-panel {
    align-self: center;
    min-width: 0;
    margin: clamp(0.8rem, 1.5vw, 1.25rem);
    margin-left: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    background: #f5f7fb;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
  }

  .product-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: 3rem;
    padding: 0 0.9rem;
    border-bottom: 1px solid #dfe4eb;
    background: #ffffff;
  }

  .product-bar p {
    color: #687386;
    font-size: 0.68rem;
    font-weight: 650;
  }

  .window-dots {
    display: flex;
    gap: 0.3rem;
  }

  .window-dots span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #dce1e8;
  }

  .live-status {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    color: #597067;
    font-size: 0.64rem;
    font-weight: 720;
  }

  .live-status i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px var(--success-soft);
  }

  figure {
    margin: 0;
  }

  .product-main {
    padding: clamp(0.8rem, 1.5vw, 1.25rem);
  }

  .product-main img,
  .product-detail img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid #e1e5eb;
    border-radius: 10px;
    background: #ffffff;
  }

  .product-main img {
    box-shadow: 0 16px 34px rgba(14, 23, 38, 0.1);
  }

  .product-detail {
    display: grid;
    grid-template-columns: minmax(210px, 0.72fr) minmax(0, 1.28fr);
    gap: 1rem;
    align-items: center;
    padding: 0 1.25rem 1.25rem;
  }

  .detail-label {
    color: var(--system);
    font-size: 0.65rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-detail h3 {
    max-width: 22ch;
    margin-top: 0.4rem;
    font-size: clamp(1.02rem, 1.45vw, 1.35rem);
    line-height: 1.18;
  }

  @media (max-width: 980px) {
    .portal-section {
      grid-template-columns: 1fr;
    }

    .portal-copy {
      padding-bottom: 1.4rem;
    }

    .product-panel {
      margin: 0 0.8rem 0.8rem;
    }
  }

  @media (max-width: 620px) {
    .portal-copy {
      padding: 1.3rem;
    }

    .product-panel {
      margin: 0 0.55rem 0.55rem;
      border-radius: 13px;
    }

    .product-bar {
      grid-template-columns: auto 1fr;
    }

    .product-bar > p {
      display: none;
    }

    .product-detail {
      grid-template-columns: 1fr;
      padding: 0 0.8rem 0.8rem;
    }
  }
</style>
