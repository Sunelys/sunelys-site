---
import MediaFrame from "./MediaFrame.astro";

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    benefits: string[];
    cta: {
      label: string;
      href: string;
      track: string;
    };
    image?: {
      src: string;
      alt: string;
    };
    secondaryImage?: {
      src: string;
      alt: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="section-shell portal-section reveal">
  <div class="portal-copy">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
    <p class="text">{data.text}</p>

    <ul class="benefits">
      {
        data.benefits.map((benefit) => (
          <li>{benefit}</li>
        ))
      }
    </ul>

    <a class="btn btn-primary" href={data.cta.href} data-track={data.cta.track}>{data.cta.label}</a>
  </div>

  <div class="portal-mock" aria-label="Aperçu du portail Sunelys">
    <header>
      <span class="chip">Portail Sunelys</span>
      <span class="status">Vue client</span>
    </header>

    <div class="portal-intro">
      <div>
        <p class="portal-kicker">Aperçu produit</p>
        <h3>Une interface claire pour visualiser l'avancement et agir sans friction.</h3>
      </div>
      <div class="portal-tags" aria-label="Points clés du portail">
        <span>Dossiers en cours</span>
        <span>Pièces à transmettre</span>
        <span>Progression visible</span>
      </div>
    </div>

    {data.image && (
      <div class="portal-media portal-media-primary">
        <MediaFrame src={data.image.src} alt={data.image.alt} label="Vue d'ensemble du portail" variant="showcase" />
      </div>
    )}

    {data.secondaryImage && (
      <div class="portal-secondary">
        <div class="portal-secondary-copy">
          <p class="portal-kicker">Vue détaillée</p>
          <h3>Chaque dossier garde sa prochaine étape, son statut et son niveau d'avancement à portée de regard.</h3>
          <p>
            Une lecture compacte pour réduire les allers-retours et sécuriser le suivi administratif au quotidien.
          </p>
        </div>

        <div class="portal-media portal-media-secondary">
          <MediaFrame
            src={data.secondaryImage.src}
            alt={data.secondaryImage.alt}
            label="Liste des dossiers du portail"
            variant="ultrawide"
          />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .portal-section {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 0.72rem;
    align-items: stretch;
  }

  .portal-copy {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: var(--radius-xl);
    background: linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 90%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.15rem, 2.5vw, 2rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.55rem, 2.8vw, 2.8rem);
    line-height: 1.04;
    max-width: 23ch;
  }

  .text {
    margin: 0.84rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.54;
  }

  .benefits {
    margin: 0.78rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.38rem;
  }

  .benefits li {
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    padding: 0.55rem 0.68rem;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .portal-copy .btn {
    margin-top: 0.86rem;
    width: fit-content;
  }

  .portal-mock {
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 58%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: 0.96rem;
    display: grid;
    gap: 0.72rem;
    position: relative;
    overflow: hidden;
  }

  .portal-mock::after {
    content: "";
    position: absolute;
    right: -14%;
    top: -30%;
    width: clamp(220px, 34vw, 420px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.85);
    filter: blur(calc(var(--shape-blur) * 1.25));
    pointer-events: none;
  }

  .portal-media {
    position: relative;
    z-index: 1;
  }

  .portal-media :global(.media-frame) {
    border-color: color-mix(in srgb, var(--line) 64%, var(--accent));
    box-shadow:
      0 26px 54px rgba(18, 26, 44, 0.12),
      0 10px 22px rgba(201, 172, 133, 0.16);
  }

  .portal-media :global(.media-frame img) {
    object-fit: contain;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 243, 236, 0.98));
  }

  .portal-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.72rem;
    align-items: end;
    position: relative;
    z-index: 1;
  }

  .portal-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .portal-intro h3,
  .portal-secondary h3 {
    margin: 0.32rem 0 0;
    font-size: clamp(1.02rem, 1.9vw, 1.42rem);
    line-height: 1.16;
    max-width: 24ch;
  }

  .portal-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.42rem;
  }

  .portal-tags span {
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--surface) 92%, white);
    padding: 0.42rem 0.64rem;
    color: var(--text);
    font-size: 0.68rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .portal-media-primary {
    margin-top: 0.08rem;
  }

  .portal-secondary {
    display: grid;
    grid-template-columns: minmax(0, 0.48fr) minmax(0, 0.52fr);
    gap: 0.72rem;
    align-items: center;
    position: relative;
    z-index: 1;
    margin-top: 0.04rem;
    padding: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--line) 76%, white);
    border-radius: calc(var(--radius-xl) - 8px);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(250, 246, 239, 0.92));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .portal-secondary-copy p:last-child {
    margin: 0.54rem 0 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.5;
    max-width: 30ch;
  }

  .portal-mock header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.7rem;
    position: relative;
    z-index: 1;
  }

  .chip,
  .status {
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.62rem;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--surface);
  }

  .status {
    color: #205f42;
  }

  @media (max-width: 1080px) {
    .portal-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .portal-intro,
    .portal-secondary {
      grid-template-columns: 1fr;
    }

    .portal-tags {
      justify-content: flex-start;
    }

    .portal-copy .btn {
      width: 100%;
    }
  }
</style>
