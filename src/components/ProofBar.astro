---
interface LogoItem {
  name: string;
  src: string;
}

interface MetricItem {
  value: string;
  label: string;
}

interface ProofData {
  kicker: string;
  title: string;
  logos: LogoItem[];
  metrics: MetricItem[];
  testimonial?: {
    quote: string;
    author: string;
    note: string;
  };
  testimonials?: Array<{
    quote: string;
    author: string;
    note: string;
  }>;
}

interface Props {
  data: ProofData;
}

const { data } = Astro.props;
const featuredTestimonial = data.testimonial ?? data.testimonials?.[0];
---

<section class="section block reveal">
  <div class="block-head">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
  </div>

  <div class="logo-grid" aria-label="Partenaires Sunelys">
    {
      data.logos.map((logo) => (
        <article class="logo-cell" aria-label={logo.name}>
          {logo.src ? <img src={logo.src} alt={logo.name} loading="lazy" /> : <span>{logo.name}</span>}
        </article>
      ))
    }
  </div>

  <div class="metrics-grid">
    {
      data.metrics.map((metric) => (
        <article class="metric">
          <p class="value">{metric.value}</p>
          <p class="label">{metric.label}</p>
        </article>
      ))
    }
  </div>

  {
    featuredTestimonial && (
      <blockquote class="testimonial">
        <p>"{featuredTestimonial.quote}"</p>
        <cite>{featuredTestimonial.author}</cite>
        <small>{featuredTestimonial.note}</small>
      </blockquote>
    )
  }
</section>

<style>
  .section {
    margin-top: clamp(1.1rem, 2vw, 1.8rem);
  }

  .block {
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.1rem, 2.4vw, 1.8rem);
  }

  .block-head h2 {
    margin: 0.5rem 0 0;
    font-size: var(--step-2);
    line-height: 1.2;
    max-width: 30ch;
    text-wrap: balance;
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  .logo-grid {
    margin-top: 1rem;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .logo-cell {
    min-height: 3rem;
    display: grid;
    place-items: center;
    border: 1px dashed color-mix(in srgb, var(--color-hairline) 74%, var(--color-accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 84%, white);
    padding: 0.6rem;
    text-align: center;
  }

  .logo-cell img {
    width: 100%;
    max-height: 28px;
    object-fit: contain;
  }

  .logo-cell span {
    color: var(--color-muted);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .metrics-grid {
    margin-top: 0.8rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .metric {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-surface) 90%, white);
    padding: 0.76rem;
  }

  .value {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-3);
    line-height: 0.95;
  }

  .label {
    margin: 0.42rem 0 0;
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  .testimonial {
    margin: 0.8rem 0 0;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 86%, white);
    padding: 0.78rem;
  }

  .testimonial p {
    margin: 0;
    font-size: var(--step--1);
    color: var(--color-text-strong);
    line-height: 1.5;
  }

  .testimonial cite {
    margin-top: 0.48rem;
    display: inline-block;
    font-style: normal;
    color: var(--color-muted);
    font-size: 0.78rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .testimonial small {
    display: block;
    margin-top: 0.2rem;
    color: var(--color-muted);
    font-size: 0.75rem;
  }

  @media (max-width: 980px) {
    .logo-grid,
    .metrics-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .logo-grid,
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
