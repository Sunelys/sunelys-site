---
interface ServiceCard {
  label: string;
  title: string;
  benefit: string;
  description: string;
  ctaLabel: string;
  href: string;
  track: string;
}

interface PricingData {
  eyebrow: string;
  text: string;
  href: string;
  label: string;
  track: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    pricing?: PricingData;
    cards: ServiceCard[];
  };
}

const { data } = Astro.props;
---

<section id="services" class="section-shell services-section reveal" aria-labelledby="services-title">
  <div class="services-head" data-reveal-item>
    <div>
      <p class="kicker">{data.kicker}</p>
      <h2 id="services-title">{data.title}</h2>
    </div>

    {
      data.pricing && (
        <aside class="pricing-note">
          <p>{data.pricing.eyebrow}</p>
          <strong>{data.pricing.text}</strong>
          <a href={data.pricing.href} data-track={data.pricing.track}>
            {data.pricing.label}
            <span aria-hidden="true">→</span>
          </a>
        </aside>
      )
    }
  </div>

  <div class="services-grid">
    {
      data.cards.map((card, index) => (
        <article class="service-card" data-reveal-item>
          <div class="card-top">
            <span>0{index + 1}</span>
            <p>{card.label.replace(/^Service\s*/i, "")}</p>
          </div>
          <h3>{card.title}</h3>
          <p class="benefit">{card.benefit}</p>
          <p class="description">{card.description}</p>
          <a class="service-link" href={card.href} data-track={card.track}>
            {card.ctaLabel}
            <span aria-hidden="true">→</span>
          </a>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services-section {
    display: grid;
    gap: clamp(1.3rem, 2.8vw, 2.3rem);
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .services-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.56fr);
    gap: clamp(1.2rem, 4vw, 4.5rem);
    align-items: end;
  }

  .kicker {
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 22ch;
    margin-top: 0.65rem;
    font-size: clamp(2rem, 3.7vw, 3.7rem);
  }

  .pricing-note {
    display: grid;
    gap: 0.38rem;
    padding: 1rem 0 0.15rem 1rem;
    border-left: 3px solid var(--accent);
  }

  .pricing-note p {
    color: var(--accent-strong);
    font-size: 0.68rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pricing-note strong {
    color: var(--text);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .pricing-note a,
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: var(--text);
    font-size: 0.76rem;
    font-weight: 760;
    text-decoration: none;
  }

  .pricing-note a {
    margin-top: 0.25rem;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 50%, transparent);
    text-underline-offset: 0.25rem;
  }

  .pricing-note a span,
  .service-link span {
    color: var(--system);
    font-size: 1rem;
    transition: transform 160ms ease;
  }

  .pricing-note a:hover span,
  .service-link:hover span {
    transform: translateX(3px);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .service-card {
    position: relative;
    grid-column: span 2;
    min-height: 24rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1rem, 2.2vw, 1.6rem);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    transition: background-color 170ms ease;
  }

  .service-card:nth-child(n + 4) {
    grid-column: span 3;
    min-height: 21rem;
  }

  .service-card:hover {
    background: color-mix(in srgb, var(--system-soft) 54%, white);
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: var(--system);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 190ms ease;
  }

  .service-card:nth-child(even)::before {
    background: var(--accent);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-top span {
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .card-top p {
    color: var(--text-muted);
    font-size: 0.64rem;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .service-card h3 {
    max-width: 13ch;
    margin-top: clamp(1.5rem, 3vw, 2.8rem);
    font-size: clamp(1.55rem, 2.2vw, 2.25rem);
    line-height: 1;
  }

  .benefit {
    max-width: 42ch;
    margin-top: 1rem;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .description {
    max-width: 52ch;
    margin-top: 0.6rem;
    color: var(--text-muted);
    font-size: 0.79rem;
    line-height: 1.55;
  }

  .service-link {
    margin-top: auto;
    padding-top: 1.25rem;
  }

  @media (max-width: 980px) {
    .services-head {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-card,
    .service-card:nth-child(n + 4) {
      grid-column: span 1;
      min-height: 21rem;
    }

    .service-card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 620px) {
    .services-section {
      padding: 1.15rem;
    }

    .services-grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: min(84vw, 22rem);
      gap: 0.75rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      overscroll-behavior-inline: contain;
      border: 0;
      padding-bottom: 0.5rem;
    }

    .service-card,
    .service-card:nth-child(n + 4),
    .service-card:last-child:nth-child(odd) {
      grid-column: auto;
      min-height: 22rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      scroll-snap-align: start;
    }

    .service-card h3 {
      margin-top: 1.5rem;
    }

    .service-link {
      margin-top: 1rem;
    }
  }
</style>
