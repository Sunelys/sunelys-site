---
import SwipeCue from "./SwipeCue.astro";

interface ServiceCard {
  label: string;
  title: string;
  stage?: string;
  benefit: string;
  description: string;
  ctaLabel: string;
  href: string;
  track: string;
}

interface PricingData {
  eyebrow: string;
  text: string;
  href: string;
  label: string;
  track: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    pricing?: PricingData;
    cards: ServiceCard[];
  };
}

const { data } = Astro.props;
---

<section
  id="services"
  class="section-shell services-section reveal"
  aria-labelledby="services-title"
  data-track-view="homepage_services_view"
  data-track-label="homepage_services"
>
  <div class="services-head" data-reveal-item>
    <div>
      <p class="kicker">{data.kicker}</p>
      <h2 id="services-title">{data.title}</h2>
    </div>

    {
      data.pricing && (
        <aside class="pricing-note">
          <span>{data.pricing.eyebrow}</span>
          <p>{data.pricing.text}</p>
          <a href={data.pricing.href} data-track={data.pricing.track}>
            {data.pricing.label}
            <span aria-hidden="true">→</span>
          </a>
        </aside>
      )
    }
  </div>

  <SwipeCue label="5 briques à parcourir" />

  <div
    class="services-grid"
    aria-label="Briques administratives Sunelys — utilisez les flèches horizontales pour les parcourir"
    tabindex="0"
    data-scroll-rail
    data-scroll-label="briques_administratives"
  >
    {
      data.cards.map((card, index) => (
        <article class="service-card" data-reveal-item>
          <div class="card-top">
            <span>{card.label.replace(/^Service\s*/i, "")}</span>
            {card.stage && <p>{card.stage}</p>}
          </div>

          <div class="service-copy">
            <h3>{card.title}</h3>
            <p class="benefit">{card.benefit}</p>
            <p class="description">{card.description}</p>
          </div>

          <div class="service-foot">
            <a class="service-link" href={card.href} data-track={card.track} data-track-label={card.title}>
              {card.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services-section {
    position: relative;
    display: grid;
    gap: 1rem;
    overflow: hidden;
    padding: 1.45rem;
    border: 1px solid color-mix(in srgb, var(--system) 11%, var(--line));
    border-radius: var(--radius-xl);
    background:
      linear-gradient(90deg, rgba(54, 98, 227, 0.045) 1px, transparent 1px) 0 0 / 40px 40px,
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 98%, white), color-mix(in srgb, var(--system-soft) 36%, white));
    box-shadow: var(--shadow-sm);
  }

  .services-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(310px, 0.38fr);
    gap: 1.1rem;
    align-items: stretch;
  }

  .kicker {
    margin: 0;
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h2 {
    max-width: 20ch;
    margin: 0.65rem 0 0;
    font-size: 3.05rem;
    letter-spacing: 0;
  }

  .pricing-note {
    align-self: stretch;
    display: grid;
    align-content: space-between;
    gap: 1rem;
    min-height: 12rem;
    padding: 1.15rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    border-radius: 14px;
    background:
      radial-gradient(80% 120% at 100% 0%, color-mix(in srgb, var(--accent-soft) 58%, transparent), transparent 62%),
      color-mix(in srgb, var(--surface) 94%, white);
  }

  .pricing-note span {
    color: var(--accent-strong);
    font-size: 0.68rem;
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .pricing-note p {
    color: var(--text);
    font-size: 1rem;
    font-weight: 720;
    line-height: 1.42;
  }

  .pricing-note a,
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 760;
    text-decoration: none;
  }

  .pricing-note a {
    margin-top: 0.25rem;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 50%, transparent);
    text-underline-offset: 0.25rem;
  }

  .pricing-note a span,
  .service-link span {
    color: var(--system);
    font-size: 1rem;
    transition: transform 160ms ease;
  }

  .pricing-note a:hover span,
  .service-link:hover span {
    transform: translateX(3px);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(10, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .service-card {
    position: relative;
    grid-column: span 2;
    min-height: 23rem;
    display: grid;
    align-content: space-between;
    gap: 1.4rem;
    min-width: 0;
    padding: 1rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.78);
    transition:
      border-color 170ms ease,
      background-color 170ms ease,
      transform 170ms ease;
  }

  .service-card:nth-child(-n + 3) {
    grid-column: span 3;
  }

  .service-card:nth-child(4),
  .service-card:nth-child(5) {
    grid-column: span 5;
    min-height: 17rem;
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: var(--system);
  }

  .service-card:nth-child(even)::before {
    background: var(--accent);
  }

  .service-card:hover {
    border-color: color-mix(in srgb, var(--system) 28%, var(--line));
    background: #ffffff;
    transform: translateY(-2px);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-top span {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 800;
  }

  .card-top p {
    margin: 0;
    padding: 0.32rem 0.48rem;
    border-radius: 999px;
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 760;
    text-transform: uppercase;
  }

  .service-copy {
    display: grid;
    gap: 0.8rem;
  }

  .service-card h3 {
    max-width: 14ch;
    margin: 0;
    font-size: 1.74rem;
    letter-spacing: 0;
    line-height: 1.03;
  }

  .benefit {
    max-width: 42ch;
    margin: 0;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .description {
    max-width: 52ch;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.79rem;
    line-height: 1.55;
  }

  .service-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
  }

  .service-link {
    color: var(--ink);
  }

  @media (max-width: 980px) {
    .services-head {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-card,
    .service-card:nth-child(-n + 3),
    .service-card:nth-child(4),
    .service-card:nth-child(5) {
      grid-column: span 1;
      min-height: 20rem;
    }

    .service-card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 620px) {
    .services-section {
      padding: 1rem;
      border-radius: 18px;
    }

    h2 {
      font-size: 2.15rem;
    }

    .pricing-note {
      min-height: 0;
    }

    .services-grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: min(84vw, 22rem);
      gap: 0.75rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      overscroll-behavior-inline: contain;
      scrollbar-width: none;
      scroll-padding-inline: 0.15rem;
      border: 0;
      padding-bottom: 0.5rem;
    }

    .services-grid::-webkit-scrollbar {
      display: none;
    }

    .services-grid:focus-visible {
      outline: 3px solid color-mix(in srgb, var(--system) 34%, transparent);
      outline-offset: 3px;
    }

    .service-card,
    .service-card:nth-child(-n + 3),
    .service-card:nth-child(4),
    .service-card:nth-child(5),
    .service-card:last-child:nth-child(odd) {
      grid-column: auto;
      min-height: 22rem;
      border: 1px solid var(--line);
      scroll-snap-align: start;
    }

    .service-card h3 {
      margin-top: 1.5rem;
    }

    .service-link {
      margin-top: 1rem;
    }
  }
</style>
