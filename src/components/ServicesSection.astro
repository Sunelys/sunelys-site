---
interface ServiceCard {
  label: string;
  title: string;
  benefit: string;
  description: string;
  ctaLabel: string;
  href: string;
  track: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    cards: ServiceCard[];
  };
}

const { data } = Astro.props;
---

<section id="services" class="section-shell services-section reveal">
  <div class="services-head">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
  </div>

  <div class="services-grid">
    {
      data.cards.map((card) => (
        <article class="service-card">
          <p class="label">{card.label}</p>
          <h3>{card.title}</h3>
          <p class="benefit">{card.benefit}</p>
          <p class="description">{card.description}</p>
          <a class="btn btn-secondary" href={card.href} data-track={card.track}>{card.ctaLabel}</a>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services-section {
    position: relative;
    padding: clamp(1.2rem, 2.5vw, 2rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 90%, white), var(--surface));
    box-shadow: var(--shadow-sm);
  }

  .services-head {
    max-width: 36rem;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 29ch;
    font-size: clamp(1.5rem, 2.7vw, 2.6rem);
    line-height: 1.04;
  }

  .services-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .service-card {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface));
    box-shadow: 0 10px 22px rgba(22, 17, 11, 0.065);
    padding: 1rem;
    display: grid;
    gap: 0.52rem;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease, background-color 180ms ease;
    overflow: hidden;
    position: relative;
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: -10% auto auto -18%;
    width: 52%;
    aspect-ratio: 1;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 72%, white);
    opacity: 0.26;
    filter: blur(16px);
    pointer-events: none;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--line) 68%, var(--accent));
  }

  .label {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .service-card h3 {
    margin: 0;
    font-size: clamp(1.55rem, 2vw, 1.95rem);
    line-height: 0.96;
    position: relative;
    z-index: 1;
  }

  .benefit {
    margin: 0;
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.4;
    position: relative;
    z-index: 1;
  }

  .description {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.48;
    min-height: 4.2rem;
    position: relative;
    z-index: 1;
  }

  .service-card .btn {
    margin-top: 0.4rem;
    width: fit-content;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1000px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .description {
      min-height: 0;
    }

    .service-card .btn {
      width: 100%;
    }
  }
</style>
