---
interface StepItem {
  title: string;
  text: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    steps: StepItem[];
  };
}

const { data } = Astro.props;
---

<section id="parcours" class="section-shell process-section reveal">
  <div class="process-head">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
  </div>

  <ol class="process-track" aria-label="Parcours Sunelys en quatre étapes">
    {
      data.steps.map((step, index) => (
        <li class="process-step">
          <span class="index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .process-section {
    position: relative;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 92%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.2rem, 2.6vw, 2.2rem);
  }

  .process-head {
    max-width: 34rem;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.55rem, 2.8vw, 2.8rem);
    line-height: 1.04;
    text-wrap: balance;
  }

  .process-track {
    margin: 1.1rem 0 0;
    padding: 0;
    list-style: none;
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.62rem;
  }

  .process-track::before {
    content: "";
    position: absolute;
    left: 4%;
    right: 4%;
    top: 1.38rem;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-soft) 72%, white),
      color-mix(in srgb, var(--accent) 45%, white),
      color-mix(in srgb, var(--accent-soft) 72%, white)
    );
    pointer-events: none;
  }

  .process-step {
    position: relative;
    z-index: 1;
    border-radius: calc(var(--radius-md) - 4px);
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
    padding: 0.95rem 0.92rem;
    min-height: 10.3rem;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .process-step:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--line) 64%, var(--accent));
  }

  .index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent-soft) 80%, white), color-mix(in srgb, var(--accent-soft) 52%, white));
    color: var(--text);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    font-weight: 700;
    font-family: var(--font-sans);
  }

  .process-step h3 {
    margin: 0.7rem 0 0;
    font-size: 1.1rem;
    line-height: 1.14;
  }

  .process-step p {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.48;
  }

  @media (max-width: 1080px) {
    .process-track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .process-track::before {
      display: none;
    }
  }

  @media (max-width: 680px) {
    .process-track {
      grid-template-columns: 1fr;
    }

    .process-step {
      min-height: auto;
    }
  }
</style>
