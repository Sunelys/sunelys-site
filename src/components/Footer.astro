---
interface LinkItem {
  href: string;
  label: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-primary">
      <p>contact@sunelys.fr</p>
      <p>06 95 90 79 19</p>
      <a href="https://portail.sunelys.fr/login" data-track="cta_footer_portal">Portail client</a>
    </div>

    <nav class="footer-secondary" aria-label="Pages SEO">
      {
        links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid color-mix(in srgb, var(--line) 70%, white);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--bg-soft) 92%, white), color-mix(in srgb, var(--bg) 96%, white));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.4rem 0 2.2rem;
  }

  .footer-primary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    color: var(--text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .footer-primary p {
    margin: 0;
  }

  .footer-primary a,
  .footer-secondary a {
    color: var(--text);
    text-decoration: none;
    transition: color 170ms ease;
  }

  .footer-primary a:hover,
  .footer-primary a:focus-visible,
  .footer-secondary a:hover,
  .footer-secondary a:focus-visible {
    color: #000;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .footer-secondary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.9rem;
    justify-content: flex-end;
    font-size: 0.74rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  @media (max-width: 940px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .footer-secondary {
      justify-content: flex-start;
    }
  }
</style>
