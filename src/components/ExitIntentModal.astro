---
interface Props {
  action: string;
  path: string;
}

const { action, path } = Astro.props;
---

<div
  id="exit-intent-modal"
  class="exit-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="exit-modal-title"
  hidden
  data-path={path}
>
  <div class="exit-modal__panel" role="document">
    <button class="exit-modal__close" type="button" aria-label="Fermer la fenêtre">
      <span aria-hidden="true">×</span>
    </button>

    <div class="exit-modal__copy">
      <p class="exit-modal__kicker">Diagnostic dossiers bloqués</p>
      <h2 id="exit-modal-title">Avant de partir : faites identifier l'étape qui ralentit vos dossiers</h2>
      <p>
        DP, Consuel ou raccordement : indiquez votre volume et le blocage principal. Sunelys vous répond
        avec le premier périmètre à reprendre en priorité.
      </p>
    </div>

    <form
      id="exit-intent-form"
      class="exit-modal__form"
      action={action}
      method="POST"
      data-lead-form
      data-conversion-type="form_contact"
    >
      <input type="hidden" name="_subject" value="Nouveau diagnostic dossiers bloqués Sunelys" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="source_page" value="exit-intent-diagnostic-dossiers-bloques" />
      <input type="hidden" name="source" value="exit-intent-diagnostic-dossiers-bloques" />
      <input type="hidden" name="need" value="Pilotage complet" />
      <input type="hidden" name="message" value="Demande de diagnostic dossiers bloqués depuis exit intent" />
      <input type="hidden" name="conversion_type" value="form_contact" />
      <input type="hidden" name="lead_stage" value="exit_intent_form_submitted" />
      <input type="hidden" name="service_interest" value="Pilotage complet" />
      <input type="hidden" name="lead_source_detail" value="exit_intent_diagnostic_modal" />
      <input type="hidden" name="qualification_hint" value="email professionnel, volume mensuel et étape bloquée depuis exit intent" />
      <input type="hidden" name="lead_status" value="Nouveau lead" />
      <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic dossiers bloqués" />
      <input type="hidden" name="lead_owner" value="Sunelys commercial" />
      <input type="hidden" name="follow_up_sla" value="24h" />
      <input type="hidden" name="landing_page" data-exit-attribution="landing_page" />
      <input type="hidden" name="first_referrer" data-exit-attribution="first_referrer" />
      <input type="hidden" name="utm_source" data-exit-attribution="utm_source" />
      <input type="hidden" name="utm_medium" data-exit-attribution="utm_medium" />
      <input type="hidden" name="utm_campaign" data-exit-attribution="utm_campaign" />
      <input type="hidden" name="utm_term" data-exit-attribution="utm_term" />
      <input type="hidden" name="utm_content" data-exit-attribution="utm_content" />
      <input type="hidden" name="gclid" data-exit-attribution="gclid" />
      <input type="hidden" name="fbclid" data-exit-attribution="fbclid" />
      <input type="hidden" name="msclkid" data-exit-attribution="msclkid" />

      <label>
        <span>Volume mensuel</span>
        <select name="volume" required>
          <option value="">Sélectionner</option>
          <option value="1-10">1-10 dossiers</option>
          <option value="10-30">10-30 dossiers</option>
          <option value="+30">+30 dossiers</option>
        </select>
      </label>

      <label>
        <span>Étape bloquée</span>
        <select name="blocked_stage" required>
          <option value="">Sélectionner</option>
          <option value="Avant dépôt">Avant dépôt</option>
          <option value="Complément mairie">Complément mairie</option>
          <option value="Consuel à préparer">Consuel à préparer</option>
          <option value="Raccordement en attente">Raccordement en attente</option>
          <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
          <option value="Prime à suivre">Prime à suivre</option>
          <option value="Mise en service bloquée">Mise en service bloquée</option>
          <option value="Pilotage global">Pilotage global</option>
          <option value="Je ne sais pas encore">Je ne sais pas encore</option>
        </select>
      </label>

      <label>
        <span>Email professionnel</span>
        <input id="exit-intent-email" type="email" name="email" autocomplete="email" inputmode="email" required />
      </label>

      <button class="btn btn-primary btn-accent" type="submit" data-track="cta_exit_intent_submit">
        Recevoir mon diagnostic
      </button>

      <p class="exit-modal__note" id="exit-intent-status" aria-live="polite">
        Réponse sous 24h ouvrées. Aucun engagement.
      </p>
      <a
        class="exit-modal__download"
        id="exit-intent-download"
        href="/contact?source=exit_intent_success#contact-form"
        data-track="cta_exit_intent_diagnostic_context"
        hidden
      >
        Compléter mon contexte
      </a>
    </form>
  </div>
</div>

<script>
  const modal = document.querySelector("#exit-intent-modal");
  const modalPanel = modal?.querySelector(".exit-modal__panel");
  const closeButton = modal?.querySelector(".exit-modal__close");
  const exitForm = document.querySelector("#exit-intent-form");
  const exitStatus = document.querySelector("#exit-intent-status");
  const exitDownload = document.querySelector("#exit-intent-download");
  const shownKey = "sunelys_exit_intent_shown";
  const submittedKey = "sunelys_form_submitted";
  let lastFocusedElement = null;
  let hasReachedHalfPage = false;
  let previousScrollY = window.scrollY;

  const canUseStorage = () => {
    try {
      sessionStorage.setItem("sunelys_storage_test", "1");
      sessionStorage.removeItem("sunelys_storage_test");
      return true;
    } catch (_error) {
      return false;
    }
  };

  const storageAvailable = canUseStorage();
  const readSessionFlag = (key) => storageAvailable && sessionStorage.getItem(key) === "true";
  const writeSessionFlag = (key) => {
    if (storageAvailable) sessionStorage.setItem(key, "true");
  };

  const isExcludedPage = () => {
    const path = modal instanceof HTMLElement ? modal.dataset.path || window.location.pathname : window.location.pathname;
    return path === "/contact" || path.startsWith("/contact/");
  };

  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "textarea:not([disabled])",
    "[tabindex]:not([tabindex='-1'])",
  ].join(",");

  const getFocusableElements = () => {
    if (!(modalPanel instanceof HTMLElement)) return [];
    return Array.from(modalPanel.querySelectorAll(focusableSelector)).filter((element) => {
      return element instanceof HTMLElement && element.offsetParent !== null;
    });
  };

  const closeModal = () => {
    if (!(modal instanceof HTMLElement)) return;
    modal.hidden = true;
    document.body.classList.remove("exit-modal-open");
    document.removeEventListener("keydown", handleKeydown);
    if (lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus();
  };

  function handleKeydown(event) {
    if (event.key === "Escape") {
      closeModal();
      return;
    }

    if (event.key !== "Tab") return;

    const focusableElements = getFocusableElements();
    if (focusableElements.length === 0) {
      event.preventDefault();
      return;
    }

    const firstElement = focusableElements[0];
    const lastElement = focusableElements[focusableElements.length - 1];

    if (event.shiftKey && document.activeElement === firstElement) {
      event.preventDefault();
      lastElement.focus();
    } else if (!event.shiftKey && document.activeElement === lastElement) {
      event.preventDefault();
      firstElement.focus();
    }
  }

  const openModal = () => {
    if (!(modal instanceof HTMLElement)) return;
    if (isExcludedPage() || readSessionFlag(shownKey) || readSessionFlag(submittedKey)) return;

    writeSessionFlag(shownKey);
    lastFocusedElement = document.activeElement;
    modal.hidden = false;
    document.body.classList.add("exit-modal-open");
    document.addEventListener("keydown", handleKeydown);
    window.trackEvent?.("exit_intent_modal_viewed", {
      category: "lead",
      label: "Diagnostic dossiers bloqués",
      source: "exit-intent-diagnostic-dossiers-bloques",
      conversion_type: "form_contact",
      lead_stage: "exit_intent_viewed",
      service_interest: "Pilotage complet",
    });

    window.requestAnimationFrame(() => {
      const focusTarget = document.querySelector("#exit-intent-email") || closeButton;
      if (focusTarget instanceof HTMLElement) focusTarget.focus();
    });
  };

  if (modal instanceof HTMLElement && !isExcludedPage() && !readSessionFlag(shownKey) && !readSessionFlag(submittedKey)) {
    const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
    modal.querySelectorAll("[data-exit-attribution]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.exitAttribution || "";
      field.value = attribution[key] || "";
    });

    document.addEventListener("mouseleave", (event) => {
      if (event.clientY <= 0) openModal();
    });

    window.addEventListener(
      "scroll",
      () => {
        const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (scrollableHeight <= 0) return;

        const currentScrollY = window.scrollY;
        const scrollProgress = currentScrollY / scrollableHeight;
        if (scrollProgress >= 0.65) hasReachedHalfPage = true;

        if (hasReachedHalfPage && previousScrollY - currentScrollY > 80) {
          openModal();
        }

        previousScrollY = currentScrollY;
      },
      { passive: true }
    );
  }

  closeButton?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });

  if (exitForm instanceof HTMLFormElement) {
    exitForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const submitButton = exitForm.querySelector("button[type='submit']");
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      if (exitStatus) exitStatus.textContent = "Envoi du diagnostic en cours...";
      const exitFormData = new FormData(exitForm);

      try {
        const response = await fetch(exitForm.action, {
          method: "POST",
          body: exitFormData,
          headers: { Accept: "application/json" },
        });

        if (!response.ok) throw new Error("Lead magnet submit failed");

        writeSessionFlag(submittedKey);
          window.trackEvent?.("lead_form_submit", {
            category: "lead",
            label: "Diagnostic dossiers bloqués",
            source: "exit-intent-diagnostic-dossiers-bloques",
            volume: String(exitFormData.get("volume") || ""),
            need: String(exitFormData.get("need") || ""),
            blocked_stage: String(exitFormData.get("blocked_stage") || ""),
            conversion_type: "form_contact",
            lead_stage: "exit_intent_form_submitted",
            service_interest: "Pilotage complet",
          });
          window.trackEvent?.("generate_lead", {
            category: "lead",
            label: "Diagnostic dossiers bloqués",
            source: "exit-intent-diagnostic-dossiers-bloques",
            volume: String(exitFormData.get("volume") || ""),
            need: String(exitFormData.get("need") || ""),
            blocked_stage: String(exitFormData.get("blocked_stage") || ""),
            conversion_type: "form_contact",
            lead_stage: "exit_intent_form_submitted",
            service_interest: "Pilotage complet",
          });
          window.trackEvent?.("lead_converted", {
            category: "lead",
            label: "Diagnostic dossiers bloqués",
            source: "exit-intent-diagnostic-dossiers-bloques",
            volume: String(exitFormData.get("volume") || ""),
            need: String(exitFormData.get("need") || ""),
            blocked_stage: String(exitFormData.get("blocked_stage") || ""),
            conversion_type: "form_contact",
            lead_stage: "lead_confirmed",
            service_interest: "Pilotage complet",
          });

        if (exitStatus) {
          exitStatus.textContent = "Merci, votre demande est bien prise en compte. On vous revient avec une première lecture.";
        }
        if (exitDownload instanceof HTMLElement) {
          exitDownload.hidden = false;
          exitDownload.focus();
        }
      } catch (_error) {
        if (exitStatus) {
          exitStatus.textContent =
            "L'envoi n'a pas abouti. Vous pouvez réessayer ou passer par le formulaire de contact.";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement && !readSessionFlag(submittedKey)) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

<style>
  .exit-modal {
    position: fixed;
    inset: 0;
    z-index: 220;
    display: grid;
    place-items: center;
    padding: max(1rem, env(safe-area-inset-top, 0px)) max(1rem, env(safe-area-inset-right, 0px))
      max(1rem, env(safe-area-inset-bottom, 0px)) max(1rem, env(safe-area-inset-left, 0px));
    background: rgba(18, 15, 11, 0.44);
    backdrop-filter: blur(8px);
  }

  .exit-modal[hidden] {
    display: none;
  }

  :global(body.exit-modal-open) {
    overflow: hidden;
  }

  .exit-modal__panel {
    position: relative;
    width: min(100%, 34rem);
    display: grid;
    gap: 1rem;
    border: 1px solid color-mix(in srgb, var(--line) 58%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 52%, transparent), transparent 58%),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 97%, white), var(--surface));
    box-shadow: 0 34px 90px rgba(20, 16, 10, 0.22);
    padding: clamp(1.1rem, 3vw, 1.65rem);
  }

  .exit-modal__close {
    position: absolute;
    top: 0.78rem;
    right: 0.78rem;
    width: 2.35rem;
    height: 2.35rem;
    display: inline-grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--line) 72%, white);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    color: var(--text);
    font-size: 1.45rem;
    line-height: 1;
    cursor: pointer;
  }

  .exit-modal__copy {
    display: grid;
    gap: 0.62rem;
    padding-right: 2.2rem;
  }

  .exit-modal__kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h2 {
    max-width: 17ch;
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.45rem);
    line-height: 1;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.58;
  }

  .exit-modal__form {
    display: grid;
    gap: 0.72rem;
  }

  label {
    display: grid;
    gap: 0.38rem;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  select {
    width: 100%;
    min-height: 3rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: #fffefa;
    color: var(--text);
    padding: 0.76rem 0.9rem;
    font: inherit;
    letter-spacing: 0;
    text-transform: none;
  }

  input:focus-visible,
  select:focus-visible {
    border-color: #111111;
  }

  .exit-modal__form .btn {
    width: 100%;
  }

  .exit-modal__download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    border: 1px solid #0f0c09;
    border-radius: 999px;
    background: linear-gradient(180deg, #12100d, #090806);
    color: #fffdfa;
    text-decoration: none;
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.72rem 1.2rem;
  }

  .exit-modal__download[hidden] {
    display: none;
  }

  .exit-modal__note {
    font-size: var(--step--1);
    text-align: center;
  }

  @media (max-width: 560px) {
    .exit-modal {
      align-items: end;
      padding: 0.75rem;
    }

    .exit-modal__panel {
      border-radius: var(--radius-md);
    }

    .exit-modal__copy {
      padding-right: 1.9rem;
    }
  }

  /* Direction visuelle 2026 */
  .exit-modal {
    padding: max(1rem, env(safe-area-inset-top, 0px)) max(1rem, env(safe-area-inset-right, 0px))
      max(1rem, env(safe-area-inset-bottom, 0px)) max(1rem, env(safe-area-inset-left, 0px));
    background: rgba(5, 10, 19, 0.62);
    backdrop-filter: blur(12px);
  }

  .exit-modal__panel {
    position: relative;
    width: min(100%, 60rem);
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(20rem, 0.62fr);
    gap: 0;
    overflow: hidden;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-xl);
    background: #ffffff;
    box-shadow: 0 38px 110px rgba(0, 0, 0, 0.38);
  }

  .exit-modal__close {
    z-index: 2;
    top: 0.8rem;
    right: 0.8rem;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--line);
    background: #ffffff;
    color: var(--ink);
    font-size: 1.25rem;
  }

  .exit-modal__copy {
    position: relative;
    isolation: isolate;
    display: grid;
    align-content: center;
    gap: 0.85rem;
    min-height: 31rem;
    padding: clamp(2rem, 5vw, 4.5rem);
    background:
      radial-gradient(circle at 100% 0%, rgba(54, 98, 227, 0.4), transparent 35%),
      radial-gradient(circle at 0% 100%, rgba(212, 130, 42, 0.23), transparent 34%),
      var(--ink);
  }

  .exit-modal__copy::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -10rem;
    width: 19rem;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 3rem rgba(255, 255, 255, 0.025),
      0 0 0 6rem rgba(255, 255, 255, 0.018);
  }

  .exit-modal__kicker {
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.11em;
  }

  .exit-modal__copy h2 {
    max-width: 15ch;
    color: #ffffff;
    font-size: clamp(1.9rem, 3.5vw, 3.25rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .exit-modal__copy > p:not(.exit-modal__kicker) {
    max-width: 40ch;
    color: #cbd5e1;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .exit-modal__form {
    display: grid;
    align-content: center;
    gap: 0.75rem;
    padding: clamp(1.4rem, 3vw, 2.4rem);
    background: #ffffff;
  }

  .exit-modal__form label {
    gap: 0.32rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .exit-modal__form input,
  .exit-modal__form select {
    min-height: 2.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: #ffffff;
    color: var(--ink);
  }

  .exit-modal__form input:focus-visible,
  .exit-modal__form select:focus-visible {
    border-color: var(--system);
    outline: 3px solid color-mix(in srgb, var(--system-soft) 80%, transparent);
  }

  .exit-modal__download {
    min-height: 2.7rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: none;
  }

  .exit-modal__note {
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  @media (max-width: 760px) {
    .exit-modal {
      align-items: end;
      padding: 0.5rem;
    }

    .exit-modal__panel {
      grid-template-columns: 1fr;
      max-height: calc(100vh - 1rem);
      overflow-y: auto;
      border-radius: var(--radius-md);
    }

    .exit-modal__copy {
      min-height: 0;
      padding: 1.35rem 3.2rem 1.35rem 1.35rem;
    }

    .exit-modal__copy h2 {
      font-size: clamp(1.7rem, 8vw, 2.3rem);
    }

    .exit-modal__form {
      padding: 1.15rem;
    }
  }
</style>
