---
interface FaqItem {
  question: string;
  answer: string;
}

interface FaqData {
  kicker: string;
  title: string;
  items: FaqItem[];
}

interface Props {
  data: FaqData;
}

const { data } = Astro.props;
const objectionSignals = [
  "Périmètre",
  "Rôle",
  "Tarifs",
  "Profil client",
  "Reprise",
];
---

<section
  class="section-shell faq-section reveal"
  aria-labelledby="faq-title"
  data-track-view="homepage_faq_view"
  data-track-label="homepage_faq"
>
  <div class="faq-head" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="faq-title">{data.title}</h2>
    <p class="faq-intro">Les informations essentielles pour savoir si la délégation correspond à votre organisation.</p>

    <div class="faq-decision-card" aria-label="À quoi sert cette FAQ">
      <span>Avant de déléguer</span>
      <strong>Valider le cadre, le prix et la reprise possible.</strong>
      <a href="/contact?source=faq#contact-form" data-track="cta_faq_contact">
        Poser ma question
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="faq-list" data-reveal-item>
    {
      data.items.map((item, index) => (
        <details class="faq-item">
          <summary data-track={`faq_homepage_${index + 1}`} data-track-label={item.question}>
            <span class="faq-number">0{index + 1}</span>
            <span class="faq-signal">{objectionSignals[index] ?? "Question"}</span>
            <span class="faq-question">{item.question}</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-section {
    position: relative;
    display: grid;
    grid-template-columns: minmax(280px, 0.62fr) minmax(0, 1.38fr);
    gap: 1rem;
    align-items: start;
    overflow: hidden;
    padding: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: var(--radius-xl);
    background:
      linear-gradient(90deg, rgba(54, 98, 227, 0.045) 1px, transparent 1px) 0 0 / 40px 40px,
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, white), color-mix(in srgb, var(--system-soft) 54%, white));
  }

  .faq-head {
    position: sticky;
    top: 6.5rem;
    display: grid;
    align-content: start;
    gap: 1rem;
    min-width: 0;
    padding: 1.05rem;
  }

  .kicker {
    margin: 0;
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h2 {
    max-width: 17ch;
    margin: 0;
    font-size: 2.9rem;
    letter-spacing: 0;
  }

  .faq-intro {
    max-width: 48ch;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .faq-decision-card {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.4rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.74);
  }

  .faq-decision-card > span {
    color: var(--accent-deep);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .faq-decision-card strong {
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.38;
  }

  .faq-decision-card a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 780;
    text-decoration: none;
  }

  .faq-decision-card a span {
    color: var(--system);
  }

  .faq-list {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.76);
  }

  .faq-item {
    border-bottom: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  summary {
    cursor: pointer;
    list-style: none;
    display: grid;
    grid-template-columns: auto minmax(84px, 0.26fr) 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .faq-number {
    color: var(--system);
    font-size: 0.66rem;
    font-weight: 800;
  }

  .faq-signal {
    width: fit-content;
    padding: 0.32rem 0.52rem;
    border-radius: 999px;
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 780;
  }

  .faq-question {
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 740;
    line-height: 1.4;
  }

  .faq-icon {
    position: relative;
    width: 1.8rem;
    height: 1.8rem;
    border: 1px solid color-mix(in srgb, var(--system) 16%, var(--line));
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.66);
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.65rem;
    height: 1px;
    background: var(--text);
    transform: translate(-50%, -50%);
    transition: transform 160ms ease;
  }

  .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-item[open] .faq-icon {
    border-color: color-mix(in srgb, var(--system) 46%, var(--line));
    background: #ffffff;
  }

  .faq-item[open] .faq-icon::after {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .faq-item > p {
    max-width: 70ch;
    margin: -0.25rem 3rem 1.1rem calc(1rem + 2rem + 0.75rem + min(26%, 11rem) + 0.75rem);
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.62;
  }

  @media (max-width: 860px) {
    .faq-section {
      grid-template-columns: 1fr;
    }

    .faq-head {
      position: static;
    }
  }

  @media (max-width: 520px) {
    .faq-section {
      padding: 1rem;
      border-radius: 18px;
    }

    .faq-head {
      padding: 0.35rem 0.1rem 0.2rem;
    }

    h2 {
      font-size: 2.12rem;
    }

    summary {
      grid-template-columns: auto 1fr auto;
      gap: 0.62rem;
      padding: 0.9rem;
    }

    .faq-signal {
      display: none;
    }

    .faq-item > p {
      margin: -0.15rem 0.9rem 1rem;
    }
  }
</style>
