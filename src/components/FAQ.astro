---
interface FaqItem {
  question: string;
  answer: string;
}

interface FaqData {
  kicker: string;
  title: string;
  items: FaqItem[];
}

interface Props {
  data: FaqData;
}

const { data } = Astro.props;
---

<section class="section-shell faq-section reveal" aria-labelledby="faq-title">
  <div class="faq-head">
    <p class="kicker">{data.kicker}</p>
    <h2 id="faq-title">{data.title}</h2>
  </div>

  <div class="faq-list">
    {
      data.items.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-section {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 0.75rem;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.15rem, 2.6vw, 2.1rem);
  }

  .faq-head {
    position: sticky;
    top: 6rem;
  }

  .kicker {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 700;
  }

  h2 {
    margin: 0.55rem 0 0;
    font-size: clamp(1.65rem, 2.8vw, 2.8rem);
    line-height: 1.04;
    max-width: 22ch;
    text-wrap: balance;
  }

  .faq-list {
    display: grid;
    gap: 0.55rem;
  }

  .faq-item {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: 0 10px 22px rgba(22, 17, 11, 0.045);
    padding: 0.08rem 0.82rem;
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }

  .faq-item[open] {
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
    box-shadow: var(--shadow-sm);
  }

  summary {
    cursor: pointer;
    list-style: none;
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 700;
    padding: 0.86rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "+";
    display: inline-grid;
    place-items: center;
    width: 1.55rem;
    height: 1.55rem;
    flex: 0 0 auto;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text-muted);
    background: var(--surface);
    font-size: 1rem;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    content: "-";
    color: var(--text);
    border-color: color-mix(in srgb, var(--line) 62%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 68%, white);
  }

  .faq-item p {
    margin: 0 0 0.9rem;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.58;
    max-width: 74ch;
  }

  @media (max-width: 860px) {
    .faq-section {
      grid-template-columns: 1fr;
    }

    .faq-head {
      position: static;
    }
  }
</style>
