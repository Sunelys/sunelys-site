---
interface FaqItem {
  question: string;
  answer: string;
}

interface FaqData {
  kicker: string;
  title: string;
  items: FaqItem[];
}

interface Props {
  data: FaqData;
}

const { data } = Astro.props;
---

<section class="section-shell faq-section reveal" aria-labelledby="faq-title">
  <div class="faq-head" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="faq-title">{data.title}</h2>
    <p>Les informations essentielles pour savoir si la délégation correspond à votre organisation.</p>
  </div>

  <div class="faq-list" data-reveal-item>
    {
      data.items.map((item, index) => (
        <details class="faq-item">
          <summary>
            <span class="faq-number">0{index + 1}</span>
            <span class="faq-question">{item.question}</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: start;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--system-soft) 60%, var(--surface));
  }

  .faq-head {
    position: sticky;
    top: 6.5rem;
  }

  .kicker {
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 17ch;
    margin-top: 0.65rem;
    font-size: clamp(2rem, 3.5vw, 3.45rem);
  }

  .faq-head > p:last-child {
    max-width: 48ch;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .faq-list {
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .faq-item {
    border-bottom: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  summary {
    cursor: pointer;
    list-style: none;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 1.15rem 0;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .faq-number {
    color: var(--system);
    font-size: 0.66rem;
    font-weight: 800;
  }

  .faq-question {
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 740;
    line-height: 1.4;
  }

  .faq-icon {
    position: relative;
    width: 1.8rem;
    height: 1.8rem;
    border: 1px solid color-mix(in srgb, var(--system) 16%, var(--line));
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.66);
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.65rem;
    height: 1px;
    background: var(--text);
    transform: translate(-50%, -50%);
    transition: transform 160ms ease;
  }

  .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-item[open] .faq-icon {
    border-color: color-mix(in srgb, var(--system) 46%, var(--line));
    background: #ffffff;
  }

  .faq-item[open] .faq-icon::after {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .faq-item > p {
    max-width: 70ch;
    margin: -0.15rem 2.65rem 1.2rem 1.78rem;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.62;
  }

  @media (max-width: 860px) {
    .faq-section {
      grid-template-columns: 1fr;
    }

    .faq-head {
      position: static;
    }
  }

  @media (max-width: 520px) {
    .faq-section {
      padding: 1.15rem;
    }

    .faq-item > p {
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
