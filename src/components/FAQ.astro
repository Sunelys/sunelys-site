---
interface FaqItem {
  question: string;
  answer: string;
}

interface FaqData {
  kicker: string;
  title: string;
  items: FaqItem[];
}

interface Props {
  data: FaqData;
}

const { data } = Astro.props;
---

<section class="section reveal">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>

  <div class="faq-list">
    {
      data.items.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .section {
    margin-top: clamp(1.4rem, 3vw, 2.5rem);
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: var(--step-3);
    line-height: 1.08;
    max-width: 24ch;
  }

  .faq-list {
    margin-top: 0.95rem;
    display: grid;
    gap: 0.62rem;
  }

  .faq-item {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
    padding: 0.1rem 0.82rem;
  }

  .faq-item[open] {
    border-color: color-mix(in srgb, var(--color-hairline) 64%, var(--color-accent));
  }

  summary {
    cursor: pointer;
    list-style: none;
    font-size: var(--step-0);
    color: var(--color-text-strong);
    font-weight: 600;
    padding: 0.8rem 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "+";
    color: var(--color-muted);
    font-size: 1.15rem;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    margin: 0 0 0.85rem;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: 74ch;
  }
</style>
