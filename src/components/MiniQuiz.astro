---
import FormPrivacyNote from "./FormPrivacyNote.astro";

interface QuizOption {
  value: string;
  label: string;
  message: string;
}

interface QuizData {
  kicker: string;
  title: string;
  question: string;
  options: QuizOption[];
  leadForm: {
    action: string;
  };
  emailStepTitle: string;
  emailLabel: string;
  emailSubmitLabel: string;
  emailNote: string;
  resultCtaLabel: string;
  ctaHref: string;
  phoneLabel: string;
  phoneHref: string;
}

interface Props {
  data: QuizData;
}

const { data } = Astro.props;
const messages = Object.fromEntries(data.options.map((option) => [option.value, option.message]));
---

<section class="section quiz reveal" id="estimation-gain">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>
  <p class="question">{data.question}</p>

  <div class="quiz-panel">
    <div class="step-indicator" aria-label="Étapes du tunnel quiz" data-reveal-item>
      <span class="step-pill is-active" id="quiz-step-pill-1">Étape 1</span>
      <span class="step-pill" id="quiz-step-pill-2">Étape 2</span>
      <span class="step-pill" id="quiz-step-pill-3">Étape 3</span>
    </div>

    <div class="options" role="radiogroup" aria-label={data.question} data-reveal-item>
      {
        data.options.map((option) => (
          <button
            type="button"
            class="option"
            data-volume={option.value}
            data-track="quiz_step_1"
            data-track-label={option.label}
            aria-pressed="false"
          >
            {option.label}
          </button>
        ))
      }
    </div>

    <form
      id="quiz-email-form"
      class="email-step"
      action={data.leadForm.action}
      method="POST"
      hidden
      data-reveal-item
      data-lead-form
          data-conversion-type="quiz_submit"
    >
      <input type="hidden" name="_subject" value="Nouveau lead quiz Sunelys" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="source_page" value="quiz-homepage" />
      <input type="hidden" name="source" value="quiz-homepage" />
      <input type="hidden" name="volume" id="quiz-volume-field" />
      <input type="hidden" name="blocked_stage" value="Pilotage global" />
      <input type="hidden" name="conversion_type" value="quiz_submit" />
      <input type="hidden" name="lead_stage" value="quiz_email_submitted" />
      <input type="hidden" name="service_interest" value="Pilotage administratif photovoltaïque" />
      <input type="hidden" name="lead_source_detail" value="homepage_quiz" />
      <input type="hidden" name="qualification_hint" value="email professionnel, volume mensuel déclaré et besoin de pilotage global" />
      <input type="hidden" name="lead_status" value="Nouveau lead" />
      <input type="hidden" name="lead_pipeline" value="Site web - Quiz volume" />
      <input type="hidden" name="lead_owner" value="Sunelys commercial" />
      <input type="hidden" name="follow_up_sla" value="24h" />
      <input type="hidden" name="landing_page" data-quiz-attribution="landing_page" />
      <input type="hidden" name="first_referrer" data-quiz-attribution="first_referrer" />
      <input type="hidden" name="utm_source" data-quiz-attribution="utm_source" />
      <input type="hidden" name="utm_medium" data-quiz-attribution="utm_medium" />
      <input type="hidden" name="utm_campaign" data-quiz-attribution="utm_campaign" />
      <input type="hidden" name="utm_term" data-quiz-attribution="utm_term" />
      <input type="hidden" name="utm_content" data-quiz-attribution="utm_content" />
      <input type="hidden" name="gclid" data-quiz-attribution="gclid" />
      <input type="hidden" name="fbclid" data-quiz-attribution="fbclid" />
      <input type="hidden" name="msclkid" data-quiz-attribution="msclkid" />

      <p class="email-step-title">{data.emailStepTitle}</p>

      <label>
        <span>{data.emailLabel}</span>
        <input id="quiz-email-field" type="email" name="email" autocomplete="email" inputmode="email" required />
      </label>

      <button class="btn btn-primary btn-accent" type="submit" data-track="cta_quiz_email_submit">
        {data.emailSubmitLabel}
      </button>

      <p class="email-note" id="quiz-email-status" aria-live="polite">
        {data.emailNote}
      </p>
      <FormPrivacyNote />
    </form>

    <div class="result" id="quiz-result" hidden data-reveal-item>
      <p id="quiz-message"></p>

      <div class="result-actions">
        <a
          id="quiz-cta"
          class="btn btn-primary btn-accent"
          href={data.ctaHref}
          data-track="cta_quiz_calendly"
          target="_blank"
          rel="noreferrer"
        >
          {data.resultCtaLabel}
        </a>
        <a class="result-phone" href={data.phoneHref} data-track="cta_quiz_phone">
          {data.phoneLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ messages, ctaHref: data.ctaHref }}>
  const quizButtons = document.querySelectorAll("[data-volume]");
  const quizEmailForm = document.querySelector("#quiz-email-form");
  const quizEmailStatus = document.querySelector("#quiz-email-status");
  const quizVolumeField = document.querySelector("#quiz-volume-field");
  const quizResult = document.querySelector("#quiz-result");
  const quizMessage = document.querySelector("#quiz-message");
  const quizCta = document.querySelector("#quiz-cta");
  const quizPill1 = document.querySelector("#quiz-step-pill-1");
  const quizPill2 = document.querySelector("#quiz-step-pill-2");
  const quizPill3 = document.querySelector("#quiz-step-pill-3");
  let selectedQuizVolume = "";

  const setQuizStep = (step) => {
    [quizPill1, quizPill2, quizPill3].forEach((pill, index) => {
      if (!(pill instanceof HTMLElement)) return;
      pill.classList.toggle("is-active", index + 1 === step);
      pill.classList.toggle("is-complete", index + 1 < step);
    });
  };

  if (quizEmailForm instanceof HTMLFormElement) {
    const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
    quizEmailForm.querySelectorAll("[data-quiz-attribution]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.quizAttribution || "";
      field.value = attribution[key] || "";
    });
  }

  const showQuizResult = (value) => {
    const message = messages[value];
    if (!message || !quizResult || !quizMessage || !quizCta) return;

    quizMessage.textContent = message;
    const ctaUrl = new URL(ctaHref, window.location.origin);
    ctaUrl.searchParams.set("volume", value);
    quizCta.setAttribute("href", ctaUrl.toString());
    quizResult.hidden = false;
    setQuizStep(3);

    if (window.trackEvent) {
      window.trackEvent("quiz_complete", {
        category: "quiz",
        volume: value,
        label: "Quiz complete",
        source: "quiz-homepage",
      });
    }
  };

  const setQuizValue = (value) => {
    if (!messages[value] || !(quizEmailForm instanceof HTMLFormElement)) return;

    selectedQuizVolume = value;
    quizButtons.forEach((button) => {
      button.setAttribute("aria-pressed", button.dataset.volume === value ? "true" : "false");
    });

    localStorage.setItem("sunelys_volume_range", value);
    if (quizVolumeField instanceof HTMLInputElement) quizVolumeField.value = value;
    quizEmailForm.hidden = false;
    quizResult.hidden = true;
    setQuizStep(2);
    quizEmailForm.querySelector("input[type='email']")?.focus();

    if (window.trackEvent) {
      window.trackEvent("quiz_step_1", {
        category: "quiz",
        volume: value,
        label: value,
        source: "quiz-homepage",
      });
    }
  };

  quizButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setQuizValue(button.dataset.volume);
    });
  });

  if (quizEmailForm instanceof HTMLFormElement) {
    quizEmailForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!selectedQuizVolume) return;

      const submitButton = quizEmailForm.querySelector("button[type='submit']");
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
      if (quizEmailStatus) quizEmailStatus.textContent = "Envoi du cadrage en cours...";

      const formData = new FormData(quizEmailForm);

      try {
        const response = await fetch(quizEmailForm.action, {
          method: "POST",
          body: formData,
          headers: { Accept: "application/json" },
        });

        if (!response.ok) throw new Error("Lead submit failed");

        if (window.trackEvent) {
          window.trackEvent("quiz_step_2", {
            category: "form",
            volume: selectedQuizVolume,
            label: "Quiz email capture",
            source: "quiz-homepage",
            conversion_type: "quiz_submit",
            lead_stage: "quiz_email_submitted",
            service_interest: "Pilotage administratif photovoltaïque",
          });

          window.trackEvent("lead_converted", {
            category: "lead",
            volume: selectedQuizVolume,
            label: "Quiz email capture",
            source: "quiz-homepage",
            conversion_type: "quiz_submit",
            lead_stage: "lead_confirmed",
            service_interest: "Pilotage administratif photovoltaïque",
          });
        }

        quizEmailForm.hidden = true;
        showQuizResult(selectedQuizVolume);
      } catch (_error) {
        if (quizEmailStatus) {
          quizEmailStatus.textContent =
            "L'envoi n'a pas abouti. Vous pouvez réessayer ou passer par le formulaire de contact.";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      }
    });
  }
</script>

<style>
  .section {
    margin-top: 0;
  }

  .quiz {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
    gap: clamp(0.9rem, 2vw, 1.4rem);
    align-items: center;
    background:
      radial-gradient(90% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 52%, transparent), transparent 58%),
      linear-gradient(160deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: clamp(1.05rem, 2.2vw, 1.7rem);
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.45rem, 2.4vw, 2.55rem);
    line-height: 1.05;
    max-width: 19ch;
  }

  .question {
    margin: 0.72rem 0 0;
    max-width: 44ch;
    font-size: var(--step-0);
    color: var(--color-muted);
  }

  .quiz-panel {
    display: grid;
    gap: 0.72rem;
  }

  .step-indicator {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .step-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.95rem;
    padding: 0.24rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--color-hairline);
    background: color-mix(in srgb, var(--color-surface) 88%, white);
    color: var(--color-muted);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .step-pill.is-active {
    border-color: color-mix(in srgb, var(--color-hairline) 64%, var(--color-accent));
    background: color-mix(in srgb, var(--color-cream) 72%, white);
    color: var(--color-text-strong);
  }

  .step-pill.is-complete {
    border-color: color-mix(in srgb, var(--color-hairline) 62%, var(--accent-strong));
    color: var(--color-text-strong);
  }

  .options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.58rem;
  }

  .option {
    border: 1px solid var(--color-hairline);
    background: color-mix(in srgb, var(--color-surface) 88%, white);
    color: var(--color-text-strong);
    border-radius: var(--radius-pill);
    padding: 0.55rem 0.88rem;
    font-size: var(--step--1);
    font-weight: 600;
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .option:hover,
  .option:focus-visible,
  .option[aria-pressed="true"] {
    border-color: color-mix(in srgb, var(--color-hairline) 68%, var(--color-accent));
    background: color-mix(in srgb, var(--color-cream) 72%, white);
    transform: translateY(-1px);
  }

  .email-step {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 84%, white);
    padding: 0.75rem;
    display: grid;
    gap: 0.65rem;
  }

  .email-step-title {
    margin: 0;
    color: var(--color-text-strong);
    font-size: 0.96rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .email-step[hidden],
  .result[hidden] {
    display: none;
  }

  .email-step label {
    display: grid;
    gap: 0.4rem;
    color: var(--color-text-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .email-step input {
    min-height: 2.85rem;
    border: 1px solid color-mix(in srgb, var(--color-hairline) 82%, var(--color-accent));
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-surface) 92%, white);
    color: var(--color-text-strong);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.72rem 0.82rem;
    outline: none;
  }

  .email-step input:focus-visible {
    border-color: color-mix(in srgb, var(--color-accent) 82%, var(--color-text-strong));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-cream) 72%, transparent);
  }

  .email-step .btn {
    width: fit-content;
  }

  .email-step .btn:disabled {
    cursor: wait;
    opacity: 0.72;
  }

  .email-note {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.45;
  }

  .result {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 84%, white);
    padding: 0.9rem;
    display: grid;
    gap: 0.85rem;
  }

  .result p {
    margin: 0;
    color: var(--color-text-strong);
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .result-actions {
    display: grid;
    gap: 0.62rem;
  }

  .result-phone {
    color: var(--color-text-strong);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .result-phone:hover,
  .result-phone:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.22rem;
  }

  @media (max-width: 820px) {
    .quiz {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .option,
    .result .btn,
    .email-step .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
