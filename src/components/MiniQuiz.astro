---
interface QuizOption {
  value: string;
  label: string;
  message: string;
}

interface QuizData {
  kicker: string;
  title: string;
  question: string;
  options: QuizOption[];
  ctaLabel: string;
  ctaHref: string;
}

interface Props {
  data: QuizData;
}

const { data } = Astro.props;
const messages = Object.fromEntries(data.options.map((option) => [option.value, option.message]));
---

<section class="section quiz reveal" id="estimation-gain">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>
  <p class="question">{data.question}</p>

  <div class="options" role="radiogroup" aria-label={data.question}>
    {
      data.options.map((option) => (
        <button
          type="button"
          class="option"
          data-volume={option.value}
          data-track="quiz_option_click"
          data-track-label={option.label}
          aria-pressed="false"
        >
          {option.label}
        </button>
      ))
    }
  </div>

  <div class="result" id="quiz-result" hidden>
    <p id="quiz-message"></p>
    <a id="quiz-cta" class="btn btn-primary" href={data.ctaHref} data-track="cta_quiz_estimation">
      {data.ctaLabel}
    </a>
  </div>
</section>

<script define:vars={{ messages, ctaHref: data.ctaHref }}>
  const quizButtons = document.querySelectorAll("[data-volume]");
  const quizResult = document.querySelector("#quiz-result");
  const quizMessage = document.querySelector("#quiz-message");
  const quizCta = document.querySelector("#quiz-cta");

  const setQuizValue = (value) => {
    const message = messages[value];
    if (!message || !quizResult || !quizMessage || !quizCta) return;

    quizButtons.forEach((button) => {
      button.setAttribute("aria-pressed", button.dataset.volume === value ? "true" : "false");
    });

    localStorage.setItem("sunelys_volume_range", value);
    quizMessage.textContent = message;
    const ctaUrl = new URL(ctaHref, window.location.origin);
    ctaUrl.searchParams.set("volume", value);
    quizCta.setAttribute("href", `${ctaUrl.pathname}${ctaUrl.search}`);
    quizResult.hidden = false;

    if (window.trackEvent) {
      window.trackEvent("quiz_volume_selected", { volume: value });
    }
  };

  quizButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setQuizValue(button.dataset.volume);
    });
  });
</script>

<style>
  .section {
    margin-top: 0;
  }

  .quiz {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
    gap: clamp(0.9rem, 2vw, 1.4rem);
    align-items: center;
    background:
      radial-gradient(90% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 52%, transparent), transparent 58%),
      linear-gradient(160deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: clamp(1.05rem, 2.2vw, 1.7rem);
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h2 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.45rem, 2.4vw, 2.55rem);
    line-height: 1.05;
    max-width: 19ch;
  }

  .question {
    margin: 0.72rem 0 0;
    max-width: 44ch;
    font-size: var(--step-0);
    color: var(--color-muted);
  }

  .options {
    margin-top: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.58rem;
  }

  .option {
    border: 1px solid var(--color-hairline);
    background: color-mix(in srgb, var(--color-surface) 88%, white);
    color: var(--color-text-strong);
    border-radius: var(--radius-pill);
    padding: 0.55rem 0.88rem;
    font-size: var(--step--1);
    font-weight: 600;
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  .option:hover,
  .option:focus-visible,
  .option[aria-pressed="true"] {
    border-color: color-mix(in srgb, var(--color-hairline) 68%, var(--color-accent));
    background: color-mix(in srgb, var(--color-cream) 72%, white);
    transform: translateY(-1px);
  }

  .result {
    grid-column: 1 / -1;
    margin-top: 0;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-bg-elevated) 84%, white);
    padding: 0.75rem;
    display: grid;
    gap: 0.72rem;
  }

  .result p {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.55;
  }

  .result .btn {
    width: fit-content;
  }

  @media (max-width: 820px) {
    .quiz {
      grid-template-columns: 1fr;
    }

    .options {
      margin-top: 0.2rem;
    }
  }

  @media (max-width: 640px) {
    .option {
      width: 100%;
      justify-content: center;
    }

    .result .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
