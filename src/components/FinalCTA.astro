---
interface CtaAction {
  label: string;
  href: string;
  track: string;
}

interface FinalCtaData {
  kicker: string;
  title: string;
  text: string;
  primaryCta: CtaAction;
  secondaryCta: CtaAction;
}

interface Props {
  data: FinalCtaData;
}

const { data } = Astro.props;
---

<section class="section final-cta reveal" id="contact">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>
  <p class="text">{data.text}</p>

  <div class="actions">
    <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
      {data.primaryCta.label}
    </a>
    <a class="btn btn-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
      {data.secondaryCta.label}
    </a>
  </div>
</section>

<style>
  .section {
    margin-top: clamp(1.55rem, 3vw, 2.7rem);
  }

  .final-cta {
    position: relative;
    background:
      radial-gradient(110% 130% at 0% 0%, color-mix(in srgb, var(--color-cream) 86%, white), transparent 58%),
      linear-gradient(160deg, color-mix(in srgb, var(--color-surface) 88%, white), var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-hairline) 72%, var(--color-accent));
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.3rem, 2.8vw, 2.15rem);
    overflow: hidden;
  }

  .final-cta::before {
    content: "";
    position: absolute;
    right: -11%;
    bottom: -54%;
    width: clamp(210px, 30vw, 420px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.95);
    filter: blur(calc(var(--shape-blur) * 1.15));
    pointer-events: none;
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h2 {
    margin: 0.52rem 0 0;
    max-width: 22ch;
    font-size: var(--step-4);
    line-height: 1.02;
    text-wrap: balance;
  }

  .text {
    margin: 0.85rem 0 0;
    max-width: 64ch;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.55;
  }

  .actions {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 640px) {
    .actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
