---
interface FrictionCard {
  title: string;
  consequence: string;
  solution: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    cards: FrictionCard[];
    closing: string;
  };
}

const { data } = Astro.props;
---

<section class="section-shell friction-section reveal">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>

  <div class="friction-grid">
    {
      data.cards.map((card) => (
        <article class="friction-card">
          <h3>{card.title}</h3>
          <p class="consequence">{card.consequence}</p>
          <p class="solution">{card.solution}</p>
        </article>
      ))
    }
  </div>

  <p class="closing">{data.closing}</p>
</section>

<style>
  .friction-section {
    padding: clamp(1.2rem, 2.6vw, 2.1rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, white), var(--bg-soft));
    box-shadow: var(--shadow-sm);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 27ch;
    font-size: clamp(1.5rem, 2.7vw, 2.55rem);
    line-height: 1.07;
  }

  .friction-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .friction-card {
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: var(--radius-md);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-sm);
    padding: 0.88rem;
    display: grid;
    gap: 0.46rem;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .friction-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .friction-card h3 {
    margin: 0;
    font-size: clamp(1.08rem, 1.5vw, 1.28rem);
    line-height: 1.12;
  }

  .consequence,
  .solution {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.48;
  }

  .consequence {
    color: var(--text-muted);
  }

  .solution {
    color: var(--text);
    font-weight: 600;
  }

  .closing {
    margin: 0.9rem 0 0;
    border: 1px solid color-mix(in srgb, var(--line) 84%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 62%, white);
    border-radius: var(--radius-md);
    padding: 0.78rem 0.88rem;
    color: var(--text);
    font-weight: 600;
    line-height: 1.5;
    font-size: 0.9rem;
  }

  @media (max-width: 1080px) {
    .friction-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .friction-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
