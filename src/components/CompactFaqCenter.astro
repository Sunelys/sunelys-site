---
interface FaqItem {
  question: string;
  answer: string;
}

interface ActionLink {
  label: string;
  href: string;
  track: string;
  external?: boolean;
}

interface SourceLink {
  label: string;
  href: string;
}

interface Props {
  source: string;
  kicker: string;
  title: string;
  intro: string;
  items: FaqItem[];
  panelKicker: string;
  panelTitle: string;
  panelText: string;
  facts: string[];
  primaryAction: ActionLink;
  secondaryAction?: ActionLink;
  sourceNote?: string;
  sourceLink?: SourceLink;
}

const {
  source,
  kicker,
  title,
  intro,
  items,
  panelKicker,
  panelTitle,
  panelText,
  facts,
  primaryAction,
  secondaryAction,
  sourceNote,
  sourceLink,
} = Astro.props;

const centerId = `compact-faq-${source.replace(/[^a-zA-Z0-9_-]/g, "_")}`;
const titleId = `${centerId}-title`;
---

<section
  id={centerId}
  class="compact-faq-center section-shell reveal"
  aria-labelledby={titleId}
  data-track-view="special_service_faq_view"
  data-track-label={source}
>
  <div class="compact-faq-head" data-reveal-item>
    <div>
      <p class="compact-faq-kicker">{kicker}</p>
      <h2 id={titleId}>{title}</h2>
    </div>
    <p>{intro}</p>
  </div>

  <div class="compact-faq-layout">
    <div class="compact-faq-list" data-reveal-item>
      <header>
        <span>Réponses directes</span>
        <strong>{items.length} questions traitées</strong>
      </header>

      {items.map((item, index) => (
        <details class="compact-faq-item" open={index === 0}>
          <summary data-track={`faq_${source}_${index + 1}`}>
            <span>0{index + 1}</span>
            <strong>{item.question}</strong>
            <i aria-hidden="true"></i>
          </summary>
          <div>
            <p>{item.answer}</p>
            <a href={primaryAction.href} data-track={`cta_${source}_faq_${index + 1}`}>
              Passer à l'action
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </details>
      ))}
    </div>

    <aside class="compact-faq-panel" data-reveal-item>
      <p class="compact-faq-kicker">{panelKicker}</p>
      <h3>{panelTitle}</h3>
      <p>{panelText}</p>

      <ul aria-label="Repères de l'offre">
        {facts.map((fact) => <li>{fact}</li>)}
      </ul>

      <div class="compact-faq-actions">
        <a
          class="btn btn-accent"
          href={primaryAction.href}
          target={primaryAction.external ? "_blank" : undefined}
          rel={primaryAction.external ? "noreferrer" : undefined}
          data-track={primaryAction.track}
        >
          {primaryAction.label}
          <span aria-hidden="true">→</span>
        </a>
        {secondaryAction && (
          <a
            class="compact-faq-secondary"
            href={secondaryAction.href}
            target={secondaryAction.external ? "_blank" : undefined}
            rel={secondaryAction.external ? "noreferrer" : undefined}
            data-track={secondaryAction.track}
          >
            {secondaryAction.label}
            <span aria-hidden="true">↗</span>
          </a>
        )}
      </div>

      {(sourceNote || sourceLink) && (
        <div class="compact-faq-source">
          {sourceNote && <p>{sourceNote}</p>}
          {sourceLink && (
            <a href={sourceLink.href} target="_blank" rel="noreferrer">
              {sourceLink.label}
              <span aria-hidden="true">↗</span>
            </a>
          )}
        </div>
      )}
    </aside>
  </div>
</section>

<script define:vars={{ centerId }}>
  const compactFaqCenter = document.getElementById(centerId);
  const compactFaqItems = Array.from(
    compactFaqCenter?.querySelectorAll(".compact-faq-item") || []
  );

  compactFaqItems.forEach((item) => {
    item.addEventListener("toggle", () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) return;

      compactFaqItems.forEach((sibling) => {
        if (sibling instanceof HTMLDetailsElement && sibling !== item) {
          sibling.open = false;
        }
      });
    });
  });
</script>

<style>
  .compact-faq-center {
    overflow: hidden;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 100% at 100% 0%, rgba(54, 98, 227, 0.12), transparent 64%),
      var(--system-soft);
    box-shadow: var(--shadow-md);
  }

  .compact-faq-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.62fr);
    gap: clamp(1rem, 4vw, 4rem);
    align-items: end;
  }

  .compact-faq-kicker {
    margin: 0;
    color: var(--system);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .compact-faq-head h2 {
    max-width: 16ch;
    margin: 0.65rem 0 0;
    color: var(--ink);
    font-size: clamp(2rem, 3.6vw, 3.6rem);
    line-height: 0.98;
  }

  .compact-faq-head > p {
    max-width: 48ch;
    margin: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--accent);
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.6;
  }

  .compact-faq-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.16fr) minmax(330px, 0.84fr);
    gap: 0.75rem;
    align-items: start;
    margin-top: 1.5rem;
  }

  .compact-faq-list {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 18px;
    background: #ffffff;
  }

  .compact-faq-list > header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--system-soft) 74%, white);
  }

  .compact-faq-list > header span,
  .compact-faq-list > header strong {
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .compact-faq-list > header span {
    color: var(--system);
  }

  .compact-faq-list > header strong {
    color: var(--text-muted);
  }

  .compact-faq-item {
    border-bottom: 1px solid var(--line);
  }

  .compact-faq-item:last-child {
    border-bottom: 0;
  }

  .compact-faq-item summary {
    cursor: pointer;
    display: grid;
    grid-template-columns: 2.1rem minmax(0, 1fr) 2.2rem;
    gap: 0.75rem;
    align-items: center;
    min-height: 4.7rem;
    padding: 0.72rem 0.9rem;
    list-style: none;
    transition: background 180ms ease;
  }

  .compact-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .compact-faq-item summary:hover,
  .compact-faq-item[open] summary {
    background: color-mix(in srgb, var(--system-soft) 78%, white);
  }

  .compact-faq-item summary > span {
    display: inline-grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 9px;
    background: var(--system-soft);
    color: var(--system);
    font-size: 0.61rem;
    font-weight: 800;
  }

  .compact-faq-item summary strong {
    color: var(--text);
    font-size: 0.78rem;
    line-height: 1.42;
  }

  .compact-faq-item summary i {
    position: relative;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #ffffff;
  }

  .compact-faq-item summary i::before,
  .compact-faq-item summary i::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0.62rem;
    height: 1px;
    background: var(--text);
    transform: translate(-50%, -50%);
    transition: transform 180ms ease;
  }

  .compact-faq-item summary i::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .compact-faq-item[open] summary i::after {
    transform: translate(-50%, -50%) rotate(0);
  }

  .compact-faq-item > div {
    padding: 0.1rem 4rem 1rem;
    background: color-mix(in srgb, var(--system-soft) 78%, white);
  }

  .compact-faq-item > div p {
    max-width: 72ch;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.62;
  }

  .compact-faq-item > div a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.72rem;
    color: var(--accent-deep);
    font-size: 0.64rem;
    font-weight: 800;
    text-decoration: none;
  }

  .compact-faq-panel {
    position: relative;
    overflow: hidden;
    display: grid;
    align-content: start;
    padding: clamp(1.1rem, 2.5vw, 1.6rem);
    border: 1px solid var(--ink);
    border-radius: 18px;
    background:
      radial-gradient(90% 80% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
  }

  .compact-faq-panel::after {
    content: "";
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 13rem;
    height: 13rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 50%;
    box-shadow:
      0 0 0 3rem rgba(255, 255, 255, 0.022),
      0 0 0 6rem rgba(255, 255, 255, 0.014);
    pointer-events: none;
  }

  .compact-faq-panel > * {
    position: relative;
    z-index: 1;
  }

  .compact-faq-panel .compact-faq-kicker {
    color: var(--accent);
  }

  .compact-faq-panel h3 {
    max-width: 15ch;
    margin: 0.65rem 0 0;
    color: #ffffff;
    font-size: clamp(1.5rem, 2.4vw, 2.4rem);
    line-height: 1.02;
  }

  .compact-faq-panel > p:not(.compact-faq-kicker) {
    max-width: 46ch;
    margin: 0.75rem 0 0;
    color: rgba(255, 255, 255, 0.56);
    font-size: 0.72rem;
    line-height: 1.58;
  }

  .compact-faq-panel ul {
    display: grid;
    gap: 0;
    margin: 1rem 0 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.11);
    list-style: none;
  }

  .compact-faq-panel li {
    position: relative;
    padding: 0.72rem 0 0.72rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.11);
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.68rem;
    line-height: 1.45;
  }

  .compact-faq-panel li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.03rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .compact-faq-actions {
    display: grid;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .compact-faq-actions .btn {
    width: 100%;
  }

  .compact-faq-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.8rem;
    padding: 0.65rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.66rem;
    font-weight: 800;
    text-decoration: none;
  }

  .compact-faq-secondary span {
    color: var(--accent);
  }

  .compact-faq-source {
    display: grid;
    gap: 0.45rem;
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .compact-faq-source p {
    margin: 0;
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.59rem;
    line-height: 1.5;
  }

  .compact-faq-source a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.61rem;
    font-weight: 800;
    text-decoration: none;
  }

  .compact-faq-source a span {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .compact-faq-head,
    .compact-faq-layout {
      grid-template-columns: 1fr;
    }

    .compact-faq-head h2 {
      max-width: 18ch;
    }

    .compact-faq-head > p {
      padding-left: 0.8rem;
    }
  }

  @media (max-width: 620px) {
    .compact-faq-center {
      padding: 1rem;
      border-radius: var(--radius-md);
    }

    .compact-faq-item > div {
      padding-right: 0.8rem;
      padding-left: 3.65rem;
    }

    .compact-faq-list > header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }

    .compact-faq-panel {
      padding: 1.1rem;
    }
  }
</style>
