---
interface AudienceItem {
  title: string;
  text: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    items: AudienceItem[];
  };
}

const { data } = Astro.props;
---

<section class="section-shell audience-section reveal" aria-labelledby="audience-title">
  <div class="audience-intro">
    <p class="kicker">{data.kicker}</p>
    <h2 id="audience-title">{data.title}</h2>
    <p>{data.text}</p>
  </div>

  <div class="audience-grid">
    {
      data.items.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .audience-section {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 0.7rem;
    align-items: stretch;
  }

  .audience-intro,
  .audience-grid article {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.1rem, 2.4vw, 1.9rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0.55rem 0 0;
    max-width: 21ch;
    font-size: clamp(1.6rem, 2.8vw, 2.8rem);
    line-height: 1.04;
    text-wrap: balance;
  }

  .audience-intro p:not(.kicker) {
    margin: 0.8rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.58rem;
  }

  .audience-grid article {
    border-radius: calc(var(--radius-md) - 4px);
    padding: 1rem;
    position: relative;
    overflow: hidden;
  }

  .audience-grid article::before {
    content: "";
    position: absolute;
    inset: auto 1rem 1rem auto;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 72%, white);
    opacity: 0.8;
  }

  .audience-grid h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1.7vw, 1.42rem);
    line-height: 1.08;
  }

  .audience-grid p {
    margin: 0.58rem 0 0;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  @media (max-width: 980px) {
    .audience-section,
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
