---
interface AudienceItem {
  title: string;
  text: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    items: AudienceItem[];
    note?: string;
    cta?: {
      label: string;
      href: string;
      track: string;
    };
  };
}

const { data } = Astro.props;
---

<section class="audience section-shell reveal" aria-labelledby="audience-title">
  <div class="intro">
    <p class="kicker">{data.kicker}</p>
    <h2 id="audience-title">{data.title}</h2>
    <p class="text">{data.text}</p>
    {data.note && <p class="note">{data.note}</p>}
  </div>

  <div class="cards">
    {
      data.items.map((item) => (
        <article class="card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))
    }
  </div>

  {
    data.cta && (
      <div class="actions">
        <a class="btn btn-primary" href={data.cta.href} data-track={data.cta.track}>
          {data.cta.label}
        </a>
      </div>
    )
  }
</section>

<style>
  .audience {
    display: grid;
    gap: 0.95rem;
    padding: clamp(1.15rem, 2.4vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(96% 125% at 100% 0%, color-mix(in srgb, var(--accent-soft) 54%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
  }

  .intro {
    display: grid;
    gap: 0.56rem;
    max-width: 70ch;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h2 {
    margin: 0;
    max-width: 22ch;
    font-size: clamp(1.8rem, 3.1vw, 3rem);
    line-height: 1.02;
  }

  .text,
  .note,
  .card p {
    color: var(--text-muted);
    line-height: 1.58;
  }

  .note {
    font-size: 0.9rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .card {
    display: grid;
    gap: 0.55rem;
    min-height: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid color-mix(in srgb, var(--line) 76%, white);
    border-radius: calc(var(--radius-md) - 5px);
    background: color-mix(in srgb, var(--surface) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  @media (max-width: 900px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .actions .btn {
      width: 100%;
    }
  }
</style>
