---
import HeroProductMockup from "./HeroProductMockup.astro";

interface PreviewProject {
  name: string;
  progress: string;
  status: string;
}

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  proofs: string[];
  ctaNote?: string;
  preview: {
    label: string;
    title: string;
    projects: PreviewProject[];
    timeline?: string[];
    documents?: string[];
    footer?: string;
    variant?: "minimal" | "full";
  };
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero section-shell">
  <div class="hero-copy reveal">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.subtitle}</p>

    <ul class="proof-bar" aria-label="Preuves clés Sunelys">
      {
        data.proofs.map((proof) => (
          <li>{proof}</li>
        ))
      }
    </ul>

    <div class="hero-actions">
      <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
      </a>
      <a class="btn btn-secondary hero-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
      </a>
    </div>

    {data.ctaNote && <p class="cta-note">{data.ctaNote}</p>}
  </div>

  <HeroProductMockup data={data.preview} variant={data.preview.variant ?? "full"} />
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.02fr);
    gap: clamp(1rem, 2.8vw, 2.5rem);
    align-items: stretch;
    padding-top: clamp(1rem, 1.8vw, 2rem);
    padding-bottom: clamp(1.1rem, 2vw, 2.4rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    right: -14%;
    top: -42%;
    width: clamp(460px, 74vw, 980px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.86);
    filter: blur(calc(var(--shape-blur) * 1.8));
    pointer-events: none;
    z-index: 0;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    background:
      radial-gradient(
        90% 120% at 100% 120%,
        color-mix(in srgb, var(--accent-soft) 62%, transparent),
        transparent 58%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-elevated) 92%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.55rem, 3.2vw, 3.1rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.9rem 0 0;
    max-width: 14ch;
    font-size: clamp(2.35rem, 4.6vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.025em;
    white-space: pre-line;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1rem 0 0;
    max-width: 60ch;
    color: var(--text-muted);
    font-size: clamp(1rem, 0.36vw + 0.94rem, 1.15rem);
    line-height: 1.58;
    text-wrap: pretty;
  }

  .proof-bar {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .proof-bar li {
    display: inline-flex;
    align-items: center;
    min-height: 2.3rem;
    padding: 0.46rem 0.8rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
    color: var(--text);
    font-size: 0.7rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.2;
  }

  .hero-actions {
    margin-top: 1.08rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .hero-secondary {
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
  }

  .cta-note {
    margin: 0.72rem 0 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 0.8rem;
    }

    .hero-copy {
      text-align: center;
    }

    h1 {
      margin-inline: auto;
      max-width: 12ch;
    }

    .subtitle {
      margin-inline: auto;
    }

    .proof-bar {
      justify-content: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .cta-note {
      text-align: center;
    }
  }
</style>
