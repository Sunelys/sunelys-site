---
interface HeroPreviewRow {
  name: string;
  status: string;
  tone: "ok" | "warn" | "neutral";
}

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  proofLine: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  preview: {
    label: string;
    title: string;
    rows: HeroPreviewRow[];
    footer: string;
  };
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero">
  <div class="hero-copy reveal">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.subtitle}</p>
    <p class="proof-pill">{data.proofLine}</p>

    <div class="hero-actions">
      <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
      </a>
      <a class="btn btn-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
      </a>
    </div>
  </div>

  <aside class="product-preview reveal">
    <p class="preview-kicker">{data.preview.label}</p>
    <h2>{data.preview.title}</h2>

    <div class="preview-frame" aria-label="Aperçu de pilotage Sunelys">
      {
        data.preview.rows.map((row) => (
          <article class="preview-row">
            <div>
              <p class="row-name">{row.name}</p>
              <p class={`row-status ${row.tone}`}>{row.status}</p>
            </div>
            <span class={`status-dot ${row.tone}`} aria-hidden="true"></span>
          </article>
        ))
      }
    </div>

    <p class="preview-footer">{data.preview.footer}</p>
  </aside>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: stretch;
    margin-top: clamp(1.2rem, 2vw, 1.9rem);
  }

  .hero-copy,
  .product-preview {
    position: relative;
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-hairline);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.2rem, 2.5vw, 2rem);
    overflow: hidden;
  }

  .hero-copy::before {
    content: "";
    position: absolute;
    inset: auto -20% -32% auto;
    width: clamp(230px, 42vw, 460px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: var(--shape-opacity);
    filter: blur(var(--shape-blur));
    pointer-events: none;
  }

  .kicker,
  .preview-kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h1 {
    margin: 0.8rem 0 0;
    max-width: 14ch;
    font-size: var(--step-5);
    line-height: 0.97;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1rem 0 0;
    max-width: 46ch;
    color: var(--color-muted);
    font-size: var(--step-0);
    line-height: 1.55;
  }

  .proof-pill {
    margin: 1rem 0 0;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-cream) 86%, white);
    padding: 0.42rem 0.8rem;
    color: var(--color-text-strong);
    font-size: var(--step--1);
    font-weight: 600;
    line-height: 1.2;
  }

  .hero-actions {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .product-preview h2 {
    margin: 0.7rem 0 0;
    font-size: var(--step-2);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .preview-frame {
    margin-top: 1rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 0.75rem;
    display: grid;
    gap: 0.56rem;
  }

  .preview-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    background: color-mix(in srgb, var(--color-surface) 92%, white);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    padding: 0.62rem 0.7rem;
  }

  .row-name {
    margin: 0;
    color: var(--color-text-strong);
    font-size: var(--step--1);
    font-weight: 600;
  }

  .row-status {
    margin: 0.18rem 0 0;
    color: var(--color-muted);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .row-status.ok {
    color: #2d5f43;
  }

  .row-status.warn {
    color: #7d6430;
  }

  .status-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: #8f8f8f;
    flex-shrink: 0;
  }

  .status-dot.ok {
    background: #2d5f43;
  }

  .status-dot.warn {
    background: #a88331;
  }

  .status-dot.neutral {
    background: #797979;
  }

  .preview-footer {
    margin: 0.75rem 0 0;
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 20ch;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: var(--step-4);
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
