---

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  expertLine?: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  leadForm?: {
    action: string;
    successUrl: string;
    submitLabel: string;
    note: string;
  };
  proofs: string[];
  portalDemo?: { label: string; href: string; track: string };
  ctaNote?: string;
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero section-shell" data-sticky-guard="hero">
  <div class:list={["hero-copy reveal", data.leadForm && "hero-copy-with-form"]}>
    <div class="hero-narrative">
      <p class="kicker">{data.kicker}</p>
      <h1>{data.title}</h1>
      <p class="subtitle">{data.subtitle}</p>
      {data.expertLine && <p class="expert-line">{data.expertLine}</p>}

      <div class="portal-proof" aria-label="Réassurance immédiate">
        <ul class="proof-bar">
          {
            data.proofs.map((proof) => (
              <li>{proof}</li>
            ))
          }
        </ul>
      </div>
    </div>

    {
      data.leadForm ? (
        <div class="hero-intake-card">
          <div class="hero-intake-head">
            <p class="hero-intake-kicker">Diagnostic sous 24h</p>
            <p class="hero-intake-copy">
              Décrivez votre volume et vos blocages. On vous indique le premier périmètre à reprendre, sans jargon
              ni friction inutile.
            </p>
          </div>

          <form
            id="hero-lead-form"
            class="hero-lead-form"
            action={data.leadForm.action}
            method="POST"
            data-lead-form
            data-conversion-type="form_contact"
          >
            <input type="hidden" name="_subject" value="Nouveau diagnostic gratuit - Hero Sunelys" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value={data.leadForm.successUrl} />
            <input type="hidden" name="source_page" value="homepage_hero" />
            <input type="hidden" name="conversion_type" value="form_contact" />
            <input type="hidden" name="lead_stage" value="homepage_hero_form_submitted" />
            <input type="hidden" name="service_interest" value="Pilotage administratif photovoltaïque" />
            <input type="hidden" name="lead_source_detail" value="homepage_hero_form" />
            <input type="hidden" name="qualification_hint" value="prenom, email professionnel, téléphone, volume mensuel et étape bloquée" />
            <input type="hidden" name="lead_status" value="Nouveau lead" />
            <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic gratuit" />
            <input type="hidden" name="lead_owner" value="Sunelys commercial" />
            <input type="hidden" name="follow_up_sla" value="24h" />
            <input type="hidden" name="landing_page" data-hero-attribution="landing_page" />
            <input type="hidden" name="first_referrer" data-hero-attribution="first_referrer" />
            <input type="hidden" name="utm_source" data-hero-attribution="utm_source" />
            <input type="hidden" name="utm_medium" data-hero-attribution="utm_medium" />
            <input type="hidden" name="utm_campaign" data-hero-attribution="utm_campaign" />
            <input type="hidden" name="utm_term" data-hero-attribution="utm_term" />
            <input type="hidden" name="utm_content" data-hero-attribution="utm_content" />
            <input type="hidden" name="gclid" data-hero-attribution="gclid" />
            <input type="hidden" name="fbclid" data-hero-attribution="fbclid" />
            <input type="hidden" name="msclkid" data-hero-attribution="msclkid" />

            <div class="hero-form-fields">
              <label>
                <span>Prénom</span>
                <input type="text" name="first_name" autocomplete="given-name" required />
              </label>
              <label>
                <span>Email professionnel</span>
                <input type="email" name="email" autocomplete="email" inputmode="email" required />
              </label>
              <label>
                <span>Téléphone pour rappel</span>
                <input type="tel" name="phone" autocomplete="tel" inputmode="tel" required />
              </label>
              <label>
                <span>Volume mensuel</span>
                <select name="volume" required>
                  <option value="">Sélectionner</option>
                  <option value="1-10 dossiers">1-10 dossiers</option>
                  <option value="10-30 dossiers">10-30 dossiers</option>
                  <option value="+30 dossiers">+30 dossiers</option>
                </select>
              </label>
              <label>
                <span>Étape bloquée</span>
                <select name="blocked_stage" required>
                  <option value="">Sélectionner</option>
                  <option value="Avant dépôt">Avant dépôt</option>
                  <option value="Complément mairie">Complément mairie</option>
                  <option value="Consuel à préparer">Consuel à préparer</option>
                  <option value="Raccordement en attente">Raccordement en attente</option>
                  <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
                  <option value="Prime à suivre">Prime à suivre</option>
                  <option value="Mise en service bloquée">Mise en service bloquée</option>
                  <option value="Pilotage global">Pilotage global</option>
                  <option value="Je ne sais pas encore">Je ne sais pas encore</option>
                </select>
              </label>
            </div>

            <div class="hero-form-actions">
              <button class="btn btn-primary btn-accent" type="submit" data-track="cta_hero_lead_submit">
                {data.leadForm.submitLabel}
              </button>
              <a
                class="btn btn-secondary hero-secondary"
                href={data.secondaryCta.href}
                data-track={data.secondaryCta.track}
                target="_blank"
                rel="noreferrer"
              >
                {data.secondaryCta.label}
              </a>
            </div>

            <p class="hero-form-note">{data.leadForm.note}</p>
          </form>
        </div>
      ) : (
        <div class="hero-actions">
          <a class="btn btn-primary btn-accent" href={data.primaryCta.href} data-track={data.primaryCta.track}>
            {data.primaryCta.label}
          </a>
          <a class="btn btn-secondary hero-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
            {data.secondaryCta.label}
          </a>
        </div>
      )
    }

    {data.ctaNote && <p class="cta-note">{data.ctaNote}</p>}
  </div>

</section>

<script>
  const heroLeadForm = document.querySelector("#hero-lead-form");
  if (heroLeadForm instanceof HTMLFormElement) {
    const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
    heroLeadForm.querySelectorAll("[data-hero-attribution]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.heroAttribution || "";
      field.value = attribution[key] || "";
    });

    heroLeadForm.addEventListener("submit", () => {
      const formData = new FormData(heroLeadForm);
      window.trackEvent?.("lead_hero_form_submit", {
        category: "form",
        label: "Recevoir un diagnostic gratuit",
        volume: String(formData.get("volume") || ""),
        blocked_stage: String(formData.get("blocked_stage") || ""),
        source: "homepage_hero",
        conversion_type: "form_contact",
        lead_stage: "homepage_hero_form_submitted",
        service_interest: "Pilotage administratif photovoltaïque",
      });
    });
  }
</script>

<style>
  .hero {
    position: relative;
    max-width: 74rem;
    padding-top: clamp(1rem, 1.8vw, 2rem);
    padding-bottom: clamp(1.1rem, 2vw, 2.4rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    right: -14%;
    top: -42%;
    width: clamp(460px, 74vw, 980px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.86);
    filter: blur(calc(var(--shape-blur) * 1.8));
    pointer-events: none;
    z-index: 0;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(1rem, 2vw, 1.35rem);
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    background:
      radial-gradient(
        80% 115% at 100% 120%,
        color-mix(in srgb, var(--accent-soft) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-elevated) 92%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.45rem, 3vw, 2.7rem);
  }

  .hero-copy-with-form {
    grid-template-columns: minmax(0, 1fr) minmax(330px, 0.78fr);
    align-items: start;
  }

  .hero-copy::after {
    content: "";
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.46);
    border-radius: calc(var(--radius-xl) - 10px);
    pointer-events: none;
  }

  .hero-narrative {
    display: grid;
    align-content: start;
    gap: 0;
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.9rem 0 0;
    max-width: 12.8ch;
    font-size: clamp(2.35rem, 4.2vw, 4.65rem);
    line-height: 0.92;
    letter-spacing: 0;
    white-space: pre-line;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1rem 0 0;
    max-width: 58ch;
    color: var(--text-muted);
    font-size: clamp(1rem, 0.36vw + 0.94rem, 1.15rem);
    line-height: 1.58;
    text-wrap: pretty;
  }

  .expert-line {
    margin: 0.9rem 0 0;
    max-width: 52ch;
    border-left: 3px solid var(--accent-strong);
    padding: 0.1rem 0 0.1rem 0.82rem;
    color: var(--text);
    font-size: clamp(0.98rem, 0.28vw + 0.92rem, 1.08rem);
    font-weight: 650;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .portal-proof {
    margin: 1rem 0 0;
    display: grid;
    gap: 0.42rem;
  }

  .proof-bar {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .proof-bar li {
    display: inline-flex;
    align-items: center;
    min-height: 2.18rem;
    padding: 0.42rem 0.74rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--line) 78%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 82%, white);
    color: var(--text);
    font-size: 0.9rem;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 650;
    line-height: 1.4;
    box-shadow: 0 12px 28px rgba(20, 16, 10, 0.06);
  }

  .hero-actions {
    margin-top: 1.08rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .hero-intake-card {
    margin-top: 1.16rem;
    border: 1px solid color-mix(in srgb, var(--line) 74%, var(--accent));
    border-radius: 18px;
    background:
      radial-gradient(120% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 58%),
      rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 44px rgba(20, 16, 10, 0.08);
    padding: clamp(0.95rem, 1.8vw, 1.18rem);
    backdrop-filter: blur(12px);
  }

  .hero-copy-with-form .hero-intake-card {
    margin-top: 0;
  }

  .hero-intake-head {
    display: grid;
    gap: 0.28rem;
  }

  .hero-intake-kicker {
    margin: 0;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-intake-copy {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.52;
  }

  .hero-lead-form {
    margin-top: 0.82rem;
    display: grid;
    gap: 0.72rem;
  }

  .hero-form-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.62rem;
  }

  .hero-lead-form label {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-lead-form input,
  .hero-lead-form select {
    width: 100%;
    min-height: 2.85rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, var(--accent));
    border-radius: 11px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    color: var(--text);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.72rem 0.82rem;
    box-shadow: 0 8px 24px rgba(20, 16, 10, 0.04);
    outline: none;
  }

  .hero-lead-form input:focus-visible,
  .hero-lead-form select:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 82%, var(--text));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-soft) 72%, transparent);
  }

  .hero-form-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
    align-items: center;
  }

  .hero-form-actions .btn {
    min-height: 2.9rem;
  }

  .hero-form-actions button {
    cursor: pointer;
  }

  .hero-form-note {
    margin: -0.1rem 0 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .hero-secondary {
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
  }

  .cta-note {
    grid-column: 1 / -1;
    margin: 0.72rem 0 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 0.8rem;
    }

    .hero-copy {
      text-align: center;
    }

    .hero-copy-with-form {
      grid-template-columns: 1fr;
    }

    h1 {
      margin-inline: auto;
      max-width: 12ch;
    }

    .subtitle {
      margin-inline: auto;
    }

    .expert-line {
      margin-inline: auto;
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
      padding: 0.72rem 0;
      max-width: 28rem;
    }

    .portal-proof,
    .proof-bar {
      justify-content: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .hero-form-fields {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .hero-form-actions {
      justify-content: center;
    }

    .hero-form-actions .btn {
      width: 100%;
    }

    .cta-note {
      text-align: center;
    }
  }
</style>
