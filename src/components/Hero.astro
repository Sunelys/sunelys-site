---
import FormPrivacyNote from "./FormPrivacyNote.astro";

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  expertLine?: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  leadForm?: {
    action: string;
    successUrl: string;
    submitLabel: string;
    note: string;
  };
  proofs: string[];
  operationsSnapshot?: {
    eyebrow: string;
    title: string;
    src: string;
    avifSrcset?: string;
    alt: string;
    items: Array<{ label: string; status: string }>;
  };
  ctaNote?: string;
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
const secondaryIsExternal = /^https?:\/\//.test(data.secondaryCta.href);
---

<section class="hero section-shell" data-sticky-guard="hero">
  <div class:list={["hero-stage reveal", data.leadForm && "hero-stage-with-form"]}>
    <div class="hero-narrative">
      <p class="hero-kicker">
        <span aria-hidden="true"></span>
        {data.kicker}
      </p>

      <h1>{data.title}</h1>
      <p class="hero-subtitle">{data.subtitle}</p>

      {data.expertLine && (
        <p class="expert-line">
          <span aria-hidden="true">✓</span>
          {data.expertLine}
        </p>
      )}

      <ul class="proof-bar" aria-label="Preuves Sunelys">
        {
          data.proofs.map((proof) => (
            <li>
              <span aria-hidden="true"></span>
              {proof}
            </li>
          ))
        }
      </ul>

      {
        data.operationsSnapshot && (
          <div class="operations-snapshot" data-track-view="homepage_operations_snapshot_view">
            <picture>
              {data.operationsSnapshot.avifSrcset && (
                <source
                  type="image/avif"
                  srcset={data.operationsSnapshot.avifSrcset}
                  sizes="(max-width: 820px) 100vw, 34rem"
                />
              )}
              <img
                src={data.operationsSnapshot.src}
                alt={data.operationsSnapshot.alt}
                width="1600"
                height="900"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </picture>
            <div class="snapshot-copy">
              <span>{data.operationsSnapshot.eyebrow}</span>
              <strong>{data.operationsSnapshot.title}</strong>
              <ul aria-label="Exemples de statuts visibles">
                {data.operationsSnapshot.items.map((item) => (
                  <li>
                    <small>{item.label}</small>
                    <em>{item.status}</em>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        )
      }
    </div>

    {
      data.leadForm ? (
        <div class="hero-conversion">
          <div
            class="hero-intake-card"
            data-track-view="homepage_hero_form_view"
            data-track-label="homepage_hero"
          >
            <div class="hero-intake-head">
              <div>
                <p class="hero-intake-kicker">Choisissez un premier périmètre</p>
                <span class="no-commitment">Sans engagement</span>
              </div>
              <p class="hero-intake-copy">
                Quel dossier voulez-vous sortir de votre équipe ? Sunelys vous répond avec le premier cadre utile.
              </p>
            </div>

            <form
              id="hero-lead-form"
              class="hero-lead-form"
              action={data.leadForm.action}
              method="POST"
              data-lead-form
              data-conversion-type="form_contact"
            >
              <input type="hidden" name="_subject" value="Nouveau diagnostic gratuit - Hero Sunelys" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value={data.leadForm.successUrl} />
              <input type="hidden" name="source_page" value="homepage_hero" />
              <input type="hidden" name="conversion_type" value="form_contact" />
              <input type="hidden" name="lead_stage" value="homepage_hero_form_submitted" />
              <input id="hero-service-interest" type="hidden" name="service_interest" />
              <input id="hero-blocked-stage" type="hidden" name="blocked_stage" />
              <input type="hidden" name="lead_source_detail" value="homepage_hero_form" />
              <input type="hidden" name="qualification_hint" value="email professionnel, offre choisie et volume mensuel optionnel" />
              <input type="hidden" name="lead_status" value="Nouveau lead" />
              <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic gratuit" />
              <input type="hidden" name="lead_owner" value="Sunelys commercial" />
              <input type="hidden" name="follow_up_sla" value="24h" />
              <input type="hidden" name="landing_page" data-hero-attribution="landing_page" />
              <input type="hidden" name="first_referrer" data-hero-attribution="first_referrer" />
              <input type="hidden" name="utm_source" data-hero-attribution="utm_source" />
              <input type="hidden" name="utm_medium" data-hero-attribution="utm_medium" />
              <input type="hidden" name="utm_campaign" data-hero-attribution="utm_campaign" />
              <input type="hidden" name="utm_term" data-hero-attribution="utm_term" />
              <input type="hidden" name="utm_content" data-hero-attribution="utm_content" />
              <input type="hidden" name="gclid" data-hero-attribution="gclid" />
              <input type="hidden" name="fbclid" data-hero-attribution="fbclid" />
              <input type="hidden" name="msclkid" data-hero-attribution="msclkid" />

              <fieldset
                class="hero-offer-options"
                data-track-view="homepage_offer_view"
                data-track-label="homepage_hero_offers"
              >
                <legend>Que souhaitez-vous déléguer ?</legend>
                <label>
                  <input
                    type="radio"
                    name="need"
                    value="Declaration prealable"
                    data-service-interest="Déclaration préalable panneaux solaires"
                    data-blocked-stage="Avant dépôt"
                    data-offer-price="119"
                    required
                  />
                  <span>
                    <small>Sécuriser le départ</small>
                    <strong>DP complète</strong>
                  </span>
                  <em>119 € <small>HT / dossier</small></em>
                </label>
                <label>
                  <input
                    type="radio"
                    name="need"
                    value="Raccordement Enedis + Consuel"
                    data-service-interest="Raccordement Enedis + Consuel"
                    data-blocked-stage="Raccordement en attente"
                    data-offer-price="89"
                  />
                  <span>
                    <small>Finaliser le réseau</small>
                    <strong>Raccordement + Consuel</strong>
                  </span>
                  <em>89 € <small>HT / dossier</small></em>
                </label>
                <label>
                  <input
                    type="radio"
                    name="need"
                    value="Pilotage complet"
                    data-service-interest="Pilotage complet DP, raccordement et Consuel"
                    data-blocked-stage="Pilotage global"
                    data-offer-price="199"
                  />
                  <span>
                    <small>Tout déléguer</small>
                    <strong>Chaîne complète</strong>
                  </span>
                  <em>199 € <small>HT / dossier</small></em>
                </label>
                <label>
                  <input
                    type="radio"
                    name="need"
                    value="Je ne sais pas encore"
                    data-service-interest="Diagnostic administratif photovoltaïque"
                    data-blocked-stage="Je ne sais pas encore"
                    data-offer-price="0"
                  />
                  <span>
                    <small>Être orienté</small>
                    <strong>Diagnostic gratuit</strong>
                  </span>
                  <em>24h <small>ouvrées</small></em>
                </label>
              </fieldset>

              <div class="hero-form-fields">
                <label class="email-field">
                  <span>Email professionnel</span>
                  <input type="email" name="email" autocomplete="email" inputmode="email" placeholder="vous@entreprise.fr" required />
                </label>

                <label>
                  <span>Volume mensuel <em>optionnel</em></span>
                  <select name="volume">
                    <option value="">À préciser plus tard</option>
                    <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
                    <option value="10-30 dossiers">10-30 dossiers</option>
                    <option value="+30 dossiers">+30 dossiers</option>
                  </select>
                </label>
              </div>

              <button class="btn btn-accent hero-submit" type="submit" data-track="cta_hero_lead_submit">
                {data.leadForm.submitLabel}
                <span aria-hidden="true">→</span>
              </button>

              <div class="hero-form-footer">
                <p>{data.leadForm.note}</p>
                <a
                  href={data.secondaryCta.href}
                  data-track={data.secondaryCta.track}
                  target={secondaryIsExternal ? "_blank" : undefined}
                  rel={secondaryIsExternal ? "noreferrer" : undefined}
                >
                  {data.secondaryCta.label}
                </a>
              </div>
              <div class="hero-human-proof" aria-label="Réponse humaine Sunelys">
                <span>Lu par Myriam Zaoui</span>
                <a href="mailto:contact@sunelys.fr" data-track="cta_hero_email_reassurance">
                  contact@sunelys.fr
                </a>
              </div>
              <FormPrivacyNote />
            </form>
          </div>
        </div>
      ) : (
        <div class="hero-actions">
          <a class="btn btn-accent" href={data.primaryCta.href} data-track={data.primaryCta.track}>
            {data.primaryCta.label}
          </a>
          <a
            class="btn btn-secondary"
            href={data.secondaryCta.href}
            data-track={data.secondaryCta.track}
            target={secondaryIsExternal ? "_blank" : undefined}
            rel={secondaryIsExternal ? "noreferrer" : undefined}
          >
            {data.secondaryCta.label}
          </a>
        </div>
      )
    }

    {data.ctaNote && <p class="cta-note">{data.ctaNote}</p>}
  </div>
</section>

<script>
  const heroLeadForm = document.querySelector("#hero-lead-form");
  if (heroLeadForm instanceof HTMLFormElement) {
    const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
    heroLeadForm.querySelectorAll("[data-hero-attribution]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.heroAttribution || "";
      field.value = attribution[key] || "";
    });

    const serviceInterestField = heroLeadForm.querySelector("#hero-service-interest");
    const blockedStageField = heroLeadForm.querySelector("#hero-blocked-stage");

    const syncHeroSelection = (field) => {
      if (!(field instanceof HTMLInputElement) || !field.checked) return;
        if (serviceInterestField instanceof HTMLInputElement) {
          serviceInterestField.value = field.dataset.serviceInterest || field.value;
        }
        if (blockedStageField instanceof HTMLInputElement) {
          blockedStageField.value = field.dataset.blockedStage || "";
        }
    };

    heroLeadForm.querySelectorAll("input[name='need']").forEach((field) => {
      field.addEventListener("change", () => {
        syncHeroSelection(field);
        if (!(field instanceof HTMLInputElement) || !field.checked) return;

        window.trackEvent?.("homepage_offer_selected", {
          category: "form",
          label: field.value,
          need: field.value,
          blocked_stage: field.dataset.blockedStage || "",
          service_interest: field.dataset.serviceInterest || field.value,
          value: Number(field.dataset.offerPrice || 0),
          currency: "EUR",
          source: "homepage_hero",
          form_id: "hero-lead-form",
          form_location: "homepage_hero_form",
        });
      });
    });

    heroLeadForm.addEventListener("submit", () => {
      syncHeroSelection(heroLeadForm.querySelector("input[name='need']:checked"));
      const formData = new FormData(heroLeadForm);
      window.trackEvent?.("lead_hero_form_submit", {
        category: "form",
        label: "Recevoir un diagnostic sous 24h",
        volume: String(formData.get("volume") || ""),
        need: String(formData.get("need") || ""),
        blocked_stage: String(formData.get("blocked_stage") || ""),
        source: "homepage_hero",
        conversion_type: "form_contact",
        lead_stage: "homepage_hero_form_submitted",
        service_interest: String(formData.get("service_interest") || ""),
        form_id: "hero-lead-form",
        form_location: "homepage_hero_form",
      });
    });
  }
</script>

<style>
  .hero {
    margin: 0;
  }

  .hero-stage {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(350px, 0.92fr);
    gap: clamp(2rem, 4.6vw, 4.8rem);
    align-items: center;
    min-height: 41rem;
    padding: clamp(2rem, 4.4vw, 4.5rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 26px;
    background:
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.27), transparent 62%),
      radial-gradient(65% 82% at 0% 100%, rgba(212, 130, 42, 0.22), transparent 65%),
      var(--ink);
    box-shadow: 0 30px 80px rgba(14, 23, 38, 0.18);
  }

  .hero-stage::before {
    content: "";
    position: absolute;
    z-index: -1;
    width: 20rem;
    aspect-ratio: 1;
    right: -7rem;
    bottom: -10rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    box-shadow:
      0 0 0 3rem rgba(255, 255, 255, 0.025),
      0 0 0 7rem rgba(255, 255, 255, 0.018);
  }

  .hero-narrative {
    min-width: 0;
    color: #ffffff;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-kicker span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 5px rgba(212, 130, 42, 0.16);
  }

  h1 {
    max-width: 11.4ch;
    margin: 1.25rem 0 0;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: clamp(3rem, 5.15vw, 5.3rem);
    font-weight: 720;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 56ch;
    margin: 1.35rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1rem, 0.36vw + 0.96rem, 1.16rem);
    line-height: 1.62;
    text-wrap: pretty;
  }

  .expert-line {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    max-width: 56ch;
    margin: 1.15rem 0 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.96rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .expert-line span {
    flex: 0 0 auto;
    display: inline-grid;
    place-items: center;
    width: 1.3rem;
    height: 1.3rem;
    margin-top: 0.08rem;
    border-radius: 50%;
    background: var(--success);
    color: #ffffff;
    font-size: 0.72rem;
  }

  .proof-bar {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    margin: 1.6rem 0 0;
    padding: 0;
    list-style: none;
  }

  .proof-bar li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    min-height: 3.7rem;
    padding: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.055);
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.78rem;
    font-weight: 620;
    line-height: 1.42;
  }

  .proof-bar li span {
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.32rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .operations-snapshot {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
    gap: 0.78rem;
    align-items: stretch;
    max-width: 46rem;
    margin-top: 1rem;
    padding: 0.72rem;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(14px);
  }

  .operations-snapshot picture {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 9.8rem;
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.08);
  }

  .operations-snapshot picture::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 23, 38, 0.05), rgba(14, 23, 38, 0.28));
    pointer-events: none;
  }

  .operations-snapshot img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top;
    filter: saturate(0.95) contrast(1.02);
  }

  .snapshot-copy {
    display: grid;
    align-content: center;
    gap: 0.58rem;
    min-width: 0;
    padding: 0.2rem 0.2rem 0.2rem 0;
  }

  .snapshot-copy > span {
    color: var(--accent);
    font-size: 0.58rem;
    font-weight: 820;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .snapshot-copy > strong {
    color: #ffffff;
    font-size: clamp(0.98rem, 1.4vw, 1.22rem);
    line-height: 1.25;
    text-wrap: balance;
  }

  .snapshot-copy ul {
    display: grid;
    gap: 0.38rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .snapshot-copy li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.72rem;
    min-height: 2rem;
    padding: 0.38rem 0.48rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.055);
  }

  .snapshot-copy small {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.64rem;
    font-weight: 720;
  }

  .snapshot-copy em {
    color: #ffffff;
    font-size: 0.64rem;
    font-style: normal;
    font-weight: 760;
    white-space: nowrap;
  }

  .hero-conversion {
    position: relative;
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .hero-intake-card {
    border-radius: 18px;
    box-shadow: 0 24px 60px rgba(4, 10, 20, 0.2);
  }

  .hero-intake-card {
    padding: clamp(1.05rem, 2vw, 1.35rem);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: #ffffff;
    color: var(--text);
  }

  .hero-intake-head {
    display: grid;
    gap: 0.45rem;
  }

  .hero-intake-head > div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-intake-kicker {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .no-commitment {
    padding: 0.28rem 0.52rem;
    border-radius: 999px;
    background: var(--success-soft);
    color: #10745a;
    font-size: 0.66rem;
    font-weight: 700;
  }

  .hero-intake-copy {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .hero-lead-form {
    display: grid;
    gap: 0.72rem;
    margin-top: 0.9rem;
  }

  .hero-offer-options {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .hero-offer-options legend {
    margin-bottom: 0.05rem;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .hero-lead-form .hero-offer-options > label {
    position: relative;
    display: grid;
    grid-template-columns: 1.1rem minmax(0, 1fr) auto;
    gap: 0.65rem;
    align-items: center;
    min-height: 3.55rem;
    padding: 0.6rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--bg-soft);
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, box-shadow 160ms ease;
  }

  .hero-offer-options > label:hover,
  .hero-offer-options > label:has(input:checked) {
    border-color: var(--system);
    background: var(--system-soft);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--system) 12%, transparent);
  }

  .hero-lead-form .hero-offer-options input[type="radio"] {
    width: 1rem;
    height: 1rem;
    margin: 0;
    accent-color: var(--system);
  }

  .hero-offer-options label > span {
    display: grid;
    gap: 0.08rem;
    min-width: 0;
  }

  .hero-offer-options label > span small {
    color: var(--text-muted);
    font-size: 0.58rem;
    font-weight: 650;
    text-transform: uppercase;
  }

  .hero-offer-options label > span strong {
    color: var(--text);
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .hero-offer-options label > em {
    color: var(--accent-deep);
    font-size: 0.9rem;
    font-style: normal;
    font-weight: 800;
    white-space: nowrap;
  }

  .hero-offer-options label > em small {
    font-size: 0.54rem;
    font-weight: 700;
  }

  .hero-form-fields {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
    gap: 0.65rem;
  }

  .hero-form-fields .email-field {
    grid-column: auto;
  }

  .hero-lead-form label {
    display: grid;
    gap: 0.34rem;
    min-width: 0;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .hero-lead-form label > span em {
    color: var(--text-muted);
    font-size: 0.62rem;
    font-style: normal;
    font-weight: 560;
  }

  .hero-lead-form input:not([type="radio"]),
  .hero-lead-form select {
    width: 100%;
    min-height: 2.85rem;
    padding: 0.68rem 0.76rem;
    border: 1px solid var(--line);
    border-radius: 11px;
    outline: none;
    background: var(--bg-soft);
    color: var(--text);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 520;
    text-transform: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
  }

  .hero-lead-form input:not([type="radio"])::placeholder {
    color: color-mix(in srgb, var(--text-muted) 72%, white);
  }

  .hero-lead-form input:not([type="radio"]):focus-visible,
  .hero-lead-form select:focus-visible {
    border-color: var(--system);
    background: #ffffff;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--system) 16%, transparent);
  }

  .hero-submit {
    width: 100%;
    min-height: 3.05rem;
    justify-content: space-between;
    padding-inline: 1rem;
