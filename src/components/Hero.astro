---
interface PreviewItem {
  name: string;
  status: string;
}

interface PreviewColumn {
  heading: string;
  items: PreviewItem[];
}

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  proofs: string[];
  preview: {
    label: string;
    title: string;
    columns: PreviewColumn[];
    footer: string;
  };
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero section-shell">
  <div class="hero-copy reveal">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.subtitle}</p>

    <p class="proof-line">{data.proofs.join(" • ")}</p>

    <div class="hero-actions">
      <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
      </a>
      <a class="btn btn-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
      </a>
    </div>

    <ul class="proofs" aria-label="Preuves clés">
      {
        data.proofs.map((proof) => (
          <li>{proof}</li>
        ))
      }
    </ul>
  </div>

  <aside class="hero-preview reveal" aria-label="Aperçu produit">
    <div class="preview-head">
      <p class="preview-kicker">{data.preview.label}</p>
      <span class="preview-status">Live workflow</span>
    </div>
    <h2>{data.preview.title}</h2>

    <div class="preview-grid">
      {
        data.preview.columns.map((column) => (
          <article class="preview-column">
            <h3>{column.heading}</h3>
            <ul>
              {
                column.items.map((item) => (
                  <li>
                    <span>{item.name}</span>
                    <small>{item.status}</small>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>

    <div class="preview-timeline" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>

    <p class="preview-footer">{data.preview.footer}</p>
  </aside>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 1fr);
    gap: clamp(1rem, 2.6vw, 2.2rem);
    align-items: stretch;
    margin-top: 0.4rem;
  }

  .hero-copy,
  .hero-preview {
    position: relative;
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .hero-copy {
    padding: clamp(1.45rem, 3.3vw, 3rem);
    background:
      radial-gradient(90% 120% at 102% 118%, color-mix(in srgb, var(--accent-soft) 72%, transparent), transparent 54%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 92%, white), var(--surface)),
      var(--surface);
  }

  .hero-copy::after {
    content: "";
    position: absolute;
    right: -20%;
    bottom: -50%;
    width: clamp(260px, 48vw, 620px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 1.05);
    filter: blur(calc(var(--shape-blur) * 1.5));
    pointer-events: none;
  }

  .kicker,
  .preview-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
  }

  h1 {
    margin: 0.92rem 0 0;
    max-width: 12ch;
    font-size: clamp(2.25rem, 4.7vw, 4.8rem);
    line-height: 0.89;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1.02rem 0 0;
    max-width: 52ch;
    font-size: clamp(1rem, 0.35vw + 0.93rem, 1.16rem);
    color: var(--text-muted);
    line-height: 1.56;
  }

  .proof-line {
    margin: 0.9rem 0 0;
    color: var(--text);
    font-size: 0.8rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1.4;
  }

  .hero-actions {
    margin-top: 1.05rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .proofs {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.48rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .proofs li {
    border: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent));
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
    min-height: 2.25rem;
    display: grid;
    place-items: center;
    padding: 0.35rem 0.6rem;
    text-align: center;
    color: var(--text);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1.2;
  }

  .hero-preview {
    padding: clamp(1.05rem, 2.4vw, 1.85rem);
    background:
      radial-gradient(120% 120% at 90% -10%, color-mix(in srgb, var(--accent-soft) 50%, transparent), transparent 52%),
      linear-gradient(150deg, color-mix(in srgb, var(--surface) 92%, white), var(--surface-elevated));
  }

  .preview-head {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    align-items: center;
  }

  .preview-status {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 66%, white);
    padding: 0.32rem 0.55rem;
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    font-weight: 700;
  }

  .hero-preview h2 {
    margin: 0.7rem 0 0;
    font-size: clamp(1.25rem, 2.05vw, 1.95rem);
    line-height: 1.06;
    max-width: 18ch;
  }

  .preview-grid {
    margin-top: 0.92rem;
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .preview-column {
    border: 1px solid color-mix(in srgb, var(--line) 85%, white);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 84%, white);
    padding: 0.58rem;
    box-shadow: 0 6px 18px rgba(20, 16, 10, 0.055);
  }

  .preview-column h3 {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .preview-column ul {
    margin: 0.52rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.34rem;
  }

  .preview-column li {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    padding: 0.4rem;
    display: grid;
    gap: 0.18rem;
  }

  .preview-column span {
    font-size: 0.73rem;
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
  }

  .preview-column small {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .preview-timeline {
    margin-top: 0.74rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .preview-timeline span {
    display: block;
    height: 0.3rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 72%, white);
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
  }

  .preview-footer {
    margin: 0.72rem 0 0;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.48;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 15ch;
    }
  }

  @media (max-width: 760px) {
    .proof-line {
      font-size: 0.72rem;
    }

    .proofs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .preview-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .proofs {
      grid-template-columns: 1fr;
    }
  }
</style>
