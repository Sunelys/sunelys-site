---
interface PreviewProject {
  name: string;
  progress: string;
  status: string;
}

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  proofs: string[];
  preview: {
    label: string;
    title: string;
    projects: PreviewProject[];
    timeline: string[];
    documents: string[];
    footer: string;
  };
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero section-shell">
  <div class="hero-copy reveal">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.subtitle}</p>

    <ul class="proof-bar" aria-label="Preuves clés Sunelys">
      {
        data.proofs.map((proof) => (
          <li>{proof}</li>
        ))
      }
    </ul>

    <div class="hero-actions">
      <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
      </a>
      <a class="btn btn-secondary hero-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
      </a>
    </div>
  </div>

  <aside class="hero-product reveal" aria-label="Aperçu du portail Sunelys">
    <div class="product-shell">
      <header class="product-head">
        <span class="product-label">{data.preview.label}</span>
        <span class="product-live">Live</span>
      </header>

      <h2>{data.preview.title}</h2>

      <div class="product-layout">
        <section class="panel panel-projects">
          <p class="panel-label">Liste dossiers</p>
          <ul>
            {
              data.preview.projects.map((project) => (
                <li>
                  <strong>{project.name}</strong>
                  <small>{project.progress}</small>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel panel-status">
          <p class="panel-label">Statuts</p>
          <ul>
            {
              data.preview.projects.map((project) => (
                <li>{project.status}</li>
              ))
            }
          </ul>
        </section>

        <section class="panel panel-timeline">
          <p class="panel-label">Timeline administrative</p>
          <ol>
            {
              data.preview.timeline.map((step) => (
                <li>{step}</li>
              ))
            }
          </ol>
        </section>

        <section class="panel panel-docs">
          <p class="panel-label">Documents attachés</p>
          <ul>
            {
              data.preview.documents.map((document) => (
                <li>{document}</li>
              ))
            }
          </ul>
        </section>
      </div>

      <p class="product-footer">{data.preview.footer}</p>
    </div>
  </aside>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.02fr);
    gap: clamp(1rem, 2.8vw, 2.5rem);
    align-items: stretch;
    padding-top: clamp(1rem, 1.8vw, 2rem);
    padding-bottom: clamp(1.1rem, 2vw, 2.4rem);
  }

  .hero::before {
    content: "";
    position: absolute;
    right: -14%;
    top: -42%;
    width: clamp(460px, 74vw, 980px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.86);
    filter: blur(calc(var(--shape-blur) * 1.8));
    pointer-events: none;
    z-index: 0;
  }

  .hero-copy,
  .hero-product {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    background:
      radial-gradient(90% 120% at 100% 120%, color-mix(in srgb, var(--accent-soft) 62%, transparent), transparent 58%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 92%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.55rem, 3.2vw, 3.1rem);
  }

  .kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0.9rem 0 0;
    max-width: 14ch;
    font-size: clamp(2.35rem, 4.6vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.025em;
    white-space: pre-line;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1rem 0 0;
    max-width: 60ch;
    color: var(--text-muted);
    font-size: clamp(1rem, 0.36vw + 0.94rem, 1.15rem);
    line-height: 1.58;
    text-wrap: pretty;
  }

  .proof-bar {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .proof-bar li {
    display: inline-flex;
    align-items: center;
    min-height: 2.3rem;
    padding: 0.46rem 0.8rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
    color: var(--text);
    font-size: 0.7rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.2;
  }

  .hero-actions {
    margin-top: 1.08rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem;
  }

  .hero-secondary {
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
  }

  .hero-product {
    border-radius: var(--radius-xl);
    border: 1px solid color-mix(in srgb, var(--line) 74%, var(--accent));
    background:
      radial-gradient(120% 100% at 92% -8%, color-mix(in srgb, var(--accent-soft) 55%, transparent), transparent 58%),
      linear-gradient(160deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1rem, 2.2vw, 1.45rem);
  }

  .product-shell {
    border: 1px solid color-mix(in srgb, var(--line) 86%, white);
    border-radius: calc(var(--radius-xl) - 8px);
    background: color-mix(in srgb, var(--surface-elevated) 95%, white);
    box-shadow: 0 18px 42px rgba(16, 12, 8, 0.12);
    padding: 0.9rem;
  }

  .product-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .product-label,
  .product-live {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    background: color-mix(in srgb, var(--surface) 90%, white);
    min-height: 1.9rem;
    padding: 0.34rem 0.58rem;
    font-size: 0.62rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text);
  }

  .product-live {
    background: color-mix(in srgb, var(--accent-soft) 66%, white);
  }

  .hero-product h2 {
    margin: 0.76rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1vw + 0.88rem, 1.4rem);
    line-height: 1.2;
    letter-spacing: 0.01em;
    font-weight: 650;
    max-width: 28ch;
  }

  .product-layout {
    margin-top: 0.8rem;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 0.5rem;
  }

  .panel {
    border: 1px solid color-mix(in srgb, var(--line) 86%, white);
    border-radius: calc(var(--radius-md) - 6px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
    padding: 0.58rem;
  }

  .panel-label {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .panel ul,
  .panel ol {
    margin: 0.48rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.34rem;
  }

  .panel-projects li {
    border: 1px solid var(--line);
    border-radius: calc(var(--radius-sm) - 2px);
    background: var(--surface);
    padding: 0.42rem;
    display: grid;
    gap: 0.14rem;
  }

  .panel-projects strong {
    font-size: 0.73rem;
    line-height: 1.2;
    color: var(--text);
    font-weight: 650;
  }

  .panel-projects small {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .panel-status ul {
    align-content: start;
  }

  .panel-status li {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 74%, white);
    background: color-mix(in srgb, var(--surface) 88%, white);
    padding: 0.34rem 0.55rem;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: var(--text);
  }

  .panel-status li:nth-child(1) {
    background: color-mix(in srgb, #d9f5e2 60%, white);
    border-color: color-mix(in srgb, #7ab38d 50%, var(--line));
  }

  .panel-status li:nth-child(2) {
    background: color-mix(in srgb, #fef3d7 70%, white);
    border-color: color-mix(in srgb, #d2b16c 45%, var(--line));
  }

  .panel-status li:nth-child(3) {
    background: color-mix(in srgb, #e8f1ff 74%, white);
    border-color: color-mix(in srgb, #7e9cc8 45%, var(--line));
  }

  .panel-timeline ol {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.22rem;
  }

  .panel-timeline li {
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    background: color-mix(in srgb, var(--accent-soft) 66%, white);
    min-height: 1.65rem;
    display: grid;
    place-items: center;
    padding: 0.2rem 0.3rem;
    text-align: center;
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.15;
  }

  .panel-docs ul li {
    border-bottom: 1px solid color-mix(in srgb, var(--line) 64%, white);
    padding: 0.24rem 0;
    font-size: 0.67rem;
    color: var(--text-muted);
  }

  .panel-docs ul li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .product-footer {
    margin: 0.64rem 0 0;
    color: var(--text-muted);
    font-size: 0.69rem;
    line-height: 1.5;
    letter-spacing: 0.04em;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding-top: 0.8rem;
    }

    .hero-copy {
      text-align: center;
    }

    h1 {
      margin-inline: auto;
      max-width: 12ch;
    }

    .subtitle {
      margin-inline: auto;
    }

    .proof-bar {
      justify-content: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .product-layout {
      grid-template-columns: 1fr;
    }

    .panel-timeline ol {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
