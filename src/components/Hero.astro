---
import FormPrivacyNote from "./FormPrivacyNote.astro";

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  expertLine?: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  leadForm?: {
    action: string;
    successUrl: string;
    submitLabel: string;
    note: string;
  };
  proofs: string[];
  portalDemo?: { label: string; href: string; track: string };
  ctaNote?: string;
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
const secondaryIsExternal = /^https?:\/\//.test(data.secondaryCta.href);
---

<section class="hero section-shell" data-sticky-guard="hero">
  <div class:list={["hero-stage reveal", data.leadForm && "hero-stage-with-form"]}>
    <div class="hero-narrative">
      <p class="hero-kicker">
        <span aria-hidden="true"></span>
        {data.kicker}
      </p>

      <h1>{data.title}</h1>
      <p class="hero-subtitle">{data.subtitle}</p>

      {data.expertLine && (
        <p class="expert-line">
          <span aria-hidden="true">✓</span>
          {data.expertLine}
        </p>
      )}

      <ul class="proof-bar" aria-label="Preuves Sunelys">
        {
          data.proofs.map((proof) => (
            <li>
              <span aria-hidden="true"></span>
              {proof}
            </li>
          ))
        }
      </ul>
    </div>

    {
      data.leadForm ? (
        <div class="hero-conversion">
          <div class="portal-snapshot" aria-label="Aperçu du portail client Sunelys">
            <div class="portal-snapshot-head">
              <div>
                <span class="live-dot" aria-hidden="true"></span>
                <strong>Portail client inclus</strong>
              </div>
              <span>Vue en temps réel</span>
            </div>

            <div class="portal-snapshot-body">
              <div class="portal-summary">
                <span>Dossiers pilotés</span>
                <strong>1 357</strong>
                <small>Traçabilité centralisée</small>
              </div>

              <div class="portal-progress" aria-hidden="true">
                <div>
                  <span>DP déposée</span>
                  <i class="progress-track"><i style="--progress: 88%"></i></i>
                  <em class="status status-success">Validée</em>
                </div>
                <div>
                  <span>Consuel</span>
                  <i class="progress-track"><i style="--progress: 62%"></i></i>
                  <em class="status status-system">En cours</em>
                </div>
                <div>
                  <span>Raccordement</span>
                  <i class="progress-track"><i style="--progress: 38%"></i></i>
                  <em class="status status-warning">À suivre</em>
                </div>
              </div>
            </div>
          </div>

          <div class="hero-intake-card">
            <div class="hero-intake-head">
              <div>
                <p class="hero-intake-kicker">Diagnostic sous 24h</p>
                <span class="no-commitment">Sans engagement</span>
              </div>
              <p class="hero-intake-copy">
                Indiquez votre volume et votre principal blocage. Nous vous répondons avec le premier périmètre à
                déléguer.
              </p>
            </div>

            <form
              id="hero-lead-form"
              class="hero-lead-form"
              action={data.leadForm.action}
              method="POST"
              data-lead-form
              data-conversion-type="form_contact"
            >
              <input type="hidden" name="_subject" value="Nouveau diagnostic gratuit - Hero Sunelys" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value={data.leadForm.successUrl} />
              <input type="hidden" name="source_page" value="homepage_hero" />
              <input type="hidden" name="conversion_type" value="form_contact" />
              <input type="hidden" name="lead_stage" value="homepage_hero_form_submitted" />
              <input type="hidden" name="service_interest" value="Pilotage administratif photovoltaïque" />
              <input type="hidden" name="lead_source_detail" value="homepage_hero_form" />
              <input type="hidden" name="qualification_hint" value="email professionnel, volume mensuel et étape bloquée" />
              <input type="hidden" name="lead_status" value="Nouveau lead" />
              <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic gratuit" />
              <input type="hidden" name="lead_owner" value="Sunelys commercial" />
              <input type="hidden" name="follow_up_sla" value="24h" />
              <input type="hidden" name="landing_page" data-hero-attribution="landing_page" />
              <input type="hidden" name="first_referrer" data-hero-attribution="first_referrer" />
              <input type="hidden" name="utm_source" data-hero-attribution="utm_source" />
              <input type="hidden" name="utm_medium" data-hero-attribution="utm_medium" />
              <input type="hidden" name="utm_campaign" data-hero-attribution="utm_campaign" />
              <input type="hidden" name="utm_term" data-hero-attribution="utm_term" />
              <input type="hidden" name="utm_content" data-hero-attribution="utm_content" />
              <input type="hidden" name="gclid" data-hero-attribution="gclid" />
              <input type="hidden" name="fbclid" data-hero-attribution="fbclid" />
              <input type="hidden" name="msclkid" data-hero-attribution="msclkid" />

              <div class="hero-form-fields">
                <label class="email-field">
                  <span>Email professionnel</span>
                  <input type="email" name="email" autocomplete="email" inputmode="email" placeholder="vous@entreprise.fr" required />
                </label>

                <label>
                  <span>Volume mensuel</span>
                  <select name="volume" required>
                    <option value="">Sélectionner</option>
                    <option value="1-10 dossiers">1-10 dossiers</option>
                    <option value="10-30 dossiers">10-30 dossiers</option>
                    <option value="+30 dossiers">+30 dossiers</option>
                  </select>
                </label>

                <label>
                  <span>Étape bloquée</span>
                  <select name="blocked_stage" required>
                    <option value="">Sélectionner</option>
                    <option value="Avant dépôt">Avant dépôt</option>
                    <option value="Complément mairie">Complément mairie</option>
                    <option value="Consuel à préparer">Consuel à préparer</option>
                    <option value="Raccordement en attente">Raccordement en attente</option>
                    <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
                    <option value="Prime à suivre">Prime à suivre</option>
                    <option value="Mise en service bloquée">Mise en service bloquée</option>
                    <option value="Pilotage global">Pilotage global</option>
                    <option value="Je ne sais pas encore">Je ne sais pas encore</option>
                  </select>
                </label>
              </div>

              <button class="btn btn-accent hero-submit" type="submit" data-track="cta_hero_lead_submit">
                {data.leadForm.submitLabel}
                <span aria-hidden="true">→</span>
              </button>

              <div class="hero-form-footer">
                <p>{data.leadForm.note}</p>
                <a
                  href={data.secondaryCta.href}
                  data-track={data.secondaryCta.track}
                  target={secondaryIsExternal ? "_blank" : undefined}
                  rel={secondaryIsExternal ? "noreferrer" : undefined}
                >
                  {data.secondaryCta.label}
                </a>
              </div>
              <FormPrivacyNote />
            </form>
          </div>
        </div>
      ) : (
        <div class="hero-actions">
          <a class="btn btn-accent" href={data.primaryCta.href} data-track={data.primaryCta.track}>
            {data.primaryCta.label}
          </a>
          <a
            class="btn btn-secondary"
            href={data.secondaryCta.href}
            data-track={data.secondaryCta.track}
            target={secondaryIsExternal ? "_blank" : undefined}
            rel={secondaryIsExternal ? "noreferrer" : undefined}
          >
            {data.secondaryCta.label}
          </a>
        </div>
      )
    }

    {data.ctaNote && <p class="cta-note">{data.ctaNote}</p>}
  </div>
</section>

<script>
  const heroLeadForm = document.querySelector("#hero-lead-form");
  if (heroLeadForm instanceof HTMLFormElement) {
    const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
    heroLeadForm.querySelectorAll("[data-hero-attribution]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.heroAttribution || "";
      field.value = attribution[key] || "";
    });

    heroLeadForm.addEventListener("submit", () => {
      const formData = new FormData(heroLeadForm);
      window.trackEvent?.("lead_hero_form_submit", {
        category: "form",
        label: "Recevoir un diagnostic sous 24h",
        volume: String(formData.get("volume") || ""),
        blocked_stage: String(formData.get("blocked_stage") || ""),
        source: "homepage_hero",
        conversion_type: "form_contact",
        lead_stage: "homepage_hero_form_submitted",
        service_interest: "Pilotage administratif photovoltaïque",
      });
    });
  }
</script>

<style>
  .hero {
    margin: 0;
  }

  .hero-stage {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(350px, 0.92fr);
    gap: clamp(2rem, 4.6vw, 4.8rem);
    align-items: center;
    min-height: 41rem;
    padding: clamp(2rem, 4.4vw, 4.5rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 26px;
    background:
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.27), transparent 62%),
      radial-gradient(65% 82% at 0% 100%, rgba(212, 130, 42, 0.22), transparent 65%),
      var(--ink);
    box-shadow: 0 30px 80px rgba(14, 23, 38, 0.18);
  }

  .hero-stage::before {
    content: "";
    position: absolute;
    z-index: -1;
    width: 20rem;
    aspect-ratio: 1;
    right: -7rem;
    bottom: -10rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    box-shadow:
      0 0 0 3rem rgba(255, 255, 255, 0.025),
      0 0 0 7rem rgba(255, 255, 255, 0.018);
  }

  .hero-narrative {
    min-width: 0;
    color: #ffffff;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-kicker span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 5px rgba(212, 130, 42, 0.16);
  }

  h1 {
    max-width: 11.4ch;
    margin: 1.25rem 0 0;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: clamp(3rem, 5.15vw, 5.3rem);
    font-weight: 720;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .hero-subtitle {
    max-width: 56ch;
    margin: 1.35rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1rem, 0.36vw + 0.96rem, 1.16rem);
    line-height: 1.62;
    text-wrap: pretty;
  }

  .expert-line {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    max-width: 56ch;
    margin: 1.15rem 0 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.96rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .expert-line span {
    flex: 0 0 auto;
    display: inline-grid;
    place-items: center;
    width: 1.3rem;
    height: 1.3rem;
    margin-top: 0.08rem;
    border-radius: 50%;
    background: var(--success);
    color: #ffffff;
    font-size: 0.72rem;
  }

  .proof-bar {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    margin: 1.6rem 0 0;
    padding: 0;
    list-style: none;
  }

  .proof-bar li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    min-height: 3.7rem;
    padding: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.055);
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.78rem;
    font-weight: 620;
    line-height: 1.42;
  }

  .proof-bar li span {
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.32rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero-conversion {
    position: relative;
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .portal-snapshot,
  .hero-intake-card {
    border-radius: 18px;
    box-shadow: 0 24px 60px rgba(4, 10, 20, 0.2);
  }

  .portal-snapshot {
    padding: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: var(--system-soft);
    color: var(--text);
  }

  .portal-snapshot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.72rem;
    border-bottom: 1px solid color-mix(in srgb, var(--system) 15%, var(--line));
    font-size: 0.73rem;
  }

  .portal-snapshot-head div {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
  }

  .portal-snapshot-head > span {
    color: var(--system);
    font-weight: 700;
  }

  .live-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 4px var(--success-soft);
    animation: live-pulse 2.4s ease-out infinite;
  }

  .portal-snapshot-body {
    display: grid;
    grid-template-columns: minmax(0, 0.38fr) minmax(0, 1fr);
    gap: 0.8rem;
    padding-top: 0.8rem;
  }

  .portal-summary {
    display: grid;
    align-content: center;
    padding: 0.72rem;
    border-radius: 12px;
    background: #ffffff;
  }

  .portal-summary span,
  .portal-summary small {
    color: var(--text-muted);
    font-size: 0.68rem;
  }

  .portal-summary strong {
    margin: 0.05rem 0;
    font-size: 1.55rem;
    letter-spacing: -0.04em;
  }

  .portal-progress {
    display: grid;
    gap: 0.36rem;
  }

  .portal-progress > div {
    display: grid;
    grid-template-columns: 5.4rem minmax(2rem, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.05rem;
    padding: 0.38rem 0.48rem;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.72);
    font-size: 0.65rem;
    font-weight: 650;
    animation: portal-row-enter 620ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .portal-progress > div:nth-child(2) {
    animation-delay: 110ms;
  }

  .portal-progress > div:nth-child(3) {
    animation-delay: 220ms;
  }

  .progress-track {
    position: relative;
    display: block;
    height: 0.3rem;
    overflow: hidden;
    border-radius: 999px;
    background: var(--line);
  }

  .progress-track i {
    display: block;
    width: var(--progress);
    height: 100%;
    border-radius: inherit;
    background: var(--system);
    transform: scaleX(0);
    transform-origin: left;
    animation: portal-progress-fill 920ms cubic-bezier(0.22, 1, 0.36, 1) 260ms forwards;
  }

  .status {
    padding: 0.24rem 0.38rem;
    border-radius: 999px;
    font-size: 0.58rem;
    font-style: normal;
    white-space: nowrap;
  }

  .status-success {
    background: var(--success-soft);
    color: #10745a;
  }

  .status-system {
    background: #e4eaff;
    color: #294ebd;
  }

  .status-warning {
    background: var(--accent-soft);
    color: var(--accent-deep);
  }

  @keyframes portal-row-enter {
    from {
      opacity: 0;
      transform: translateY(0.45rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes portal-progress-fill {
    to {
      transform: scaleX(1);
    }
  }

  @keyframes live-pulse {
    0%,
    55% {
      box-shadow: 0 0 0 4px var(--success-soft);
    }

    85%,
    100% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  .hero-intake-card {
    padding: clamp(1.05rem, 2vw, 1.35rem);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: #ffffff;
    color: var(--text);
  }

  .hero-intake-head {
    display: grid;
    gap: 0.45rem;
  }

  .hero-intake-head > div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-intake-kicker {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .no-commitment {
    padding: 0.28rem 0.52rem;
    border-radius: 999px;
    background: var(--success-soft);
    color: #10745a;
    font-size: 0.66rem;
    font-weight: 700;
  }

  .hero-intake-copy {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .hero-lead-form {
    display: grid;
    gap: 0.72rem;
    margin-top: 0.9rem;
  }

  .hero-form-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .hero-form-fields .email-field {
    grid-column: 1 / -1;
  }

  .hero-lead-form label {
    display: grid;
    gap: 0.34rem;
    min-width: 0;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .hero-lead-form input,
  .hero-lead-form select {
    width: 100%;
    min-height: 2.85rem;
    padding: 0.68rem 0.76rem;
    border: 1px solid var(--line);
    border-radius: 11px;
    outline: none;
    background: var(--bg-soft);
    color: var(--text);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 520;
    text-transform: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
  }

  .hero-lead-form input::placeholder {
    color: color-mix(in srgb, var(--text-muted) 72%, white);
  }

  .hero-lead-form input:focus-visible,
  .hero-lead-form select:focus-visible {
    border-color: var(--system);
    background: #ffffff;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--system) 16%, transparent);
  }

  .hero-submit {
    width: 100%;
    min-height: 3.05rem;
    justify-content: space-between;
    padding-inline: 1rem;
    cursor: pointer;
  }

  .hero-submit span {
    font-size: 1.1rem;
  }

  .hero-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-form-footer p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.7rem;
  }

  .hero-form-footer a {
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 720;
    text-underline-offset: 0.2rem;
    white-space: nowrap;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .cta-note {
    grid-column: 1 / -1;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.8rem;
  }

  @media (max-width: 1100px) {
    .hero-stage {
      grid-template-columns: minmax(0, 0.95fr) minmax(330px, 1.05fr);
      gap: 2rem;
      padding: 2.25rem;
    }

    h1 {
      font-size: clamp(2.9rem, 6vw, 4.5rem);
    }

    .proof-bar {
      grid-template-columns: 1fr;
    }

    .proof-bar li {
      min-height: auto;
    }
  }

  @media (max-width: 820px) {
    .hero-stage {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 2.2rem;
    }

    h1 {
      max-width: 12ch;
      font-size: clamp(2.8rem, 9vw, 4.7rem);
    }

    .proof-bar {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .hero-stage {
      gap: 1.45rem;
      padding: 1.5rem 1rem 1rem;
      border-radius: 18px;
    }

    .hero-kicker {
      font-size: 0.68rem;
    }

    h1 {
      max-width: 100%;
      margin-top: 1rem;
      font-size: clamp(2.25rem, 9.7vw, 2.9rem);
      letter-spacing: -0.05em;
    }

    .hero-subtitle {
      margin-top: 1rem;
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .expert-line {
      margin-top: 0.9rem;
      font-size: 0.86rem;
    }

    .proof-bar {
      grid-template-columns: 1fr;
      gap: 0.38rem;
      margin-top: 1.1rem;
    }

    .proof-bar li {
      min-height: auto;
      padding: 0.58rem 0.68rem;
      font-size: 0.74rem;
    }

    .portal-snapshot {
      padding: 0.78rem;
      border-radius: 14px;
    }

    .portal-snapshot-head {
      padding-bottom: 0;
      border-bottom: 0;
    }

    .portal-snapshot-body {
      display: none;
    }

    .hero-intake-card {
      padding: 1rem;
      border-radius: 14px;
    }

    .hero-form-fields {
      grid-template-columns: 1fr;
    }

    .hero-form-fields .email-field {
      grid-column: auto;
    }

    .hero-form-footer {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.42rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-dot,
    .portal-progress > div,
    .progress-track i {
      animation: none;
    }

    .progress-track i {
      transform: scaleX(1);
    }
  }
</style>
