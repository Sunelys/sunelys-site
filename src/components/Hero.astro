---
interface PreviewItem {
  name: string;
  status: string;
}

interface PreviewColumn {
  heading: string;
  items: PreviewItem[];
}

interface HeroData {
  kicker: string;
  title: string;
  subtitle: string;
  primaryCta: { label: string; href: string; track: string };
  secondaryCta: { label: string; href: string; track: string };
  proofs: string[];
  preview: {
    label: string;
    title: string;
    columns: PreviewColumn[];
    footer: string;
  };
}

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
---

<section class="hero section-shell">
  <div class="hero-copy reveal">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.subtitle}</p>

    <div class="hero-actions">
      <a class="btn btn-primary" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
      </a>
      <a class="btn btn-secondary" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
      </a>
    </div>

    <ul class="proofs" aria-label="Preuves clés">
      {
        data.proofs.map((proof) => (
          <li>{proof}</li>
        ))
      }
    </ul>
  </div>

  <aside class="hero-preview reveal" aria-label="Aperçu produit">
    <p class="preview-kicker">{data.preview.label}</p>
    <h2>{data.preview.title}</h2>

    <div class="preview-grid">
      {
        data.preview.columns.map((column) => (
          <article class="preview-column">
            <h3>{column.heading}</h3>
            <ul>
              {
                column.items.map((item) => (
                  <li>
                    <span>{item.name}</span>
                    <small>{item.status}</small>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>

    <p class="preview-footer">{data.preview.footer}</p>
  </aside>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.03fr) minmax(350px, 0.97fr);
    gap: clamp(1.2rem, 2.8vw, 2.5rem);
    align-items: stretch;
  }

  .hero-copy,
  .hero-preview {
    position: relative;
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .hero-copy {
    padding: clamp(1.5rem, 3.4vw, 2.9rem);
    background:
      radial-gradient(85% 120% at 90% 120%, color-mix(in srgb, var(--accent-soft) 70%, transparent), transparent 52%),
      var(--surface);
  }

  .hero-copy::after {
    content: "";
    position: absolute;
    right: -14%;
    bottom: -42%;
    width: clamp(230px, 45vw, 520px);
    aspect-ratio: 1;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 1.25);
    filter: blur(calc(var(--shape-blur) * 1.4));
    pointer-events: none;
  }

  .kicker,
  .preview-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
  }

  h1 {
    margin: 0.95rem 0 0;
    max-width: 14ch;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .subtitle {
    margin: 1rem 0 0;
    max-width: 47ch;
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: 1.58;
  }

  .hero-actions {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .proofs {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .proofs li {
    border: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 86%, white);
    min-height: 3.1rem;
    display: grid;
    place-items: center;
    padding: 0.5rem;
    text-align: center;
    color: var(--text);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1.24;
  }

  .hero-preview {
    padding: clamp(1.2rem, 2.6vw, 2.1rem);
    background:
      linear-gradient(150deg, color-mix(in srgb, var(--surface) 90%, white), var(--surface-elevated));
  }

  .hero-preview h2 {
    margin: 0.8rem 0 0;
    font-size: clamp(1.4rem, 2.2vw, 2.1rem);
    line-height: 1.08;
    max-width: 18ch;
  }

  .preview-grid {
    margin-top: 1rem;
    display: grid;
    gap: 0.62rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .preview-column {
    border: 1px solid color-mix(in srgb, var(--line) 85%, white);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 84%, white);
    padding: 0.66rem;
    box-shadow: var(--shadow-sm);
  }

  .preview-column h3 {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .preview-column ul {
    margin: 0.62rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.42rem;
  }

  .preview-column li {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    padding: 0.44rem;
    display: grid;
    gap: 0.18rem;
  }

  .preview-column span {
    font-size: 0.79rem;
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
  }

  .preview-column small {
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .preview-footer {
    margin: 0.78rem 0 0;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 1080px) {
    .hero {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 18ch;
    }
  }

  @media (max-width: 760px) {
    .proofs {
      grid-template-columns: 1fr;
    }

    .preview-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }
</style>
