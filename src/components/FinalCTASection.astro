---
interface ActionItem {
  label: string;
  href: string;
  track: string;
}

interface ContactPoint {
  label: string;
  value: string;
  href: string;
  track: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    primaryCta: ActionItem;
    secondaryCta: ActionItem;
    contactPoints?: ContactPoint[];
  };
}

const { data } = Astro.props;
---

<section id="contact" class="section-shell final-section reveal" aria-labelledby="final-title">
  <div class="final-copy" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="final-title">{data.title}</h2>
    <p class="text">{data.text}</p>

    <div class="actions">
      <a class="btn btn-accent" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
        <span aria-hidden="true">→</span>
      </a>
      <a class="secondary-action" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  {
    data.contactPoints && data.contactPoints.length > 0 && (
      <div class="contact-panel" aria-label="Options de contact Sunelys" data-reveal-item>
        <div class="contact-panel-head">
          <p>Choisissez votre point d’entrée</p>
          <span>Réponse humaine</span>
        </div>
        <div class="contact-grid">
          {data.contactPoints.map((item, index) => (
            <a class="contact-row" href={item.href} data-track={item.track}>
              <span class="contact-index">0{index + 1}</span>
              <span>
                <small>{item.label}</small>
                <strong>{item.value}</strong>
              </span>
              <i aria-hidden="true">→</i>
            </a>
          ))}
        </div>
      </div>
    )
  }
</section>

<style>
  .final-section {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(310px, 0.72fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
    overflow: hidden;
    padding: clamp(1.5rem, 3.5vw, 3.6rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 90% at 2% 100%, rgba(212, 130, 42, 0.22), transparent 62%),
      radial-gradient(70% 110% at 90% 0%, rgba(54, 98, 227, 0.28), transparent 60%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .final-section::after {
    content: "S";
    position: absolute;
    right: -0.05em;
    bottom: -0.42em;
    color: rgba(255, 255, 255, 0.025);
    font-size: clamp(20rem, 42vw, 40rem);
    font-weight: 800;
    line-height: 1;
    pointer-events: none;
  }

  .final-copy,
  .contact-panel {
    position: relative;
    z-index: 1;
  }

  .kicker {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 17ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.2rem, 4.4vw, 4.7rem);
  }

  .text {
    max-width: 62ch;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.94rem;
    line-height: 1.64;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .secondary-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.22);
    text-underline-offset: 0.28rem;
  }

  .secondary-action span {
    color: var(--accent);
  }

  .contact-panel {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
  }

  .contact-panel-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-panel-head p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .contact-panel-head span {
    color: var(--success);
    font-size: 0.65rem;
    font-weight: 760;
  }

  .contact-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 5.1rem;
    padding: 0.75rem 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    color: #ffffff;
    text-decoration: none;
    transition: background-color 160ms ease;
  }

  .contact-row:last-child {
    border-bottom: 0;
  }

  .contact-row:hover,
  .contact-row:focus-visible {
    background: rgba(255, 255, 255, 0.07);
  }

  .contact-index {
    color: var(--accent);
    font-size: 0.65rem;
    font-weight: 800;
  }

  .contact-row > span:nth-child(2) {
    display: grid;
    gap: 0.18rem;
  }

  .contact-row small {
    color: rgba(255, 255, 255, 0.44);
    font-size: 0.63rem;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-row strong {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    line-height: 1.35;
  }

  .contact-row i {
    color: var(--accent);
    font-size: 0.9rem;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .final-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .final-section {
      padding: 1.3rem;
    }

    .actions {
      align-items: stretch;
      flex-direction: column;
    }

    .actions .btn,
    .secondary-action {
      width: 100%;
      justify-content: center;
    }
  }
</style>
