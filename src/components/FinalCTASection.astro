---
interface ActionItem {
  label: string;
  href: string;
  track: string;
}

interface ContactPoint {
  label: string;
  value: string;
  href: string;
  track: string;
}

interface DecisionPoint {
  label: string;
  text: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    text: string;
    primaryCta: ActionItem;
    secondaryCta: ActionItem;
    contactPoints?: ContactPoint[];
    decisionPoints?: DecisionPoint[];
  };
}

const { data } = Astro.props;
const decisionPoints =
  data.decisionPoints && data.decisionPoints.length > 0
    ? data.decisionPoints
    : [
        { label: "Périmètre", text: "La première brique à reprendre." },
        { label: "Réponse", text: "Un retour humain sous 24h ouvrées." },
        { label: "Liberté", text: "Un dossier ponctuel suffit pour commencer." },
      ];
---

<section
  id="contact"
  class="section-shell final-section reveal"
  aria-labelledby="final-title"
  data-track-view="homepage_final_cta_view"
  data-track-label="homepage_final_cta"
>
  <div class="final-copy" data-reveal-item>
    <p class="kicker">{data.kicker}</p>
    <h2 id="final-title">{data.title}</h2>
    <p class="text">{data.text}</p>

    <div class="decision-strip" aria-label="Ce que Sunelys clarifie après votre demande">
      {
        decisionPoints.map((item) => (
          <article>
            <strong>{item.label}</strong>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>

    <div class="actions">
      <a class="btn btn-accent" href={data.primaryCta.href} data-track={data.primaryCta.track}>
        {data.primaryCta.label}
        <span aria-hidden="true">→</span>
      </a>
      <a class="secondary-action" href={data.secondaryCta.href} data-track={data.secondaryCta.track}>
        {data.secondaryCta.label}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  {
    data.contactPoints && data.contactPoints.length > 0 && (
      <div class="contact-panel" aria-label="Options de contact Sunelys" data-reveal-item>
        <div class="contact-panel-head">
          <p>Choisissez votre point d’entrée</p>
          <span>Réponse humaine</span>
        </div>
        <div class="contact-grid">
          {data.contactPoints.map((item, index) => (
            <a class="contact-row" href={item.href} data-track={item.track} data-track-label={item.label}>
              <span class="contact-index">0{index + 1}</span>
              <span>
                <small>{item.label}</small>
                <strong>{item.value}</strong>
              </span>
              <i aria-hidden="true">→</i>
            </a>
          ))}
        </div>
      </div>
    )
  }
</section>

<style>
  .final-section {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(330px, 0.52fr);
    gap: 1rem;
    align-items: stretch;
    overflow: hidden;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px) 0 0 / 42px 42px,
      linear-gradient(180deg, var(--ink-soft), var(--ink));
    box-shadow: var(--shadow-md);
  }

  .final-copy,
  .contact-panel {
    position: relative;
    z-index: 1;
  }

  .final-copy {
    display: grid;
    align-content: center;
    gap: 1rem;
    min-width: 0;
    padding: 2rem;
  }

  .kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h2 {
    max-width: 17ch;
    margin: 0;
    color: #ffffff;
    font-size: 3.8rem;
    letter-spacing: 0;
    line-height: 1.04;
  }

  .text {
    max-width: 62ch;
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.98rem;
    line-height: 1.64;
  }

  .decision-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 0.15rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .decision-strip article {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
    padding: 0.85rem 0.9rem 0.85rem 0;
  }

  .decision-strip article + article {
    padding-left: 0.9rem;
    border-left: 1px solid rgba(255, 255, 255, 0.12);
  }

  .decision-strip strong {
    color: #ffffff;
    font-size: 0.82rem;
  }

  .decision-strip p {
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.72rem;
    line-height: 1.42;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 0.2rem;
  }

  .secondary-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.22);
    text-underline-offset: 0.28rem;
  }

  .secondary-action span {
    color: var(--accent);
  }

  .contact-panel {
    align-self: stretch;
    display: grid;
    align-content: start;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
  }

  .contact-panel-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-panel-head p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .contact-panel-head span {
    color: var(--success);
    font-size: 0.65rem;
    font-weight: 760;
  }

  .contact-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 5.1rem;
    padding: 0.75rem 0.95rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    color: #ffffff;
    text-decoration: none;
    transition: background-color 160ms ease;
  }

  .contact-row:last-child {
    border-bottom: 0;
  }

  .contact-row:hover,
  .contact-row:focus-visible {
    background: rgba(255, 255, 255, 0.07);
  }

  .contact-index {
    color: var(--accent);
    font-size: 0.65rem;
    font-weight: 800;
  }

  .contact-row > span:nth-child(2) {
    display: grid;
    gap: 0.18rem;
  }

  .contact-row small {
    color: rgba(255, 255, 255, 0.44);
    font-size: 0.63rem;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-row strong {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    line-height: 1.35;
  }

  .contact-row i {
    color: var(--accent);
    font-size: 0.9rem;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .final-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .final-section {
      padding: 0.72rem;
      border-radius: 18px;
    }

    .final-copy {
      padding: 1rem 0.7rem 1.1rem;
    }

    h2 {
      font-size: 2.42rem;
    }

    .decision-strip {
      grid-template-columns: 1fr;
      border-bottom: 0;
    }

    .decision-strip article,
    .decision-strip article + article {
      padding: 0.72rem 0;
      border-left: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .actions {
      align-items: stretch;
      flex-direction: column;
    }

    .actions .btn,
    .secondary-action {
      width: 100%;
      justify-content: center;
    }
  }
</style>
