---
export interface NavLink {
  href: string;
  label: string;
}

interface Props {
  path: string;
  navLinks: NavLink[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  path,
  navLinks,
  ctaHref = "/contact",
  ctaLabel = "Diagnostic gratuit",
} = Astro.props;
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand-link" href="/" aria-label="Sunelys" data-track="nav_brand_home">
      <img src="/brand/wordmark.svg" alt="Sunelys" width="136" height="27" loading="eager" decoding="async" />
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
      <ul>
        {
          navLinks.map((link) => {
            const active = path === link.href;
            return (
              <li>
                <a
                  class:list={["nav-link", active && "active"]}
                  href={link.href}
                  aria-current={active ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a
        class="portal-link"
        href="https://portail.sunelys.fr/login"
        data-track="cta_header_portal"
      >
        <span>Deja client ?</span>
        <strong>Acceder au portail</strong>
      </a>
      <a class="btn btn-primary btn-accent nav-cta" href={ctaHref} data-track="cta_header_primary">{ctaLabel}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 120;
    border-bottom: 1px solid color-mix(in srgb, var(--line) 74%, transparent);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg-soft) 94%, transparent),
      color-mix(in srgb, var(--surface) 86%, transparent)
    );
    backdrop-filter: blur(18px) saturate(118%);
  }

  .header-row {
    min-height: 4.55rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    min-width: 0;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
    isolation: isolate;
    min-width: 0;
    overflow: hidden;
  }

  .brand-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.36);
    filter: blur(calc(var(--shape-blur) * 0.42));
    pointer-events: none;
    z-index: -1;
    transform: scale(1.75);
  }

  .brand-link img {
    width: clamp(110px, 9.6vw, 136px);
    height: clamp(22px, 2vw, 30px);
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .main-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.32rem;
  }

  .main-nav {
    min-width: 0;
    max-width: 100%;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.15rem;
    padding: 0.42rem 0.78rem;
    border-radius: 10px;
    border: 1px solid transparent;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.active {
    color: var(--text);
    border-color: color-mix(in srgb, var(--line) 82%, white);
    background: color-mix(in srgb, var(--surface) 88%, white);
    box-shadow: 0 10px 24px rgba(20, 16, 10, 0.05);
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .portal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.1rem;
    padding: 0.1rem 0;
    text-decoration: none;
    color: var(--text-muted);
    letter-spacing: 0;
    text-transform: uppercase;
    font-size: 0.66rem;
    font-weight: 600;
    transition: color 180ms ease, opacity 180ms ease, transform 180ms ease;
  }

  .portal-link:hover,
  .portal-link:focus-visible {
    color: var(--text);
    transform: translateY(-1px);
  }

  .portal-link span {
    opacity: 0.72;
  }

  .portal-link strong {
    font-size: 0.68rem;
    letter-spacing: 0;
  }

  .nav-cta {
    min-height: 2.35rem;
    white-space: nowrap;
  }

  @media (max-width: 1320px) {
    .header-row {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "brand actions"
        "nav nav";
      row-gap: 0.55rem;
      padding-block: 0.72rem;
      min-height: auto;
    }

    .brand-link {
      grid-area: brand;
    }

    .header-actions {
      grid-area: actions;
      justify-self: end;
    }

    .main-nav {
      grid-area: nav;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      contain: paint;
      padding-bottom: 0.2rem;
    }

    .main-nav ul {
      justify-content: flex-start;
      min-width: max-content;
    }
  }

  @media (max-width: 640px) {
    .header-row {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "brand actions"
        "cta cta"
        "nav nav";
      gap: 0.48rem 0.8rem;
      padding-block: 0.62rem 0.58rem;
    }

    .header-actions {
      display: contents;
    }

    .nav-cta {
      grid-area: cta;
      width: 100%;
      min-height: 2.62rem;
    }

    .portal-link {
      grid-area: actions;
      width: auto;
      justify-content: flex-end;
      justify-self: end;
      min-height: 1.8rem;
      font-size: 0.65rem;
    }

    .main-nav {
      overflow-x: auto;
      overflow-y: hidden;
      contain: paint;
      scrollbar-width: none;
      padding-bottom: 0;
    }

    .main-nav::-webkit-scrollbar {
      display: none;
    }

    .main-nav ul {
      width: 100%;
      min-width: max-content;
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: 0.28rem;
    }

    .nav-link {
      min-height: 1.92rem;
      padding: 0.32rem 0.54rem;
      font-size: 0.68rem;
      letter-spacing: 0;
    }

    .portal-link span {
      display: none;
    }

    .brand-link::before {
      content: none;
    }
  }
</style>
