---
export interface NavLink {
  href: string;
  label: string;
}

interface Props {
  path: string;
  navLinks: NavLink[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  path,
  navLinks,
  ctaHref = "/contact",
  ctaLabel = "Planifier un échange",
} = Astro.props;
---

<header class="site-header">
  <div class="container header-grid">
    <a class="brand-link" href="/" aria-label="Sunelys accueil" data-track="nav_brand_home">
      <img
        src="/brand/wordmark.svg"
        alt="Sunelys"
        width="158"
        height="30"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
      <ul>
        {
          navLinks.map((link) => {
            const active = path === link.href;
            return (
              <li>
                <a
                  href={link.href}
                  class:list={["nav-item", active && "active"]}
                  aria-current={active ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <a class="btn btn-primary header-cta" href={ctaHref} data-track="cta_header_primary">
      {ctaLabel}
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-hairline);
    background: color-mix(in srgb, var(--color-bg) 78%, transparent);
    backdrop-filter: blur(var(--blur-header));
  }

  .header-grid {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(0.8rem, 2vw, 1.4rem);
    align-items: center;
    min-height: 4.55rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
  }

  .brand-link::after {
    content: "";
    position: absolute;
    inset: -1.1rem -1.3rem;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.28);
    pointer-events: none;
    filter: blur(calc(var(--shape-blur) * 0.18));
  }

  .brand-link img {
    display: block;
    width: clamp(110px, 12vw, 158px);
    height: auto;
    position: relative;
    z-index: 1;
  }

  .main-nav ul {
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(0.2rem, 0.8vw, 0.6rem);
    margin: 0;
    padding: 0;
  }

  .nav-item {
    display: inline-block;
    text-decoration: none;
    color: var(--color-muted);
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 0.52rem 0.82rem;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease;
  }

  .nav-item:hover,
  .nav-item:focus-visible,
  .nav-item.active {
    color: var(--color-text);
    border-color: var(--color-hairline);
    background: color-mix(in srgb, var(--color-surface) 76%, white);
  }

  .header-cta {
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .header-grid {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "brand cta"
        "nav nav";
      row-gap: 0.6rem;
      min-height: auto;
      padding-block: 0.75rem;
    }

    .brand-link {
      grid-area: brand;
    }

    .main-nav {
      grid-area: nav;
      overflow-x: auto;
      padding-bottom: 0.25rem;
    }

    .main-nav ul {
      justify-content: flex-start;
      min-width: max-content;
    }

    .header-cta {
      grid-area: cta;
      justify-self: end;
    }
  }

  @media (max-width: 640px) {
    .header-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "brand"
        "cta"
        "nav";
    }

    .header-cta {
      justify-self: start;
      width: 100%;
      justify-content: center;
    }
  }
</style>
