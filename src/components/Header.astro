---
export interface NavLink {
  href: string;
  label: string;
}

interface Props {
  path: string;
  navLinks: NavLink[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  path,
  navLinks,
  ctaHref = "/contact",
  ctaLabel = "Réserver un échange",
} = Astro.props;
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand-link" href="/" aria-label="Sunelys" data-track="nav_brand_home">
      <img src="/brand/wordmark.svg" alt="Sunelys" width="148" height="29" loading="eager" decoding="async" />
    </a>

    <nav class="main-nav" aria-label="Navigation principale">
      <ul>
        {
          navLinks.map((link) => {
            const active = path === link.href;
            return (
              <li>
                <a
                  class:list={["nav-link", active && "active"]}
                  href={link.href}
                  aria-current={active ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <a class="btn btn-primary nav-cta" href={ctaHref} data-track="cta_header_primary">{ctaLabel}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid color-mix(in srgb, var(--line) 80%, transparent);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(120%);
  }

  .header-row {
    min-height: 4.55rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
    isolation: isolate;
  }

  .brand-link::before {
    content: "";
    position: absolute;
    inset: -1rem -1.2rem;
    background: url("/brand/shape-clean.svg") no-repeat center / contain;
    opacity: calc(var(--shape-opacity) * 0.28);
    filter: blur(calc(var(--shape-blur) * 0.25));
    pointer-events: none;
    z-index: -1;
  }

  .brand-link img {
    width: clamp(118px, 10.6vw, 148px);
    height: auto;
    display: block;
  }

  .main-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.45rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.1rem;
    padding: 0.42rem 0.82rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    color: var(--text-muted);
    font-size: 0.79rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.active {
    color: var(--text);
    border-color: var(--line);
    background: color-mix(in srgb, var(--surface) 84%, white);
  }

  .nav-cta {
    min-height: 2.2rem;
  }

  @media (max-width: 980px) {
    .header-row {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "brand cta"
        "nav nav";
      row-gap: 0.55rem;
      padding-block: 0.72rem;
      min-height: auto;
    }

    .brand-link {
      grid-area: brand;
    }

    .nav-cta {
      grid-area: cta;
      justify-self: end;
    }

    .main-nav {
      grid-area: nav;
      overflow-x: auto;
      padding-bottom: 0.2rem;
    }

    .main-nav ul {
      justify-content: flex-start;
      min-width: max-content;
    }
  }

  @media (max-width: 640px) {
    .header-row {
      grid-template-columns: 1fr;
      grid-template-areas:
        "brand"
        "cta"
        "nav";
    }

    .nav-cta {
      width: 100%;
      justify-content: center;
      justify-self: stretch;
    }
  }
</style>
