---
export interface NavLink {
  href: string;
  label: string;
}

interface Props {
  path: string;
  navLinks: NavLink[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  path,
  navLinks,
  ctaHref = "/contact",
  ctaLabel = "Diagnostic sous 24h",
} = Astro.props;

const contactEmail = "contact@sunelys.fr";
const founderName = "Myriam Zaoui";
---

<header class="site-header" data-site-header>
  <div class="container header-row">
    <a class="brand-link" href="/" aria-label="Sunelys — Accueil" data-track="nav_brand_home">
      <img src="/brand/wordmark.svg" alt="Sunelys" width="136" height="27" loading="eager" decoding="async" />
    </a>

    <nav class="main-nav" id="main-navigation" aria-label="Navigation principale">
      <div class="nav-panel">
        <div class="mobile-menu-intro">
          <p>Sunelys</p>
          <strong>Vos dossiers solaires.<br />Enfin sous contrôle.</strong>
          <span>Navigation</span>
        </div>

        <ul>
          {
            navLinks.map((link, index) => {
              const active = path === link.href;
              return (
                <li>
                  <a
                    class:list={["nav-link", active && "active"]}
                    href={link.href}
                    aria-current={active ? "page" : undefined}
                  >
                    <span class="mobile-nav-index">0{index + 1}</span>
                    <span class="nav-label">{link.label}</span>
                    <span class="mobile-nav-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              );
            })
          }
        </ul>

        <a
          class="mobile-portal-link"
          href="https://portail.sunelys.fr/login"
          data-track="cta_header_portal_mobile"
        >
          <span>Déjà client ?</span>
          <strong>Accéder au portail</strong>
        </a>
      </div>
    </nav>

    <div class="header-actions">
      <div class="header-contact-chip" aria-label={`Contact ${founderName}`}>
        <span>{founderName}</span>
        <a href={`mailto:${contactEmail}`} data-track="header_email">{contactEmail}</a>
      </div>

      <a
        class="portal-link"
        href="https://portail.sunelys.fr/login"
        data-track="cta_header_portal"
      >
        <span class="portal-status" aria-hidden="true"></span>
        <span>Portail client</span>
      </a>

      <a class="btn btn-accent nav-cta" href={ctaHref} data-track="cta_header_primary">
        <span class="cta-label-full">{ctaLabel}</span>
        <span class="cta-label-short">Diagnostic</span>
      </a>

      <button
        class="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="main-navigation"
        aria-label="Ouvrir le menu"
        data-menu-toggle
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll("[data-site-header]").forEach((header) => {
    if (!(header instanceof HTMLElement)) return;

    const toggle = header.querySelector("[data-menu-toggle]");
    const nav = header.querySelector("#main-navigation");
    if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return;

    const pageSurfaces = document.querySelectorAll("body > main, body > footer, body > .sticky-lead-bar");
    const setPageInert = (isInert) => {
      pageSurfaces.forEach((surface) => {
        if (surface instanceof HTMLElement) surface.inert = isInert;
      });
    };

    const closeMenu = (restoreFocus = false) => {
      header.removeAttribute("data-menu-open");
      document.documentElement.classList.remove("menu-open");
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Ouvrir le menu");
      setPageInert(false);
      if (restoreFocus) toggle.focus({ preventScroll: true });
    };

    const openMenu = () => {
      header.setAttribute("data-menu-open", "true");
      document.documentElement.classList.add("menu-open");
      toggle.setAttribute("aria-expanded", "true");
      toggle.setAttribute("aria-label", "Fermer le menu");
      setPageInert(true);

      const firstMenuLink = nav.querySelector("a");
      if (firstMenuLink instanceof HTMLAnchorElement) {
        window.setTimeout(() => firstMenuLink.focus({ preventScroll: true }), 220);
      }
    };

    toggle.addEventListener("click", () => {
      if (toggle.getAttribute("aria-expanded") === "true") {
        closeMenu(false);
      } else {
        openMenu();
      }
    });

    nav.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => closeMenu(false)));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") closeMenu(true);
    });

    window.matchMedia("(min-width: 1081px)").addEventListener?.("change", () => closeMenu(false));
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 120;
    border-bottom: 1px solid color-mix(in srgb, var(--line) 84%, transparent);
    background: color-mix(in srgb, var(--bg-soft) 92%, transparent);
    backdrop-filter: blur(18px) saturate(125%);
  }

  .header-row {
    min-height: 4.5rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.4rem);
  }

  .brand-link {
    position: relative;
    display: block;
    width: clamp(112px, 9vw, 136px);
    height: clamp(27px, 2.15vw, 32px);
    overflow: hidden;
    min-width: 0;
    text-decoration: none;
  }

  .brand-link img {
    position: absolute;
    inset: 50% 0 auto;
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: translateY(-50%);
  }

  .main-nav {
    min-width: 0;
  }

  .nav-panel,
  .main-nav ul {
    display: flex;
    align-items: center;
  }

  .nav-panel {
    justify-content: center;
  }

  .main-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.12rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.5rem 0.68rem;
    border-radius: 10px;
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 650;
    text-decoration: none;
    transition: color 160ms ease, background-color 160ms ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.active {
    color: var(--text);
    background: var(--surface);
  }

  .nav-link.active {
    box-shadow: inset 0 0 0 1px var(--line), 0 8px 20px rgba(14, 23, 38, 0.05);
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.72rem;
  }

  .header-contact-chip {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.16rem;
    min-height: 2.4rem;
    padding: 0.1rem 0.6rem 0.1rem 0;
    border-left: 1px solid color-mix(in srgb, var(--line) 55%, transparent);
    color: var(--text-muted);
  }

  .header-contact-chip span {
    font-size: 0.68rem;
    font-weight: 680;
    letter-spacing: 0.02em;
  }

  .header-contact-chip a {
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 710;
    text-decoration: none;
  }

  .header-contact-chip a:hover,
  .header-contact-chip a:focus-visible {
    color: var(--accent);
  }

  .portal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.4rem;
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 650;
    text-decoration: none;
    white-space: nowrap;
  }

  .portal-status {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 4px var(--success-soft);
  }

  .nav-cta {
    min-height: 2.7rem;
    padding-inline: 1rem;
    white-space: nowrap;
  }

  .cta-label-short,
  .mobile-menu-intro,
  .mobile-nav-index,
  .mobile-nav-arrow,
  .mobile-portal-link,
  .menu-toggle {
    display: none;
  }

  @media (max-width: 1180px) {
    .portal-link {
      display: none;
    }

    .header-contact-chip {
      display: none;
    }
  }

  @media (max-width: 1080px) {
    .header-row {
      grid-template-columns: auto minmax(0, 1fr) auto;
      min-height: 4.15rem;
      gap: 1rem;
    }

    .main-nav {
      position: absolute;
      inset: 100% 0 auto;
      height: calc(100dvh - 100%);
      overflow-y: auto;
      padding: clamp(1.4rem, 4vw, 3rem) var(--container-padding) calc(2rem + env(safe-area-inset-bottom, 0px));
      border: 0;
      background:
        radial-gradient(circle at 86% 18%, rgba(54, 98, 227, 0.3), transparent 31%),
        radial-gradient(circle at 8% 100%, rgba(255, 107, 44, 0.15), transparent 30%),
        var(--ink);
      box-shadow: none;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-0.75rem);
      transition: opacity 190ms ease, transform 190ms ease, visibility 190ms ease;
    }

    .site-header[data-menu-open="true"] .main-nav {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }

    .nav-panel {
      width: min(var(--max-width), 100%);
      margin-inline: auto;
      display: grid;
      grid-template-columns: minmax(14rem, 0.62fr) minmax(0, 1.38fr);
      gap: clamp(1.5rem, 5vw, 5rem);
      align-items: start;
    }

    .mobile-menu-intro {
      position: sticky;
      top: 0;
      display: grid;
      gap: 0.7rem;
      padding-top: 0.55rem;
    }

    .mobile-menu-intro p,
    .mobile-menu-intro span {
      color: var(--accent);
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.11em;
      text-transform: uppercase;
    }

    .mobile-menu-intro strong {
      max-width: 13ch;
      color: #ffffff;
      font-size: clamp(1.65rem, 4.4vw, 3.2rem);
      line-height: 1;
      letter-spacing: -0.045em;
    }

    .mobile-menu-intro span {
      margin-top: 1.2rem;
      color: rgba(255, 255, 255, 0.38);
    }

    .main-nav ul {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.14);
    }

    .nav-link {
      display: grid;
      grid-template-columns: 2.2rem minmax(0, 1fr) auto;
      gap: 0.8rem;
      align-items: center;
      min-height: 4.55rem;
      padding: 0.9rem 0;
      border-radius: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      background: transparent;
      box-shadow: none;
      color: #ffffff;
      font-size: clamp(1.15rem, 2.2vw, 1.55rem);
      letter-spacing: -0.025em;
    }

    .nav-link:hover,
    .nav-link:focus-visible,
    .nav-link.active {
      background: transparent;
      color: #ffffff;
    }

    .nav-link.active .nav-label,
    .nav-link:hover .nav-label,
    .nav-link:focus-visible .nav-label {
      color: var(--accent);
      transform: translateX(0.18rem);
    }

    .nav-label {
      transition: color 160ms ease, transform 160ms ease;
    }

    .mobile-nav-index,
    .mobile-nav-arrow {
      display: inline;
      color: rgba(255, 255, 255, 0.34);
      font-size: 0.66rem;
      font-weight: 800;
      letter-spacing: 0.06em;
    }

    .mobile-nav-arrow {
      color: var(--system);
      font-size: 1rem;
    }

    .mobile-portal-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      grid-column: 2;
      min-height: 4rem;
      margin-top: 0.75rem;
      padding: 0.9rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 14px;
      background: var(--accent);
      color: #ffffff;
      font-size: 0.82rem;
      text-decoration: none;
    }

    .mobile-portal-link span {
      color: rgba(255, 255, 255, 0.74);
    }

    .menu-toggle {
      width: 2.7rem;
      height: 2.7rem;
      padding: 0;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--surface);
      display: inline-grid;
      place-content: center;
      gap: 0.34rem;
      color: var(--text);
      cursor: pointer;
    }

    .menu-toggle span {
      display: block;
      width: 1.08rem;
      height: 2px;
      border-radius: 999px;
      background: currentColor;
      transition: transform 180ms ease;
    }

    .site-header[data-menu-open="true"] .menu-toggle span:first-child {
      transform: translateY(0.18rem) rotate(45deg);
    }

    .site-header[data-menu-open="true"] .menu-toggle span:last-child {
      transform: translateY(-0.18rem) rotate(-45deg);
    }
  }

  @media (max-width: 560px) {
    .header-row {
      min-height: 3.9rem;
      gap: 0.65rem;
    }

    .brand-link {
      width: 108px;
      height: 27px;
    }

    .header-actions {
      gap: 0.45rem;
    }

    .nav-cta {
      min-height: 2.55rem;
      padding-inline: 0.82rem;
    }

    .cta-label-full {
      display: none;
    }

    .cta-label-short {
      display: inline;
    }

    .menu-toggle {
      width: 2.55rem;
      height: 2.55rem;
    }

    .main-nav {
      inset: 100% 0 auto;
      height: calc(100dvh - 100%);
      padding-inline: 1rem;
    }

    .nav-panel {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .mobile-menu-intro {
      position: static;
      gap: 0.45rem;
      padding: 0;
    }

    .mobile-menu-intro strong {
      max-width: 15ch;
      font-size: clamp(1.55rem, 8vw, 2.35rem);
    }

    .mobile-menu-intro span {
      margin-top: 0.5rem;
    }

    .nav-link {
      min-height: 3.75rem;
      font-size: 1.05rem;
    }

    .mobile-portal-link {
      grid-column: 1;
      margin-top: 0.25rem;
    }
  }

  :global(html.menu-open) {
    overflow: hidden;
  }
</style>
