---
import SwipeCue from "./SwipeCue.astro";

interface LogoItem {
  name: string;
  src: string;
  width: number;
  height: number;
}

interface MetricItem {
  value: string;
  label: string;
}

interface Props {
  data: {
    kicker: string;
    title: string;
    logos: LogoItem[];
    metrics: MetricItem[];
    trustNote?: string;
  };
}

const { data } = Astro.props;
const visibleLogos = data.logos.filter((logo) => logo.src);
---

<section class="section-shell trust-section reveal" aria-labelledby="trust-title">
  <div class="trust-head" data-reveal-item>
    <div>
      <p class="kicker">{data.kicker}</p>
      <h2 id="trust-title">{data.title}</h2>
    </div>

    <p class="trust-note">
      {data.trustNote ?? "Des dossiers suivis, des pièces mieux cadrées et une visibilité plus claire pour les équipes."}
    </p>
  </div>

  <SwipeCue label="4 chiffres clés à parcourir" />

  <div
    class="trust-metrics"
    aria-label="Chiffres clés Sunelys — utilisez les flèches horizontales pour les parcourir"
    tabindex="0"
    data-scroll-rail
    data-scroll-label="chiffres_cles"
    data-reveal-item
  >
    {
      data.metrics.map((metric, index) => (
        <article class:list={["metric", index === 0 && "is-featured"]}>
          <strong>{metric.value}</strong>
          <p>{metric.label}</p>
        </article>
      ))
    }
  </div>

  {
    visibleLogos.length > 0 && (
      <div class="logo-wall" aria-label="Clients Sunelys" data-reveal-item>
        <div class="logo-wall-head">
          <p>Structures accompagnées</p>
          <span>Des installateurs qui nous confient tout ou partie de leur administratif.</span>
        </div>

        <div class="logo-row">
          {
            visibleLogos.map((logo) => (
              <div class="logo-slot" title={logo.name}>
                <img
                  src={logo.src}
                  alt={logo.name}
                  width={logo.width}
                  height={logo.height}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))
          }
        </div>
      </div>
    )
  }
</section>

<style>
  .trust-section {
    display: grid;
    gap: 1rem;
    padding: clamp(1.3rem, 3vw, 2.4rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .trust-head {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.75fr);
    gap: clamp(1.2rem, 4vw, 4rem);
    align-items: end;
  }

  .kicker {
    margin: 0;
    color: var(--system);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 18ch;
    margin: 0.6rem 0 0;
    font-size: clamp(2rem, 3.7vw, 3.6rem);
  }

  .trust-note {
    margin: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--accent);
    color: var(--text-muted);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .trust-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
    border-radius: 16px;
    background:
      radial-gradient(60% 140% at 0% 100%, rgba(212, 130, 42, 0.22), transparent 68%),
      var(--ink);
  }

  .metric {
    min-height: 9.5rem;
    padding: 1.2rem;
    display: grid;
    align-content: end;
    gap: 0.45rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .metric:last-child {
    border-right: 0;
  }

  .metric strong {
    color: #ffffff;
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 720;
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .metric.is-featured strong {
    color: var(--accent);
  }

  .metric p {
    max-width: 24ch;
    margin: 0;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.78rem;
    line-height: 1.46;
  }

  .logo-wall {
    display: grid;
    gap: 0.8rem;
    padding-top: 0.2rem;
  }

  .logo-wall-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo-wall-head p,
  .logo-wall-head span {
    margin: 0;
  }

  .logo-wall-head p {
    color: var(--text);
    font-size: 0.76rem;
    font-weight: 760;
  }

  .logo-wall-head span {
    color: var(--text-muted);
    font-size: 0.74rem;
  }

  .logo-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .logo-slot {
    min-height: 4.3rem;
    display: grid;
    place-items: center;
    padding: 0.65rem;
    border-radius: 11px;
    background: var(--bg-soft);
  }

  .logo-slot img {
    display: block;
    width: auto;
    max-width: min(72%, 132px);
    max-height: 34px;
    object-fit: contain;
  }

  .logo-slot img[alt="Be Travaux"] {
    max-width: 102px;
    max-height: 32px;
  }

  @media (max-width: 920px) {
    .trust-head {
      grid-template-columns: 1fr;
    }

    .trust-metrics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .metric:nth-child(2) {
      border-right: 0;
    }

    .metric:nth-child(-n + 2) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .logo-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .trust-section {
      padding: 1rem;
      border-radius: 18px;
    }

    .trust-metrics {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: min(72vw, 15rem);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      overscroll-behavior-inline: contain;
      scrollbar-width: none;
      scroll-padding-inline: 0.15rem;
    }

    .trust-metrics::-webkit-scrollbar {
      display: none;
    }

    .trust-metrics:focus-visible {
      outline: 3px solid color-mix(in srgb, var(--system) 34%, transparent);
      outline-offset: 3px;
    }

    .metric {
      min-height: 7.8rem;
      padding: 0.9rem;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      border-bottom: 0;
      scroll-snap-align: start;
    }

    .metric:nth-child(2),
    .metric:nth-child(-n + 2) {
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      border-bottom: 0;
    }

    .metric:last-child {
      border-right: 0;
    }

    .logo-wall-head {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
    }

    .logo-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
