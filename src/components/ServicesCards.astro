---
interface ServiceItem {
  title: string;
  text: string;
  href: string;
  track: string;
}

interface ServicesData {
  kicker: string;
  title: string;
  items: ServiceItem[];
}

interface Props {
  data: ServicesData;
}

const { data } = Astro.props;
---

<section id="services" class="section reveal">
  <p class="kicker">{data.kicker}</p>
  <h2>{data.title}</h2>

  <div class="service-grid">
    {
      data.items.map((item) => (
        <article class="service-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <a class="btn btn-secondary" href={item.href} data-track={item.track}>Découvrir</a>
        </article>
      ))
    }
  </div>
</section>

<style>
  .section {
    margin-top: clamp(1.45rem, 3vw, 2.55rem);
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  h2 {
    margin: 0.5rem 0 0;
    max-width: 32ch;
    font-size: var(--step-3);
    line-height: 1.08;
    text-wrap: balance;
  }

  .service-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: 1rem;
    display: grid;
    gap: 0.62rem;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    border-color: color-mix(in srgb, var(--color-hairline) 64%, var(--color-accent));
  }

  .service-card h3 {
    margin: 0;
    font-size: var(--step-2);
    line-height: 1.08;
    letter-spacing: -0.01em;
  }

  .service-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.52;
  }

  .service-card .btn {
    margin-top: 0.35rem;
    width: fit-content;
  }

  @media (max-width: 980px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-card .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
