---
interface CaseResult {
  value: string;
  label: string;
}

interface CaseStudyData {
  kicker: string;
  title: string;
  client: string;
  context: string;
  results: CaseResult[];
  summary: string;
  cta: {
    label: string;
    href: string;
    track: string;
  };
}

interface Props {
  data: CaseStudyData;
}

const { data } = Astro.props;
---

<section class="section case reveal">
  <div class="case-head">
    <p class="kicker">{data.kicker}</p>
    <h2>{data.title}</h2>
  </div>

  <div class="case-grid">
    <article class="case-main">
      <p class="case-client">{data.client}</p>
      <p class="case-context">{data.context}</p>
      <p class="case-summary">{data.summary}</p>
      <a class="btn btn-secondary" href={data.cta.href} data-track={data.cta.track}>{data.cta.label}</a>
    </article>

    <div class="case-results">
      {
        data.results.map((result) => (
          <article class="result-card">
            <p class="value">{result.value}</p>
            <p class="label">{result.label}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    margin-top: clamp(1.4rem, 3vw, 2.5rem);
  }

  .case {
    background: var(--color-surface);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.1rem, 2.4vw, 1.9rem);
  }

  .kicker {
    margin: 0;
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  .case-head h2 {
    margin: 0.5rem 0 0;
    max-width: 26ch;
    font-size: var(--step-3);
    line-height: 1.08;
    text-wrap: balance;
  }

  .case-grid {
    margin-top: 1rem;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
  }

  .case-main,
  .result-card {
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-surface) 90%, white);
    padding: 0.92rem;
  }

  .case-client {
    margin: 0;
    font-size: var(--step-1);
    font-weight: 600;
    color: var(--color-text-strong);
  }

  .case-context {
    margin: 0.35rem 0 0;
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .case-summary {
    margin: 0.7rem 0 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.54;
  }

  .case-main .btn {
    margin-top: 0.75rem;
    width: fit-content;
  }

  .case-results {
    display: grid;
    gap: 0.65rem;
  }

  .result-card .value {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-3);
    line-height: 0.95;
  }

  .result-card .label {
    margin: 0.35rem 0 0;
    font-size: var(--step--1);
    color: var(--color-muted);
  }

  @media (max-width: 920px) {
    .case-grid {
      grid-template-columns: 1fr;
    }

    .case-main .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
