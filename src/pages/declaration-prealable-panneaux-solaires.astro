---
import BaseLayout from "../layouts/BaseLayout.astro";
import SeoLandingPage from "../components/SeoLandingPage.astro";
import { seoPages } from "../data/seoPages";

const pageData = seoPages.declarationPrealable;
const canonicalUrl = "https://sunelys.fr/declaration-prealable-panneaux-solaires";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: pageData.faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: pageData.heroTitle,
    description: pageData.heroSubtitle,
    serviceType: "Gestion administrative photovoltaïque",
    provider: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    areaServed: {
      "@type": "Country",
      name: "France",
    },
    ...(pageData.conversionOffer
      ? {
          offers: {
            "@type": "Offer",
            price: pageData.conversionOffer.price.replace(/[^\d]/g, ""),
            priceCurrency: "EUR",
            description: pageData.conversionOffer.scope,
          },
        }
      : {}),
    url: canonicalUrl,
  },
];
---

<BaseLayout title={pageData.metaTitle} description={pageData.metaDescription} structuredData={structuredData}>
  <SeoLandingPage data={pageData} />
</BaseLayout>
