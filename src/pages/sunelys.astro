---
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "Sunelys",
    description:
      "Sunelys est une société française spécialisée dans la gestion administrative photovoltaïque pour installateurs.",
    url: "https://sunelys.fr/sunelys",
    mainEntity: {
      "@type": "Organization",
      name: "Sunelys",
      legalName: "SUNELYS",
      url: "https://sunelys.fr",
      email: "contact@sunelys.fr",
      identifier: {
        "@type": "PropertyValue",
        propertyID: "SIREN",
        value: "943493759",
      },
    },
  },
];
---

<BaseLayout
  title="Sunelys | Site officiel de gestion administrative photovoltaïque"
  description="Sunelys est le site officiel de SUNELYS, société française spécialisée dans la gestion administrative photovoltaïque pour installateurs : DP, Consuel et raccordement Enedis."
  robots="noindex,follow"
  structuredData={structuredData}
>
  <main class="brand-page section-shell">
    <section class="brand-hero">
      <p class="eyebrow">Site officiel</p>
      <h1>Sunelys</h1>
      <p>
        Sunelys est une société française dédiée à la gestion administrative photovoltaïque
        pour les installateurs : déclaration préalable, Consuel, raccordement Enedis et suivi
        documentaire.
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/contact">Contacter Sunelys</a>
        <a class="btn btn-secondary" href="/services">Voir les services</a>
      </div>
    </section>

    <section class="brand-grid" aria-label="Informations officielles Sunelys">
      <article>
        <span>Nom</span>
        <strong>Sunelys</strong>
      </article>
      <article>
        <span>Société</span>
        <strong>SUNELYS SASU</strong>
      </article>
      <article>
        <span>SIREN</span>
        <strong>943 493 759</strong>
      </article>
      <article>
        <span>Activité</span>
        <strong>Administratif photovoltaïque</strong>
      </article>
    </section>

    <section class="brand-copy">
      <h2>La bonne orthographe est Sunelys</h2>
      <p>
        Sunelys s'écrit avec un y. La marque accompagne les professionnels du solaire sur
        la partie administrative de leurs projets, sans réaliser les installations sur chantier.
      </p>
      <p>
        Le site officiel est sunelys.fr et l'adresse de contact officielle est
        contact@sunelys.fr.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .brand-page {
    padding-top: clamp(3.5rem, 8vw, 7rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .brand-hero {
    max-width: 780px;
  }

  .brand-hero h1 {
    margin: 0;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
  }

  .brand-hero p {
    max-width: 680px;
    margin: 1.25rem 0 0;
    color: var(--color-text-soft);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .brand-grid article {
    border: 1px solid rgba(36, 48, 53, 0.12);
    border-radius: 8px;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .brand-grid span {
    display: block;
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  .brand-grid strong {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-text);
  }

  .brand-copy {
    max-width: 720px;
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .brand-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.25rem);
  }

  .brand-copy p {
    color: var(--color-text-soft);
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .brand-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
