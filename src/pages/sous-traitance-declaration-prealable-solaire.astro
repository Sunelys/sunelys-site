---
import BaseLayout from "../layouts/BaseLayout.astro";
import SeoLandingPage from "../components/SeoLandingPage.astro";
import { seoPages } from "../data/seoPages";

const pageData = seoPages.sousTraitanceDeclarationPrealable;
const canonicalUrl = "https://sunelys.fr/sous-traitance-declaration-prealable-solaire";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: pageData.faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: pageData.heroTitle,
    description: pageData.heroSubtitle,
    serviceType: "Sous-traitance déclaration préalable solaire",
    provider: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    areaServed: {
      "@type": "Country",
      name: "France",
    },
    url: canonicalUrl,
  },
];
---

<BaseLayout title={pageData.metaTitle} description={pageData.metaDescription} structuredData={structuredData}>
  <SeoLandingPage data={pageData} />
</BaseLayout>
