    font-size: 0.62rem;
    font-weight: 700;
  }

  .map-head strong {
    color: #ffffff;
    font-size: 0.86rem;
  }

  .map-head > span {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.28rem 0.48rem;
    border-radius: 999px;
    background: rgba(29, 155, 117, 0.12);
    color: #aee7d3;
  }

  .map-head > span i,
  .map-foot span i {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.12);
  }

  .flow-origin {
    display: grid;
    gap: 0.22rem;
    margin: 0.8rem 1rem 0;
    padding: 0.72rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.055);
  }

  .flow-origin span {
    color: var(--accent);
    font-size: 0.58rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .flow-origin strong {
    color: #ffffff;
    font-size: 0.76rem;
  }

  .map-flow {
    position: relative;
    display: grid;
    gap: 0.35rem;
    margin: 0;
    padding: 0.8rem 1rem;
    list-style: none;
  }

  .map-flow::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 2.18rem;
    width: 1px;
    background: linear-gradient(var(--accent), var(--system), var(--success));
    opacity: 0.55;
  }

  .map-flow li {
    position: relative;
    display: grid;
    grid-template-columns: 2.15rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    min-height: 3.45rem;
    padding: 0.55rem 0.7rem 0.55rem 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.04);
  }

  .flow-node {
    z-index: 1;
    display: grid;
    width: 1.5rem;
    height: 1.5rem;
    place-items: center;
    justify-self: center;
    border: 1px solid var(--system);
    border-radius: 0.42rem;
    background: var(--ink);
    color: #aebfff;
    font-size: 0.54rem;
    font-weight: 800;
  }

  .map-flow .is-success .flow-node {
    border-color: var(--success);
    color: #aee7d3;
  }

  .map-flow .is-accent .flow-node {
    border-color: var(--accent);
    color: #ffd2a8;
  }

  .map-flow li > div {
    min-width: 0;
  }

  .map-flow p {
    color: rgba(255, 255, 255, 0.44);
    font-size: 0.56rem;
  }

  .map-flow strong {
    display: block;
    margin-top: 0.12rem;
    overflow: hidden;
    color: #ffffff;
    font-size: 0.72rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .map-flow em {
    padding: 0.25rem 0.42rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.54rem;
    font-style: normal;
    font-weight: 680;
    white-space: nowrap;
  }

  .map-branch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin: 0 1rem 0.8rem;
    padding: 0.62rem 0.75rem;
    border: 1px dashed rgba(212, 130, 42, 0.42);
    border-radius: 10px;
    background: rgba(212, 130, 42, 0.07);
  }

  .map-branch span {
    color: var(--accent);
    font-size: 0.56rem;
    font-weight: 780;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .map-branch strong {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.66rem;
  }

  .map-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.78rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.035);
  }

  .map-foot span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.59rem;
    font-weight: 680;
  }

  .map-foot strong {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.6rem;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
    border-radius: 16px;
    background: var(--ink);
  }

  .proof-strip article {
    min-height: 8rem;
    display: grid;
    align-content: end;
    gap: 0.4rem;
    padding: 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .proof-strip article:last-child {
    border-right: 0;
  }

  .proof-strip strong {
    color: #ffffff;
    font-size: clamp(2rem, 3vw, 3.2rem);
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .proof-strip .is-featured strong {
    color: var(--accent);
  }

  .proof-strip span {
    max-width: 22ch;
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .service-choice-board {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(280px, 0.48fr) minmax(0, 1fr);
    gap: clamp(1rem, 2.8vw, 1.7rem);
    padding: clamp(1.2rem, 3vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--system) 13%, var(--line));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(80% 120% at 100% 0%, color-mix(in srgb, var(--system-soft) 78%, transparent), transparent 65%),
      linear-gradient(90deg, rgba(54, 98, 227, 0.045) 1px, transparent 1px) 0 0 / 40px 40px,
      color-mix(in srgb, var(--surface) 97%, white);
    box-shadow: var(--shadow-sm);
  }

  .service-choice-board::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--system), var(--accent));
  }

  .choice-board-head {
    display: grid;
    align-content: center;
    gap: 0.7rem;
  }

  .choice-board-head h2 {
    max-width: 15ch;
    margin: 0;
    color: var(--ink);
    font-size: clamp(2rem, 3.7vw, 3.6rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
  }

  .choice-board-head > p:not(.eyebrow) {
    max-width: 47ch;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.62;
  }

  .choice-board-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .choice-board-card {
    min-height: 14.5rem;
    display: grid;
    align-content: space-between;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .choice-board-card:hover,
  .choice-board-card:focus-visible {
    border-color: color-mix(in srgb, var(--system) 26%, var(--line));
    background: #ffffff;
    transform: translateY(-2px);
  }

  .choice-board-card > span {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 820;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .choice-board-card strong {
    max-width: 18ch;
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.16;
  }

  .choice-board-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1.52;
  }

  .choice-board-card small {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    padding-top: 0.72rem;
    border-top: 1px solid color-mix(in srgb, var(--system) 10%, var(--line));
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .choice-board-card i {
    color: var(--accent-strong);
    font-style: normal;
    transition: transform 160ms ease;
  }

  .choice-board-card:hover i,
  .choice-board-card:focus-visible i {
    transform: translateX(3px);
  }

  .choice-board-card.is-featured {
    background:
      radial-gradient(90% 90% at 100% 0%, rgba(212, 130, 42, 0.18), transparent 62%),
      var(--ink);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    color: #ffffff;
  }

  .choice-board-card.is-featured > span,
  .choice-board-card.is-featured i {
    color: var(--accent);
  }

  .choice-board-card.is-featured strong,
  .choice-board-card.is-featured small {
    color: #ffffff;
  }

  .choice-board-card.is-featured p {
    color: rgba(255, 255, 255, 0.62);
  }

  .choice-board-card.is-featured small {
    border-top-color: rgba(255, 255, 255, 0.12);
  }

  .delegation-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1.22fr);
    gap: 0.75rem;
    padding: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .delegation-copy {
    padding: clamp(1rem, 2.8vw, 2.2rem);
  }

  .delegation-copy h2,
  .section-head h2,
  .flow-head h2 {
    max-width: 18ch;
    margin-top: 0.6rem;
    font-size: clamp(2rem, 3.6vw, 3.6rem);
  }

  .delegation-copy > p:last-of-type,
  .section-head > p,
  .flow-head > p {
