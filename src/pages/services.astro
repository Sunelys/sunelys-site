  .complete-chain ul {
    display: grid;
    gap: 0.5rem;
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .complete-chain li {
    display: flex;
    gap: 0.55rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.73rem;
    line-height: 1.45;
  }

  .complete-chain li::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    flex: 0 0 auto;
    margin-top: 0.3rem;
    border-radius: 50%;
    background: var(--accent);
