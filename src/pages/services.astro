---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    title: "Gestion administrative photovoltaïque",
    description:
      "Pilotage global du flux administratif pour structurer vos dossiers et soulager vos equipes.",
    href: "/gestion-administrative-photovoltaique",
  },
  {
    title: "Dossier Consuel photovoltaïque",
    description:
      "Preparation, controle et suivi des elements Consuel jusqu'a validation.",
    href: "/dossier-consuel-photovoltaique",
  },
  {
    title: "Raccordement Enedis photovoltaïque",
    description:
      "Gestion du dossier de raccordement et coordination administrative jusqu'a la mise en service.",
    href: "/raccordement-enedis-photovoltaique",
  },
];
---

<BaseLayout
  title="Services photovoltaïques | Sunelys"
  description="Sunelys gère vos démarches administratives photovoltaïques: declaration prealable, raccordement Enedis et dossier Consuel."
>
  <section class="hero card">
    <h1>Services Sunelys</h1>
    <p>
      Nous prenons en charge les démarches administratives liees a votre installation
      photovoltaïque, du premier dossier a la mise en service.
    </p>
  </section>

  <section class="section">
    <h2>Offres specialisees</h2>
    <div class="grid">
      {
        services.map((service) => (
          <article class="card service-card">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <a
              class="cta cta-secondary"
              href={service.href}
              data-track="cta_services_detail"
              data-track-label={service.title}
            >
              Voir le detail
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section card box">
    <h2>Besoin d'un accompagnement complet ?</h2>
    <p>
      Nous adaptons notre intervention selon votre volume de dossiers et votre
      organisation commerciale.
    </p>
    <a class="cta" href="/contact" data-track="cta_services_contact">Demander un audit</a>
  </section>
</BaseLayout>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: var(--shadow);
  }

  h1 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.75rem, 4.5vw, 2.8rem);
    line-height: 1.15;
  }

  h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  h3 {
    margin: 0 0 0.45rem;
    font-size: 1.15rem;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .service-card {
    display: grid;
    gap: 0.75rem;
  }

  .cta {
    display: inline-block;
    padding: 0.72rem 1.2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    color: #f4f1e8;
    background: var(--primary);
  }

  .cta:hover,
  .cta:focus-visible {
    color: var(--primary-dark);
    background: var(--accent-dark);
  }

  .cta-secondary {
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    background: var(--accent);
    border-color: var(--accent-dark);
  }

  .box {
    text-align: center;
    display: grid;
    gap: 0.85rem;
  }

  .box .cta {
    justify-self: center;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
