    display: grid;
    margin-top: 1.3rem;
  }

  .delegation-list article {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .delegation-list article > span {
    color: var(--system);
    font-size: 0.65rem;
    font-weight: 800;
  }

  .delegation-list h3 {
    font-size: 0.88rem;
  }

  .delegation-list p {
    margin-top: 0.2rem;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.5;
  }

  .complete-chain {
    display: flex;
    flex-direction: column;
    padding: clamp(1.3rem, 3vw, 2.7rem);
    border-radius: 17px;
    background:
      radial-gradient(85% 80% at 100% 0%, rgba(54, 98, 227, 0.28), transparent 62%),
      var(--ink);
    color: #ffffff;
  }

  .chain-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .chain-head p,
  .chain-head span {
    font-size: 0.64rem;
    font-weight: 780;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .chain-head p {
    color: var(--accent);
  }

  .chain-head span {
    color: rgba(255, 255, 255, 0.4);
  }

  .complete-chain h2 {
    max-width: 15ch;
    margin-top: clamp(2rem, 4vw, 4rem);
    color: #ffffff;
    font-size: clamp(2rem, 3.8vw, 4rem);
