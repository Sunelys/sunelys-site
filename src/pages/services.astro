---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockedDiagnostic from "../components/BlockedDiagnostic.astro";
import { isVisibleHref, publicBlogSlugs } from "../lib/blogPublication";

const services = [
  {
    title: "Déclaration préalable panneaux solaires",
    benefit: "Des dossiers plus cadrés pour limiter les refus et sécuriser le lancement chantier.",
    description:
      "Sunelys constitue, vérifie et suit la déclaration préalable jusqu'au retour administratif afin de réduire les retours et les délais cachés.",
    points: [
      "Montage administratif du dossier",
      "Contrôle des pièces et cohérence documentaire",
      "Suivi mairie et relances utiles",
    ],
    href: "/declaration-prealable-panneaux-solaires",
    guideHref: "/blog/declaration-prealable-panneaux-solaires-pieces-delais",
    guideLabel: "Lire le guide DP",
  },
  {
    title: "Sous-traitance DP solaire",
    benefit: "Un relais dédié pour absorber vos déclarations préalables sans mobiliser vos équipes.",
    description:
      "Nous cadrons, contrôlons et suivons vos DP solaires dans une logique de flux régulier, avec visibilité sur les statuts et les points manquants.",
    points: [
      "Traitement récurrent des dossiers DP",
      "Contrôle qualité avant dépôt",
      "Organisation adaptée à votre flux",
    ],
    href: "/sous-traitance-declaration-prealable-solaire",
    guideHref: "/blog/sous-traiter-declaration-prealable-photovoltaique",
    guideLabel: "Sous-traiter ses DP",
  },
  {
    title: "Dossier Consuel photovoltaïque",
    benefit: "Une conformité mieux anticipée pour accélérer la mise en service.",
    description:
      "Nous préparons les pièces, suivons les échanges et pilotons le dossier Consuel pour garder de la visibilité jusqu'à validation.",
    points: [
      "Préparation des pièces administratives",
      "Pilotage des compléments demandés",
      "Suivi jusqu'à validation finale",
    ],
    href: "/dossier-consuel-photovoltaique",
    guideHref: "/blog/attestation-consuel-photovoltaique",
    guideLabel: "Attestation Consuel",
  },
  {
    title: "Raccordement Enedis photovoltaïque",
    benefit: "Un suivi réseau centralisé pour mieux tenir vos délais de chantier.",
    description:
      "Sunelys prend en charge le volet administratif du raccordement Enedis et coordonne les jalons pour réduire les angles morts.",
    points: [
      "Constitution du dossier de raccordement",
      "Suivi des échanges administratifs",
      "Traçabilité des jalons et blocages",
    ],
    href: "/raccordement-enedis-photovoltaique",
    guideHref: "/blog/etapes-raccordement-enedis-panneaux-solaires",
    guideLabel: "Étapes raccordement",
  },
  {
    title: "MaPrimeRénov' - montage & suivi",
    benefit: "Des dossiers d'aide structurés pour limiter les refus et sécuriser le versement.",
    description:
      "Sunelys vérifie l'éligibilité, monte le dossier, prépare le dépôt ANAH et suit les échanges jusqu'à la décision.",
    points: [
      "Contrôle des informations client et chantier",
      "Montage conforme du dossier MaPrimeRénov'",
      "Suivi administratif jusqu'au versement",
    ],
    href: "/contact?source=maprimerenov#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer MaPrimeRénov'",
  },
  {
    title: "CEE - certificats d'économies d'énergie",
    benefit: "Un contrôle administratif pour éviter les dossiers CEE rejetés ou incomplets.",
    description:
      "Nous contrôlons les devis et factures, montons le dossier CEE et suivons la validation avec les éléments attendus.",
    points: [
      "Contrôle devis, facture et cohérence documentaire",
      "Montage du dossier CEE",
      "Suivi jusqu'à validation",
    ],
    href: "/contact?source=cee#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer les CEE",
  },
  {
    title: "Pack MaPrimeRénov' + CEE",
    benefit: "Les deux aides pilotées ensemble sur un même chantier.",
    description:
      "Sunelys coordonne le montage MaPrimeRénov' et CEE pour éviter les doublons, les oublis et les allers-retours dispersés.",
    points: [
      "Gestion des deux dossiers d'aides",
      "Suivi coordonné jusqu'aux validations",
      "Lecture claire des pièces manquantes",
    ],
    href: "/contact?source=pack-maprimerenov-cee#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer le pack aides",
  },
  {
    title: "Gestion administrative photovoltaïque",
    benefit: "Un pilotage global pour alléger vos équipes et industrialiser vos flux.",
    description:
      "Quand vos volumes montent, Sunelys structure l'ensemble du parcours administratif pour préserver la qualité d'exécution.",
    points: [
      "Prise en charge multi-dossiers",
      "Méthode documentaire standardisée",
      "Coordination continue avec vos équipes",
    ],
    href: "/gestion-administrative-photovoltaique",
    guideHref: "/blog/externaliser-administratif-photovoltaique",
    guideLabel: "Externaliser l'admin PV",
  },
];

const fitItems = [
  "Vous voulez réduire la charge administrative de vos équipes commerciales ou travaux.",
  "Vous cherchez plus de visibilité sur les dossiers en cours et les points de blocage.",
  "Vous voulez absorber plus de volume sans dégrader l'expérience client.",
];

const partnerMetrics = [
  { value: "96 %", label: "DP sans pièce complémentaire" },
  { value: "48 h", label: "production lorsque le dossier est complet" },
  { value: "1 357", label: "dossiers pilotés" },
];

const completeChainItems = [
  "Déclaration préalable, raccordement réseau et Consuel dans le même flux",
  "Un interlocuteur unique pour centraliser les échanges et les relances",
  "Pilotage intégral de A à Z, avec suivi en temps réel côté installateur",
  "199 € HT / dossier, tarif unitaire fixe",
];

const renovationAidItems = [
  "MaPrimeRénov' : montage et suivi à 129 € HT / dossier",
  "CEE : contrôle, montage et validation à 99 € HT / dossier",
  "Pack MaPrimeRénov' + CEE : gestion des deux dossiers à 199 € HT / dossier",
];

const visibleServices = services.map((service) => ({
  ...service,
  showGuide: Boolean(service.guideHref) && isVisibleHref(service.guideHref, publicBlogSlugs),
}));
---

<BaseLayout
  title="Services administratifs photovoltaïques | Sunelys"
  description="DP, Consuel, raccordement, MaPrimeRénov' et CEE : services administratifs délégables pour installateurs et structures ENR."
>
  <section class="hero card">
    <p class="eyebrow">Services Sunelys</p>
    <h1>Externalisez le pilotage administratif photovoltaïque, sans perdre la maîtrise de vos dossiers.</h1>
    <p class="intro">
      Sunelys prend en charge le pilotage complet de vos dossiers administratifs qui ralentissent vos installations.
      Vos équipes gardent la relation commerciale, nous sécurisons l'exécution documentaire, les aides et les priorités.
    </p>
    <div class="hero-actions">
      <a class="cta" href="/contact?source=services#contact-form" data-track="cta_services_hero_primary">Cadrer votre pilotage complet</a>
      <a class="cta cta-secondary" href="/parcours" data-track="cta_services_hero_secondary">Voir le fonctionnement</a>
    </div>
  </section>

  <section class="section proof-strip" aria-label="Preuves opérationnelles Sunelys">
    {partnerMetrics.map((metric) => (
      <article class="proof-metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </article>
    ))}
  </section>

  <section class="section fit-grid">
    <article class="card fit-card">
      <p class="eyebrow">Pour qui</p>
      <h2>Le bon fit pour les installateurs qui veulent industrialiser sans rigidifier.</h2>
      <ul>
        {fitItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="card fit-card highlight-card">
      <p class="eyebrow">Bénéfices métier</p>
      <h2>Moins de charge interne. Plus de dossiers bien pilotés.</h2>
      <div class="benefit-list">
        <p>Moins de retours documentaires</p>
        <p>Plus de visibilité sur les étapes</p>
        <p>Des délais mieux tenus côté client</p>
      </div>
    </article>
  </section>

  <section class="section card complete-chain">
    <div>
      <p class="eyebrow">Recommandé</p>
      <h2>Chaîne administrative complète : le choix des installateurs qui veulent piloter sans recruter.</h2>
      <p>
        Sunelys peut piloter toute la chaîne DP, raccordement et Consuel avec un seul interlocuteur,
        une production sous 48h lorsque le dossier est complet, une visibilité continue sur les statuts
        et un tarif unique par dossier.
      </p>
    </div>
    <ul>
      {completeChainItems.map((item) => <li>{item}</li>)}
    </ul>
    <div class="box-actions">
      <a class="cta" href="/contact?source=services-pilotage-complet#contact-form" data-track="cta_services_complete_chain">
        Cadrer un pilotage complet
      </a>
      <a class="cta cta-secondary" href="/tarifs" data-track="cta_services_complete_chain_tarifs">
        Voir les tarifs
      </a>
    </div>
  </section>

  <section class="section card complete-chain aid-chain">
    <div>
      <p class="eyebrow">Nouveau</p>
      <h2>Aides à la rénovation : MaPrimeRénov' et CEE pilotés sans dispersion.</h2>
      <p>
        Les dossiers d'aides demandent autant de rigueur que les démarches photovoltaïques :
        éligibilité, pièces client, devis, factures, dépôt et suivi jusqu'à validation.
        Sunelys peut gérer MaPrimeRénov', les CEE ou les deux ensemble.
      </p>
    </div>
    <ul>
      {renovationAidItems.map((item) => <li>{item}</li>)}
    </ul>
    <div class="box-actions">
      <a class="cta" href="/contact?source=aides-renovation#contact-form" data-track="cta_services_aides_renovation">
        Cadrer vos aides
      </a>
      <a class="cta cta-secondary" href="/tarifs#aides-renovation" data-track="cta_services_aides_tarifs">
        Voir les tarifs aides
      </a>
    </div>
  </section>

  <BlockedDiagnostic
    source="services_diagnostic_dossiers_bloques"
    title="Vous avez plusieurs dossiers à débloquer ? On identifie le flux à reprendre en premier."
    text="Le diagnostic aide à prioriser entre DP, Consuel, raccordement et pilotage global, sans transformer tout votre process d'un coup."
  />

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Offres spécialisées</p>
      <h2>Huit blocs d'intervention selon votre organisation.</h2>
    </div>
    <div class="grid">
      {
        visibleServices.map((service) => (
          <article class="card service-card">
            <div class="service-copy">
              <h3>{service.title}</h3>
              <p class="benefit">{service.benefit}</p>
              <p>{service.description}</p>
            </div>
            <ul>
              {service.points.map((point) => <li>{point}</li>)}
            </ul>
            <a
              class="cta cta-secondary"
              href={service.href}
              data-track="cta_services_detail"
              data-track-label={service.title}
            >
              {service.ctaLabel ?? "Voir le détail"}
            </a>
            {
              service.showGuide && (
                <a
                  class="service-guide-link"
                  href={service.guideHref}
                  data-track="cta_services_guide"
                  data-track-label={service.title}
                >
                  {service.guideLabel}
                </a>
              )
            }
          </article>
        ))
      }
    </div>
  </section>

  <section class="section card box">
    <p class="eyebrow">Accompagnement</p>
    <h2>Vous voulez piloter votre administratif au complet ?</h2>
    <p>
      Nous adaptons le niveau de prise en charge à votre organisation, à votre structure et à la
      maturité de vos flux administratifs.
    </p>
    <div class="box-actions">
      <a class="cta" href="/contact?source=services-final#contact-form" data-track="cta_services_contact">Démarrer un cadrage complet</a>
      <a class="cta cta-secondary" href="/tarifs" data-track="cta_services_pricing">Comprendre les offres</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 95%, white),
      var(--surface)
    );
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(1.15rem, 2.6vw, 2rem);
    box-shadow: var(--shadow-md);
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.8vw, 4.4rem);
    line-height: 0.95;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2.4rem);
    line-height: 1.02;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1.4vw, 1.45rem);
    line-height: 1.12;
  }

  p,
  li {
    margin: 0;
    color: var(--text-muted);
  }

  .intro {
    max-width: 62ch;
    font-size: var(--step-0);
    line-height: 1.6;
  }

  .hero {
    display: grid;
    gap: 1rem;
  }

  .hero-actions,
  .box-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .fit-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.85rem;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .proof-metric {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
    padding: 1rem;
    display: grid;
    gap: 0.28rem;
  }

  .proof-metric strong {
    color: var(--text);
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 0.95;
  }

  .proof-metric span {
    color: var(--text-muted);
    line-height: 1.35;
  }

  .complete-chain {
    display: grid;
    gap: 1rem;
    background:
      radial-gradient(100% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 38%, transparent), transparent 58%),
      linear-gradient(165deg, #1b1712, #11100d);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .complete-chain h2,
  .complete-chain p,
  .complete-chain li,
  .complete-chain .eyebrow {
    color: #f7f2e8;
  }

  .complete-chain p,
  .complete-chain li {
    color: #ded2c1;
  }

  .complete-chain ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.46rem;
  }

  .fit-card {
    display: grid;
    gap: 0.9rem;
  }

  .fit-card ul,
  .service-card ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.42rem;
  }

  .service-guide-link {
    width: fit-content;
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .service-guide-link:hover,
  .service-guide-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .highlight-card {
    background:
      radial-gradient(
        120% 110% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 58%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
  }

  .benefit-list {
    display: grid;
    gap: 0.55rem;
  }

  .benefit-list p,
  .benefit {
    color: var(--text);
    font-weight: 600;
  }

  .section-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.9rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .service-card {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .service-copy {
    display: grid;
    gap: 0.55rem;
  }

  .box {
    display: grid;
    gap: 1rem;
    justify-items: start;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.22rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    color: #f7f3ec;
    background: var(--text);
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease;
  }

  .cta:hover,
  .cta:focus-visible {
    color: #fff;
    background: #0f0d0a;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .cta-secondary {
    color: var(--text);
    background: transparent;
    border: 1px solid var(--line);
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
  }

  @media (max-width: 900px) {
    .fit-grid,
    .proof-strip,
    .grid {
      grid-template-columns: 1fr;
    }

    .hero-actions,
    .box-actions {
      display: grid;
    }

    .hero-actions .cta,
    .box-actions .cta {
      width: 100%;
    }
  }
</style>
