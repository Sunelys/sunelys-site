  .core-service-list ul,
  .flow-grid ul {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .core-service-list li,
  .flow-grid li {
    display: flex;
    gap: 0.48rem;
    color: var(--text-muted);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .core-service-list li::before,
  .flow-grid li::before {
    content: "";
    width: 0.36rem;
    height: 0.36rem;
    flex: 0 0 auto;
    margin-top: 0.28rem;
    border-radius: 50%;
    background: var(--system);
  }

  .service-actions {
    display: grid;
    justify-items: start;
    gap: 0.75rem;
  }

  .service-actions a:last-child:not(:first-child) {
    color: var(--text-muted);
    font-size: 0.64rem;
  }

  .flow-services {
    display: grid;
    grid-template-columns: minmax(280px, 0.64fr) minmax(0, 1.36fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
