  .flow-grid article {
    min-height: 29rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1rem, 2.2vw, 1.6rem);
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 16px;
    background: #ffffff;
