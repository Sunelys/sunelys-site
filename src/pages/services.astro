  .service-map {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 18px;
    background:
      radial-gradient(100% 80% at 100% 0%, rgba(54, 98, 227, 0.2), transparent 56%),
      var(--ink);
    box-shadow: 0 30px 80px rgba(14, 23, 38, 0.24);
  }

  .map-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
