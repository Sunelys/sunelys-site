  .is-primary .flow-card-head p {
    color: var(--accent);
  }

  .flow-grid h3 {
    max-width: 16ch;
    margin-top: 2.5rem;
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
  }

  .is-primary h3 {
    color: #ffffff;
  }

  .flow-benefit {
    margin-top: 0.9rem;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .flow-description {
    margin-top: 0.5rem;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.55;
  }

  .flow-grid ul {
    margin-top: 1.2rem;
  }

  .is-primary .flow-benefit {
    color: rgba(255, 255, 255, 0.88);
  }

  .is-primary .flow-description,
  .is-primary li,
  .is-primary .flow-decision-cue {
    color: rgba(255, 255, 255, 0.52);
  }

  .is-primary .flow-price-chip {
    border-color: rgba(212, 130, 42, 0.3);
    background: rgba(212, 130, 42, 0.12);
  }

  .is-primary .flow-price-chip span {
    color: #ffffff;
  }

  .is-primary .flow-price-chip small {
    color: rgba(255, 255, 255, 0.52);
  }

  .is-primary li::before {
    background: var(--accent);
  }

