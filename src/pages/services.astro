  .service-index {
    display: grid;
    justify-items: center;
    gap: 0.5rem;
  }

  .service-index span {
    color: var(--system);
    font-size: 0.66rem;
    font-weight: 800;
  }

  .service-index i {
    width: 0.5rem;
    height: 0.5rem;
    border: 2px solid var(--accent);
    border-radius: 50%;
  }

  .service-main h3 {
    max-width: 18ch;
    font-size: clamp(1.45rem, 2.2vw, 2.2rem);
  }

  .service-benefit {
    max-width: 47ch;
    margin-top: 0.65rem;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .service-description {
    max-width: 54ch;
    margin-top: 0.42rem;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.52;
  }

  .service-price-chip,
  .flow-price-chip {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
    width: fit-content;
    margin-top: 0.8rem;
    padding: 0.46rem 0.62rem;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 42%, white);
  }

  .service-price-chip span,
  .flow-price-chip span {
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 820;
  }

  .service-price-chip small,
  .flow-price-chip small {
    color: var(--text-muted);
    font-size: 0.62rem;
    font-weight: 720;
  }

  .service-decision-cue,
  .flow-decision-cue,
  .aid-decision-cue {
    margin: 0;
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.48;
