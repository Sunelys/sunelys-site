    border-radius: var(--radius-xl);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.58fr);
    gap: clamp(1.2rem, 4vw, 4rem);
    align-items: end;
  }

  .section-head > p {
    margin-top: 0;
  }

  .core-service-list {
    margin-top: 1.8rem;
    border-top: 1px solid var(--line);
  }

  .core-service-list > article {
    display: grid;
    grid-template-columns:
      auto minmax(250px, 1.05fr) minmax(180px, 0.72fr)
      minmax(150px, 0.62fr) minmax(120px, auto);
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: center;
    min-height: 13rem;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--line);
