  .chain-price {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-top: auto;
    padding-top: 1.6rem;
  }

  .chain-price > div {
    display: grid;
    gap: 0.12rem;
  }

  .chain-price strong {
    color: var(--accent);
    font-size: clamp(2.8rem, 5vw, 5rem);
    letter-spacing: -0.065em;
    line-height: 0.9;
  }

  .chain-price > div span {
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.65rem;
    font-weight: 700;
  }

  .chain-price a {
    color: rgba(255, 255, 255, 0.76);
  }

  .core-services,
  .aid-services {
    padding: clamp(1.3rem, 3vw, 2.6rem);
