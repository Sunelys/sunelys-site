  .flow-card-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .flow-card-head span,
  .flow-card-head p {
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 780;
    text-transform: uppercase;
