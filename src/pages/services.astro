---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockedDiagnostic from "../components/BlockedDiagnostic.astro";
import { isVisibleHref, publicBlogSlugs } from "../lib/blogPublication";

const services = [
  {
    title: "Déclaration préalable panneaux solaires",
    shortTitle: "Déclaration préalable",
    benefit: "Des dossiers mieux cadrés pour limiter les refus et sécuriser le lancement chantier.",
    description:
      "Sunelys constitue, vérifie et suit la déclaration préalable jusqu'au retour administratif afin de réduire les compléments et les délais cachés.",
    points: ["Montage du dossier", "Contrôle documentaire", "Dépôt et suivi mairie"],
    href: "/declaration-prealable-panneaux-solaires",
    guideHref: "/blog/declaration-prealable-panneaux-solaires-pieces-delais",
    guideLabel: "Lire le guide DP",
  },
  {
    title: "Sous-traitance DP solaire",
    shortTitle: "Sous-traitance DP",
    benefit: "Un relais dédié pour absorber vos déclarations préalables sans mobiliser vos équipes.",
    description:
      "Nous cadrons, contrôlons et suivons vos DP solaires dans une logique de flux régulier, avec une visibilité claire sur les statuts.",
    points: ["Traitement récurrent", "Contrôle avant dépôt", "Organisation adaptée au flux"],
    href: "/sous-traitance-declaration-prealable-solaire",
    guideHref: "/blog/sous-traiter-declaration-prealable-photovoltaique",
    guideLabel: "Sous-traiter ses DP",
  },
  {
    title: "Dossier Consuel photovoltaïque",
    shortTitle: "Consuel",
    benefit: "Une conformité mieux anticipée pour accélérer la mise en service.",
    description:
      "Nous préparons les pièces, suivons les échanges et pilotons le dossier Consuel jusqu'à validation.",
    points: ["Préparation des pièces", "Gestion des compléments", "Suivi jusqu'à validation"],
    href: "/dossier-consuel-photovoltaique",
    guideHref: "/blog/attestation-consuel-photovoltaique",
    guideLabel: "Attestation Consuel",
  },
  {
    title: "Raccordement Enedis photovoltaïque",
    shortTitle: "Raccordement Enedis",
    benefit: "Un suivi réseau centralisé pour mieux tenir les délais de chantier.",
    description:
      "Sunelys prend en charge le volet administratif du raccordement et coordonne les jalons pour réduire les angles morts.",
    points: ["Constitution du dossier", "Suivi des échanges", "Traçabilité des jalons"],
    href: "/raccordement-enedis-photovoltaique",
    guideHref: "/blog/etapes-raccordement-enedis-panneaux-solaires",
    guideLabel: "Étapes raccordement",
  },
  {
    title: "EDF OA - compte et contrat d'achat",
    shortTitle: "EDF OA",
    benefit: "Un parcours contractuel cadré jusqu'à la signature électronique du client final.",
    description:
      "Sunelys accompagne l'activation de l'espace producteur, suit le dossier et sécurise les demandes de complément.",
    points: ["Activation du compte", "Suivi du dossier", "Invitation de signature"],
    href: "/edf-oa",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Voir l'offre EDF OA",
  },
  {
    title: "MaPrimeRénov' - montage & suivi",
    shortTitle: "MaPrimeRénov'",
    benefit: "Des dossiers d'aide structurés pour limiter les refus et sécuriser le versement.",
    description:
      "Sunelys vérifie l'éligibilité, monte le dossier, prépare le dépôt ANAH et suit les échanges jusqu'à la décision.",
    points: ["Contrôle d'éligibilité", "Montage et dépôt", "Suivi jusqu'au versement"],
    href: "/contact?source=maprimerenov#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer MaPrimeRénov'",
    price: "129 €",
  },
  {
    title: "CEE - certificats d'économies d'énergie",
    shortTitle: "CEE",
    benefit: "Un contrôle administratif pour éviter les dossiers rejetés ou incomplets.",
    description:
      "Nous contrôlons les devis et factures, montons le dossier CEE et suivons la validation avec les éléments attendus.",
    points: ["Contrôle documentaire", "Montage du dossier", "Suivi jusqu'à validation"],
    href: "/contact?source=cee#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer les CEE",
    price: "99 €",
  },
  {
    title: "Pack MaPrimeRénov' + CEE",
    shortTitle: "Pack aides",
    benefit: "Les deux aides pilotées ensemble sur un même chantier.",
    description:
      "Sunelys coordonne les deux montages pour éviter les doublons, les oublis et les allers-retours dispersés.",
    points: ["Deux dossiers coordonnés", "Suivi des validations", "Pièces manquantes visibles"],
    href: "/contact?source=pack-maprimerenov-cee#contact-form",
    guideHref: "",
    guideLabel: "",
    ctaLabel: "Cadrer le pack aides",
    price: "199 €",
  },
  {
    title: "Gestion administrative photovoltaïque",
    shortTitle: "Pilotage multi-dossiers",
    benefit: "Un pilotage global pour alléger vos équipes et industrialiser vos flux.",
    description:
      "Quand les volumes montent, Sunelys structure l'ensemble du parcours administratif pour préserver la qualité d'exécution.",
    points: ["Prise en charge multi-dossiers", "Méthode standardisée", "Coordination continue"],
    href: "/gestion-administrative-photovoltaique",
    guideHref: "/blog/externaliser-administratif-photovoltaique",
    guideLabel: "Externaliser l'admin PV",
  },
];

const coreServices = [services[0], services[2], services[3], services[4]];
const flowServices = [services[1], services[8]];
const aidServices = [services[5], services[6], services[7]];

const delegationModes = [
  {
    label: "Dossier ponctuel",
    text: "Une démarche précise ou un dossier déjà bloqué à reprendre proprement.",
  },
  {
    label: "Pic de charge",
    text: "Un volume temporaire à absorber sans dégrader vos délais internes.",
  },
  {
    label: "Flux récurrent",
    text: "Une organisation stable pour déléguer chaque nouveau dossier.",
  },
];

const partnerMetrics = [
  { value: "96 %", label: "DP sans pièce complémentaire" },
  { value: "48 h", label: "production sur dossier complet" },
  { value: "1 357", label: "dossiers pilotés" },
  { value: "24 h", label: "pour recevoir un cadrage" },
];

const completeChainItems = [
  "Déclaration préalable, raccordement réseau et Consuel dans le même flux",
  "Un interlocuteur unique pour centraliser les échanges et les relances",
  "Suivi en temps réel côté installateur",
  "199 € HT par dossier, sans abonnement",
];

const visibleCoreServices = coreServices.map((service) => ({
  ...service,
  showGuide: Boolean(service.guideHref) && isVisibleHref(service.guideHref, publicBlogSlugs),
}));

const visibleFlowServices = flowServices.map((service) => ({
  ...service,
  showGuide: Boolean(service.guideHref) && isVisibleHref(service.guideHref, publicBlogSlugs),
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  name: "Services administratifs Sunelys",
  itemListElement: services.map((service) => ({
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: service.title,
      description: service.description,
      url: new URL(service.href, "https://sunelys.fr").toString(),
    },
  })),
};
---

<BaseLayout
  title="Services administratifs photovoltaïques | Sunelys"
  description="DP, Consuel, raccordement, EDF OA, MaPrimeRénov' et CEE : services administratifs délégables pour installateurs et structures ENR."
  structuredData={[structuredData]}
>
  <section class="services-hero reveal" aria-labelledby="services-title">
    <div class="hero-copy" data-reveal-item>
      <p class="eyebrow">Services Sunelys</p>
      <h1 id="services-title">Déléguez l’administratif. Gardez la maîtrise du chantier.</h1>
      <p class="hero-intro">
        Sunelys reprend une démarche précise ou pilote l’ensemble du flux administratif photovoltaïque. Vos équipes
        conservent la relation client ; nous sécurisons les pièces, les échanges et les prochaines actions.
      </p>

      <div class="hero-actions">
        <a
          class="btn btn-accent"
          href="#blocked-diagnostic-services_diagnostic_dossiers_bloques"
          data-track="cta_services_hero_primary"
        >
          Faire cadrer mon besoin
          <span aria-hidden="true">→</span>
        </a>
        <a class="hero-link" href="/tarifs" data-track="cta_services_hero_pricing">
          Voir les tarifs fixes
          <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="hero-assurance">
        <span><i aria-hidden="true"></i> Dossier ponctuel accepté</span>
        <span><i aria-hidden="true"></i> Aucun abonnement</span>
      </div>
    </div>

    <aside class="service-map" aria-label="Périmètre des services Sunelys" data-reveal-item>
      <div class="map-head">
        <div>
          <p>Périmètre administratif</p>
          <strong>Un suivi de bout en bout</strong>
        </div>
        <span>5 expertises</span>
      </div>
      <div class="map-list">
        {
          ["Déclaration préalable", "Consuel", "Raccordement Enedis", "EDF OA", "MaPrimeRénov' + CEE"].map(
            (label, index) => (
              <div class:list={["map-row", index === 4 && "is-aid"]}>
                <span>0{index + 1}</span>
                <p>{label}</p>
                <strong><i aria-hidden="true"></i> Délégable</strong>
              </div>
            ),
          )
        }
      </div>
      <div class="map-foot">
        <span>Portail de suivi</span>
        <span>Interlocuteur humain</span>
      </div>
    </aside>
  </section>

  <section class="proof-strip reveal" aria-label="Preuves opérationnelles Sunelys">
    {
      partnerMetrics.map((metric, index) => (
        <article class:list={[index === 0 && "is-featured"]} data-reveal-item>
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
        </article>
      ))
    }
  </section>

  <section class="delegation-section reveal" aria-labelledby="delegation-title">
    <div class="delegation-copy" data-reveal-item>
      <p class="eyebrow">Votre organisation</p>
      <h2 id="delegation-title">Trois façons simples de commencer.</h2>
      <p>
        La délégation n’impose pas de basculer tout votre process. Le périmètre peut évoluer au rythme de vos
        dossiers et de votre charge interne.
      </p>

      <div class="delegation-list">
        {
          delegationModes.map((mode, index) => (
            <article>
              <span>0{index + 1}</span>
              <div>
                <h3>{mode.label}</h3>
                <p>{mode.text}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <aside class="complete-chain" data-reveal-item>
      <div class="chain-head">
        <p>Solution recommandée</p>
        <span>DP + Enedis + Consuel</span>
      </div>
      <h2>La chaîne administrative complète.</h2>
      <p>
        Un seul flux, un seul interlocuteur et une visibilité continue, sans recruter une ressource administrative
        supplémentaire.
      </p>
      <ul>
        {completeChainItems.map((item) => <li>{item}</li>)}
      </ul>
      <div class="chain-price">
        <div>
          <strong>199 €</strong>
          <span>HT / dossier</span>
        </div>
        <a href="/tarifs#tarifs-photovoltaique" data-track="cta_services_complete_chain_tarifs">
          Voir le détail
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </aside>
  </section>

  <section class="core-services reveal" aria-labelledby="core-services-title">
    <div class="section-head" data-reveal-item>
      <div>
        <p class="eyebrow">Démarches photovoltaïques</p>
        <h2 id="core-services-title">Déléguez l’étape qui ralentit vos installations.</h2>
      </div>
      <p>
        Chaque service dispose d’un périmètre précis. Vous pouvez commencer par une seule étape avant d’élargir la
        prise en charge.
      </p>
    </div>

    <div class="core-service-list">
      {
        visibleCoreServices.map((service, index) => (
          <article data-reveal-item>
            <div class="service-index">
              <span>0{index + 1}</span>
              <i aria-hidden="true"></i>
            </div>
            <div class="service-main">
              <h3>{service.shortTitle}</h3>
              <p class="service-benefit">{service.benefit}</p>
              <p class="service-description">{service.description}</p>
            </div>
            <ul>
              {service.points.map((point) => <li>{point}</li>)}
            </ul>
            <div class="service-actions">
              <a href={service.href} data-track="cta_services_detail" data-track-label={service.title}>
                {service.ctaLabel ?? "Voir le service"}
                <span aria-hidden="true">→</span>
              </a>
              {
                service.showGuide && (
                  <a href={service.guideHref} data-track="cta_services_guide" data-track-label={service.title}>
                    {service.guideLabel}
                  </a>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="flow-services reveal" aria-labelledby="flow-services-title">
    <div class="flow-head" data-reveal-item>
      <p class="eyebrow">Organisation des flux</p>
      <h2 id="flow-services-title">Quand le problème n’est plus un dossier, mais le volume.</h2>
      <p>
        Sunelys peut devenir le relais administratif régulier de vos équipes, sur les seules DP ou sur l’ensemble
        du parcours photovoltaïque.
      </p>
    </div>

    <div class="flow-grid">
      {
        visibleFlowServices.map((service, index) => (
          <article class:list={[index === 1 && "is-primary"]} data-reveal-item>
            <div class="flow-card-head">
              <span>0{index + 1}</span>
              <p>{index === 0 ? "Spécialisation DP" : "Pilotage global"}</p>
            </div>
            <h3>{service.shortTitle}</h3>
            <p class="flow-benefit">{service.benefit}</p>
            <p class="flow-description">{service.description}</p>
            <ul>
              {service.points.map((point) => <li>{point}</li>)}
            </ul>
            <a href={service.href} data-track="cta_services_flow_detail">
              Explorer cette organisation
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="aid-services reveal" aria-labelledby="aid-services-title">
    <div class="section-head" data-reveal-item>
      <div>
        <p class="eyebrow">Aides à la rénovation</p>
        <h2 id="aid-services-title">MaPrimeRénov’ et CEE, sans dispersion documentaire.</h2>
      </div>
      <p>
        Éligibilité, devis, factures, dépôt et suivi : les deux aides peuvent être confiées séparément ou pilotées
        ensemble.
      </p>
    </div>

    <div class="aid-grid">
      {
        aidServices.map((service, index) => (
          <article class:list={[index === 2 && "is-featured"]} data-reveal-item>
            <div class="aid-top">
              <span>0{index + 1}</span>
              {index === 2 && <p>Le plus demandé</p>}
            </div>
            <h3>{service.shortTitle}</h3>
            <p>{service.benefit}</p>
            <div class="aid-price">
              <strong>{service.price}</strong>
              <span>HT / dossier</span>
            </div>
            <a href={service.href} data-track="cta_services_aid_detail">
              {service.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>

    <a class="pricing-link" href="/tarifs#aides-renovation" data-track="cta_services_aides_tarifs">
      Comparer les tarifs des aides
      <span aria-hidden="true">↗</span>
    </a>
  </section>

  <BlockedDiagnostic
    source="services_diagnostic_dossiers_bloques"
    title="Quel flux faut-il sortir de votre équipe en premier ?"
    text="Indiquez votre volume, l'étape qui bloque et votre urgence. Sunelys vous répond avec un premier périmètre concret, sans transformer tout votre process."
    submitLabel="Recevoir mon cadrage sous 24h"
  />
</BaseLayout>

<style>
  .services-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(350px, 0.74fr);
    gap: clamp(1.5rem, 4vw, 4.2rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(1.5rem, 3.8vw, 4rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 100% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 62%),
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .eyebrow {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy .eyebrow {
    color: var(--accent);
  }

  h1 {
    max-width: 14ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 5.15rem);
    line-height: 0.94;
  }

  .hero-intro {
    max-width: 62ch;
    margin-top: 1.15rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-link,
  .core-service-list a,
  .flow-grid a,
  .aid-grid a,
  .pricing-link,
  .chain-price a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    color: inherit;
    font-size: 0.76rem;
    font-weight: 760;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 28%, transparent);
    text-underline-offset: 0.28rem;
  }

  .hero-link {
    color: rgba(255, 255, 255, 0.76);
  }

  .hero-link span,
  .core-service-list a span,
  .flow-grid a span,
  .aid-grid a span,
  .pricing-link span,
  .chain-price a span {
    color: var(--accent);
  }

  .hero-assurance {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    margin-top: 1.35rem;
  }

  .hero-assurance span {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.69rem;
    font-weight: 650;
  }

  .hero-assurance i,
  .map-row strong i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.14);
  }

  .service-map {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    background: #f8fafc;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .map-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--line);
    background: #ffffff;
  }

  .map-head > div {
    display: grid;
    gap: 0.12rem;
  }

  .map-head p,
  .map-head > span {
    color: var(--text-muted);
    font-size: 0.62rem;
    font-weight: 700;
  }

  .map-head strong {
    color: var(--text);
    font-size: 0.86rem;
  }

  .map-head > span {
    padding: 0.28rem 0.48rem;
    border-radius: 999px;
    background: var(--system-soft);
    color: var(--system);
  }

  .map-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 3.7rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .map-row > span {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 800;
  }

  .map-row p {
    color: var(--text);
    font-size: 0.74rem;
    font-weight: 720;
  }

  .map-row strong {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--text-muted);
    font-size: 0.6rem;
  }

  .map-row.is-aid {
    background: var(--system-soft);
  }

  .map-foot {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding: 0.72rem 1rem;
  }

  .map-foot span {
    color: var(--text-muted);
    font-size: 0.59rem;
    font-weight: 680;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
    border-radius: 16px;
    background: var(--ink);
  }

  .proof-strip article {
    min-height: 8rem;
    display: grid;
    align-content: end;
    gap: 0.4rem;
    padding: 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .proof-strip article:last-child {
    border-right: 0;
  }

  .proof-strip strong {
    color: #ffffff;
    font-size: clamp(2rem, 3vw, 3.2rem);
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .proof-strip .is-featured strong {
    color: var(--accent);
  }

  .proof-strip span {
    max-width: 22ch;
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .delegation-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1.22fr);
    gap: 0.75rem;
    padding: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .delegation-copy {
    padding: clamp(1rem, 2.8vw, 2.2rem);
  }

  .delegation-copy h2,
  .section-head h2,
  .flow-head h2 {
    max-width: 18ch;
    margin-top: 0.6rem;
    font-size: clamp(2rem, 3.6vw, 3.6rem);
  }

  .delegation-copy > p:last-of-type,
  .section-head > p,
  .flow-head > p {
    max-width: 53ch;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.87rem;
    line-height: 1.62;
  }

  .delegation-list {
    display: grid;
    margin-top: 1.3rem;
  }

  .delegation-list article {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .delegation-list article > span {
    color: var(--system);
    font-size: 0.65rem;
    font-weight: 800;
  }

