---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProofSection from "../components/ProofSection.astro";
import FrictionSection from "../components/FrictionSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import PortalSection from "../components/PortalSection.astro";
import CaseStudySection from "../components/CaseStudySection.astro";
import VisionSection from "../components/VisionSection.astro";
import FinalCTASection from "../components/FinalCTASection.astro";
import {
  caseStudySectionData,
  finalCtaSectionData,
  frictionSectionData,
  heroData,
  homeSeo,
  portalSectionData,
  processSectionData,
  proofSectionData,
  servicesSectionData,
  visionSectionData,
} from "../data/home";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Gestion administrative photovoltaïque",
    provider: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Services Sunelys",
      itemListElement: servicesSectionData.cards.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service.title,
          description: service.description,
          url: `https://sunelys.fr${service.href}`,
        },
      })),
    },
  },
];
---

<BaseLayout title={homeSeo.title} description={homeSeo.description} structuredData={structuredData}>
  <Hero data={heroData} />
  <ProofSection data={proofSectionData} />
  <FrictionSection data={frictionSectionData} />
  <ProcessSection data={processSectionData} />
  <ServicesSection data={servicesSectionData} />
  <PortalSection data={portalSectionData} />
  <CaseStudySection data={caseStudySectionData} />
  <VisionSection data={visionSectionData} />
  <FinalCTASection data={finalCtaSectionData} />
</BaseLayout>
