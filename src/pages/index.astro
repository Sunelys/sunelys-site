---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProofSection from "../components/ProofSection.astro";
import SolutionSection from "../components/SolutionSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import PortalSection from "../components/PortalSection.astro";
import MiniQuiz from "../components/MiniQuiz.astro";
import CaseStudySection from "../components/CaseStudySection.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTASection from "../components/FinalCTASection.astro";
import {
  caseStudySectionData,
  faqSectionData,
  finalCtaSectionData,
  heroData,
  homeSeo,
  portalSectionData,
  processSectionData,
  proofSectionData,
  quizSectionData,
  servicesSectionData,
  solutionSectionData,
} from "../data/home";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Gestion administrative photovoltaïque",
    areaServed: "France",
    provider: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Services Sunelys",
      itemListElement: servicesSectionData.cards.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service.title,
          description: service.description,
          url: `https://sunelys.fr${service.href}`,
        },
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqSectionData.items.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title={homeSeo.title} description={homeSeo.description} structuredData={structuredData}>
  <Hero data={heroData} />
  <ProofSection data={proofSectionData} />
  <MiniQuiz data={quizSectionData} />
  <SolutionSection data={solutionSectionData} />
  <ServicesSection data={servicesSectionData} />
  <PortalSection data={portalSectionData} />
  <ProcessSection data={processSectionData} />
  <CaseStudySection data={caseStudySectionData} />
  <FAQ data={faqSectionData} />
  <FinalCTASection data={finalCtaSectionData} />
</BaseLayout>
