---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProofBar from "../components/ProofBar.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Steps from "../components/Steps.astro";
import ServicesCards from "../components/ServicesCards.astro";
import CaseStudy from "../components/CaseStudy.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from "../components/FinalCTA.astro";
import MiniQuiz from "../components/MiniQuiz.astro";
import {
  caseStudyData,
  faqData,
  finalCtaData,
  frictionData,
  heroData,
  homeSeo,
  proofData,
  quizData,
  servicesData,
  stepsData,
} from "../data/home";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Gestion administrative photovoltaïque",
    provider: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Services Sunelys",
      itemListElement: servicesData.items.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service.title,
          description: service.text,
          url: `https://sunelys.fr${service.href}`,
        },
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqData.items.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title={homeSeo.title} description={homeSeo.description} structuredData={structuredData}>
  <Hero data={heroData} />
  <ProofBar data={proofData} />
  <FeatureGrid data={frictionData} />
  <Steps data={stepsData} />
  <ServicesCards data={servicesData} />
  <MiniQuiz data={quizData} />
  <CaseStudy data={caseStudyData} />
  <FAQ data={faqData} />
  <FinalCTA data={finalCtaData} />
</BaseLayout>
