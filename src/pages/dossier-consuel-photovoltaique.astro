---
import BaseLayout from "../layouts/BaseLayout.astro";

const processSteps = [
  "Verification de la conformite documentaire avant depot",
  "Preparation du dossier Consuel selon votre configuration",
  "Coordination des ajustements jusqu'a validation",
  "Suivi des etapes finales avant mise en service",
];

const scopeItems = [
  "Cadrage du dossier Consuel photovoltaïque",
  "Controle des pieces et des informations critiques",
  "Gestion des echanges administratifs",
  "Alerte proactive sur les points bloquants",
  "Suivi jusqu'a obtention de l'attestation",
];

const faqItems = [
  {
    question: "Pourquoi externaliser le dossier Consuel ?",
    answer:
      "Pour reduire les erreurs recurrentes, accelerer les allers-retours et liberer du temps operationnel pour vos equipes.",
  },
  {
    question: "Intervenez-vous en support d'une equipe interne ?",
    answer:
      "Oui. Nous pouvons agir en renfort ponctuel ou en pilotage dedie selon votre charge.",
  },
  {
    question: "Que se passe-t-il en cas de piece manquante ?",
    answer:
      "Nous identifions les manques en amont et proposons une liste d'actions priorisees pour limiter les retards.",
  },
  {
    question: "Le service est-il adapte aux volumes eleves ?",
    answer:
      "Oui. Notre methode est pensee pour les structures qui traitent des flux reguliers ou en croissance.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title="Dossier Consuel photovoltaïque | Sunelys"
  description="Sunelys prend en charge le montage et le suivi de votre dossier Consuel photovoltaïque pour fiabiliser la mise en service."
  structuredData={structuredData}
>
  <section class="card hero">
    <h1>Dossier Consuel photovoltaïque</h1>
    <p>
      Nous structurons votre dossier Consuel pour reduire les frictions administratives
      et securiser la mise en service de vos installations.
    </p>
  </section>

  <section class="section card">
    <h2>Ce que nous prenons en charge</h2>
    <ul>
      {scopeItems.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="section card">
    <h2>Process</h2>
    <ol>
      {processSteps.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section class="section card faq">
    <h2>FAQ</h2>
    <div class="faq-grid">
      {
        faqItems.map((item) => (
          <article class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section card cta-box">
    <h2>Besoin d'un cadrage Consuel rapide ?</h2>
    <a class="cta" href="/contact" data-track="cta_seo_consuel_audit">Demander un audit</a>
  </section>
</BaseLayout>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: var(--shadow);
  }

  h1 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.9rem, 4.5vw, 2.9rem);
    line-height: 1.14;
  }

  h2 {
    margin: 0 0 0.85rem;
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  h3 {
    margin: 0 0 0.45rem;
    font-size: 1.07rem;
  }

  p,
  li {
    margin: 0;
    color: var(--muted);
  }

  ul,
  ol {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.45rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem;
  }

  .cta-box {
    text-align: center;
  }

  .cta {
    margin-top: 0.5rem;
    display: inline-block;
    padding: 0.75rem 1.3rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    color: #f4f1e8;
    background: var(--primary);
  }

  .cta:hover,
  .cta:focus-visible {
    color: var(--primary-dark);
    background: var(--accent-dark);
  }

  @media (max-width: 820px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
