---
import BaseLayout from "../layouts/BaseLayout.astro";

const pricingRows = [
  {
    service: "Déclarations préalables",
    scope: "Analyse, production, dépôt, suivi et validation",
    lessThan20: "À partir de 149 € HT",
    from21To50: "À partir de 119 € HT",
    moreThan51: "À partir de 79 € HT",
  },
  {
    service: "Raccordement réseau + Consuel",
    scope: "Dépôt de demande, gestion des échanges, validation et mise en service",
    lessThan20: "À partir de 100 € HT",
    from21To50: "À partir de 85 € HT",
    moreThan51: "À partir de 70 € HT",
  },
];

const collaborationItems = [
  "Production sous 48h lorsque le dossier est complet",
  "Suivi sur espace dédié",
  "Interlocuteur unique dédié",
  "Facturation mensuelle selon le volume réel",
];
---

<BaseLayout
  title="Tarifs Sunelys | Gestion administrative photovoltaïque"
  description="Tarifs Sunelys pour installateurs photovoltaïques : déclaration préalable, raccordement réseau et Consuel avec prix dégressifs selon le volume mensuel."
>
  <section class="hero pricing-hero">
    <p class="eyebrow">Tarification Sunelys</p>
    <h1>Des prix clairs, dégressifs selon votre volume.</h1>
    <p class="intro">
      Les montants ci-dessous donnent une base de cadrage pour les installateurs photovoltaïques.
      Le prix final dépend du périmètre, de la qualité des pièces transmises et du volume réellement traité.
    </p>
  </section>

  <section class="pricing-table-shell">
    <div class="table-head">
      <p class="eyebrow">Prix par dossier</p>
      <h2>Deux blocs d'accompagnement, avec tarifs dégressifs.</h2>
    </div>

    <div class="pricing-table" role="table" aria-label="Tableau des offres Sunelys">
      <div class="pricing-row pricing-row-head" role="row">
        <div class="pricing-cell pricing-label" role="columnheader">Service</div>
        <div class="pricing-cell pricing-plan-head" role="columnheader">
          <strong>Moins de 20 dossiers / mois</strong>
        </div>
        <div class="pricing-cell pricing-plan-head" role="columnheader">
          <strong>21 à 50 dossiers / mois</strong>
        </div>
        <div class="pricing-cell pricing-plan-head" role="columnheader">
          <strong>Plus de 51 dossiers / mois</strong>
        </div>
      </div>

      {
        pricingRows.map((row) => (
          <div class="pricing-row" role="row">
            <div class="pricing-cell pricing-service" role="rowheader">
              <strong>{row.service}</strong>
              <span>{row.scope}</span>
            </div>
            <div class="pricing-cell price-cell" role="cell">{row.lessThan20}</div>
            <div class="pricing-cell price-cell" role="cell">{row.from21To50}</div>
            <div class="pricing-cell price-cell" role="cell">{row.moreThan51}</div>
          </div>
        ))
      }

      <div class="pricing-row pricing-row-cta" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Cadrage</div>
        <div class="pricing-cell cta-cell" role="cell">
          <a class="btn btn-primary btn-accent" href="/contact?source=tarifs-moins-20#contact-form" data-track="cta_tarifs_volume" data-track-label="moins de 20 dossiers">
            Cadrer mon volume
          </a>
        </div>
        <div class="pricing-cell cta-cell" role="cell">
          <a class="btn btn-primary btn-accent" href="/contact?source=tarifs-21-50#contact-form" data-track="cta_tarifs_volume" data-track-label="21 à 50 dossiers">
            Cadrer mon volume
          </a>
        </div>
        <div class="pricing-cell cta-cell" role="cell">
          <a class="btn btn-primary btn-accent" href="/contact?source=tarifs-51-plus#contact-form" data-track="cta_tarifs_volume" data-track-label="plus de 51 dossiers">
            Cadrer mon volume
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing-note">
    <div>
      <p class="eyebrow">Pack stratégique</p>
      <h2>Chaîne administrative complète</h2>
      <p>
        Déclaration préalable, raccordement réseau et coordination Consuel peuvent être pilotés ensemble
        avec un interlocuteur unique et une facturation mensuelle selon le volume réel.
      </p>
      <ul class="collaboration-list">
        {collaborationItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="note-actions">
      <a class="btn btn-primary btn-accent" href="/contact?source=tarifs#contact-form" data-track="cta_tarifs_primary">
        Recevoir un cadrage
      </a>
      <a class="btn btn-secondary" href="/tarif-declaration-prealable-photovoltaique" data-track="cta_tarifs_dp_detail">
        Tarif DP détaillé
      </a>
      <a class="btn btn-secondary" href="/services" data-track="cta_tarifs_services">
        Voir les services
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .pricing-hero,
  .pricing-table-shell,
  .pricing-note {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.2rem, 2.8vw, 2rem);
  }

  .pricing-table-shell,
  .pricing-note {
    margin-top: 1.5rem;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.8vw, 4.3rem);
    line-height: 0.95;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.3rem);
    line-height: 1.04;
  }

  .intro,
  .pricing-note p,
  .pricing-cell {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .intro {
    margin-top: 1rem;
    max-width: 48rem;
    font-size: var(--step-0);
  }

  .table-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .pricing-table {
    display: grid;
    gap: 0.72rem;
  }

  .pricing-row {
    display: grid;
    grid-template-columns: minmax(220px, 1.05fr) repeat(3, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .pricing-cell {
    min-height: 5.1rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 24px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.95rem;
    display: grid;
    align-content: center;
    justify-items: start;
  }

  .pricing-row-head .pricing-cell,
  .pricing-label {
    background:
      radial-gradient(120% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 58%),
      color-mix(in srgb, var(--surface-elevated) 95%, white);
  }

  .pricing-plan-head strong,
  .pricing-label,
  .pricing-service strong,
  .price-cell {
    color: var(--text);
    font-weight: 700;
  }

  .pricing-service {
    gap: 0.35rem;
  }

  .pricing-service span {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .price-cell {
    font-size: clamp(1rem, 1.2vw, 1.18rem);
  }

  .pricing-label {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.74rem;
  }

  .pricing-row-cta .pricing-cell {
    min-height: auto;
  }

  .cta-cell .btn {
    width: 100%;
  }

  .collaboration-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .collaboration-list li {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    color: var(--text-muted);
    padding: 0.85rem 0.9rem;
    line-height: 1.45;
  }

  .note-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  @media (max-width: 960px) {
    .pricing-row {
      grid-template-columns: 1fr;
    }

    .pricing-cell {
      min-height: auto;
    }

    .collaboration-list {
      grid-template-columns: 1fr;
    }
  }
</style>
