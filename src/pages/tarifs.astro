---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockedDiagnostic from "../components/BlockedDiagnostic.astro";
import BrandSignature from "../components/BrandSignature.astro";

const pricingOffers = [
  {
    service: "Déclaration préalable complète",
    scope: "Pièces, dépôt en mairie et suivi de l'instruction jusqu'à validation.",
    bestFor: "Dossier vendu à transformer en dépôt mairie propre.",
    decisionCue: "À choisir avant dépôt, après complément ou pour fiabiliser un flux DP.",
    price: "119 €",
    note: "HT / dossier",
    badge: "Garantie zéro pièce complémentaire",
    ctaLabel: "Sécuriser la DP",
    ctaHref: "/contact?source=tarif_dp_complete#contact-form",
    ctaTrack: "cta_tarifs_offre_dp",
    ctaHint: "Idéal quand un dépôt local est prêt à être présenté en mairie.",
  },
  {
    service: "Raccordement réseau + Consuel",
    scope: "Demande, gestion des échanges, validation et mise en service.",
    bestFor: "Chantier prêt à passer vers le réseau et la mise en service.",
    decisionCue: "À choisir quand Enedis, Consuel ou les pièces techniques ralentissent la suite.",
    price: "89 €",
    note: "HT / dossier",
    badge: "",
    ctaLabel: "Ajouter le raccordement",
    ctaHref: "/contact?source=tarif_raccordement_consuel#contact-form",
    ctaTrack: "cta_tarifs_offre_raccordement",
    ctaHint: "Option réactive quand le chantier est prêt à basculer vers la phase technique.",
  },
  {
    service: "Chaîne administrative complète",
    scope: "DP, raccordement et Consuel avec interlocuteur unique et pilotage intégral de A à Z.",
    bestFor: "Installer un relais administratif complet sans recrutement.",
    decisionCue: "À choisir quand le flux entier doit sortir de vos équipes internes.",
    price: "199 €",
    note: "HT / dossier",
    badge: "Le choix des pros",
    highlighted: true,
    ctaLabel: "Piloter toute la chaîne",
    ctaHref: "/contact?source=tarif_chaine_complete#contact-form",
    ctaTrack: "cta_tarifs_offre_chaine",
    ctaHint: "Parcours recommandé pour sortir du pilotage interne en mode complet.",
  },
];

const renovationAidOffers = [
  {
    service: "MaPrimeRénov'",
    scope: "Éligibilité, montage conforme, dépôt ANAH et suivi jusqu'au versement.",
    price: "129 €",
    note: "HT / dossier",
    ctaLabel: "Préparer ce dossier",
    ctaHref: "/contact?source=tarif_maprimerenov#contact-form",
    ctaTrack: "cta_tarifs_aide_maprimerenov",
  },
  {
    service: "CEE",
    scope: "Contrôle devis et factures, montage du dossier et suivi jusqu'à validation.",
    price: "99 €",
    note: "HT / dossier",
    ctaLabel: "Préparer le CEE",
    ctaHref: "/contact?source=tarif_cee#contact-form",
    ctaTrack: "cta_tarifs_aide_cee",
  },
  {
    service: "Pack MaPrimeRénov' + CEE",
    scope: "Les deux dossiers montés et suivis ensemble sur un même chantier.",
    price: "199 €",
    note: "HT / dossier",
    badge: "Le plus demandé",
    ctaLabel: "Choisir le pack",
    ctaHref: "/contact?source=tarif_maprimerenov_cee#contact-form",
    ctaTrack: "cta_tarifs_aide_pack",
  },
];

const edfOaOffer = {
  service: "EDF OA",
  scope:
    "Activation ou création de l'espace producteur, suivi du dossier et accompagnement jusqu'à la signature électronique du client final.",
  price: "49 €",
  note: "HT / dossier",
  ctaLabel: "Demander un cadrage EDF OA",
  ctaHref: "/contact?source=tarif_edf_oa#contact-form",
  ctaTrack: "cta_tarifs_edf_oa",
};

const specialistChecks = [
  "100 % dossiers photovoltaïques",
  "Sans abonnement",
  "Sans minimum de volume",
  "Facturation au réel",
];

const collaborationItems = [
  "Production sous 48h lorsque le dossier est complet",
  "Suivi en temps réel sur un espace dédié",
  "Interlocuteur unique pour vos équipes",
  "Facturation mensuelle des dossiers traités",
];

const pricingSignals = [
  "Tarifs unitaires en euros HT, TVA 20 % en sus.",
  "Dossier ponctuel accepté avant un éventuel flux récurrent.",
  "La garantie zéro pièce complémentaire s'applique à la DP complète lorsque le dépôt et le suivi sont assurés par Sunelys.",
  "Les décisions des organismes tiers — mairie, Enedis, Consuel, EDF OA, ANAH ou obligés CEE — restent indépendantes de Sunelys.",
];

const snapshotPrices = [
  { need: "Activer le contrat", label: "EDF OA", price: "49 €", href: "#edf-oa", ctaTrack: "cta_tarifs_matrix_edf_oa" },
  {
    need: "Finaliser le réseau",
    label: "Raccordement + Consuel",
    price: "89 €",
    href: "#tarifs-photovoltaique",
    ctaTrack: "cta_tarifs_matrix_raccordement",
  },
  {
    need: "Sécuriser le départ",
    label: "DP complète",
    price: "119 €",
    href: "#tarifs-photovoltaique",
    ctaTrack: "cta_tarifs_matrix_dp",
  },
  {
    need: "Tout déléguer",
    label: "Chaîne complète",
    price: "199 €",
    href: "#tarifs-photovoltaique",
    ctaTrack: "cta_tarifs_matrix_chaine",
    highlighted: true,
    badge: "Option recommandée",
  },
];

const decisionPaths = [
  {
    signal: "Je dois sécuriser le départ",
    title: "La mairie est le premier risque.",
    text: "Le dossier doit partir complet, avec les bonnes pièces et un suivi d'instruction clair.",
    recommended: "DP complète",
    price: "119 € HT",
    href: "#tarifs-photovoltaique",
    track: "cta_tarifs_path_dp",
  },
  {
    signal: "Je dois finaliser le chantier",
    title: "La mise en service ne doit pas décrocher.",
    text: "Les jalons réseau, le Consuel et les compléments doivent être suivis ensemble.",
    recommended: "Raccordement + Consuel",
    price: "89 € HT",
    href: "#tarifs-photovoltaique",
    track: "cta_tarifs_path_raccordement",
  },
  {
    signal: "Je veux sortir le flux complet",
    title: "L'administratif déborde l'équipe.",
    text: "DP, raccordement et Consuel sont pilotés dans une seule chaîne, avec un interlocuteur unique.",
    recommended: "Chaîne complète",
    price: "199 € HT",
    href: "#tarifs-photovoltaique",
    track: "cta_tarifs_path_chaine",
    featured: true,
  },
  {
    signal: "Je dois débloquer un après-chantier",
    title: "EDF OA ou les aides restent en attente.",
    text: "Le bon périmètre dépend du dossier à reprendre : contrat d'achat, MaPrimeRénov' ou CEE.",
    recommended: "Offres complémentaires",
    price: "Dès 49 € HT",
    href: "#edf-oa",
    track: "cta_tarifs_path_complementaires",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  name: "Tarifs Sunelys par dossier",
  itemListElement: [...pricingOffers, edfOaOffer, ...renovationAidOffers].map((offer) => ({
    "@type": "Offer",
    price: offer.price.replace(/[^\d]/g, ""),
    priceCurrency: "EUR",
    itemOffered: {
      "@type": "Service",
      name: offer.service,
      description: offer.scope,
    },
  })),
};
---

<BaseLayout
  title="Tarifs gestion administrative photovoltaïque | Sunelys"
  description="Tarifs unitaires au dossier pour DP, Consuel, raccordement, EDF OA, MaPrimeRénov' et CEE. Demandez un cadrage gratuit."
  structuredData={[structuredData]}
>
  <section class="pricing-hero reveal" aria-labelledby="pricing-title">
    <BrandSignature variant="pricing" />
    <div class="hero-copy" data-reveal-item>
      <p class="eyebrow">Tarifs Sunelys · 2026</p>
      <h1 id="pricing-title">Un prix clair par dossier. Pas de coût caché.</h1>
      <p class="hero-intro">
        Déléguez une démarche ponctuelle ou un flux complet avec le même principe : un périmètre précis, un tarif
        fixe et une facturation sur les dossiers réellement traités.
      </p>

      <div class="hero-actions">
        <a class="btn btn-accent" href="#tarifs-photovoltaique" data-track="cta_tarifs_hero_compare">
          Comparer les offres
          <span aria-hidden="true">↓</span>
        </a>
        <a class="hero-link" href="#blocked-diagnostic-tarifs_diagnostic_dossiers_bloques" data-track="cta_tarifs_hero_diagnostic">
          Faire cadrer mon besoin
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="hero-momentum" aria-label="Parcours recommandés">
        <span>Entrée recommandée</span>
        <a class="hero-momentum-link" href="#tarifs-photovoltaique" data-track="cta_tarifs_hero_entry_chain">
          Chaîne complète
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="hero-assurance" aria-label="Conditions principales">
        <span><i aria-hidden="true"></i> Dossier ponctuel accepté</span>
        <span><i aria-hidden="true"></i> Réponse sous 24h</span>
      </div>
    </div>

    <aside class="price-matrix" aria-label="Matrice de choix des principaux tarifs" data-reveal-item>
      <div class="matrix-head">
        <div>
          <p>Matrice de décision</p>
          <strong>Choisissez selon ce qu'il faut sortir de votre équipe</strong>
        </div>
        <span>HT / dossier</span>
      </div>

      <div class="matrix-list">
        {
          snapshotPrices.map((item, index) => (
            <a
              class:list={["matrix-row", item.highlighted && "is-featured"]}
              href={item.href}
              data-track={item.ctaTrack || "cta_tarifs_hero_matrix"}
              data-track-label={item.label}
            >
              <span>0{index + 1}</span>
              <div>
                <small>{item.need}</small>
                <p>{item.label}</p>
              </div>
              <strong>{item.price}</strong>
              {item.badge && <span class="matrix-badge">{item.badge}</span>}
              <i aria-hidden="true">→</i>
            </a>
          ))
        }
      </div>

      <div class="matrix-foot">
        <span>Aucun abonnement</span>
        <span>Aucun minimum de volume</span>
      </div>
    </aside>
  </section>

  <section class="specialist-strip reveal" aria-label="Principes de tarification Sunelys">
    {
      specialistChecks.map((item, index) => (
        <div data-reveal-item>
          <span>0{index + 1}</span>
          <strong>{item}</strong>
        </div>
      ))
    }
  </section>

  <section class="pricing-choice-lab reveal" aria-labelledby="choice-lab-title">
    <div class="choice-lab-head" data-reveal-item>
      <p class="eyebrow">Choisir sans se tromper</p>
      <h2 id="choice-lab-title">Partez du blocage, pas de la ligne de prix.</h2>
      <p>
        Le tarif devient évident quand on identifie ce qu'il faut sortir de votre équipe :
        un dépôt mairie, une mise en service, un flux complet ou un dossier complémentaire.
      </p>
    </div>

    <div class="choice-paths" aria-label="Parcours de choix des tarifs Sunelys">
      {
        decisionPaths.map((path, index) => (
          <a
            class:list={["choice-path", path.featured && "is-featured"]}
            href={path.href}
            data-track={path.track}
            data-track-label={path.recommended}
            data-reveal-item
          >
            <span>0{index + 1} · {path.signal}</span>
            <strong>{path.title}</strong>
            <p>{path.text}</p>
            <div>
              <small>{path.recommended}</small>
              <b>{path.price}</b>
              <i aria-hidden="true">→</i>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="solar-pricing reveal" id="tarifs-photovoltaique" aria-labelledby="solar-pricing-title">
    <div class="section-head" data-reveal-item>
      <div>
        <p class="eyebrow">Cœur de l’offre</p>
        <h2 id="solar-pricing-title">DP, raccordement et Consuel.</h2>
      </div>
      <p>
        Choisissez la démarche à sortir de vos équipes ou confiez la chaîne complète à un interlocuteur unique.
      </p>
    </div>

    <div class="offer-grid" aria-label="Offres photovoltaïques Sunelys">
      {
        pricingOffers.map((offer, index) => (
          <article class:list={["offer-card", offer.highlighted && "is-highlighted"]} data-reveal-item>
            <div class="offer-top">
              <span>0{index + 1}</span>
              {offer.badge && <p>{offer.badge}</p>}
            </div>
            <h3>{offer.service}</h3>
            <p class="offer-scope">{offer.scope}</p>
            <div class="offer-fit" aria-label={`Bon cas d'usage ${offer.service}`}>
              <span>Bon cas d'usage</span>
              <strong>{offer.bestFor}</strong>
              <p>{offer.decisionCue}</p>
            </div>
            <div class="offer-price">
              <strong>{offer.price}</strong>
              <span>{offer.note}</span>
            </div>
            <a
              class="offer-cta btn btn-accent"
              href={offer.ctaHref}
              data-track={offer.ctaTrack}
              data-track-label={offer.service}
            >
              {offer.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
            {offer.ctaHint && <p class="offer-hint">{offer.ctaHint}</p>}
          </article>
        ))
      }
    </div>

    <div class="pricing-guidance" data-reveal-item>
      <p>
        <strong>Vous ne savez pas quelle formule choisir ?</strong>
        Décrivez le dossier : Sunelys vous indique le premier périmètre utile, sans empiler les prestations.
      </p>
      <a href="#blocked-diagnostic-tarifs_diagnostic_dossiers_bloques" data-track="cta_tarifs_offers_guidance">
        Être orienté
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="complementary-pricing reveal" aria-labelledby="complementary-title">
    <div class="section-head" data-reveal-item>
      <div>
        <p class="eyebrow">Dossiers complémentaires</p>
        <h2 id="complementary-title">EDF OA et aides à la rénovation.</h2>
      </div>
      <p>Deux périmètres distincts, avec la même transparence tarifaire et le même suivi opérationnel.</p>
    </div>

    <div class="complementary-layout">
      <article class="edf-offer" id="edf-oa" data-reveal-item>
        <div class="complementary-label">
          <span>Contrat d’achat</span>
          <i aria-hidden="true"></i>
        </div>
        <h3>{edfOaOffer.service}</h3>
        <p>{edfOaOffer.scope}</p>
        <div class="complementary-price">
          <strong>{edfOaOffer.price}</strong>
          <span>{edfOaOffer.note}</span>
        </div>
        <a class="complementary-cta-secondary" href="/edf-oa" data-track="cta_edf_oa_tarifs">
          Voir le périmètre EDF OA
          <span aria-hidden="true">→</span>
        </a>
        <a class="complementary-cta btn btn-accent" href={edfOaOffer.ctaHref} data-track={edfOaOffer.ctaTrack}>
          {edfOaOffer.ctaLabel}
          <span aria-hidden="true">→</span>
        </a>
      </article>

      <div class="aid-panel" id="aides-renovation" data-reveal-item>
        <div class="aid-panel-head">
          <p>Aides à la rénovation</p>
          <span>Montage + suivi</span>
        </div>
        <div class="aid-list">
          {
            renovationAidOffers.map((offer, index) => (
              <article>
                <span>0{index + 1}</span>
                <div>
                  <div class="aid-title">
                    <h3>{offer.service}</h3>
                    {offer.badge && <small>{offer.badge}</small>}
                  </div>
                  <p>{offer.scope}</p>
                </div>
                <div class="aid-price">
                  <strong>{offer.price}</strong>
                  <span>{offer.note}</span>
                </div>
                <a class="aid-cta" href={offer.ctaHref} data-track={offer.ctaTrack}>
                  {offer.ctaLabel}
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pricing-conditions reveal" aria-labelledby="conditions-title">
    <div class="conditions-copy" data-reveal-item>
      <p class="eyebrow">Collaboration</p>
      <h2 id="conditions-title">Ce que le prix comprend vraiment.</h2>
      <p>
        Le tarif rémunère le pilotage du dossier : contrôle des pièces, production, échanges, suivi et visibilité
        jusqu’à l’étape prévue dans l’offre.
      </p>
    </div>

    <div class="conditions-content" data-reveal-item>
      <ul class="collaboration-list">
        {collaborationItems.map((item) => <li>{item}</li>)}
      </ul>

      <details>
        <summary>Conditions et périmètre détaillés <span aria-hidden="true">+</span></summary>
        <ul class="legal-list">
          {pricingSignals.map((item) => <li>{item}</li>)}
        </ul>
      </details>
    </div>
  </section>

  <BlockedDiagnostic
    source="tarifs_diagnostic_dossiers_bloques"
    kicker="Diagnostic tarifaire"
    title="Le bon tarif dépend surtout du premier blocage à sortir de votre équipe."
    text="Indiquez votre volume, votre urgence et le service concerné. Sunelys vous répond avec un périmètre concret, sans abonnement imposé."
    submitLabel="Recevoir mon cadrage sous 24h"
  />
</BaseLayout>

<style>
  .pricing-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(400px, 1.12fr);
    gap: clamp(1.5rem, 4vw, 4.2rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(1.5rem, 3.8vw, 4rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 100% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 62%),
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .pricing-hero > .hero-copy,
  .pricing-hero > .price-matrix {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy .eyebrow {
    color: var(--accent);
  }

  h1 {
    max-width: 11ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    line-height: 0.94;
  }

  .hero-intro {
    max-width: 63ch;
    margin-top: 1.15rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-link,
  .pricing-guidance a,
  .complementary-cta-secondary,
  .complementary-cta,
  .aid-cta,
  .matrix-row > i {
    display: inline-flex;
    align-items: center;
    gap: 0.52rem;
    color: inherit;
    font-size: 0.78rem;
    font-weight: 760;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 28%, transparent);
    text-underline-offset: 0.28rem;
  }

  .hero-link {
    color: rgba(255, 255, 255, 0.76);
  }

  .hero-link span,
  .pricing-guidance a span,
  .complementary-cta span,
  .complementary-cta-secondary span,
  .aid-cta span {
    color: var(--accent);
  }

  .hero-assurance {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    margin-top: 1.35rem;
  }

  .hero-assurance span {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.69rem;
    font-weight: 650;
  }

  .hero-assurance i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.14);
  }

  .hero-momentum {
    display: inline-flex;
    align-items: center;
    gap: 0.58rem;
    margin-top: 1.1rem;
    padding: 0.62rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgba(255, 255, 255, 0.04);
  }

  .hero-momentum span {
    color: rgba(255, 255, 255, 0.46);
  }

  .hero-momentum-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #ffffff;
    font-size: 0.67rem;
    font-weight: 760;
  }

  .price-matrix {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 18px;
    background: #f8fafc;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.05rem 1.15rem;
    border-bottom: 1px solid var(--line);
    background: #ffffff;
  }

  .matrix-head div {
    display: grid;
    gap: 0.18rem;
  }

  .matrix-head p,
  .matrix-head > span {
    color: var(--text-muted);
    font-size: 0.6rem;
    font-weight: 700;
  }

  .matrix-head p {
    color: var(--system);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .matrix-head strong {
    max-width: 32ch;
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.25;
  }

  .matrix-list {
    display: grid;
  }

  .matrix-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto auto;
    gap: 0.85rem;
    align-items: center;
    min-height: 4.55rem;
    padding: 0.65rem 1.15rem;
    border-bottom: 1px solid var(--line);
    color: var(--text);
    text-decoration: none;
    transition:
      background-color 160ms ease,
      transform 160ms ease;
  }

  .matrix-row:hover,
  .matrix-row:focus-visible {
    background: var(--system-soft);
  }

  .matrix-row > span {
    color: var(--system);
    font-size: 0.63rem;
    font-weight: 800;
  }

  .matrix-row > div {
    min-width: 0;
  }

  .matrix-row small {
    display: block;
