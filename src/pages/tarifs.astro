---
import BaseLayout from "../layouts/BaseLayout.astro";

const plans = [
  {
    name: "Essentiel",
    fit: "1-10 dossiers/mois",
    services: "DP ou Consuel ou Raccordement",
    portal: "Accès inclus",
    followUp: "Hebdomadaire",
    price: "Sur devis",
  },
  {
    name: "Structuré",
    fit: "10-30 dossiers/mois",
    services: "2 services au choix",
    portal: "Accès inclus",
    followUp: "Bi-hebdomadaire",
    price: "Sur devis",
  },
  {
    name: "Pilotage complet",
    fit: "+30 dossiers/mois",
    services: "DP + Consuel + Raccordement",
    portal: "Accès inclus",
    followUp: "Quotidien",
    price: "Sur devis",
  },
];
---

<BaseLayout
  title="Tarifs Sunelys | Gestion administrative photovoltaïque"
  description="Découvrez le fonctionnement tarifaire Sunelys par volume de dossiers pour les installateurs photovoltaïques : essentiel, structuré ou pilotage complet."
>
  <section class="hero pricing-hero">
    <p class="eyebrow">Tarification Sunelys</p>
    <h1>Une tarification au volume, pas à la tâche.</h1>
    <p class="intro">
      Nous adaptons le périmètre et la cadence à votre organisation. Voici comment nous travaillons.
    </p>
  </section>

  <section class="pricing-table-shell">
    <div class="table-head">
      <p class="eyebrow">Formules</p>
      <h2>Trois cadres d'accompagnement selon votre flux mensuel.</h2>
    </div>

    <div class="pricing-table" role="table" aria-label="Tableau des offres Sunelys">
      <div class="pricing-row pricing-row-head" role="row">
        <div class="pricing-cell pricing-label" role="columnheader"></div>
        {plans.map((plan) => (
          <div class="pricing-cell pricing-plan-head" role="columnheader">
            <strong>{plan.name}</strong>
          </div>
        ))}
      </div>

      <div class="pricing-row" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Pour</div>
        {plans.map((plan) => <div class="pricing-cell" role="cell">{plan.fit}</div>)}
      </div>

      <div class="pricing-row" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Services</div>
        {plans.map((plan) => <div class="pricing-cell" role="cell">{plan.services}</div>)}
      </div>

      <div class="pricing-row" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Portail</div>
        {plans.map((plan) => <div class="pricing-cell" role="cell">{plan.portal}</div>)}
      </div>

      <div class="pricing-row" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Suivi</div>
        {plans.map((plan) => <div class="pricing-cell" role="cell">{plan.followUp}</div>)}
      </div>

      <div class="pricing-row" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">Tarif</div>
        {plans.map((plan) => <div class="pricing-cell" role="cell">{plan.price}</div>)}
      </div>

      <div class="pricing-row pricing-row-cta" role="row">
        <div class="pricing-cell pricing-label" role="rowheader">CTA</div>
        {
          plans.map((plan) => (
            <div class="pricing-cell" role="cell">
              <a
                class="btn btn-primary btn-accent"
                href={`/contact?source=tarifs-${plan.name.toLowerCase().replace(/\s+/g, "-")}#contact-form`}
                data-track="cta_tarifs_plan"
                data-track-label={plan.name}
              >
                Demander un devis
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pricing-note">
    <p>
      Les tarifs sont construits sur votre volume et votre périmètre. Contactez-nous pour un cadrage sans engagement.
    </p>
    <div class="note-actions">
      <a class="btn btn-primary btn-accent" href="/contact?source=tarifs#contact-form" data-track="cta_tarifs_primary">
        Demander un devis
      </a>
      <a class="btn btn-secondary" href="/services" data-track="cta_tarifs_services">
        Voir les services
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .pricing-hero,
  .pricing-table-shell,
  .pricing-note {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.2rem, 2.8vw, 2rem);
  }

  .pricing-table-shell,
  .pricing-note {
    margin-top: 1.5rem;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.8vw, 4.3rem);
    line-height: 0.95;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.3rem);
    line-height: 1.04;
  }

  .intro,
  .pricing-note p,
  .pricing-cell {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .intro {
    margin-top: 1rem;
    max-width: 48rem;
    font-size: var(--step-0);
  }

  .table-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .pricing-table {
    display: grid;
    gap: 0.72rem;
  }

  .pricing-row {
    display: grid;
    grid-template-columns: minmax(160px, 0.8fr) repeat(3, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .pricing-cell {
    min-height: 5.1rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 24px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 0.95rem;
    display: grid;
    align-content: center;
    justify-items: start;
  }

  .pricing-row-head .pricing-cell,
  .pricing-label {
    background:
      radial-gradient(120% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 58%),
      color-mix(in srgb, var(--surface-elevated) 95%, white);
  }

  .pricing-plan-head strong,
  .pricing-label {
    color: var(--text);
    font-weight: 700;
  }

  .pricing-label {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.74rem;
  }

  .pricing-row-cta .pricing-cell {
    min-height: auto;
  }

  .pricing-row-cta .btn {
    width: 100%;
  }

  .note-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  @media (max-width: 960px) {
    .pricing-row {
      grid-template-columns: 1fr;
    }

    .pricing-cell {
      min-height: auto;
    }
  }
</style>
