---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockedDiagnostic from "../components/BlockedDiagnostic.astro";

const pricingOffers = [
  {
    service: "Déclaration préalable complète",
    scope: "Pièces, dépôt en mairie et suivi de l'instruction jusqu'à validation.",
    price: "119 €",
    note: "HT / dossier",
    badge: "Garantie zéro pièce complémentaire",
  },
  {
    service: "Raccordement réseau + Consuel",
    scope: "Demande, gestion des échanges, validation et mise en service.",
    price: "89 €",
    note: "HT / dossier",
    badge: "",
  },
  {
    service: "Chaîne administrative complète",
    scope: "DP, raccordement et Consuel avec interlocuteur unique et pilotage intégral de A à Z.",
    price: "199 €",
    note: "HT / dossier",
    badge: "Recommandé - le choix des pros",
    highlighted: true,
  },
];

const renovationAidOffers = [
  {
    service: "MaPrimeRénov' - montage & suivi",
    scope: "Éligibilité, montage conforme, dépôt ANAH et suivi jusqu'au versement de la prime.",
    price: "129 €",
    note: "HT / dossier",
    badge: "Mandat administratif possible",
  },
  {
    service: "CEE - certificats d'économies d'énergie",
    scope: "Contrôle devis et factures, montage du dossier CEE et suivi jusqu'à validation.",
    price: "99 €",
    note: "HT / dossier",
    badge: "",
  },
  {
    service: "Pack MaPrimeRénov' + CEE",
    scope: "Les deux dossiers montés et suivis ensemble, sur un même chantier.",
    price: "199 €",
    note: "HT / dossier",
    badge: "Le plus demandé",
    highlighted: true,
  },
];

const edfOaOffer = {
  service: "EDF OA - compte et contrat d'achat",
  scope:
    "Activation ou création de l'espace producteur, suivi du dossier EDF OA et accompagnement jusqu'à la signature électronique du client final.",
  price: "49 €",
  note: "HT / dossier",
  badge: "Sans abonnement ni minimum",
};

const collaborationItems = [
  "Production sous 48h lorsque le dossier est complet",
  "Suivi en temps réel sur espace dédié",
  "Interlocuteur unique dédié",
  "Facturation mensuelle sur les dossiers réellement traités",
];

const pricingSignals = [
  "Tarifs unitaires en euros HT",
  "Prix unitaires fixes par dossier",
  "Dossier ponctuel accepté, flux récurrent possible",
  "Garantie zéro pièce complémentaire applicable sur la formule DP complète avec dépôt et suivi assurés par Sunelys",
  "TVA 20 % en sus, facturation mensuelle selon les dossiers réellement traités",
];

const specialistChecks = [
  "Périmètre concentré sur les dossiers photovoltaïques installateurs",
  "Prix publics avant diagnostic pour cadrer vite le bon niveau de délégation",
  "Dossier ponctuel accepté avant de basculer un flux récurrent",
  "Lecture opérationnelle des blocages : mairie, Consuel, Enedis, EDF OA, ANAH et CEE",
];
---

<BaseLayout
  title="Tarifs gestion administrative photovoltaïque | Sunelys"
  description="Tarifs unitaires au dossier pour DP, Consuel, raccordement, EDF OA, MaPrimeRénov' et CEE. Demandez un cadrage gratuit de 15 min."
>
  <section class="hero pricing-hero">
    <p class="eyebrow">Tarification Sunelys</p>
    <h1>Des tarifs uniques et clairs pour un pilotage complet par dossier.</h1>
    <p class="intro">
      Les montants ci-dessous sont les prix unitaires Sunelys pour les installateurs photovoltaïques.
      Chaque tarif correspond à un périmètre précis : DP, raccordement + Consuel, chaîne complète,
      dossier EDF OA ou dossiers d'aides à la rénovation MaPrimeRénov' et CEE. Vous pouvez démarrer par un dossier
      ponctuel, puis structurer un flux récurrent si le besoin se confirme.
    </p>
  </section>

  <section class="specialist-pricing-note">
    <div>
      <p class="eyebrow">Spécialiste PV</p>
      <h2>Une tarification pensée pour déléguer sans se retrouver dans une offre généraliste.</h2>
      <p>
        Sunelys n'est pas une promesse administrative tous secteurs. L'offre est construite pour les
        installateurs photovoltaïques qui veulent sortir DP, raccordement, Consuel et aides de leurs équipes.
      </p>
    </div>
    <ul>
      {specialistChecks.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="pricing-table-shell" id="tarifs-photovoltaique">
    <div class="table-head">
      <p class="eyebrow">Prix par dossier</p>
      <h2>Photovoltaïque : DP, raccordement et Consuel.</h2>
      <p>
        Une assistante ADV dédiée représente souvent plus de 2 000 € par mois de charges.
        Un dossier piloté par Sunelys démarre à 89 € HT. Le calcul reste lisible dossier par dossier.
      </p>
    </div>

    <div class="offer-grid" aria-label="Offres Sunelys">
      {
        pricingOffers.map((offer) => (
          <article class:list={["offer-card", { "offer-card-highlight": offer.highlighted }]}>
            <div class="offer-copy">
              {offer.badge && <p class="offer-badge">{offer.badge}</p>}
              <h3>{offer.service}</h3>
              <p>{offer.scope}</p>
            </div>
            <div class="offer-price">
              <strong>{offer.price}</strong>
              <span>{offer.note}</span>
            </div>
          </article>
        ))
      }
    </div>

    <ul class="pricing-signals">
      {pricingSignals.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="pricing-table-shell edf-oa-pricing" id="edf-oa">
    <div class="table-head">
      <p class="eyebrow">Contrat d'achat</p>
      <h2>EDF OA : espace producteur et contrat d'achat.</h2>
      <p>
        Pour éviter que le dossier reste bloqué entre mise en service, mail d'activation et signature,
        Sunelys prend en charge le cadrage administratif EDF OA jusqu'à l'invitation de signature.
      </p>
    </div>

    <div class="offer-grid offer-grid-single" aria-label="Offre EDF OA Sunelys">
      <article class="offer-card offer-card-edf">
        <div class="offer-copy">
          <p class="offer-badge">{edfOaOffer.badge}</p>
          <h3>{edfOaOffer.service}</h3>
          <p>{edfOaOffer.scope}</p>
        </div>
        <div class="offer-price">
          <strong>{edfOaOffer.price}</strong>
          <span>{edfOaOffer.note}</span>
        </div>
      </article>
    </div>

    <ul class="pricing-signals">
      <li>Sunelys n'est pas EDF OA ni un service officiel EDF Obligation d'Achat</li>
      <li>Le client final active son espace et signe depuis les liens sécurisés EDF OA</li>
      <li>Enedis, Consuel et la facturation de production après signature restent des périmètres distincts</li>
    </ul>

    <div class="note-actions">
      <a class="btn btn-primary btn-accent" href="/edf-oa" data-track="cta_edf_oa_tarifs">
        Voir l'offre EDF OA
      </a>
      <a class="btn btn-secondary" href="/contact?source=edf-oa#contact-form" data-track="cta_edf_oa_contact">
        Demander un cadrage
      </a>
    </div>
  </section>

  <section class="pricing-table-shell" id="aides-renovation">
    <div class="table-head">
      <p class="eyebrow">Aides à la rénovation</p>
      <h2>MaPrimeRénov' et CEE sécurisés jusqu'au versement.</h2>
      <p>
        Un dossier d'aide refusé peut bloquer la prime du client final et fragiliser le chantier.
        Sunelys monte, dépose et suit les dossiers d'aides pour garder le flux administratif sous contrôle.
      </p>
    </div>

    <div class="offer-grid" aria-label="Offres aides à la rénovation Sunelys">
      {
        renovationAidOffers.map((offer) => (
          <article class:list={["offer-card", { "offer-card-highlight": offer.highlighted }]}>
            <div class="offer-copy">
              {offer.badge && <p class="offer-badge">{offer.badge}</p>}
              <h3>{offer.service}</h3>
              <p>{offer.scope}</p>
            </div>
            <div class="offer-price">
              <strong>{offer.price}</strong>
              <span>{offer.note}</span>
            </div>
          </article>
        ))
      }
    </div>

    <ul class="pricing-signals">
      <li>Prestation de montage et de suivi administratif</li>
      <li>Versement des primes soumis à la décision de l'ANAH et des obligés CEE</li>
      <li>Pack disponible lorsque MaPrimeRénov' et CEE sont gérés ensemble sur le même chantier</li>
    </ul>
  </section>

  <BlockedDiagnostic
    source="tarifs_diagnostic_dossiers_bloques"
    title="Vous hésitez sur le bon périmètre ? Faites cadrer vos dossiers avant de choisir l'offre."
    text="Indiquez votre volume, le blocage principal et le service concerné. Sunelys vous oriente vers le tarif utile sans empiler les prestations."
  />

  <section class="pricing-note">
    <div>
      <p class="eyebrow">Pack stratégique</p>
      <h2>Chaîne administrative complète</h2>
      <p>
        Déclaration préalable, raccordement réseau et Consuel peuvent être pilotés ensemble
        avec un interlocuteur unique, une production sous 48h lorsque les pièces sont complètes
        et un tarif unitaire fixe par dossier.
      </p>
      <ul class="collaboration-list">
        {collaborationItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="note-actions">
      <a class="btn btn-primary btn-accent" href="/contact?source=tarifs#contact-form" data-track="cta_tarifs_primary">
        Cadrer un pilotage complet
      </a>
      <a class="btn btn-secondary" href="/tarif-declaration-prealable-photovoltaique" data-track="cta_tarifs_dp_detail">
        Tarif DP détaillé
      </a>
      <a class="btn btn-secondary" href="/gestion-administrative-photovoltaique" data-track="cta_tarifs_cost_guide">
        Pilotage complet
      </a>
      <a class="btn btn-secondary" href="/services" data-track="cta_tarifs_services">
        Voir les services
      </a>
      <a class="btn btn-secondary" href="#edf-oa" data-track="cta_tarifs_edf_oa_anchor">
        Tarif EDF OA
      </a>
      <a class="btn btn-secondary" href="#aides-renovation" data-track="cta_tarifs_aides_renovation">
        Tarifs MaPrimeRénov' + CEE
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .pricing-hero,
  .pricing-table-shell,
  .specialist-pricing-note,
  .pricing-note {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.2rem, 2.8vw, 2rem);
  }

  .pricing-table-shell,
  .specialist-pricing-note,
  .pricing-note {
    margin-top: 1.5rem;
  }

  .specialist-pricing-note {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .specialist-pricing-note h2 {
    max-width: 18ch;
  }

  .specialist-pricing-note ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .specialist-pricing-note li {
    border-left: 3px solid var(--accent-strong);
    background: color-mix(in srgb, var(--surface-elevated) 84%, transparent);
    color: var(--text);
    line-height: 1.5;
    padding: 0.78rem 0.9rem;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.8vw, 4.3rem);
    line-height: 0.95;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.3rem);
    line-height: 1.04;
  }

  .intro,
  .pricing-note p,
  .pricing-cell {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .intro {
    margin-top: 1rem;
    max-width: 48rem;
    font-size: var(--step-0);
  }

  .table-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .offer-grid-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .offer-card {
    min-height: 10rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 24px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    padding: 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .offer-card-highlight {
    background: linear-gradient(165deg, #1b1712, #11100d);
    border-color: color-mix(in srgb, var(--line) 52%, var(--accent));
  }

  .offer-card-edf {
    min-height: 12rem;
    border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
    background:
      linear-gradient(115deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface) 58%),
      linear-gradient(180deg, color-mix(in srgb, var(--accent-soft) 46%, transparent), transparent);
  }

  .offer-copy {
    display: grid;
    gap: 0.44rem;
  }

  .offer-copy h3 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    line-height: 1.12;
  }

  .offer-copy p {
    margin: 0;
  }

  .offer-card-highlight h3,
  .offer-card-highlight p,
  .offer-card-highlight .offer-price strong,
  .offer-card-highlight .offer-price span {
    color: #f7f2e8;
  }

  .offer-card-highlight .offer-copy p,
  .offer-card-highlight .offer-price span {
    color: #d9cfbf;
  }

  .offer-card-highlight .offer-badge {
    color: var(--text);
  }

  .offer-badge {
    width: fit-content;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 72%, white);
    color: var(--text);
    padding: 0.28rem 0.64rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .offer-price {
    min-width: 9.5rem;
    display: grid;
    justify-items: end;
    gap: 0.12rem;
    color: var(--text);
  }

  .offer-price strong {
    font-size: clamp(2.3rem, 4vw, 4rem);
    line-height: 0.95;
    white-space: nowrap;
  }

  .offer-price span {
    color: var(--text-muted);
    font-weight: 700;
  }

  .pricing-signals {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.36rem;
  }

  .pricing-signals li {
    color: var(--text-muted);
  }

  .collaboration-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .collaboration-list li {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    color: var(--text-muted);
    padding: 0.85rem 0.9rem;
    line-height: 1.45;
  }

  .note-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  @media (max-width: 960px) {
    .specialist-pricing-note {
      grid-template-columns: 1fr;
    }

    .offer-grid {
      grid-template-columns: 1fr;
    }

    .offer-card {
      align-items: flex-start;
      flex-direction: column;
    }

    .offer-price {
      justify-items: start;
    }

    .collaboration-list {
      grid-template-columns: 1fr;
    }
  }
</style>
