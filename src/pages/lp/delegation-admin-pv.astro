---
import BaseLayout from "../../layouts/BaseLayout.astro";

const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const successUrl = "https://sunelys.fr/merci?source=lp_delegation_admin_pv";

const attributionFields = [
  "landing_page",
  "first_referrer",
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "fbclid",
  "msclkid",
];

const offers = [
  {
    title: "DP complète",
    price: "119 € HT",
    text: "Pièces, dépôt mairie et suivi jusqu'à validation.",
  },
  {
    title: "Raccordement + Consuel",
    price: "89 € HT",
    text: "Suivi Enedis, Consuel, relances et mise en service plus lisible.",
  },
  {
    title: "MaPrimeRenov'",
    price: "129 € HT",
    text: "Montage, dépôt ANAH et suivi administratif.",
  },
  {
    title: "CEE",
    price: "99 € HT",
    text: "Contrôle des pièces et suivi jusqu'à validation.",
  },
];

const proofItems = [
  "1 357 dossiers pilotés",
  "Production sous 48h lorsque le dossier est complet",
  "96 % de DP sans pièce complémentaire",
];

const visualProofItems = [
  "Un dossier reprend une action claire: pièce manquante, statut, relance ou dépôt.",
  "Vos équipes voient ce qui bloque sans rouvrir tous les portails.",
  "Le premier périmètre peut rester ponctuel avant d'élargir le flux.",
];

const specialistReasons = [
  {
    title: "Spécialiste photovoltaïque",
    text: "Sunelys parle DP, Consuel, raccordement Enedis, MaPrimeRénov' et CEE dans le contexte concret des installateurs solaires.",
  },
  {
    title: "Périmètre clair",
    text: "Vous déléguez une brique précise ou un flux complet, sans acheter une plateforme généraliste ni un accompagnement trop large.",
  },
  {
    title: "Prix visibles",
    text: "Les tarifs sont annoncés avant le contact pour filtrer les demandes peu qualifiées et cadrer vite le bon dossier.",
  },
];
---

<BaseLayout
  title="Déléguer dossiers photovoltaïques installateurs | Sunelys"
  description="Installateurs PV: déléguez DP, Consuel, raccordement Enedis, MaPrimeRénov' et CEE au dossier. Prix fixes HT et dossier ponctuel accepté."
  robots="noindex,follow"
>
  <section class="lp-hero" data-sticky-guard="hero">
    <div class="hero-copy">
      <p class="eyebrow">Installateurs photovoltaïques</p>
      <h1>
        <span class="headline-desktop">Déléguez vos dossiers DP, Consuel, Enedis et aides sans recruter.</span>
        <span class="headline-mobile">Déléguez vos dossiers PV sans recruter.</span>
      </h1>
      <p class="hero-text">
        Sunelys reprend vos démarches administratives photovoltaïques au dossier, avec prix fixes
        et démarrage possible sur un seul blocage.
      </p>
      <p class="intent-guard">
        Service réservé aux installateurs photovoltaïques, bureaux d'études et équipes admin ENR.
        Sunelys ne vend pas de panneaux et ne traite pas les demandes de pose particuliers.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary btn-accent" href="#diagnostic" data-track="cta_lp_admin_pv_hero_form">
          Recevoir mon diagnostic sous 24h
        </a>
        <a class="btn btn-secondary" href="#prix" data-track="cta_lp_admin_pv_hero_pricing">
          Voir les prix
        </a>
      </div>

      <ul class="hero-filters" aria-label="Filtres de qualification">
        <li>Installateurs PV uniquement</li>
        <li>Dossier ponctuel accepté</li>
        <li>Prix fixes HT</li>
      </ul>
    </div>

    <aside class="hero-intake" id="diagnostic" aria-label="Diagnostic délégation administrative">
      <p class="eyebrow">Diagnostic sous 24h</p>
      <h2>Quel dossier voulez-vous sortir de vos équipes ?</h2>
      <form
        class="lp-form"
        action={leadFormAction}
        method="POST"
        data-lead-form
        data-conversion-type="form_contact"
      >
        <input type="hidden" name="_subject" value="Nouveau lead SEA - delegation administrative PV" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value={successUrl} />
        <input type="hidden" name="source_page" value="lp_delegation_admin_pv" />
        <input type="hidden" name="conversion_type" value="form_contact" />
        <input type="hidden" name="lead_stage" value="lp_admin_pv_form_submitted" />
        <input type="hidden" name="service_interest" value="Délégation administrative photovoltaïque" />
        <input type="hidden" name="lead_source_detail" value="google_ads_lp_admin_pv" />
        <input type="hidden" name="qualification_hint" value="landing SEA: besoin, volume, email, téléphone optionnel" />
        <input type="hidden" name="lead_status" value="Nouveau lead" />
        <input type="hidden" name="lead_pipeline" value="Google Ads - Landing delegation admin PV" />
        <input type="hidden" name="lead_owner" value="Sunelys commercial" />
        <input type="hidden" name="follow_up_sla" value="24h" />
        <input type="hidden" name="follow_up_sequence" value="email_j0_then_phone_if_available_j1" />
        {attributionFields.map((fieldName) => (
          <input type="hidden" name={fieldName} data-lp-attribution={fieldName} />
        ))}

        <label>
          <span>Besoin principal</span>
          <select name="need" required>
            <option value="">Sélectionner</option>
            <option value="Declaration prealable">Déclaration préalable</option>
            <option value="Raccordement Enedis + Consuel">Raccordement + Consuel</option>
            <option value="MaPrimeRenov">MaPrimeRénov'</option>
            <option value="CEE">CEE</option>
            <option value="Pilotage complet">Pilotage complet</option>
          </select>
        </label>

        <label>
          <span>Volume mensuel</span>
          <select name="volume" required>
            <option value="">Sélectionner</option>
            <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
            <option value="10-30 dossiers">10-30 dossiers</option>
            <option value="+30 dossiers">+30 dossiers</option>
          </select>
        </label>

        <label>
          <span>Email professionnel</span>
          <input type="email" name="email" autocomplete="email" inputmode="email" required />
        </label>

        <button class="btn btn-primary btn-accent" type="submit" data-track="cta_lp_admin_pv_form_submit">
          Recevoir mon diagnostic
        </button>
        <small>3 champs suffisent pour lancer le cadrage. Les précisions ci-dessous restent optionnelles.</small>

        <details class="form-more">
          <summary>Ajouter un téléphone ou préciser le blocage <span>optionnel</span></summary>
          <div>
            <label>
              <span>Téléphone pour rappel <em>optionnel</em></span>
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
            </label>

            <label>
              <span>Blocage actuel <em>optionnel</em></span>
              <select name="blocked_stage">
                <option value="">Sélectionner</option>
                <option value="Avant depot">Avant dépôt</option>
                <option value="Complement mairie">Complément mairie</option>
                <option value="Consuel a preparer">Consuel à préparer</option>
                <option value="Raccordement en attente">Raccordement en attente</option>
                <option value="Dossier d'aide a deposer">Dossier d'aide à déposer</option>
                <option value="Mise en service bloquee">Mise en service bloquée</option>
                <option value="Je ne sais pas encore">Je ne sais pas encore</option>
              </select>
            </label>
          </div>
        </details>
      </form>
    </aside>
  </section>

  <section class="lp-proof-band" aria-label="Preuves Sunelys">
    {proofItems.map((item, index) => (
      <div>
        <span>{String(index + 1).padStart(2, "0")}</span>
        <strong>{item}</strong>
      </div>
    ))}
  </section>

  <section class="lp-section visual-proof-section" data-track-view="visual_proof_view" data-track-label="lp_admin_pv_visual_proof">
    <figure class="visual-media">
      <img
        src="/images/site/solar-admin-coordination-2026.webp"
        alt="Installateur photovoltaïque analysant des documents administratifs et plans solaires"
        width="1320"
        height="743"
        loading="eager"
        decoding="async"
      />
      <figcaption>Un service pensé pour les dossiers qui bloquent vraiment les équipes PV.</figcaption>
    </figure>

    <div class="visual-proof-copy">
      <p class="eyebrow">Preuve visuelle</p>
      <h2>Moins de relances invisibles, plus de statuts exploitables.</h2>
      <p>
        La valeur Sunelys se voit dans la clarté opérationnelle : un dossier, une étape,
        une prochaine action et un interlocuteur qui suit.
      </p>

      <ul class="visual-proof-list">
        {visualProofItems.map((item) => <li>{item}</li>)}
      </ul>

      <div class="portal-preview" aria-label="Aperçu du portail de suivi Sunelys">
        <img
          src="/google-business-profile/sunelys-gbp-portail-dashboard-propre-2026-07-21.jpg"
          alt="Aperçu anonymisé du portail Sunelys avec statuts de dossiers photovoltaïques"
          width="1600"
          height="900"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section
    class="client-proof-section"
    data-track-view="client_proof_view"
    data-track-label="lp_admin_pv_client_proof"
    aria-labelledby="client-proof-title"
  >
    <div class="client-proof-quote">
      <p class="eyebrow">Retour terrain</p>
      <blockquote id="client-proof-title">
        « Nous sommes ravis des délais, du suivi et de la réactivité de Sunelys. Le pilotage est plus fluide,
        les réponses arrivent vite et cela nous permet d'installer nos chantiers beaucoup plus rapidement. »
      </blockquote>
      <div class="client-proof-author">
        <img
          src="/images/site/client-betravaux.png"
          alt="Be Travaux"
          width="512"
          height="512"
          loading="lazy"
          decoding="async"
        />
        <p><strong>Victorion Brice</strong><span>Gérant · Be Travaux</span></p>
      </div>
    </div>

    <aside class="client-proof-impact" aria-label="Effets cités par le client">
      <p class="eyebrow">Du besoin à l'effet</p>
      <ol>
        <li>
          <span>01</span>
          <div><strong>Délais et suivi</strong><p>Le point de départ à fiabiliser.</p></div>
        </li>
        <li>
          <span>02</span>
          <div><strong>Pilotage plus fluide</strong><p>Des réponses qui arrivent vite.</p></div>
        </li>
        <li>
          <span>03</span>
          <div><strong>Chantiers installés plus vite</strong><p>L'effet opérationnel cité par Be Travaux.</p></div>
        </li>
      </ol>
      <a class="btn btn-primary btn-accent" href="#diagnostic" data-track="cta_lp_client_proof">
        Tester sur un dossier
      </a>
    </aside>
  </section>

  <section class="lp-section pricing-section" id="prix" data-track-view="pricing_view" data-track-label="lp_admin_pv_pricing">
    <div class="section-head">
      <p class="eyebrow">Prix fixes</p>
      <h2>Un tarif clair par dossier, sans minimum bloquant.</h2>
      <p>
        Commencez par un dossier ponctuel, puis gardez Sunelys sur le flux qui soulage vraiment vos équipes.
      </p>
    </div>

    <div class="price-grid">
      {offers.map((offer, index) => (
        <article class="price-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
          </div>
          <strong>{offer.price}</strong>
        </article>
      ))}
    </div>
  </section>

  <section class="lp-section specialist-section" id="specialiste-pv">
    <div class="section-head">
      <p class="eyebrow">Positionnement</p>
      <h2>Pourquoi choisir un spécialiste administratif PV.</h2>
      <p>
        Un prestataire ENR généraliste peut couvrir large. Sunelys choisit une promesse plus nette :
        reprendre les dossiers photovoltaïques qui bloquent réellement vos équipes.
      </p>
    </div>

    <div class="specialist-grid">
      {specialistReasons.map((reason, index) => (
        <article class="specialist-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <h3>{reason.title}</h3>
            <p>{reason.text}</p>
          </div>
        </article>
      ))}
    </div>

    <a class="btn btn-secondary" href="/sous-traitance-administrative-photovoltaique-installateur" data-track="cta_lp_specialist_seo_page">
      Comprendre l'approche Sunelys
    </a>
  </section>

  <section class="lp-final">
    <div>
      <p class="eyebrow">Base saine</p>
      <h2>On cadre le premier dossier à déléguer, puis on mesure.</h2>
      <p>
        Le but n'est pas de vous vendre tout le flux tout de suite. Le but est d'identifier le dossier
        qui consomme déjà trop de temps et de le sortir proprement de vos équipes.
      </p>
    </div>
    <a class="btn btn-primary btn-accent" href="#diagnostic" data-track="cta_lp_admin_pv_final">
      Recevoir mon diagnostic sous 24h
    </a>
  </section>
</BaseLayout>

<script>
  const lpAttribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};
  document.querySelectorAll("[data-lp-attribution]").forEach((field) => {
    if (!(field instanceof HTMLInputElement)) return;
    const key = field.dataset.lpAttribution || "";
    field.value = lpAttribution[key] || "";
  });
</script>

<style>
  .lp-hero,
  .lp-section,
  .lp-final {
    border: 1px solid color-mix(in srgb, var(--line) 84%, white);
    background:
      radial-gradient(110% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 40%, transparent), transparent 58%),
      linear-gradient(165deg, color-mix(in srgb, var(--surface-elevated) 94%, white), var(--surface));
    box-shadow: var(--shadow-md);
  }

  .lp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.72fr);
    gap: clamp(1rem, 2.6vw, 2.1rem);
    align-items: start;
    border-radius: var(--radius-xl);
    padding: clamp(1.1rem, 3vw, 2.4rem);
  }

  .hero-copy,
  .section-head,
  .lp-final > div {
    display: grid;
    gap: 0.86rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
  }

  h1 {
    max-width: 15ch;
    font-size: clamp(2.25rem, 4.8vw, 5.2rem);
    line-height: 0.92;
  }

  .headline-mobile {
    display: none;
  }

  .headline-desktop {
    display: block;
  }

  h2 {
    max-width: 16ch;
    font-size: clamp(1.55rem, 3vw, 3rem);
    line-height: 0.98;
  }

  h3 {
    font-size: 1.05rem;
    line-height: 1.1;
  }

  p,
  li,
  small {
    color: var(--text-muted);
    line-height: 1.56;
  }

  .hero-text {
    max-width: 48rem;
    color: var(--text);
    font-size: clamp(1.02rem, 1vw, 1.18rem);
  }

  .intent-guard {
    max-width: 46rem;
    border-left: 3px solid var(--accent-strong);
    margin: 0;
    background: color-mix(in srgb, var(--surface-elevated) 88%, transparent);
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 700;
    padding: 0.72rem 0.86rem;
  }

  .hero-portal-proof {
    display: grid;
    grid-template-columns: minmax(9.5rem, 0.42fr) minmax(0, 1fr);
    gap: 0.72rem;
    align-items: center;
    max-width: 42rem;
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 96%, white);
    box-shadow: 0 16px 36px rgba(20, 16, 10, 0.08);
    overflow: hidden;
  }

  .hero-portal-proof img {
    display: block;
    width: 100%;
    height: 7.6rem;
    object-fit: cover;
    object-position: top center;
  }

  .hero-portal-proof figcaption {
    display: grid;
    gap: 0.22rem;
    padding: 0.76rem 0.86rem 0.76rem 0;
  }

  .hero-portal-proof span {
    color: var(--accent-deep);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .hero-portal-proof strong {
    color: var(--text);
    font-size: clamp(0.92rem, 1vw, 1.08rem);
    line-height: 1.25;
  }

  .hero-filters,
  .proof-list,
  .plain-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-filters li {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    color: var(--text);
    padding: 0.42rem 0.72rem;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.68rem;
  }

  .hero-price-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .hero-price-strip span {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 14px;
    background: color-mix(in srgb, var(--surface-elevated) 96%, white);
    color: var(--accent-deep);
    font-weight: 900;
    line-height: 1.2;
    padding: 0.7rem 0.72rem;
  }

  .hero-intake {
    border: 1px solid color-mix(in srgb, var(--line) 82%, var(--accent-soft));
    border-radius: 22px;
    background: rgba(255, 253, 248, 0.84);
    padding: clamp(1rem, 2vw, 1.35rem);
    box-shadow: 0 18px 44px rgba(20, 16, 10, 0.07);
  }

  .hero-intake h2 {
    margin-top: 0.48rem;
    font-size: clamp(1.4rem, 2.2vw, 2.3rem);
  }

  .lp-form {
    display: grid;
    gap: 0.72rem;
    margin-top: 1rem;
  }

  .lp-form label {
    display: grid;
    gap: 0.28rem;
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .lp-form em {
    color: var(--text-muted);
    font-style: normal;
    font-weight: 600;
    text-transform: none;
  }

  .lp-form input,
  .lp-form select,
  .lp-form textarea {
    width: 100%;
    min-height: 2.78rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, var(--accent-soft));
    border-radius: 13px;
    background: color-mix(in srgb, var(--surface-elevated) 96%, white);
    color: var(--text);
    font: inherit;
    font-weight: 500;
    padding: 0.72rem 0.78rem;
  }

  .lp-form textarea {
    resize: vertical;
  }

  .lp-form small {
    font-size: 0.76rem;
  }

  .lp-section,
  .lp-final {
    border-radius: 24px;
    padding: clamp(1.05rem, 2.6vw, 2rem);
  }

  .pricing-section {
    display: grid;
    gap: 1rem;
  }

  .visual-proof-section {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .visual-media {
    margin: 0;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: 0 22px 54px rgba(20, 16, 10, 0.1);
  }

  .visual-media img {
    display: block;
    width: 100%;
    height: clamp(16rem, 29vw, 27rem);
    object-fit: cover;
  }

  .visual-media figcaption {
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.35;
    padding: 0.78rem 0.92rem;
  }

  .visual-proof-copy {
    display: grid;
    gap: 0.9rem;
  }

  .visual-proof-list {
    display: grid;
    gap: 0.54rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .visual-proof-list li {
    border-left: 3px solid var(--accent-strong);
    background: color-mix(in srgb, var(--surface-elevated) 86%, transparent);
    color: var(--text);
    padding: 0.7rem 0.82rem;
  }

  .portal-preview {
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: 18px;
    background: #fffdfa;
    box-shadow: 0 16px 42px rgba(20, 16, 10, 0.09);
    overflow: hidden;
  }

  .portal-preview img {
    display: block;
    width: 100%;
    height: clamp(12rem, 22vw, 18rem);
    object-fit: cover;
    object-position: top center;
  }

  .specialist-section {
    display: grid;
    gap: 1rem;
  }

  .price-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .price-card {
    min-height: 11rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: 1rem;
    display: grid;
    gap: 0.56rem;
    align-content: start;
  }

  .price-card strong {
    color: var(--accent-deep);
    font-size: clamp(1.7rem, 2vw, 2.2rem);
    line-height: 1;
    white-space: nowrap;
  }

  .specialist-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .specialist-card {
    min-height: 10rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: 1rem;
    display: grid;
    gap: 0.56rem;
    align-content: start;
  }

  .specialist-card h3 {
    color: var(--text);
  }

  .split-section,
  .proof-section,
  .lp-final {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .plain-list,
  .proof-list {
    display: grid;
    gap: 0.66rem;
  }

  .plain-list li,
  .proof-list li {
    border-left: 3px solid var(--accent-strong);
    background: color-mix(in srgb, var(--surface-elevated) 82%, transparent);
    color: var(--text);
    padding: 0.72rem 0.85rem;
  }

  .handover-section {
    display: grid;
    gap: 1rem;
  }

  .handover-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .handover-card {
    min-height: 10rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: 1rem;
    display: grid;
    gap: 0.8rem;
    align-content: start;
  }

  .handover-card span {
    width: 2rem;
    aspect-ratio: 1;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: var(--ink-soft);
    color: #fffdfa;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .handover-card p {
    color: var(--text);
  }

  .lp-final {
    background:
      radial-gradient(110% 130% at 100% 0%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 58%),
      linear-gradient(165deg, #1b1712, #11100d);
  }

  .lp-final h2,
  .lp-final p,
  .lp-final .eyebrow {
    color: #f7f2e8;
  }

  .lp-final p {
    color: #d8ccbb;
  }

  @media (max-width: 1120px) {
    .lp-hero,
    .visual-proof-section,
    .split-section,
    .proof-section,
    .lp-final {
      grid-template-columns: 1fr;
    }

    .hero-price-strip,
    .price-grid,
    .specialist-grid,
    .handover-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    h1,
    h2 {
      max-width: 18ch;
    }
  }

  @media (max-width: 680px) {
    :global(.site-header .header-row) {
      grid-template-areas:
        "brand actions"
        "cta cta";
      gap: 0.34rem 0.7rem;
      padding-block: 0.5rem;
    }

    :global(.site-header .main-nav) {
      display: none;
    }

    :global(.site-header .brand-link img) {
      width: 106px;
      height: 22px;
    }

    :global(.site-header .portal-link) {
      min-height: 1.4rem;
      font-size: 0.62rem;
    }

    :global(.site-header .nav-cta.btn) {
      min-height: 2.08rem;
      padding: 0.52rem 0.86rem;
      font-size: 0.72rem;
    }

    .lp-hero,
    .lp-section,
    .lp-final {
      border-radius: 20px;
    }

    .price-grid,
    .specialist-grid,
    .handover-grid {
      grid-template-columns: 1fr;
    }

    .lp-hero {
      gap: 0.72rem;
      padding: 0.9rem;
    }

    .hero-copy {
      gap: 0.54rem;
    }

    h1 {
      max-width: 9.8ch;
      font-size: clamp(2.15rem, 11vw, 2.72rem);
      line-height: 0.96;
    }

    .headline-desktop {
      display: none;
    }

    .headline-mobile {
      display: block;
    }

    .hero-text {
      font-size: 0.94rem;
      line-height: 1.38;
    }

    .intent-guard {
      font-size: 0.77rem;
      line-height: 1.32;
      padding: 0.52rem 0.64rem;
    }

    .hero-portal-proof {
      grid-template-columns: 4.8rem minmax(0, 1fr);
      gap: 0.54rem;
      border-radius: 15px;
    }

    .hero-portal-proof img {
      height: 4.72rem;
    }

    .hero-portal-proof figcaption {
      padding: 0.5rem 0.62rem 0.5rem 0;
    }

    .hero-portal-proof strong {
      font-size: 0.78rem;
      line-height: 1.18;
    }

    .hero-filters,
    .hero-price-strip,
    .hero-actions {
      display: none;
    }

    .hero-actions,
    .hero-actions .btn,
    .lp-final .btn {
      width: 100%;
    }

    .hero-actions .btn-secondary {
      display: none;
    }

    .hero-intake {
      padding: 0.9rem;
      border-radius: 18px;
    }

    .hero-intake h2 {
      max-width: 13ch;
      margin-top: 0.24rem;
      font-size: 1.65rem;
    }

    .lp-form {
      gap: 0.58rem;
      margin-top: 0.72rem;
    }

    .lp-form input,
    .lp-form select,
    .lp-form textarea {
      min-height: 2.58rem;
      border-radius: 12px;
      padding: 0.62rem 0.7rem;
    }

    .lp-form small {
      font-size: 0.72rem;
      line-height: 1.35;
    }

  }

  /* Direction visuelle 2026 */
  .lp-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(21rem, 0.58fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    overflow: hidden;
    min-height: min(45rem, calc(100vh - 8rem));
    padding: clamp(2rem, 5vw, 5rem);
    border: 0;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 88% 4%, rgba(54, 98, 227, 0.42), transparent 31%),
      radial-gradient(circle at 5% 100%, rgba(212, 130, 42, 0.24), transparent 32%),
      var(--ink);
    box-shadow: none;
  }

  .lp-hero::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -13rem;
    width: clamp(20rem, 36vw, 35rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .hero-copy {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .lp-hero .eyebrow {
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .lp-hero h1 {
    max-width: 13ch;
    color: #ffffff;
    font-size: clamp(2.55rem, 5.2vw, 5.35rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .lp-hero .hero-text {
    max-width: 43rem;
    color: #cbd5e1;
    font-size: clamp(1rem, 1.15vw, 1.18rem);
    line-height: 1.65;
  }

  .intent-guard {
    max-width: 44rem;
    padding: 0 0 0 0.9rem;
    border-left: 3px solid var(--accent);
    background: transparent;
    color: #aebbcf;
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  .lp-hero .btn-secondary {
    border-color: rgba(255, 255, 255, 0.28);
    background: transparent;
    color: #ffffff;
  }

  .hero-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 0.35rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-filters li {
    width: auto;
    padding: 0 1rem 0 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: #aebbcf;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  .hero-filters li:not(:last-child)::after {
    content: "";
    display: inline-block;
    width: 0.2rem;
    height: 0.2rem;
    margin-left: 1rem;
    border-radius: 50%;
    background: var(--accent);
    vertical-align: middle;
  }

  .hero-intake {
    position: relative;
    z-index: 1;
    padding: clamp(1.25rem, 2.6vw, 2rem);
    border: 0;
    border-radius: var(--radius-md);
    background: #ffffff;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.23);
  }

  .hero-intake > .eyebrow {
    color: var(--system);
  }

  .hero-intake h2 {
    max-width: 14ch;
    margin-top: 0.45rem;
    color: var(--ink);
    font-size: clamp(1.5rem, 2.5vw, 2.35rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .lp-form {
    gap: 0.7rem;
    margin-top: 1.15rem;
  }

  .lp-form label {
    gap: 0.32rem;
    color: var(--text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
  }

  .lp-form input,
  .lp-form select,
  .lp-form textarea {
    min-height: 2.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: #ffffff;
    color: var(--ink);
    padding: 0.72rem 0.78rem;
  }

  .lp-form input:focus,
  .lp-form select:focus,
  .lp-form textarea:focus {
    border-color: var(--system);
    outline: 3px solid color-mix(in srgb, var(--system-soft) 80%, transparent);
  }

  .lp-form > small {
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  .form-more {
    padding-top: 0.15rem;
    border-top: 1px solid var(--line);
  }

  .form-more summary {
    cursor: pointer;
    padding: 0.75rem 1.6rem 0.1rem 0;
    color: var(--system);
    font-size: 0.74rem;
    font-weight: 800;
    list-style: none;
  }

  .form-more summary::-webkit-details-marker {
    display: none;
  }

  .form-more summary::after {
    content: "+";
    float: right;
    margin-right: -1.5rem;
    color: var(--system);
    font-size: 1rem;
    font-weight: 500;
  }

  .form-more[open] summary::after {
    content: "−";
  }

  .form-more summary span {
    color: var(--text-muted);
    font-size: 0.66rem;
    font-weight: 600;
  }

  .form-more > div {
    display: grid;
    gap: 0.7rem;
    margin-top: 0.75rem;
  }

  .lp-proof-band {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-top: 2px solid var(--ink);
    border-bottom: 1px solid var(--line);
  }

  .lp-proof-band div {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: baseline;
    padding: 1rem clamp(0.7rem, 2vw, 1.4rem);
    border-right: 1px solid var(--line);
  }

  .lp-proof-band div:first-child {
    padding-left: 0;
  }

  .lp-proof-band div:last-child {
    border-right: 0;
  }

  .lp-proof-band span {
    color: var(--system);
    font-size: 0.68rem;
    font-weight: 850;
  }

  .lp-proof-band strong {
    color: var(--ink);
    font-size: clamp(0.82rem, 1vw, 0.95rem);
    line-height: 1.35;
  }

  .lp-section,
  .lp-final {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .visual-proof-section {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }

  .visual-media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border: 0;
    border-radius: var(--radius-md);
    background: var(--ink);
    box-shadow: none;
  }

  .visual-media img {
    width: 100%;
    height: clamp(22rem, 42vw, 38rem);
    object-fit: cover;
    filter: saturate(0.82) contrast(1.04);
  }

  .visual-media figcaption {
    position: absolute;
    inset: auto 1rem 1rem;
    max-width: 30rem;
    padding: 0.7rem 0.85rem;
    border-radius: var(--radius-sm);
    background: rgba(14, 23, 38, 0.84);
    color: #ffffff;
    font-size: 0.78rem;
    backdrop-filter: blur(8px);
  }

  .visual-proof-copy {
    display: grid;
    gap: 0.9rem;
  }

  .visual-proof-copy .eyebrow,
  .pricing-section .eyebrow {
    color: var(--system);
    letter-spacing: 0.11em;
  }

  .visual-proof-copy h2,
  .pricing-section h2,
  .specialist-section h2,
  .lp-final h2 {
    max-width: 17ch;
    color: var(--ink);
    font-size: clamp(1.85rem, 3.55vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .visual-proof-copy > p:not(.eyebrow),
  .section-head > p:last-child {
    max-width: 48ch;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .visual-proof-list {
    display: grid;
    gap: 0;
    margin-top: 0.25rem;
    border-top: 1px solid var(--line);
  }

  .visual-proof-list li {
    padding: 0.8rem 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    background: transparent;
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .portal-preview {
    margin-top: 0.3rem;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: #ffffff;
    box-shadow: none;
  }

  .portal-preview img {
    height: clamp(10rem, 18vw, 15rem);
    filter: saturate(0.76) contrast(1.02);
  }

  .client-proof-section {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(20rem, 0.88fr);
    gap: clamp(2rem, 6vw, 6rem);
    overflow: hidden;
    padding: clamp(2.2rem, 5vw, 4.6rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 92% 2%, rgba(54, 98, 227, 0.38), transparent 32%),
      radial-gradient(circle at 0% 100%, rgba(212, 130, 42, 0.2), transparent 34%),
      var(--ink);
  }

  .client-proof-section::after {
    content: "“";
    position: absolute;
    z-index: -1;
    right: 40%;
    top: -4.8rem;
    color: rgba(255, 255, 255, 0.035);
    font-family: Georgia, serif;
    font-size: clamp(18rem, 31vw, 34rem);
    line-height: 1;
  }

  .client-proof-quote {
    display: grid;
    gap: 1.25rem;
    align-content: start;
  }

  .client-proof-section .eyebrow {
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .client-proof-quote blockquote {
    max-width: 24ch;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.65rem, 3vw, 3rem);
    font-weight: 760;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .client-proof-author {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }

  .client-proof-author img {
    width: 7.4rem;
    height: 2.8rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.65rem;
    background: #ffffff;
    object-fit: cover;
  }

  .client-proof-author p {
    display: grid;
    gap: 0.15rem;
    margin: 0;
  }

  .client-proof-author strong {
    color: #ffffff;
    font-size: 0.92rem;
  }

  .client-proof-author span {
    color: #aebdd0;
    font-size: 0.78rem;
  }

  .client-proof-impact {
    display: grid;
    gap: 0.9rem;
    align-content: start;
    padding: clamp(1.1rem, 2.5vw, 1.65rem);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(14px);
  }

  .client-proof-impact ol {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.17);
    list-style: none;
  }

  .client-proof-impact li {
    display: grid;
    grid-template-columns: 2.1rem minmax(0, 1fr);
    gap: 0.75rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.17);
  }

  .client-proof-impact li > span {
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 850;
  }

  .client-proof-impact li div {
    display: grid;
    gap: 0.2rem;
  }

  .client-proof-impact strong {
    color: #ffffff;
    font-size: 0.9rem;
  }

  .client-proof-impact li p {
    margin: 0;
    color: #aebdd0;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .client-proof-impact .btn {
    justify-self: start;
    margin-top: 0.2rem;
  }

  .hero-intake[id],
  .pricing-section[id] {
    scroll-margin-top: 6rem;
  }

  .pricing-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(2rem, 5vw, 5rem);
    padding: clamp(2rem, 4.5vw, 4rem);
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .section-head {
    display: grid;
    align-content: start;
    gap: 0.75rem;
  }

  .price-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    border-top: 1px solid color-mix(in srgb, var(--system) 18%, var(--line));
  }

  .price-card {
    display: grid;
    grid-template-columns: 2.1rem minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: start;
    min-height: 0;
    padding: 1rem 0;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--system) 18%, var(--line));
    border-radius: 0;
    background: transparent;
  }

  .price-card > span {
    color: var(--system);
    font-size: 0.68rem;
    font-weight: 850;
  }

  .price-card div {
    display: grid;
    gap: 0.28rem;
  }

  .price-card h3 {
    color: var(--ink);
    font-size: 1rem;
    font-weight: 850;
  }

  .price-card p {
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .price-card > strong {
    color: var(--ink);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .specialist-section {
    display: grid;
    grid-template-columns: minmax(0, 0.68fr) minmax(0, 1.32fr);
    gap: clamp(2rem, 5vw, 5.5rem);
    padding: clamp(2.2rem, 5vw, 4.5rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 95% 5%, rgba(54, 98, 227, 0.34), transparent 32%),
      var(--ink);
  }

  .specialist-section .eyebrow {
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .specialist-section h2 {
    color: #ffffff;
  }

  .specialist-section .section-head > p:last-child {
    color: #b9c5d5;
  }

  .specialist-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .specialist-card {
    display: grid;
    grid-template-columns: 2.3rem minmax(0, 1fr);
    gap: 0.9rem;
    min-height: 0;
    padding: 1.05rem 0;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0;
    background: transparent;
  }

  .specialist-card > span {
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 850;
  }

  .specialist-card div {
    display: grid;
    gap: 0.35rem;
  }

  .specialist-card h3 {
    color: #ffffff;
    font-size: 1.05rem;
  }

  .specialist-card p {
    max-width: 56ch;
    color: #b9c5d5;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .specialist-section > .btn {
    grid-column: 2;
    justify-self: start;
    margin-top: 0.2rem;
    border-color: rgba(255, 255, 255, 0.28);
    background: transparent;
    color: #ffffff;
  }

  .lp-final {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
    padding: clamp(2.2rem, 5vw, 4.5rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 90% 0%, rgba(54, 98, 227, 0.35), transparent 34%),
      var(--ink);
  }

  .lp-final > div {
    display: grid;
    gap: 0.85rem;
  }

  .lp-final .eyebrow {
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .lp-final h2 {
    max-width: 16ch;
    color: #ffffff;
  }

  .lp-final p {
    max-width: 48ch;
    color: #cbd5e1;
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .lp-hero,
    .visual-proof-section,
    .client-proof-section,
    .pricing-section,
    .specialist-section,
    .lp-final {
      grid-template-columns: 1fr;
    }

    .lp-hero {
      min-height: 0;
    }

    .hero-intake {
      width: min(36rem, 100%);
    }

    .specialist-section > .btn {
      grid-column: 1;
    }
  }

  @media (max-width: 680px) {
    .lp-hero {
      gap: 1.2rem;
      margin-inline: calc(var(--container-padding) * -0.35);
      padding: 1.4rem;
      border-radius: var(--radius-md);
