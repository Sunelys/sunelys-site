---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Sunelys"
  description="Contactez Sunelys pour un accompagnement sur vos démarches photovoltaïques: déclaration préalable, raccordement Enedis et Consuel."
>
  <section class="hero">
    <h1>Contact</h1>
    <p>
      Parlez-nous de votre projet photovoltaïque. Nous revenons vers vous avec une
      proposition adaptée à vos besoins.
    </p>
  </section>

  <section class="grid">
    <article class="card">
      <h2>Email</h2>
      <p>Pour une demande détaillée ou l'envoi de pièces.</p>
      <p><a href="mailto:contact@sunelys.fr">contact@sunelys.fr</a></p>
    </article>

    <article class="card">
      <h2>Téléphone</h2>
      <p>Pour un échange rapide sur votre avancement.</p>
      <p><a href="tel:+33600000000">+33 6 00 00 00 00</a></p>
    </article>
  </section>

  <section class="card">
    <h2>Informations à préparer</h2>
    <ul>
      <li>Localisation du projet</li>
      <li>Type de bâtiment ou d'installation</li>
      <li>État d'avancement des démarches</li>
      <li>Délais visés</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .hero,
  .card {
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: 0 8px 20px rgba(17, 24, 39, 0.08);
  }

  h1 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.75rem, 4.5vw, 2.6rem);
    line-height: 1.15;
  }

  h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.2rem, 2.9vw, 1.5rem);
  }

  p,
  li {
    color: #4b5563;
  }

  p {
    margin: 0;
  }

  .grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .grid p + p {
    margin-top: 0.6rem;
  }

  a {
    color: #115e59;
    text-decoration: none;
    font-weight: 700;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
  }

  .card:last-child {
    margin-top: 1rem;
  }

  ul {
    margin: 0.3rem 0 0;
    padding-left: 1.1rem;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
