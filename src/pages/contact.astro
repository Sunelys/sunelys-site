---
import BaseLayout from "../layouts/BaseLayout.astro";

const successUrl = "https://sunelys.fr/merci";
---

<BaseLayout
  title="Contact installateurs photovoltaïques | Sunelys"
  description="Parlez à Sunelys de vos flux administratifs photovoltaïques. Nous cadrons vos besoins en déclaration préalable, Consuel et raccordement."
>
  <section class="hero card">
    <p class="eyebrow">Prise de contact</p>
    <h1>Faites le point sur vos flux administratifs en 15 minutes.</h1>
    <p>
      Déclaration préalable, Consuel, raccordement Enedis : nous regardons votre volume,
      vos points de friction et la façon la plus simple de soulager vos équipes.
    </p>

    <ul class="hero-points">
      <li>Réponse rapide sur votre organisation actuelle</li>
      <li>Vision claire sur les gains opérationnels possibles</li>
      <li>Échange adapté aux installateurs et aux flux multi-dossiers</li>
    </ul>

    <div class="hero-actions">
      <a class="cta" href="tel:+33695907919" data-track="cta_contact_call">Appeler maintenant</a>
      <a class="cta cta-secondary" href="mailto:contact@sunelys.fr" data-track="cta_contact_email_top">
        Envoyer un email
      </a>
    </div>
  </section>

  <section class="section grid">
    <article class="card">
      <h2>Email</h2>
      <p>Pour une demande détaillée ou l'envoi de pièces.</p>
      <p><a href="mailto:contact@sunelys.fr" data-track="cta_contact_email">contact@sunelys.fr</a></p>
    </article>

    <article class="card">
      <h2>Téléphone</h2>
      <p>Pour un échange rapide sur votre volume de dossiers ou vos délais.</p>
      <p><a href="tel:+33695907919" data-track="cta_contact_phone">06 95 90 79 19</a></p>
    </article>

    <article class="card">
      <h2>Adresse</h2>
      <p>49, impasse des lauriers</p>
      <p>83600 Les Adrets de l'Esterel</p>
    </article>
  </section>

  <section class="section card form-card">
    <h2>Recevoir un cadrage initial</h2>
    <p class="helper">
      Le volume de dossiers est pré-rempli si vous venez du mini-tunnel. Le formulaire
      envoie directement votre demande à Sunelys.
    </p>

    <form
      id="contact-form"
      class="form-grid"
      action="https://formsubmit.co/contact@sunelys.fr"
      method="POST"
    >
      <input type="hidden" name="_subject" value="Nouvelle demande Sunelys" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value={successUrl} />

      <label>
        Nom
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label>
        Société
        <input type="text" name="company" autocomplete="organization" />
      </label>
      <label>
        Email
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label>
        Téléphone
        <input type="tel" name="phone" autocomplete="tel" />
      </label>
      <label>
        Volume de dossiers / mois
        <select name="volume" id="volume-field">
          <option value="">Sélectionner</option>
          <option value="1-10">1-10</option>
          <option value="10-30">10-30</option>
          <option value="+30">+30</option>
        </select>
      </label>
      <label>
        Besoin principal
        <select name="need">
          <option value="">Sélectionner</option>
          <option value="Declaration prealable">Déclaration préalable</option>
          <option value="Consuel">Consuel</option>
          <option value="Raccordement Enedis">Raccordement Enedis</option>
          <option value="Pilotage complet">Pilotage complet</option>
        </select>
      </label>
      <label class="full-width">
        Message
        <textarea name="message" rows="5" placeholder="Contexte, zone, délais, type de projet..."></textarea>
      </label>
      <button class="cta" type="submit" data-track="cta_contact_form_submit">Demander un audit</button>
    </form>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const volumeFromQuery = params.get("volume");
  const volumeFromStorage = localStorage.getItem("sunelys_volume_range");
  const volumeField = document.querySelector("#volume-field");

  const prefillVolume = volumeFromQuery || volumeFromStorage || "";
  if (volumeField && prefillVolume) {
    volumeField.value = prefillVolume;
  }

  document.querySelector("#contact-form")?.addEventListener("submit", () => {
    if (window.trackEvent) {
      window.trackEvent("contact_form_submit", {
        volume: volumeField instanceof HTMLSelectElement ? volumeField.value : "",
      });
    }
  });
</script>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 95%, white),
      var(--surface)
    );
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(1.15rem, 2.6vw, 2rem);
    box-shadow: var(--shadow-md);
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.6vw, 4.2rem);
    line-height: 0.94;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.2rem, 2.9vw, 1.5rem);
  }

  p,
  li,
  label {
    color: var(--text-muted);
  }

  p {
    margin: 0;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .hero {
    display: grid;
    gap: 1rem;
  }

  .hero-points {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.45rem;
  }

  .hero-points li {
    position: relative;
    padding-left: 1rem;
    color: var(--text);
  }

  .hero-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.52rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .grid p + p {
    margin-top: 0.6rem;
  }

  a {
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
  }

  .helper {
    margin-bottom: 0.9rem;
    font-size: 0.92rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.92rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 84%, white);
    color: var(--text);
    border-radius: 14px;
    padding: 0.78rem 0.82rem;
    font: inherit;
  }

  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 75%, white);
    outline-offset: 2px;
    border-color: color-mix(in srgb, var(--accent) 68%, var(--line));
  }

  .full-width {
    grid-column: 1 / -1;
  }

  .cta {
    justify-self: start;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.22rem;
    border-radius: 999px;
    font-weight: 700;
    color: #f7f3ec;
    background: var(--text);
    cursor: pointer;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      color 170ms ease;
  }

  .cta:hover,
  .cta:focus-visible {
    color: #fff;
    background: #0f0d0a;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .cta-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--line);
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .full-width {
      grid-column: auto;
    }

    .hero-actions {
      display: grid;
    }

    .hero-actions .cta {
      width: 100%;
    }
  }
</style>
