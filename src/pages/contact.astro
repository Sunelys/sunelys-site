---
import BaseLayout from "../layouts/BaseLayout.astro";

const successUrl = "https://sunelys.fr/merci?source=contact_form";
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
const hasBookingUrl = Boolean(bookingUrl);

const trustBullets = [
  "Réponse sous 24h ouvrées",
  "Plan d'action administratif sans engagement",
  "Dossier ponctuel accepté",
  "DP, Consuel, raccordement, EDF OA et aides pilotés selon votre organisation",
];

const contactReasons = [
  {
    title: "Un dossier vous bloque",
    text: "Une DP, un Consuel, un raccordement, un dossier EDF OA ou une aide consomme déjà trop de temps et ralentit le chantier.",
  },
  {
    title: "Vous voulez moins de retours",
    text: "Pièces manquantes, relances et étapes floues finissent par ralentir vos mises en service.",
  },
  {
    title: "Vous voulez déléguer sans flou",
    text: "Vous cherchez un partenaire administratif présentable, traçable et capable d'intervenir sur un dossier ou un flux.",
  },
];

const whatYouGet = [
  {
    title: "Lecture du contexte",
    text: "Volume, urgence, typologie des dossiers, organisation interne et points de blocage.",
  },
  {
    title: "Priorités claires",
    text: "Le premier périmètre à déléguer pour soulager vos équipes sans casser votre fonctionnement.",
  },
  {
    title: "Recommandation exploitable",
    text: "Une lecture simple, lisible et alignée sur vos contraintes terrain, commerce et délais.",
  },
];

const supportCards = [
  {
    title: "Email",
    text: "Pour transmettre une demande détaillée ou envoyer des pièces.",
    value: "contact@sunelys.fr",
    href: "mailto:contact@sunelys.fr",
    track: "cta_contact_email",
  },
  {
    title: "Téléphone",
    text: "Pour un échange rapide sur votre volume ou un blocage en cours.",
    value: "06 95 90 79 19",
    href: "tel:+33695907919",
    track: "cta_contact_phone",
  },
  {
    title: "Adresse",
    text: "Sunelys accompagne à distance partout en France depuis le Var.",
    value: "49, impasse des lauriers · 83600 Les Adrets de l'Esterel",
    href: "https://maps.google.com/?q=49%20impasse%20des%20lauriers%2083600%20Les%20Adrets%20de%20l%27Esterel",
    track: "cta_contact_address",
  },
];
---

<BaseLayout
  title="Contact installateurs photovoltaïques | Sunelys"
  description="Demandez un diagnostic administratif Sunelys sous 24h pour vos dossiers photovoltaïques bloqués ou chronophages : DP, Consuel, raccordement, EDF OA, MaPrimeRénov' et CEE."
>
  <section class="contact-hero section-shell reveal">
    <div class="hero-copy">
      <p class="eyebrow">Prise de contact</p>
      <h1>Recevez un diagnostic sous 24h pour vos dossiers administratifs bloqués.</h1>
      <p class="hero-text">
        Décrivez votre volume, vos blocages et vos priorités. Sunelys identifie le premier périmètre à déléguer:
        DP, Consuel, raccordement, EDF OA, MaPrimeRénov' ou CEE, du dossier ponctuel au flux récurrent.
      </p>

      <ul class="trust-strip" aria-label="Réassurance contact">
        {trustBullets.map((item) => <li>{item}</li>)}
      </ul>

      <div class="hero-actions">
        <a class="btn btn-primary btn-accent" href="#contact-form" data-track="cta_contact_form_top">
          Recevoir un diagnostic sous 24h
        </a>
        {
          hasBookingUrl && (
            <a
              class="btn btn-secondary"
              href={bookingUrl}
              target="_blank"
              rel="noreferrer"
              data-track="cta_contact_booking_top"
            >
              Réserver 15 min
            </a>
          )
        }
      </div>

      <div class="reason-grid">
        {contactReasons.map((item) => (
          <article class="reason-card">
            <h2>{item.title}</h2>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>

    <aside class="hero-panel" aria-label="Réassurance Sunelys">
      <div class="hero-panel-card">
        <p class="panel-kicker">Ce que vous obtenez</p>
        <h2>Une première lecture utile, pas un call de qualification vide.</h2>
        <div class="what-grid">
          {whatYouGet.map((item, index) => (
            <article class="step-card">
              <span>{index + 1}</span>
              <div>
                <strong>{item.title}</strong>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <blockquote class="quote-card">
        <p>
          "Les déclarations préalables avancent avec un très haut niveau d'acceptation sans pièces complémentaires,
          et nous gardons la tranquillité d'esprit d'être en règle sur tout l'administratif."
        </p>
        <footer>
          <strong>Damien Guillaume</strong>
          <span>Dirigeant, SUN WATT FRANCE</span>
        </footer>
      </blockquote>
    </aside>
  </section>

  <section class="contact-main section-shell reveal">
    <div class="form-shell">
      <div class="form-head">
        <p class="eyebrow">Formulaire</p>
        <h2>Décrivez votre contexte en quelques champs.</h2>
        <p>
          Le volume de dossiers est pré-rempli si vous venez du tunnel homepage. Plus votre contexte est clair,
          plus le diagnostic permet d'identifier vite le bon périmètre à reprendre.
        </p>
      </div>

      <form
        id="contact-form"
        class="form-grid"
        action={leadFormAction}
        method="POST"
        data-lead-form
        data-conversion-type="form_contact"
      >
        <input type="hidden" name="_subject" value="Nouveau diagnostic administratif Sunelys" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value={successUrl} />
        <input type="hidden" name="source_page" id="source-page-field" />
        <input type="hidden" name="conversion_type" value="form_contact" />
        <input type="hidden" name="lead_stage" value="contact_form_submitted" />
        <input type="hidden" name="service_interest" id="service-interest-field" />
        <input type="hidden" name="lead_source_detail" id="lead-source-detail-field" />
        <input type="hidden" name="qualification_hint" value="formulaire contact avec volume, besoin, étape bloquée et message" />
        <input type="hidden" name="lead_status" value="Nouveau lead" />
        <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic administratif" />
        <input type="hidden" name="lead_owner" value="Sunelys commercial" />
        <input type="hidden" name="follow_up_sla" value="24h" />
        <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
        <input type="hidden" name="landing_page" id="landing-page-field" />
        <input type="hidden" name="first_referrer" id="first-referrer-field" />
        <input type="hidden" name="utm_source" id="utm-source-field" />
        <input type="hidden" name="utm_medium" id="utm-medium-field" />
        <input type="hidden" name="utm_campaign" id="utm-campaign-field" />
        <input type="hidden" name="utm_term" id="utm-term-field" />
        <input type="hidden" name="utm_content" id="utm-content-field" />
        <input type="hidden" name="gclid" id="gclid-field" />
        <input type="hidden" name="fbclid" id="fbclid-field" />
        <input type="hidden" name="msclkid" id="msclkid-field" />

        <label>
          Nom
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Société
          <input type="text" name="company" autocomplete="organization" />
        </label>
        <label>
          Email professionnel
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          Téléphone
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label>
          Volume de dossiers / mois
          <select name="volume" id="volume-field" required>
            <option value="">Sélectionner</option>
            <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
            <option value="10-30">10-30</option>
            <option value="+30">+30</option>
          </select>
        </label>
        <label>
          Situation
          <select name="team_context" id="team-context-field">
            <option value="">Sélectionner</option>
            <option value="Dossier ponctuel">Dossier ponctuel</option>
            <option value="Pic de charge">Pic de charge</option>
            <option value="Flux récurrent">Flux récurrent</option>
            <option value="Reprise dossier bloqué">Reprise dossier bloqué</option>
          </select>
        </label>
        <label>
          Besoin principal
          <select name="need" id="need-field" required>
            <option value="">Sélectionner</option>
            <option value="Declaration prealable">Déclaration préalable</option>
            <option value="Consuel">Consuel</option>
            <option value="Raccordement Enedis">Raccordement Enedis</option>
            <option value="EDF OA – Compte et contrat d’achat">EDF OA – Compte et contrat d’achat</option>
            <option value="MaPrimeRenov">MaPrimeRénov'</option>
            <option value="CEE">CEE</option>
            <option value="MaPrimeRenov + CEE">MaPrimeRénov' + CEE</option>
            <option value="Pilotage complet">Pilotage complet</option>
          </select>
        </label>
        <label>
          Urgence
          <select name="urgency" id="urgency-field" required>
            <option value="">Sélectionner</option>
            <option value="Sous 48h">Sous 48h</option>
            <option value="Cette semaine">Cette semaine</option>
            <option value="Ce mois-ci">Ce mois-ci</option>
            <option value="Pas urgent">Pas urgent</option>
          </select>
        </label>
        <label class="full-width">
          Étape administrative bloquée
          <select name="blocked_stage" id="blocked-stage-field" required>
            <option value="">Sélectionner</option>
            <option value="Avant dépôt">Avant dépôt</option>
            <option value="Complément mairie">Complément mairie</option>
            <option value="Consuel à préparer">Consuel à préparer</option>
            <option value="Raccordement en attente">Raccordement en attente</option>
            <option value="Compte EDF OA à activer">Compte EDF OA à activer</option>
            <option value="Dossier EDF OA à compléter">Dossier EDF OA à compléter</option>
            <option value="Contrat EDF OA à signer">Contrat EDF OA à signer</option>
            <option value="Dossier d'aide à déposer">Dossier d'aide à déposer</option>
            <option value="Prime à suivre">Prime à suivre</option>
            <option value="Mise en service bloquée">Mise en service bloquée</option>
            <option value="Pilotage global">Pilotage global</option>
            <option value="Je ne sais pas encore">Je ne sais pas encore</option>
          </select>
        </label>
        <label class="full-width">
          Message
          <textarea name="message" rows="6" placeholder="Contexte, zone, délais, organisation actuelle, irritants..."></textarea>
        </label>
        <button id="contact-form-submit" class="btn btn-primary btn-accent submit-btn" type="submit" data-track="cta_contact_form_submit">
          Recevoir mon plan d'action
        </button>
        <p class="form-note full-width">
          Réponse sous 24h ouvrées. Aucun engagement. Vos informations sont utilisées uniquement pour traiter votre demande.
        </p>
      </form>
    </div>

    <div class="booking-shell">
      <div class="booking-head">
        <p class="eyebrow">Rendez-vous</p>
        <h2>Vous préférez parler plutôt que rédiger ?</h2>
        <p>
          Si votre contexte est déjà clair, vous pouvez aussi choisir directement un créneau de 15 minutes.
        </p>
      </div>

      {
        hasBookingUrl ? (
          <>
            <a
              class="btn btn-secondary booking-link"
              href={bookingUrl}
              target="_blank"
              rel="noreferrer"
              data-track="cta_contact_booking_card"
            >
              Ouvrir le calendrier
            </a>
            <div class="booking-embed-shell" id="booking-embed-shell">
              <iframe
                id="booking-embed"
                src={bookingUrl}
                title="Calendrier de rendez-vous Sunelys"
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
              ></iframe>
            </div>
          </>
        ) : (
          <div class="booking-fallback">
            <p>Le calendrier n'est pas disponible pour le moment. Utilisez le formulaire ou appelez-nous directement.</p>
          </div>
        )
      }
    </div>
  </section>

  <section class="contact-support section-shell reveal">
    <div class="support-head">
      <p class="eyebrow">Coordonnées</p>
      <h2>Des points de contact simples, sans parcours compliqué.</h2>
    </div>

    <div class="support-grid">
      {supportCards.map((item) => (
        <a class="support-card" href={item.href} data-track={item.track} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
          <span>{item.title}</span>
          <strong>{item.value}</strong>
          <p>{item.text}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const volumeFromQuery = params.get("volume");
  const volumeFromStorage = localStorage.getItem("sunelys_volume_range");
  const sourceFromQuery = params.get("source") || params.get("service") || "";
  const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};

  const volumeField = document.querySelector("#volume-field");
  const teamContextField = document.querySelector("#team-context-field");
  const needField = document.querySelector("#need-field");
  const urgencyField = document.querySelector("#urgency-field");
  const blockedStageField = document.querySelector("#blocked-stage-field");
  const sourcePageField = document.querySelector("#source-page-field");
  const serviceInterestField = document.querySelector("#service-interest-field");
  const leadSourceDetailField = document.querySelector("#lead-source-detail-field");
  const contactForm = document.querySelector("#contact-form");
  const bookingEmbed = document.querySelector("#booking-embed");
  const bookingEmbedShell = document.querySelector("#booking-embed-shell");

  const fillHidden = (id, value) => {
    const field = document.querySelector(id);
    if (field instanceof HTMLInputElement) field.value = value || "";
  };

  const prefillVolume = volumeFromQuery || volumeFromStorage || "";
  if (volumeField instanceof HTMLSelectElement && prefillVolume) {
    volumeField.value = prefillVolume;
  }

  if (needField instanceof HTMLSelectElement && sourceFromQuery) {
    const normalizedSource = sourceFromQuery.toLowerCase();
    const isEdfOaSource =
      normalizedSource.includes("edf-oa") ||
      normalizedSource.includes("edf_oa") ||
      normalizedSource.includes("edf oa") ||
      (normalizedSource.includes("edf") && normalizedSource.includes("oa"));
    if (isEdfOaSource) needField.value = "EDF OA – Compte et contrat d’achat";
    if (normalizedSource.includes("consuel")) needField.value = "Consuel";
    if (normalizedSource.includes("raccordement") || normalizedSource.includes("enedis")) {
      needField.value = "Raccordement Enedis";
    }
    if (normalizedSource.includes("maprimerenov") || normalizedSource.includes("ma-prime-renov")) {
      needField.value = "MaPrimeRenov";
    }
    if (normalizedSource.includes("cee")) needField.value = "CEE";
    if (normalizedSource.includes("pack-maprimerenov-cee") || normalizedSource.includes("aides-renovation")) {
      needField.value = "MaPrimeRenov + CEE";
    }
    if (normalizedSource.includes("declaration") || normalizedSource.includes("prealable")) {
      needField.value = "Declaration prealable";
    }
    if (normalizedSource.includes("gestion") || normalizedSource.includes("administrative")) {
      needField.value = "Pilotage complet";
    }
    if (
      normalizedSource.includes("diagnostic") ||
      normalizedSource.includes("pilotage") ||
      normalizedSource.includes("sticky") ||
      normalizedSource.includes("header")
    ) {
      needField.value = "Pilotage complet";
    }

    if (
      blockedStageField instanceof HTMLSelectElement &&
      isEdfOaSource &&
      !blockedStageField.value
    ) {
      blockedStageField.value = "Compte EDF OA à activer";
    }
  }

  if (sourcePageField instanceof HTMLInputElement) {
    sourcePageField.value = sourceFromQuery || document.referrer || window.location.pathname;
  }

  const resolveServiceInterest = () => {
    if (needField instanceof HTMLSelectElement && needField.value) return needField.value;
    if (sourceFromQuery) return sourceFromQuery;
    return "Diagnostic administratif installateur";
  };

  const syncLeadQualificationFields = () => {
    if (serviceInterestField instanceof HTMLInputElement) {
      serviceInterestField.value = resolveServiceInterest();
    }
    if (leadSourceDetailField instanceof HTMLInputElement) {
      leadSourceDetailField.value = sourceFromQuery || window.location.pathname;
    }
  };

  syncLeadQualificationFields();
  needField?.addEventListener("change", syncLeadQualificationFields);

  fillHidden("#landing-page-field", attribution.landing_page || "");
  fillHidden("#first-referrer-field", attribution.first_referrer || "");
  fillHidden("#utm-source-field", attribution.utm_source || "");
  fillHidden("#utm-medium-field", attribution.utm_medium || "");
  fillHidden("#utm-campaign-field", attribution.utm_campaign || "");
  fillHidden("#utm-term-field", attribution.utm_term || "");
  fillHidden("#utm-content-field", attribution.utm_content || "");
  fillHidden("#gclid-field", attribution.gclid || "");
  fillHidden("#fbclid-field", attribution.fbclid || "");
  fillHidden("#msclkid-field", attribution.msclkid || "");

  const trackedStates = {
    formViewed: false,
    bookingViewed: false,
    bookingLoaded: false,
  };

  const buildContactPayload = (label) => ({
    category: "lead",
    label,
    source: sourceFromQuery,
    volume: volumeField instanceof HTMLSelectElement ? volumeField.value : "",
    team_context: teamContextField instanceof HTMLSelectElement ? teamContextField.value : "",
    need: needField instanceof HTMLSelectElement ? needField.value : "",
    urgency: urgencyField instanceof HTMLSelectElement ? urgencyField.value : "",
    blocked_stage: blockedStageField instanceof HTMLSelectElement ? blockedStageField.value : "",
  });

  const trackOnce = (key, eventName, label, extra = {}) => {
    if (trackedStates[key] || !window.trackEvent) return;
    trackedStates[key] = true;
    window.trackEvent(eventName, {
      ...buildContactPayload(label),
      ...extra,
    });
  };

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.target === contactForm) {
            trackOnce("formViewed", "contact_form_viewed", "Contact form viewed");
          }
          if (entry.isIntersecting && entry.target === bookingEmbedShell) {
            trackOnce("bookingViewed", "booking_embed_viewed", "Booking embed viewed");
          }
        });
      },
      { threshold: 0.35 }
    );

    if (contactForm instanceof HTMLFormElement) observer.observe(contactForm);
    if (bookingEmbedShell instanceof HTMLElement) observer.observe(bookingEmbedShell);
  }

  if (bookingEmbed instanceof HTMLIFrameElement) {
    bookingEmbed.addEventListener("load", () => {
      trackOnce("bookingLoaded", "booking_embed_loaded", "Booking embed loaded");
    });
  }

  document.querySelector("#contact-form")?.addEventListener("submit", () => {
    if (window.trackEvent) {
      window.trackEvent("contact_form_submit", {
        ...buildContactPayload("Contact form"),
        conversion_type: "form_contact",
        lead_stage: "contact_form_submitted",
        service_interest: resolveServiceInterest(),
        team_context: teamContextField instanceof HTMLSelectElement ? teamContextField.value : "",
        urgency: urgencyField instanceof HTMLSelectElement ? urgencyField.value : "",
        blocked_stage: blockedStageField instanceof HTMLSelectElement ? blockedStageField.value : "",
      });
    }
  });
</script>

<style>
  .contact-hero,
  .contact-main,
  .contact-support {
    display: grid;
    gap: 1rem;
  }

  .contact-hero {
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    align-items: start;
  }

  .hero-copy,
  .hero-panel,
  .form-shell,
  .booking-shell,
  .contact-support {
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(100% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 46%, transparent), transparent 58%),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.2rem, 2.8vw, 2.2rem);
  }

  .hero-copy {
    display: grid;
    gap: 1rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1,
  h2 {
    margin: 0;
    line-height: 0.98;
    text-wrap: balance;
  }

  h1 {
    max-width: 13ch;
    font-size: clamp(2.2rem, 4.6vw, 4.35rem);
  }

  h2 {
    font-size: clamp(1.55rem, 3vw, 2.7rem);
  }

  p,
  li,
  label {
    color: var(--text-muted);
  }

  .hero-text,
  .form-head p,
  .booking-head p,
  .support-card p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .trust-strip {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .trust-strip li {
    display: inline-flex;
    align-items: center;
    min-height: 2.1rem;
    padding: 0.4rem 0.74rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .btn {
    justify-self: start;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.22rem;
    border-radius: 13px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease, color 170ms ease;
  }

  .btn-primary {
    color: #f7f3ec;
    background: linear-gradient(180deg, var(--ink-soft), #080706);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    color: #fff;
    background: #0f0d0a;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--line);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
    transform: translateY(-1px);
  }

  .reason-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .reason-card,
  .hero-panel-card,
  .quote-card,
  .support-card {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  .reason-card {
    padding: 0.95rem;
