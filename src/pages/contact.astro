---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Sunelys"
  description="Contactez Sunelys pour un accompagnement sur vos démarches photovoltaïques: declaration prealable, dossier Consuel et raccordement Enedis."
>
  <section class="hero card">
    <h1>Contact</h1>
    <p>
      Parlez-nous de votre projet photovoltaïque. Nous revenons vers vous avec une
      proposition adaptee a votre volume et vos contraintes.
    </p>
  </section>

  <section class="section grid">
    <article class="card">
      <h2>Email</h2>
      <p>Pour une demande detaillee ou l'envoi de pieces.</p>
      <p><a href="mailto:contact@sunelys.fr" data-track="cta_contact_email">contact@sunelys.fr</a></p>
    </article>

    <article class="card">
      <h2>Telephone</h2>
      <p>Pour un echange rapide sur votre avancement.</p>
      <p><a href="tel:+33695907919" data-track="cta_contact_phone">06 95 90 79 19</a></p>
    </article>

    <article class="card">
      <h2>Adresse</h2>
      <p>49, impasse des lauriers</p>
      <p>83600 Les Adrets de l'Esterel</p>
    </article>
  </section>

  <section class="section card form-card">
    <h2>Demande rapide</h2>
    <p class="helper">Le volume de dossiers est pre-rempli si vous venez du mini-tunnel.</p>

    <form id="contact-form" class="form-grid">
      <label>
        Nom
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label>
        Email
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label>
        Telephone
        <input type="tel" name="phone" autocomplete="tel" />
      </label>
      <label>
        Volume de dossiers / mois
        <select name="volume" id="volume-field">
          <option value="">Selectionner</option>
          <option value="1-10">1-10</option>
          <option value="10-30">10-30</option>
          <option value="+30">+30</option>
        </select>
      </label>
      <label class="full-width">
        Message
        <textarea name="message" rows="5" placeholder="Contexte, zone, delais, type de projet..."></textarea>
      </label>
      <button class="cta" type="submit" data-track="cta_contact_form_submit">Demander un audit</button>
    </form>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const volumeFromQuery = params.get("volume");
  const volumeFromStorage = localStorage.getItem("sunelys_volume_range");
  const volumeField = document.querySelector("#volume-field");
  const form = document.querySelector("#contact-form");

  const prefillVolume = volumeFromQuery || volumeFromStorage || "";
  if (volumeField && prefillVolume) {
    volumeField.value = prefillVolume;
  }

  if (form) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const name = data.get("name") || "";
      const email = data.get("email") || "";
      const phone = data.get("phone") || "";
      const volume = data.get("volume") || "";
      const message = data.get("message") || "";

      const subject = encodeURIComponent("Demande audit Sunelys");
      const body = encodeURIComponent(
        `Nom: ${name}\nEmail: ${email}\nTelephone: ${phone}\nVolume: ${volume}\n\nMessage:\n${message}`,
      );

      if (window.trackEvent) {
        window.trackEvent("contact_form_mailto", { volume });
      }

      window.location.href = `mailto:contact@sunelys.fr?subject=${subject}&body=${body}`;
    });
  }
</script>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: var(--shadow);
  }

  h1 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.75rem, 4.5vw, 2.6rem);
    line-height: 1.15;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.2rem, 2.9vw, 1.5rem);
  }

  p,
  li,
  label {
    color: var(--muted);
  }

  p {
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .grid p + p {
    margin-top: 0.6rem;
  }

  a {
    color: var(--primary-dark);
    text-decoration: none;
    font-weight: 700;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
  }

  .helper {
    margin-bottom: 0.9rem;
    font-size: 0.92rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.92rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--border);
    background: #f7f5ee;
    color: var(--text);
    border-radius: 10px;
    padding: 0.62rem 0.7rem;
    font: inherit;
  }

  .full-width {
    grid-column: 1 / -1;
  }

  .cta {
    justify-self: start;
    border: 0;
    display: inline-block;
    padding: 0.72rem 1.2rem;
    border-radius: 10px;
    font-weight: 700;
    color: #f4f1e8;
    background: var(--primary);
    cursor: pointer;
  }

  .cta:hover,
  .cta:focus-visible {
    color: var(--primary-dark);
    background: var(--accent-dark);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .full-width {
      grid-column: auto;
    }
  }
</style>
