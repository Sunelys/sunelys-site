---
import BaseLayout from "../layouts/BaseLayout.astro";

const successUrl = "https://sunelys.fr/merci";
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
const hasBookingUrl = Boolean(bookingUrl);
---

<BaseLayout
  title="Contact installateurs photovoltaïques | Sunelys"
  description="Parlez à Sunelys de vos flux administratifs photovoltaïques. Nous cadrons vos besoins en déclaration préalable, Consuel et raccordement."
>
  <section class="hero card">
    <p class="eyebrow">Prise de contact</p>
    <h1>Réservez un audit de 15 minutes sur vos flux administratifs photovoltaïques.</h1>
    <p>
      Déclaration préalable, Consuel, raccordement Enedis : nous regardons votre volume,
      vos blocages actuels et le périmètre le plus simple à déléguer pour soulager vos équipes.
    </p>

    <ul class="hero-points">
      <li>Lecture rapide de vos points de friction et de vos priorités</li>
      <li>Estimation du périmètre à déléguer selon votre volume</li>
      <li>Réponse adaptée aux installateurs, commercialisateurs et structures multi-dossiers</li>
    </ul>

    <div class="proof-strip" aria-label="Réassurance contact">
      <span>15 minutes de cadrage</span>
      <span>Réponse sous 24h ouvrées</span>
      <span>Sans engagement</span>
    </div>

    <div class="hero-actions">
      <a
        class="cta"
        href={hasBookingUrl ? bookingUrl : "#contact-form"}
        data-track={hasBookingUrl ? "cta_contact_booking_top" : "cta_contact_form_top"}
        target={hasBookingUrl ? "_blank" : undefined}
        rel={hasBookingUrl ? "noreferrer" : undefined}
      >
        {hasBookingUrl ? "Choisir un créneau" : "Remplir le formulaire d'audit"}
      </a>
      <a class="cta cta-secondary" href="tel:+33695907919" data-track="cta_contact_call">
        Appeler maintenant
      </a>
    </div>

    {
      hasBookingUrl && (
        <p class="booking-note">
          Ou remplissez le formulaire plus bas si vous préférez envoyer votre contexte avant l'échange.
        </p>
      )
    }
  </section>

  <section class="section grid">
    {
      hasBookingUrl && (
        <article class="card booking-card">
          <h2>Prise de rendez-vous</h2>
          <p>Choisissez directement un créneau de 15 minutes pour cadrer vos flux administratifs.</p>
          <p>
            <a href={bookingUrl} target="_blank" rel="noreferrer" data-track="cta_contact_booking_card">
              Ouvrir le calendrier de rendez-vous
            </a>
          </p>
        </article>
      )
    }

    <article class="card">
      <h2>Email</h2>
      <p>Pour une demande détaillée ou l'envoi de pièces.</p>
      <p><a href="mailto:contact@sunelys.fr" data-track="cta_contact_email">contact@sunelys.fr</a></p>
    </article>

    <article class="card">
      <h2>Téléphone</h2>
      <p>Pour un échange rapide sur votre volume de dossiers ou vos délais.</p>
      <p><a href="tel:+33695907919" data-track="cta_contact_phone">06 95 90 79 19</a></p>
    </article>

    <article class="card">
      <h2>Adresse</h2>
      <p>49, impasse des lauriers</p>
      <p>83600 Les Adrets de l'Esterel</p>
    </article>
  </section>

  <section class="section card form-card">
    <h2>Recevoir un cadrage initial</h2>
    <div class="audit-steps" aria-label="Ce que vous obtenez">
      <article>
        <strong>1. Lecture du contexte</strong>
        <p>Volume, type de dossiers, rôle de vos équipes et irritants opérationnels.</p>
      </article>
      <article>
        <strong>2. Priorités identifiées</strong>
        <p>Les étapes qui consomment le plus de temps ou créent le plus de retours.</p>
      </article>
      <article>
        <strong>3. Recommandation claire</strong>
        <p>Le périmètre à déléguer en premier pour fluidifier vos dossiers.</p>
      </article>
    </div>
    <p class="helper">
      Le volume de dossiers est pré-rempli si vous venez du mini-tunnel. Le formulaire
      envoie directement votre demande à Sunelys.
    </p>

    <form
      id="contact-form"
      class="form-grid"
      action="https://formsubmit.co/contact@sunelys.fr"
      method="POST"
    >
      <input type="hidden" name="_subject" value="Nouvelle demande Sunelys" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value={successUrl} />
      <input type="hidden" name="source_page" id="source-page-field" />
      <input type="hidden" name="landing_page" id="landing-page-field" />
      <input type="hidden" name="first_referrer" id="first-referrer-field" />
      <input type="hidden" name="utm_source" id="utm-source-field" />
      <input type="hidden" name="utm_medium" id="utm-medium-field" />
      <input type="hidden" name="utm_campaign" id="utm-campaign-field" />
      <input type="hidden" name="utm_term" id="utm-term-field" />
      <input type="hidden" name="utm_content" id="utm-content-field" />
      <input type="hidden" name="gclid" id="gclid-field" />

      <label>
        Nom
        <input type="text" name="name" required autocomplete="name" />
      </label>
      <label>
        Société
        <input type="text" name="company" autocomplete="organization" />
      </label>
      <label>
        Email
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label>
        Téléphone
        <input type="tel" name="phone" autocomplete="tel" />
      </label>
      <label>
        Volume de dossiers / mois
        <select name="volume" id="volume-field">
          <option value="">Sélectionner</option>
          <option value="1-10">1-10</option>
          <option value="10-30">10-30</option>
          <option value="+30">+30</option>
        </select>
      </label>
      <label>
        Besoin principal
        <select name="need" id="need-field">
          <option value="">Sélectionner</option>
          <option value="Declaration prealable">Déclaration préalable</option>
          <option value="Consuel">Consuel</option>
          <option value="Raccordement Enedis">Raccordement Enedis</option>
          <option value="Pilotage complet">Pilotage complet</option>
        </select>
      </label>
      <label class="full-width">
        Message
        <textarea name="message" rows="5" placeholder="Contexte, zone, délais, type de projet..."></textarea>
      </label>
      <button class="cta" type="submit" data-track="cta_contact_form_submit">Réserver un audit de 15 min</button>
      <p class="form-note full-width">
        Réponse sous 24h ouvrées. Aucun engagement. Vos informations sont utilisées uniquement pour traiter votre demande.
      </p>
    </form>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const volumeFromQuery = params.get("volume");
  const volumeFromStorage = localStorage.getItem("sunelys_volume_range");
  const sourceFromQuery = params.get("source") || params.get("service") || "";
  const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};

  const volumeField = document.querySelector("#volume-field");
  const needField = document.querySelector("#need-field");
  const sourcePageField = document.querySelector("#source-page-field");

  const fillHidden = (id, value) => {
    const field = document.querySelector(id);
    if (field instanceof HTMLInputElement) field.value = value || "";
  };

  const prefillVolume = volumeFromQuery || volumeFromStorage || "";
  if (volumeField instanceof HTMLSelectElement && prefillVolume) {
    volumeField.value = prefillVolume;
  }

  if (needField instanceof HTMLSelectElement && sourceFromQuery) {
    const normalizedSource = sourceFromQuery.toLowerCase();
    if (normalizedSource.includes("consuel")) needField.value = "Consuel";
    if (normalizedSource.includes("raccordement") || normalizedSource.includes("enedis")) {
      needField.value = "Raccordement Enedis";
    }
    if (normalizedSource.includes("declaration") || normalizedSource.includes("prealable")) {
      needField.value = "Declaration prealable";
    }
    if (normalizedSource.includes("gestion") || normalizedSource.includes("administrative")) {
      needField.value = "Pilotage complet";
    }
  }

  if (sourcePageField instanceof HTMLInputElement) {
    sourcePageField.value = sourceFromQuery || document.referrer || window.location.pathname;
  }

  fillHidden("#landing-page-field", attribution.landing_page || "");
  fillHidden("#first-referrer-field", attribution.first_referrer || "");
  fillHidden("#utm-source-field", attribution.utm_source || "");
  fillHidden("#utm-medium-field", attribution.utm_medium || "");
  fillHidden("#utm-campaign-field", attribution.utm_campaign || "");
  fillHidden("#utm-term-field", attribution.utm_term || "");
  fillHidden("#utm-content-field", attribution.utm_content || "");
  fillHidden("#gclid-field", attribution.gclid || "");

  document.querySelector("#contact-form")?.addEventListener("submit", () => {
    if (window.trackEvent) {
      window.trackEvent("contact_form_submit", {
        category: "form",
        label: "Contact form",
        source: sourceFromQuery,
        volume: volumeField instanceof HTMLSelectElement ? volumeField.value : "",
        need: needField instanceof HTMLSelectElement ? needField.value : "",
      });
    }
  });
</script>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 95%, white),
      var(--surface)
    );
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(1.15rem, 2.6vw, 2rem);
    box-shadow: var(--shadow-md);
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.6vw, 4.2rem);
    line-height: 0.94;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.2rem, 2.9vw, 1.5rem);
  }

  p,
  li,
  label {
    color: var(--text-muted);
  }

  p {
    margin: 0;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .hero {
    display: grid;
    gap: 1rem;
  }

  .hero-points {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.45rem;
  }

  .hero-points li {
    position: relative;
    padding-left: 1rem;
    color: var(--text);
  }

  .hero-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.52rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .booking-note {
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .proof-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .proof-strip span {
    display: inline-flex;
    align-items: center;
    min-height: 2.15rem;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    background: color-mix(in srgb, var(--surface-elevated) 88%, white);
    color: var(--text);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.8rem;
  }

  .grid p + p {
    margin-top: 0.6rem;
  }

  .booking-card {
    border-color: color-mix(in srgb, var(--line) 62%, var(--accent));
    background:
      radial-gradient(
        100% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 38%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
  }

  a {
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
  }

  .helper {
    margin-bottom: 0.9rem;
    font-size: 0.92rem;
  }

  .audit-steps {
    margin: 0.95rem 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .audit-steps article {
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    padding: 0.85rem;
  }

  .audit-steps strong {
    display: block;
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.3;
  }

  .audit-steps p {
    margin-top: 0.38rem;
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.92rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 84%, white);
    color: var(--text);
    border-radius: 14px;
    padding: 0.78rem 0.82rem;
    font: inherit;
  }

  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 75%, white);
    outline-offset: 2px;
    border-color: color-mix(in srgb, var(--accent) 68%, var(--line));
  }

  .full-width {
    grid-column: 1 / -1;
  }

  .cta {
    justify-self: start;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.22rem;
    border-radius: 999px;
    font-weight: 700;
    color: #f7f3ec;
    background: var(--text);
    cursor: pointer;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      color 170ms ease;
  }

  .cta:hover,
  .cta:focus-visible {
    color: #fff;
    background: #0f0d0a;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .cta-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--line);
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
  }

  .form-note {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .audit-steps {
      grid-template-columns: 1fr;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .full-width {
      grid-column: auto;
    }

    .hero-actions {
      display: grid;
    }

    .hero-actions .cta {
      width: 100%;
    }
  }
</style>
