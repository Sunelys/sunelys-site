---
import BaseLayout from "../layouts/BaseLayout.astro";
import BrandSignature from "../components/BrandSignature.astro";
import FormPrivacyNote from "../components/FormPrivacyNote.astro";

const successUrl = "https://sunelys.fr/merci?source=contact_form";
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
const hasBookingUrl = Boolean(bookingUrl);

const trustBullets = [
  "Réponse sous 24h ouvrées",
  "Dossier ponctuel accepté",
  "Aucun engagement",
];

const supportCards = [
  {
    title: "Email",
    value: "contact@sunelys.fr",
    href: "mailto:contact@sunelys.fr",
    track: "cta_contact_email",
  },
  {
    title: "Téléphone",
    value: "06 95 90 79 19",
    href: "tel:+33695907919",
    track: "cta_contact_phone",
  },
  {
    title: "Localisation",
    value: "Les Adrets-de-l’Estérel · France",
    href: "https://maps.google.com/?q=49%20impasse%20des%20lauriers%2083600%20Les%20Adrets%20de%20l%27Esterel",
    track: "cta_contact_address",
  },
];
---

<BaseLayout
  title="Contact installateurs photovoltaïques | Sunelys"
  description="Demandez un diagnostic administratif Sunelys sous 24h pour vos dossiers photovoltaïques bloqués ou chronophages : DP, Consuel, raccordement, EDF OA, MaPrimeRénov' et CEE."
>
  <section class="contact-hero reveal" aria-labelledby="contact-title">
    <BrandSignature variant="human" />
    <div class="hero-copy" data-reveal-item>
      <p class="eyebrow">Diagnostic administratif</p>
      <h1 id="contact-title">Parlons du dossier qui ralentit votre équipe.</h1>
      <p class="hero-text">
        Décrivez votre volume, votre besoin et votre urgence. Sunelys identifie le premier périmètre à déléguer,
        qu’il s’agisse d’un dossier ponctuel ou d’un flux récurrent.
      </p>

      <div class="hero-actions">
        <a class="btn btn-accent" href="#contact-form" data-track="cta_contact_form_top">
          Recevoir un diagnostic sous 24h
          <span aria-hidden="true">→</span>
        </a>
        {
          hasBookingUrl && (
            <a
              class="hero-link"
              href={bookingUrl}
              target="_blank"
              rel="noreferrer"
              data-track="cta_contact_booking_top"
            >
              Réserver 15 minutes
              <span aria-hidden="true">↗</span>
            </a>
          )
        }
      </div>

      <ul class="trust-list" aria-label="Garanties du diagnostic">
        {
          trustBullets.map((item) => (
            <li>
              <i aria-hidden="true"></i>
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <aside class="contact-person" aria-label="Votre interlocutrice Sunelys" data-reveal-item>
      <picture>
        <source srcset="/images/myriam-zaoui.avif" type="image/avif" />
        <source srcset="/images/myriam-zaoui.webp" type="image/webp" />
        <img
          src="/images/myriam-zaoui.jpg"
          alt="Myriam Zaoui, fondatrice de Sunelys"
          width="768"
          height="768"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <div class="person-overlay">
        <span><i aria-hidden="true"></i> Votre demande est lue par une experte</span>
        <blockquote>
          « Je vous réponds avec un premier périmètre concret, pas avec une relance commerciale générique. »
        </blockquote>
        <div>
          <strong>Myriam Zaoui</strong>
          <p>Fondatrice de Sunelys</p>
        </div>
      </div>
    </aside>
  </section>

  <section class="contact-main reveal" aria-labelledby="form-title">
    <div class="form-intro" data-reveal-item>
      <p class="eyebrow">Votre contexte</p>
      <h2 id="form-title">Quelques informations suffisent pour commencer.</h2>
      <p>
        Le formulaire se concentre sur ce qui permet d’orienter la demande : qui vous êtes, le volume concerné, la
        démarche et le niveau d’urgence.
      </p>

      <div class="response-flow">
        <p>Après l’envoi</p>
        <ol>
          <li><span>01</span> Lecture de votre demande</li>
          <li><span>02</span> Identification du périmètre utile</li>
          <li><span>03</span> Réponse ou proposition d’échange</li>
        </ol>
      </div>

      <div class="contact-details">
        {
          supportCards.map((item) => (
            <a
              href={item.href}
              data-track={item.track}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <span>{item.title}</span>
              <strong>{item.value}</strong>
              <i aria-hidden="true">{item.href.startsWith("http") ? "↗" : "→"}</i>
            </a>
          ))
        }
      </div>
    </div>

    <div class="form-card" data-reveal-item>
      <div class="form-card-head">
        <div>
          <p>Diagnostic Sunelys</p>
          <strong>Réponse sous 24h ouvrées</strong>
        </div>
        <span><i aria-hidden="true"></i> Disponible</span>
      </div>

      <form
        id="contact-form"
        class="form-grid"
        action={leadFormAction}
        method="POST"
        data-lead-form
        data-conversion-type="form_contact"
      >
        <input type="hidden" name="_subject" value="Nouveau diagnostic administratif Sunelys" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value={successUrl} />
        <input type="hidden" name="source_page" id="source-page-field" />
        <input type="hidden" name="conversion_type" value="form_contact" />
        <input type="hidden" name="lead_stage" value="contact_form_submitted" />
        <input type="hidden" name="service_interest" id="service-interest-field" />
        <input type="hidden" name="lead_source_detail" id="lead-source-detail-field" />
        <input type="hidden" name="qualification_hint" value="formulaire contact avec volume, besoin, urgence et message" />
        <input type="hidden" name="lead_status" value="Nouveau lead" />
        <input type="hidden" name="lead_pipeline" value="Site web - Diagnostic administratif" />
        <input type="hidden" name="lead_owner" value="Sunelys commercial" />
        <input type="hidden" name="follow_up_sla" value="24h" />
        <input type="hidden" name="follow_up_sequence" value="email_j0_diagnostic_then_j1_j3_relance" />
        <input type="hidden" name="landing_page" id="landing-page-field" />
        <input type="hidden" name="first_referrer" id="first-referrer-field" />
        <input type="hidden" name="utm_source" id="utm-source-field" />
        <input type="hidden" name="utm_medium" id="utm-medium-field" />
        <input type="hidden" name="utm_campaign" id="utm-campaign-field" />
        <input type="hidden" name="utm_term" id="utm-term-field" />
        <input type="hidden" name="utm_content" id="utm-content-field" />
        <input type="hidden" name="gclid" id="gclid-field" />
        <input type="hidden" name="fbclid" id="fbclid-field" />
        <input type="hidden" name="msclkid" id="msclkid-field" />

        <label>
          <span>Nom</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          <span>Société</span>
          <input type="text" name="company" autocomplete="organization" />
        </label>
        <label>
          <span>Email professionnel</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          <span>Téléphone <em>optionnel</em></span>
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label>
          <span>Volume mensuel</span>
          <select name="volume" id="volume-field" required>
            <option value="">Sélectionner</option>
            <option value="1-10 dossiers ou ponctuel">1-10 ou dossier ponctuel</option>
            <option value="10-30">10-30 dossiers</option>
            <option value="+30">+30 dossiers</option>
          </select>
        </label>
        <label>
          <span>Besoin principal</span>
          <select name="need" id="need-field" required>
            <option value="">Sélectionner</option>
            <option value="Declaration prealable">Déclaration préalable</option>
            <option value="Consuel">Consuel</option>
            <option value="Raccordement Enedis">Raccordement Enedis</option>
            <option value="EDF OA – Compte et contrat d’achat">EDF OA</option>
            <option value="MaPrimeRenov">MaPrimeRénov'</option>
            <option value="CEE">CEE</option>
            <option value="MaPrimeRenov + CEE">MaPrimeRénov' + CEE</option>
            <option value="Pilotage complet">Pilotage complet</option>
          </select>
        </label>
        <label class="full-width">
          <span>Urgence</span>
          <select name="urgency" id="urgency-field" required>
            <option value="">Sélectionner</option>
            <option value="Sous 48h">Sous 48h</option>
            <option value="Cette semaine">Cette semaine</option>
            <option value="Ce mois-ci">Ce mois-ci</option>
            <option value="Pas urgent">Pas urgent</option>
          </select>
        </label>
        <label class="full-width">
          <span>Votre contexte <em>optionnel</em></span>
          <textarea
            name="message"
            rows="5"
            placeholder="Dossier bloqué, organisation actuelle, délai ou précision utile…"
          ></textarea>
        </label>

        <button id="contact-form-submit" class="btn btn-accent submit-btn" type="submit" data-track="cta_contact_form_submit">
          Recevoir mon diagnostic
          <span aria-hidden="true">→</span>
        </button>
        <p class="form-note full-width">
          Aucun engagement. Vos informations sont utilisées uniquement pour traiter votre demande.
        </p>
        <FormPrivacyNote />
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const volumeFromQuery = params.get("volume");
  const volumeFromStorage = localStorage.getItem("sunelys_volume_range");
  const sourceFromQuery = params.get("source") || params.get("service") || "";
  const attribution = window.getSunelysAttribution ? window.getSunelysAttribution() : {};

  const volumeField = document.querySelector("#volume-field");
  const needField = document.querySelector("#need-field");
  const urgencyField = document.querySelector("#urgency-field");
  const sourcePageField = document.querySelector("#source-page-field");
  const serviceInterestField = document.querySelector("#service-interest-field");
  const leadSourceDetailField = document.querySelector("#lead-source-detail-field");
  const contactForm = document.querySelector("#contact-form");

  const fillHidden = (id, value) => {
    const field = document.querySelector(id);
    if (field instanceof HTMLInputElement) field.value = value || "";
  };

  const prefillVolume = volumeFromQuery || volumeFromStorage || "";
  if (volumeField instanceof HTMLSelectElement && prefillVolume) {
    volumeField.value = prefillVolume;
  }

  if (needField instanceof HTMLSelectElement && sourceFromQuery) {
    const normalizedSource = sourceFromQuery.toLowerCase();
    const isEdfOaSource =
      normalizedSource.includes("edf-oa") ||
      normalizedSource.includes("edf_oa") ||
      normalizedSource.includes("edf oa") ||
      (normalizedSource.includes("edf") && normalizedSource.includes("oa"));
    if (isEdfOaSource) needField.value = "EDF OA – Compte et contrat d’achat";
    if (normalizedSource.includes("consuel")) needField.value = "Consuel";
    if (normalizedSource.includes("raccordement") || normalizedSource.includes("enedis")) {
      needField.value = "Raccordement Enedis";
    }
    if (normalizedSource.includes("maprimerenov") || normalizedSource.includes("ma-prime-renov")) {
      needField.value = "MaPrimeRenov";
    }
    if (normalizedSource.includes("cee")) needField.value = "CEE";
    if (normalizedSource.includes("pack-maprimerenov-cee") || normalizedSource.includes("aides-renovation")) {
      needField.value = "MaPrimeRenov + CEE";
    }
    if (normalizedSource.includes("declaration") || normalizedSource.includes("prealable")) {
      needField.value = "Declaration prealable";
    }
    if (normalizedSource.includes("gestion") || normalizedSource.includes("administrative")) {
      needField.value = "Pilotage complet";
    }
    if (
      normalizedSource.includes("diagnostic") ||
      normalizedSource.includes("pilotage") ||
      normalizedSource.includes("sticky") ||
      normalizedSource.includes("header")
    ) {
      needField.value = "Pilotage complet";
    }
  }

  if (sourcePageField instanceof HTMLInputElement) {
    sourcePageField.value = sourceFromQuery || document.referrer || window.location.pathname;
  }

  const resolveServiceInterest = () => {
    if (needField instanceof HTMLSelectElement && needField.value) return needField.value;
    if (sourceFromQuery) return sourceFromQuery;
    return "Diagnostic administratif installateur";
  };

  const syncLeadQualificationFields = () => {
    if (serviceInterestField instanceof HTMLInputElement) {
      serviceInterestField.value = resolveServiceInterest();
    }
    if (leadSourceDetailField instanceof HTMLInputElement) {
      leadSourceDetailField.value = sourceFromQuery || window.location.pathname;
    }
  };

  syncLeadQualificationFields();
  needField?.addEventListener("change", syncLeadQualificationFields);

  fillHidden("#landing-page-field", attribution.landing_page || "");
  fillHidden("#first-referrer-field", attribution.first_referrer || "");
  fillHidden("#utm-source-field", attribution.utm_source || "");
  fillHidden("#utm-medium-field", attribution.utm_medium || "");
  fillHidden("#utm-campaign-field", attribution.utm_campaign || "");
  fillHidden("#utm-term-field", attribution.utm_term || "");
  fillHidden("#utm-content-field", attribution.utm_content || "");
  fillHidden("#gclid-field", attribution.gclid || "");
  fillHidden("#fbclid-field", attribution.fbclid || "");
  fillHidden("#msclkid-field", attribution.msclkid || "");

  let formViewed = false;

  const buildContactPayload = (label) => ({
    category: "lead",
    label,
    source: sourceFromQuery,
    volume: volumeField instanceof HTMLSelectElement ? volumeField.value : "",
    need: needField instanceof HTMLSelectElement ? needField.value : "",
    urgency: urgencyField instanceof HTMLSelectElement ? urgencyField.value : "",
  });

  if ("IntersectionObserver" in window && contactForm instanceof HTMLFormElement) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || formViewed || !window.trackEvent) return;
          formViewed = true;
          window.trackEvent("contact_form_viewed", buildContactPayload("Contact form viewed"));
          observer.disconnect();
        });
      },
      { threshold: 0.35 }
    );
    observer.observe(contactForm);
  }

  contactForm?.addEventListener("submit", () => {
    syncLeadQualificationFields();
    if (window.trackEvent) {
      window.trackEvent("contact_form_submit", {
        ...buildContactPayload("Contact form"),
        conversion_type: "form_contact",
        lead_stage: "contact_form_submitted",
        service_interest: resolveServiceInterest(),
      });
    }
  });
</script>

<style>
  .contact-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(350px, 0.74fr);
    gap: clamp(1.5rem, 4vw, 4.2rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(1.5rem, 3.8vw, 4rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 100% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 62%),
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .contact-hero > .hero-copy,
  .contact-hero > .contact-person {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy .eyebrow {
    color: var(--accent);
  }

  h1 {
    max-width: 13ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 5.15rem);
    line-height: 0.94;
  }

  .hero-text {
    max-width: 61ch;
    margin-top: 1.15rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.76rem;
    font-weight: 740;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.22);
    text-underline-offset: 0.28rem;
  }

  .hero-link span {
    color: var(--accent);
  }

  .trust-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    margin: 1.35rem 0 0;
    padding: 0;
    list-style: none;
  }

  .trust-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.68rem;
    font-weight: 650;
  }

  .trust-list i,
  .form-card-head > span i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.14);
  }

  .contact-person {
    position: relative;
    min-height: 31rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    background: var(--ink-soft);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .contact-person picture,
  .contact-person img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .contact-person picture {
    position: absolute;
    inset: 0;
  }

  .contact-person img {
    object-fit: cover;
    object-position: center 28%;
    filter: saturate(0.78) contrast(1.04);
  }

  .contact-person::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 30%, rgba(6, 13, 25, 0.16) 50%, rgba(6, 13, 25, 0.94) 100%),
      linear-gradient(90deg, rgba(14, 23, 38, 0.08), transparent 55%);
  }

  .person-overlay {
    position: absolute;
    z-index: 1;
    inset: auto 1.15rem 1.15rem;
    display: grid;
    gap: 0.72rem;
    color: #ffffff;
  }

  .person-overlay > span {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    padding: 0.36rem 0.58rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(6, 13, 25, 0.56);
    backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.62rem;
    font-weight: 720;
  }

  .person-overlay > span i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.18);
  }

  .person-overlay blockquote {
    max-width: 31ch;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1rem, 1.4vw, 1.3rem);
    font-weight: 720;
    line-height: 1.42;
  }

  .person-overlay > div {
    padding-top: 0.7rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .person-overlay strong {
    display: block;
    color: #ffffff;
    font-size: 0.76rem;
  }

  .person-overlay p {
    margin-top: 0.12rem;
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.64rem;
  }

  .contact-main {
    display: grid;
    grid-template-columns: minmax(280px, 0.66fr) minmax(0, 1.34fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
    padding: clamp(1.3rem, 3vw, 2.6rem);
    border-radius: var(--radius-xl);
    background: var(--system-soft);
  }

  .form-intro {
    position: sticky;
    top: 6.5rem;
  }

  .form-intro h2 {
    max-width: 16ch;
    margin-top: 0.6rem;
    font-size: clamp(2rem, 3.7vw, 3.7rem);
  }

  .form-intro > p:not(.eyebrow) {
    max-width: 52ch;
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.62;
  }

  .response-flow {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .response-flow > p {
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 780;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .response-flow ol {
    display: grid;
    gap: 0.55rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
  }

  .response-flow li {
    display: flex;
    gap: 0.6rem;
    color: var(--text);
    font-size: 0.73rem;
    font-weight: 680;
  }

  .response-flow li span {
    color: var(--system);
    font-size: 0.63rem;
    font-weight: 800;
  }

  .contact-details {
    display: grid;
    margin-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
  }

  .contact-details a {
    display: grid;
    grid-template-columns: minmax(70px, auto) 1fr auto;
    gap: 0.7rem;
    align-items: center;
    min-height: 3.8rem;
    border-bottom: 1px solid color-mix(in srgb, var(--system) 14%, var(--line));
    color: var(--text);
    text-decoration: none;
  }

  .contact-details a > span {
    color: var(--system);
    font-size: 0.6rem;
    font-weight: 780;
    text-transform: uppercase;
  }

  .contact-details strong {
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .contact-details i {
    color: var(--accent);
    font-size: 0.82rem;
    font-style: normal;
  }

  .form-card {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 16px;
    background: #ffffff;
    box-shadow: var(--shadow-sm);
  }

  .form-card-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.2rem;
    border-bottom: 1px solid var(--line);
  }

  .form-card-head > div {
    display: grid;
    gap: 0.12rem;
  }

  .form-card-head p {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 780;
    text-transform: uppercase;
  }

  .form-card-head strong {
    color: var(--text);
    font-size: 0.78rem;
  }

  .form-card-head > span {
    display: inline-flex;
