---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockedDiagnostic from "../components/BlockedDiagnostic.astro";

const steps = [
  {
    title: "Cadrer le besoin",
    description:
      "Volume, urgence, démarches concernées et pièces disponibles sont clarifiés avant de définir le premier périmètre.",
    owner: "Ensemble",
    output: "Périmètre validé",
  },
  {
    title: "Transmettre le dossier",
    description:
      "Votre équipe centralise le brief et les documents disponibles. Sunelys identifie immédiatement les éléments manquants.",
    owner: "Votre équipe",
    output: "Dossier exploitable",
  },
  {
    title: "Piloter les démarches",
    description:
      "Sunelys produit, dépose, suit les échanges et traite les compléments dans le périmètre défini.",
    owner: "Sunelys",
    output: "Actions tracées",
  },
  {
    title: "Suivre et décider",
    description:
      "Les statuts, les prochaines actions et les éventuels blocages restent visibles jusqu'à l'étape finale.",
    owner: "Sunelys + vous",
    output: "Visibilité continue",
  },
];

const startModes = [
  { label: "Dossier ponctuel", text: "Tester la méthode sur un besoin précis." },
  { label: "Pic de charge", text: "Absorber un volume temporaire sans recruter." },
  { label: "Flux récurrent", text: "Installer une délégation stable dans votre organisation." },
];

const kickoffChecklist = [
  "La démarche concernée : DP, raccordement, Consuel, EDF OA ou aides",
  "Le volume à traiter et le niveau d’urgence",
  "Les pièces déjà disponibles et les accès utiles",
  "Le référent côté installateur pour les arbitrages",
];

const kickoffCards = [
  {
    label: "Jour 0",
    title: "Le point de départ est cadré.",
    text: "Sunelys identifie le périmètre utile, les pièces manquantes et la première action à lancer.",
    output: "Diagnostic actionnable",
  },
  {
    label: "Dossier repris",
    title: "La prochaine action devient visible.",
    text: "Chaque dossier garde un statut, une attente éventuelle et une responsabilité claire.",
    output: "Statut partagé",
  },
  {
    label: "Suivi continu",
    title: "Les relances sortent de votre équipe.",
    text: "Sunelys suit les échanges, traite les compléments et vous alerte uniquement quand une décision est nécessaire.",
    output: "Charge réduite",
  },
];

const visibilitySignals = [
  "Statut courant",
  "Prochaine action",
  "Pièce attendue",
  "Responsable du blocage",
];

const responsibilityColumns = [
  {
    kicker: "Vous transmettez",
    title: "Le contexte utile au bon traitement.",
    items: ["Brief chantier", "Pièces disponibles", "Contraintes et urgence", "Contact référent"],
  },
  {
    kicker: "Sunelys pilote",
    title: "L’exécution administrative et le suivi.",
    items: ["Contrôle documentaire", "Production et dépôt", "Échanges et relances", "Compléments et traçabilité"],
    highlighted: true,
  },
  {
    kicker: "Vous conservez",
    title: "La maîtrise commerciale et opérationnelle.",
    items: ["Relation client", "Décisions chantier", "Visibilité sur les statuts", "Accès à l’historique"],
  },
];

const guarantees = [
  {
    label: "Cadre",
    text: "Une méthode identique d’un dossier à l’autre pour limiter les oublis.",
  },
  {
    label: "Visibilité",
    text: "Un statut et une prochaine action lisibles pour chaque dossier.",
  },
  {
    label: "Souplesse",
    text: "Un périmètre qui peut évoluer sans abonnement ni volume minimum.",
  },
  {
    label: "Continuité",
    text: "Un interlocuteur humain derrière le portail et les relances.",
  },
];
---

<BaseLayout
  title="Parcours Sunelys | Pilotage administratif photovoltaïque"
  description="Découvrez comment Sunelys structure les démarches administratives photovoltaïques pour fluidifier les dossiers et sécuriser les délais installateurs."
>
  <section class="journey-hero reveal" aria-labelledby="journey-title">
    <div class="hero-copy" data-reveal-item>
      <p class="eyebrow">Parcours Sunelys</p>
      <h1 id="journey-title">Un process clair, du premier dossier au flux récurrent.</h1>
      <p class="hero-intro">
        Sunelys s’intègre à votre organisation sans ajouter une couche de gestion. Chacun sait ce qu’il doit
        transmettre, qui agit et quelle est la prochaine étape.
      </p>

      <div class="hero-actions">
        <a
          class="btn btn-accent"
          href="#blocked-diagnostic-parcours_diagnostic_dossiers_bloques"
          data-track="cta_parcours_primary"
        >
          Cadrer mon premier dossier
          <span aria-hidden="true">→</span>
        </a>
        <a class="hero-link" href="/services" data-track="cta_parcours_secondary">
          Voir les services
          <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="hero-assurance">
        <span><i aria-hidden="true"></i> Mise en route simple</span>
        <span><i aria-hidden="true"></i> Suivi en temps réel</span>
      </div>
    </div>

    <aside class="journey-preview" aria-label="Aperçu du parcours Sunelys" data-reveal-item>
      <div class="preview-head">
        <div>
          <p>Parcours d’un dossier</p>
          <strong>4 étapes visibles</strong>
        </div>
        <span>En continu</span>
      </div>
      <ol>
        {
          steps.map((step, index) => (
            <li class:list={[index === 2 && "is-active"]}>
              <span>0{index + 1}</span>
              <div>
                <strong>{step.title}</strong>
                <p>{step.output}</p>
              </div>
              <i aria-hidden="true"></i>
            </li>
          ))
        }
      </ol>
      <div class="preview-foot">
        <span>Portail dédié</span>
        <span>Interlocuteur humain</span>
      </div>
    </aside>
  </section>

  <section class="start-modes reveal" aria-labelledby="start-title">
    <div class="start-head" data-reveal-item>
      <p class="eyebrow">Commencer</p>
      <h2 id="start-title">Le parcours s’adapte à votre niveau de délégation.</h2>
    </div>
    <div class="mode-grid">
      {
        startModes.map((mode, index) => (
          <article data-reveal-item>
            <span>0{index + 1}</span>
            <h3>{mode.label}</h3>
            <p>{mode.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="handoff-section reveal"
    aria-labelledby="handoff-title"
    data-track-view="parcours_handoff_view"
    data-track-label="parcours_mise_en_route"
  >
    <div class="handoff-head" data-reveal-item>
      <p class="eyebrow">Mise en route concrète</p>
      <h2 id="handoff-title">Après le premier contact, vous savez quoi transmettre et ce que Sunelys reprend.</h2>
      <p>
        La délégation commence par une passation courte. L’objectif n’est pas de tout documenter parfaitement,
        mais d’identifier assez vite ce qui bloque et ce qui doit avancer.
      </p>
    </div>

    <div class="handoff-layout">
      <article class="handoff-brief" data-reveal-item>
        <div>
          <span>Votre brief utile</span>
          <strong>4 informations suffisent pour cadrer le départ.</strong>
        </div>
        <ul>
          {kickoffChecklist.map((item) => <li>{item}</li>)}
        </ul>
        <a href="#blocked-diagnostic-parcours_diagnostic_dossiers_bloques" data-track="cta_parcours_handoff_brief">
          Décrire mon premier dossier
          <span aria-hidden="true">→</span>
        </a>
      </article>

      <div class="handoff-cards" aria-label="Ce que Sunelys rend visible après la mise en route">
        {
          kickoffCards.map((card, index) => (
            <article data-reveal-item>
              <span>0{index + 1} · {card.label}</span>
              <strong>{card.title}</strong>
              <p>{card.text}</p>
              <small>{card.output}</small>
            </article>
          ))
        }
      </div>
    </div>

    <div class="visibility-strip" aria-label="Signaux de suivi visibles" data-reveal-item>
      <span>Dans le suivi</span>
      {visibilitySignals.map((signal) => <strong>{signal}</strong>)}
    </div>
  </section>

  <section class="steps-section reveal" aria-labelledby="steps-title">
    <div class="section-head" data-reveal-item>
      <div>
        <p class="eyebrow">La méthode</p>
        <h2 id="steps-title">Quatre étapes, sans zone grise.</h2>
      </div>
      <p>
        Le dossier n’entre pas dans une boîte noire. Chaque étape produit un résultat concret et rend la suivante
        immédiatement identifiable.
      </p>
    </div>

    <div class="step-list">
      {
        steps.map((step, index) => (
          <article data-reveal-item>
            <div class="step-index">
              <span>0{index + 1}</span>
              <i aria-hidden="true"></i>
            </div>
            <div class="step-copy">
              <p>{step.owner}</p>
              <h3>{step.title}</h3>
              <span>{step.description}</span>
            </div>
            <div class="step-output">
              <p>Résultat</p>
              <strong>{step.output}</strong>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="responsibility-section reveal" aria-labelledby="responsibility-title">
    <div class="responsibility-head" data-reveal-item>
      <p class="eyebrow">Qui fait quoi ?</p>
      <h2 id="responsibility-title">Vous gardez le pilotage. Sunelys absorbe l’exécution.</h2>
      <p>
        La collaboration reste lisible pour vos équipes : aucune confusion entre la relation client, les décisions
        chantier et la production administrative.
      </p>
    </div>

    <div class="responsibility-grid">
      {
        responsibilityColumns.map((column, index) => (
          <article class:list={[column.highlighted && "is-highlighted"]} data-reveal-item>
            <div class="responsibility-top">
              <span>0{index + 1}</span>
              <p>{column.kicker}</p>
            </div>
            <h3>{column.title}</h3>
            <ul>
              {column.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="guarantees-section reveal" aria-labelledby="guarantees-title">
    <div class="guarantees-head" data-reveal-item>
      <p class="eyebrow">Le cadre de collaboration</p>
      <h2 id="guarantees-title">Ce qui ne change pas quand le volume augmente.</h2>
    </div>

    <div class="guarantee-grid">
      {
        guarantees.map((item, index) => (
          <article data-reveal-item>
            <span>0{index + 1}</span>
            <strong>{item.label}</strong>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <BlockedDiagnostic
    source="parcours_diagnostic_dossiers_bloques"
    title="Quelle étape faut-il reprendre en premier ?"
    text="Indiquez le volume, la démarche concernée et l'urgence. Sunelys vous répond avec un premier périmètre clair, sans transformer tout votre fonctionnement."
    submitLabel="Recevoir mon plan de reprise"
  />
</BaseLayout>

<style>
  .journey-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(350px, 0.74fr);
    gap: clamp(1.5rem, 4vw, 4.2rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(1.5rem, 3.8vw, 4rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 100% at 0% 100%, rgba(212, 130, 42, 0.2), transparent 62%),
      radial-gradient(70% 90% at 100% 0%, rgba(54, 98, 227, 0.3), transparent 62%),
      var(--ink);
    box-shadow: var(--shadow-md);
  }

  .eyebrow {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy .eyebrow {
    color: var(--accent);
  }

  h1 {
    max-width: 13ch;
    margin-top: 0.7rem;
    color: #ffffff;
    font-size: clamp(2.4rem, 5vw, 5.15rem);
    line-height: 0.94;
  }

  .hero-intro {
    max-width: 61ch;
    margin-top: 1.15rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.76rem;
    font-weight: 740;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.22);
    text-underline-offset: 0.28rem;
  }

  .hero-link span {
    color: var(--accent);
  }

  .hero-assurance {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    margin-top: 1.35rem;
  }

  .hero-assurance span {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.68rem;
    font-weight: 650;
  }

  .hero-assurance i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(29, 155, 117, 0.14);
  }

  .journey-preview {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    background: #f8fafc;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .preview-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--line);
    background: #ffffff;
  }

  .preview-head > div {
    display: grid;
    gap: 0.12rem;
  }

  .preview-head p,
  .preview-head > span {
    color: var(--text-muted);
    font-size: 0.62rem;
    font-weight: 700;
  }

  .preview-head strong {
    color: var(--text);
    font-size: 0.86rem;
  }

  .preview-head > span {
    padding: 0.28rem 0.48rem;
    border-radius: 999px;
    background: var(--success-soft);
    color: var(--success);
  }

  .journey-preview ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .journey-preview li {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    min-height: 4.3rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .journey-preview li > span {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 800;
  }

  .journey-preview li > div {
    display: grid;
    gap: 0.12rem;
  }

  .journey-preview li strong {
    color: var(--text);
    font-size: 0.74rem;
  }

  .journey-preview li p {
    color: var(--text-muted);
    font-size: 0.6rem;
  }

  .journey-preview li > i {
    width: 0.52rem;
    height: 0.52rem;
    border: 2px solid color-mix(in srgb, var(--system) 45%, var(--line));
    border-radius: 50%;
  }

  .journey-preview li.is-active {
    background: var(--system-soft);
  }

  .journey-preview li.is-active > i {
    border-color: var(--success);
    background: var(--success);
    box-shadow: 0 0 0 3px var(--success-soft);
  }

  .preview-foot {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding: 0.72rem 1rem;
  }

  .preview-foot span {
    color: var(--text-muted);
    font-size: 0.59rem;
    font-weight: 680;
  }

  .start-modes {
    display: grid;
    grid-template-columns: minmax(260px, 0.62fr) minmax(0, 1.38fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: stretch;
    padding: clamp(1.3rem, 3vw, 2.5rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .start-head h2,
  .section-head h2,
  .responsibility-head h2,
  .guarantees-head h2 {
    max-width: 18ch;
    margin-top: 0.6rem;
    font-size: clamp(2rem, 3.6vw, 3.6rem);
  }

  .mode-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .mode-grid article {
    min-height: 15rem;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .mode-grid article > span {
    color: var(--system);
    font-size: 0.64rem;
    font-weight: 800;
  }

  .mode-grid h3 {
    margin-top: auto;
    font-size: 1.12rem;
  }

  .mode-grid p {
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.5;
  }

  .handoff-section {
    position: relative;
    overflow: hidden;
    padding: clamp(1.3rem, 3vw, 2.4rem);
    border: 1px solid color-mix(in srgb, var(--system) 13%, var(--line));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(80% 120% at 100% 0%, color-mix(in srgb, var(--system-soft) 78%, transparent), transparent 65%),
      linear-gradient(90deg, rgba(54, 98, 227, 0.045) 1px, transparent 1px) 0 0 / 40px 40px,
      color-mix(in srgb, var(--surface) 97%, white);
    box-shadow: var(--shadow-sm);
  }

  .handoff-section::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--system), var(--accent));
  }

  .handoff-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.56fr);
    gap: clamp(1.2rem, 4vw, 4rem);
    align-items: end;
  }

  .handoff-head h2 {
    max-width: 19ch;
    margin-top: 0.6rem;
    color: var(--ink);
    font-size: clamp(2rem, 3.6vw, 3.6rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .handoff-head > p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.62;
  }

  .handoff-layout {
    display: grid;
    grid-template-columns: minmax(270px, 0.5fr) minmax(0, 1fr);
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .handoff-brief {
    display: flex;
    flex-direction: column;
    min-height: 23rem;
    padding: 1.1rem;
    border-radius: 17px;
    background:
      radial-gradient(90% 85% at 100% 0%, rgba(54, 98, 227, 0.24), transparent 62%),
      var(--ink);
    color: #ffffff;
  }

  .handoff-brief > div {
    display: grid;
    gap: 0.46rem;
  }

  .handoff-brief span {
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 820;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .handoff-brief strong {
    max-width: 21ch;
    color: #ffffff;
    font-size: 1.28rem;
    line-height: 1.13;
  }

  .handoff-brief ul {
    display: grid;
    gap: 0.55rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .handoff-brief li {
    display: flex;
    gap: 0.55rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .handoff-brief li::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    flex: 0 0 auto;
    margin-top: 0.3rem;
    border-radius: 50%;
    background: var(--accent);
  }

  .handoff-brief a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    margin-top: auto;
    padding-top: 1.2rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.74rem;
    font-weight: 780;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.18);
    text-underline-offset: 0.26rem;
  }

  .handoff-brief a span {
    color: var(--accent);
  }

  .handoff-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .handoff-cards article {
    min-height: 23rem;
    display: grid;
    align-content: space-between;
    gap: 0.8rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--system) 11%, var(--line));
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
  }

  .handoff-cards article > span {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 820;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .handoff-cards strong {
    max-width: 16ch;
    color: var(--ink);
    font-size: 1.08rem;
    line-height: 1.16;
  }

  .handoff-cards p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1.52;
  }

  .handoff-cards small {
    width: fit-content;
    padding: 0.38rem 0.55rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-soft) 54%, white);
    color: var(--accent-deep);
    font-size: 0.62rem;
    font-weight: 800;
  }

  .visibility-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-top: 0.8rem;
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--system) 12%, var(--line));
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
  }

  .visibility-strip span {
    color: var(--system);
    font-size: 0.62rem;
    font-weight: 820;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .visibility-strip strong {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
    font-size: 0.72rem;
    font-weight: 760;
  }

