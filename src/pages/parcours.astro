---
import BaseLayout from "../layouts/BaseLayout.astro";

const steps = [
  {
    title: "Vous transmettez le dossier",
    description:
      "Le brief projet, les pièces disponibles et les points de vigilance sont centralisés dès l'entrée dans le flux.",
  },
  {
    title: "Sunelys pilote les démarches",
    description:
      "Nous cadrons la documentation, lançons les démarches utiles et pilotons les échanges administratifs au bon rythme.",
  },
  {
    title: "Vous suivez l'avancement",
    description:
      "Les équipes installateur gardent de la visibilité sur les statuts, les jalons et les points de blocage potentiels.",
  },
  {
    title: "Le dossier avance sans friction",
    description:
      "Moins de retours, moins de dispersion interne et une meilleure maîtrise des délais côté client final.",
  },
];

const guarantees = [
  "Cadre de traitement standardisé pour éviter les oublis récurrents",
  "Pilotage clair des points bloquants et des relances prioritaires",
  "Traçabilité de l'avancement pour vos équipes et votre client",
];
---

<BaseLayout
  title="Parcours Sunelys | Pilotage administratif photovoltaïque"
  description="Découvrez comment Sunelys structure les démarches administratives photovoltaïques pour fluidifier les dossiers et sécuriser les délais installateurs."
>
  <section class="card hero">
    <p class="eyebrow">Parcours Sunelys</p>
    <h1>Un process simple pour remettre l'administratif au service de vos chantiers.</h1>
    <p class="intro">
      Sunelys s'intègre à votre organisation sans alourdir vos équipes. Le but n'est pas
      d'ajouter une couche, mais de rendre le traitement administratif plus lisible, plus fiable
      et plus prévisible.
    </p>
    <div class="hero-actions">
      <a class="cta" href="/contact" data-track="cta_parcours_primary">Planifier un échange</a>
      <a class="cta cta-secondary" href="/services" data-track="cta_parcours_secondary">Voir les services</a>
    </div>
  </section>

  <section class="section intro-grid">
    <article class="card intro-card">
      <p class="eyebrow">Ce que vous gagnez</p>
      <h2>Moins de coordination dispersée, plus de maîtrise opérationnelle.</h2>
      <ul>
        <li>Vos équipes terrain restent concentrées sur la vente et l'installation.</li>
        <li>Les dossiers sont cadrés plus tôt et suivis plus proprement.</li>
        <li>Les retards administratifs deviennent plus lisibles et mieux pilotés.</li>
      </ul>
    </article>

    <article class="card intro-card highlight-card">
      <p class="eyebrow">Ce que Sunelys garantit</p>
      <h2>Une méthode claire, reproductible et orientée délai.</h2>
      <div class="guarantee-list">
        {guarantees.map((item) => <p>{item}</p>)}
      </div>
    </article>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Notre méthode</p>
      <h2>Quatre étapes pour garder un flux administratif prévisible.</h2>
    </div>
    <div class="steps-grid">
      {
        steps.map((step, index) => (
          <article class="card step-card">
            <p class="step-number">Étape {index + 1}</p>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card cta-box section">
    <p class="eyebrow">Décision</p>
    <h2>Le bon moment pour structurer vos flux, c'est avant que le volume ne vous rattrape.</h2>
    <p>
      Si vos équipes absorbent trop d'administratif, on peut cadrer très vite ce qui doit être
      délégué, industrialisé ou repris en main.
    </p>
    <div class="hero-actions">
      <a class="cta" href="/contact" data-track="cta_parcours_contact">Planifier un appel</a>
      <a class="cta cta-secondary" href="/tarifs" data-track="cta_parcours_pricing">Voir les offres</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    margin-top: 1.8rem;
  }

  .card {
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-elevated) 95%, white),
      var(--surface)
    );
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(1.15rem, 2.6vw, 2rem);
    box-shadow: var(--shadow-md);
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(2rem, 4.8vw, 4.2rem);
    line-height: 0.95;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2.35rem);
    line-height: 1.02;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.12rem, 1.4vw, 1.4rem);
    line-height: 1.14;
  }

  p,
  li {
    margin: 0;
    color: var(--text-muted);
  }

  .hero,
  .intro-card,
  .cta-box {
    display: grid;
    gap: 1rem;
  }

  .intro {
    max-width: 63ch;
    font-size: var(--step-0);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .intro-card ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.42rem;
  }

  .highlight-card {
    background:
      radial-gradient(
        120% 110% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 58%, transparent),
        transparent 58%
      ),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 95%, white), var(--surface));
  }

  .guarantee-list {
    display: grid;
    gap: 0.55rem;
  }

  .guarantee-list p {
    color: var(--text);
    font-weight: 600;
  }

  .section-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 0.9rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .step-card {
    display: grid;
    gap: 0.7rem;
    align-content: start;
  }

  .step-number {
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.22rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    color: #f7f3ec;
    background: var(--text);
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease;
  }

  .cta:hover,
  .cta:focus-visible {
    color: #fff;
    background: #0f0d0a;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .cta-secondary {
    color: var(--text);
    background: transparent;
    border: 1px solid var(--line);
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
  }

  @media (max-width: 820px) {
    .intro-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      display: grid;
    }

    .hero-actions .cta {
      width: 100%;
    }
  }
</style>
