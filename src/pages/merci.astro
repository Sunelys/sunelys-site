---
import BaseLayout from "../layouts/BaseLayout.astro";

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
---

<BaseLayout
  title="Merci | Sunelys"
  description="Votre demande a bien été transmise à Sunelys."
  robots="noindex,nofollow"
>
  <section class="thanks-card">
    <p class="eyebrow">Demande envoyee</p>
    <h1>Merci, votre message est bien parti.</h1>
    <p class="intro">
      Nous revenons vers vous rapidement pour cadrer votre besoin et voir si Sunelys peut
      absorber votre flux administratif.
    </p>
    <p class="intro">
      Si vous souhaitez avancer plus vite, vous pouvez aussi choisir un créneau Calendly.
      C'est optionnel : votre demande a déjà bien été envoyée.
    </p>

    <div class="delivery-card" id="checklist-delivery" hidden>
      <p class="delivery-kicker">Checklist disponible</p>
      <h2>Votre ressource DP est prête.</h2>
      <p>
        Vous pouvez l'ouvrir maintenant, puis l'imprimer ou l'enregistrer en PDF depuis votre navigateur.
      </p>
      <a
        class="btn btn-primary btn-accent"
        href="/checklist-declaration-prealable-solaire?source=merci_checklist"
        data-track="cta_thanks_checklist_download"
      >
        Ouvrir la checklist
      </a>
    </div>

    <div class="actions">
      <a class="btn btn-primary" href="/services">Voir les services</a>
      <a class="btn btn-secondary" href={bookingUrl} target="_blank" rel="noreferrer">
        Réserver un créneau optionnel
      </a>
      <a class="btn btn-secondary" href="/contact">Envoyer une autre demande</a>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const source = params.get("source") || "lead_form";
  const checklistDelivery = document.querySelector("#checklist-delivery");

  if (checklistDelivery instanceof HTMLElement && source.toLowerCase().includes("checklist")) {
    checklistDelivery.hidden = false;
  }

  window.trackEvent?.("lead_converted", {
    category: "lead",
    label: source,
    source,
    conversion_type: source.toLowerCase().includes("checklist")
      ? "checklist_download"
      : "form_contact",
    lead_stage: "lead_confirmed",
    ...(source.toLowerCase().includes("checklist")
      ? { service_interest: "Déclaration préalable panneaux solaires" }
      : { service_interest: "Pilotage administratif photovoltaïque" }),
  });
</script>

<style>
  .thanks-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(
        120% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 60%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 96%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.4rem, 3vw, 3rem);
    display: grid;
    gap: 1rem;
    max-width: 720px;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 0.94;
  }

  .intro {
    margin: 0;
    max-width: 60ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .delivery-card {
    display: grid;
    gap: 0.65rem;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: clamp(1rem, 2vw, 1.3rem);
    box-shadow: var(--shadow-sm);
  }

  .delivery-card[hidden] {
    display: none;
  }

  .delivery-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .delivery-card h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    line-height: 1.02;
  }

  .delivery-card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .delivery-card .btn {
    justify-self: start;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 760px) {
    .actions {
      display: grid;
    }

    .actions .btn {
      width: 100%;
      justify-content: center;
    }

    .delivery-card .btn {
      width: 100%;
      justify-self: stretch;
    }
  }
</style>
