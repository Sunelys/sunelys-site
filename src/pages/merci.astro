---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Merci | Sunelys"
  description="Votre demande a bien été transmise à Sunelys."
  robots="noindex,nofollow"
>
  <section class="thanks-card">
    <p class="eyebrow">Demande envoyee</p>
    <h1>Merci, votre message est bien parti.</h1>
    <p class="intro">
      Nous revenons vers vous rapidement pour cadrer votre besoin et voir si Sunelys peut
      absorber votre flux administratif.
    </p>

    <div class="actions">
      <a class="btn btn-primary" href="/services">Voir les services</a>
      <a class="btn btn-secondary" href="/contact">Envoyer une autre demande</a>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(
        120% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 60%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 96%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.4rem, 3vw, 3rem);
    display: grid;
    gap: 1rem;
    max-width: 720px;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 0.94;
  }

  .intro {
    margin: 0;
    max-width: 60ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 760px) {
    .actions {
      display: grid;
    }

    .actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
