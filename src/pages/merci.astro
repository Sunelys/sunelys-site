---
import BaseLayout from "../layouts/BaseLayout.astro";

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
---

<BaseLayout
  title="Merci | Sunelys"
  description="Votre demande a bien été transmise à Sunelys."
  robots="noindex,nofollow"
>
  <section class="thanks-card">
    <div class="thanks-copy">
      <span class="success-mark" aria-hidden="true">✓</span>
      <p class="eyebrow">Demande envoyée</p>
      <h1>Merci, votre message est bien parti.</h1>
      <p class="intro">
        Votre demande est enregistrée. Sunelys revient vers vous sous 24h pour cadrer le besoin,
        le volume et le premier périmètre utile à déléguer.
      </p>
    </div>

    <ol class="thanks-steps" aria-label="Prochaines étapes">
      <li>
        <span>01</span>
        <div>
          <strong>Lecture de votre contexte</strong>
          <p>Nous vérifions la démarche, le volume et le niveau d’urgence.</p>
        </div>
      </li>
      <li>
        <span>02</span>
        <div>
          <strong>Réponse sous 24h</strong>
          <p>Vous recevez un premier cadrage clair, sans engagement.</p>
        </div>
      </li>
      <li>
        <span>03</span>
        <div>
          <strong>Démarrage ciblé</strong>
          <p>Si le besoin correspond, nous identifions le premier dossier à reprendre.</p>
        </div>
      </li>
    </ol>

    <div class="delivery-card" id="checklist-delivery" hidden>
      <p class="delivery-kicker">Checklist disponible</p>
      <h2>Votre ressource DP est prête.</h2>
      <p>
        Vous pouvez l'ouvrir maintenant, puis l'imprimer ou l'enregistrer en PDF depuis votre navigateur.
      </p>
      <a
        class="btn btn-primary btn-accent"
        href="/checklist-declaration-prealable-solaire?source=merci_checklist"
        data-track="cta_thanks_checklist_download"
      >
        Ouvrir la checklist
      </a>
    </div>

    <div class="actions">
      <a class="btn btn-primary btn-accent" href={bookingUrl} target="_blank" rel="noreferrer">
        Réserver un créneau optionnel
      </a>
      <a class="thanks-link" href="/services">Découvrir les services <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const source = params.get("source") || "lead_form";
  const checklistDelivery = document.querySelector("#checklist-delivery");

  if (checklistDelivery instanceof HTMLElement && source.toLowerCase().includes("checklist")) {
    checklistDelivery.hidden = false;
  }

  window.trackEvent?.("lead_converted", {
    category: "lead",
    label: source,
    source,
    conversion_type: source.toLowerCase().includes("checklist")
      ? "checklist_download"
      : "form_contact",
    lead_stage: "lead_confirmed",
    ...(source.toLowerCase().includes("checklist")
      ? { service_interest: "Déclaration préalable panneaux solaires" }
      : { service_interest: "Pilotage administratif photovoltaïque" }),
  });
</script>

<style>
  .thanks-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(
        120% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 60%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 96%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.4rem, 3vw, 3rem);
    display: grid;
    gap: 1rem;
    max-width: 720px;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 0.94;
  }

  .intro {
    margin: 0;
    max-width: 60ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .delivery-card {
    display: grid;
    gap: 0.65rem;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: clamp(1rem, 2vw, 1.3rem);
    box-shadow: var(--shadow-sm);
  }

  .delivery-card[hidden] {
    display: none;
  }

  .delivery-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .delivery-card h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    line-height: 1.02;
  }

  .delivery-card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .delivery-card .btn {
    justify-self: start;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 760px) {
    .actions {
      display: grid;
    }

    .actions .btn {
      width: 100%;
      justify-content: center;
    }

    .delivery-card .btn {
      width: 100%;
      justify-self: stretch;
    }
  }

  /* Direction visuelle 2026 */
  .thanks-card {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.62fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
    overflow: hidden;
    max-width: none;
    min-height: min(39rem, calc(100vh - 8rem));
    padding: clamp(2rem, 5vw, 5rem);
    border: 0;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 88% 4%, rgba(54, 98, 227, 0.42), transparent 31%),
      radial-gradient(circle at 5% 100%, rgba(29, 155, 117, 0.23), transparent 32%),
      var(--ink);
    box-shadow: none;
    color: #ffffff;
  }

  .thanks-card::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -13rem;
    width: clamp(20rem, 36vw, 35rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .thanks-copy {
    display: grid;
    align-content: start;
    gap: 0.85rem;
  }

  .success-mark {
    width: 3.2rem;
    height: 3.2rem;
    display: grid;
    place-items: center;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 50%;
    background: rgba(29, 155, 117, 0.18);
    color: #7de0bd;
    font-size: 1.3rem;
    font-weight: 850;
  }

  .thanks-card .eyebrow {
    color: #7de0bd;
    font-weight: 850;
    letter-spacing: 0.11em;
  }

  .thanks-card h1 {
    max-width: 12ch;
    color: #ffffff;
    font-size: clamp(2.6rem, 5.5vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .thanks-card .intro {
    max-width: 44rem;
    color: #cbd5e1;
    font-size: clamp(1rem, 1.15vw, 1.18rem);
    line-height: 1.65;
  }

  .thanks-steps {
    display: grid;
    gap: 0;
    margin: 4.2rem 0 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    list-style: none;
  }

  .thanks-steps li {
    display: grid;
    grid-template-columns: 2.3rem minmax(0, 1fr);
    gap: 0.8rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .thanks-steps > li > span {
    color: #7da1ff;
    font-size: 0.68rem;
    font-weight: 850;
  }

  .thanks-steps div {
    display: grid;
    gap: 0.3rem;
  }

  .thanks-steps strong {
    color: #ffffff;
    font-size: 0.94rem;
  }

  .thanks-steps p {
    color: #aebbcf;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .delivery-card {
    grid-column: 1 / -1;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: none;
    backdrop-filter: blur(8px);
  }

  .delivery-card .delivery-kicker {
    color: #7de0bd;
  }

  .delivery-card h2 {
    color: #ffffff;
  }

  .delivery-card p {
    color: #cbd5e1;
  }

  .actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1.2rem;
    padding-top: 0.35rem;
  }

  .thanks-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
  }

  .thanks-link span {
    color: #7da1ff;
    transition: transform 160ms ease;
  }

  .thanks-link:hover span,
  .thanks-link:focus-visible span {
    transform: translateX(0.2rem);
  }

  @media (max-width: 840px) {
    .thanks-card {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .thanks-steps {
      margin-top: 0;
    }
  }

  @media (max-width: 640px) {
    .thanks-card {
      margin-inline: calc(var(--container-padding) * -0.35);
      padding: 1.4rem;
      border-radius: var(--radius-md);
    }

    .actions,
    .actions .btn {
      width: 100%;
    }

    .thanks-link {
      justify-content: center;
      width: 100%;
    }
  }
</style>
