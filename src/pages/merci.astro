---
import BaseLayout from "../layouts/BaseLayout.astro";

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";

const confirmationSignals = [
  "Demande reçue",
  "Réponse sous 24h ouvrées",
  "Sans engagement",
];

const nextSteps = [
  {
    number: "01",
    title: "Lecture de votre contexte",
    text: "Sunelys vérifie la démarche, le volume, l’urgence et le premier blocage à lever.",
  },
  {
    number: "02",
    title: "Cadrage du périmètre",
    text: "Vous recevez une réponse claire sur ce qui peut être repris en priorité.",
  },
  {
    number: "03",
    title: "Démarrage ciblé",
    text: "Si le besoin correspond, on démarre par un dossier ou un périmètre précis.",
  },
];

const prepItems = [
  "La démarche concernée : DP, Consuel, raccordement, EDF OA ou aides.",
  "Le volume approximatif et les dossiers les plus urgents.",
  "Les pièces déjà disponibles ou le point exact qui bloque.",
];

const briefFallbackItems = [
  {
    key: "service",
    label: "Besoin",
    value: "À confirmer",
  },
  {
    key: "blocked",
    label: "Blocage",
    value: "À qualifier",
  },
  {
    key: "volume",
    label: "Volume",
    value: "À préciser",
  },
  {
    key: "urgency",
    label: "Urgence",
    value: "À prioriser",
  },
];
---

<BaseLayout
  title="Merci | Sunelys"
  description="Votre demande a bien été transmise à Sunelys."
  robots="noindex,nofollow"
>
  <section
    class="thanks-card"
    data-track-view="thanks_confirmation_view"
    data-track-label="lead_thank_you_confirmation"
  >
    <div class="thanks-copy">
      <span class="success-mark" aria-hidden="true">✓</span>
      <p class="eyebrow">Demande envoyée</p>
      <h1>C’est reçu. On passe au cadrage.</h1>
      <p class="intro">
        Votre demande est enregistrée. Sunelys revient vers vous sous 24h ouvrées avec une première lecture du
        besoin, du volume et du périmètre utile à déléguer.
      </p>

      <ul class="confirmation-strip" aria-label="Confirmation de prise en charge">
        {
          confirmationSignals.map((signal) => (
            <li>
              <i aria-hidden="true"></i>
              {signal}
            </li>
          ))
        }
      </ul>
    </div>

    <aside class="thanks-panel" aria-label="Prochaines étapes">
      <p class="panel-kicker">Prochaine étape</p>
      <h2>Votre demande est traitée comme un brief, pas comme un ticket perdu.</h2>
      <ol class="thanks-steps">
        {
          nextSteps.map((step) => (
            <li>
              <span>{step.number}</span>
              <div>
                <strong>{step.title}</strong>
                <p>{step.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </aside>

    <div
      class="brief-recap"
      id="brief-recap"
      aria-labelledby="brief-recap-title"
      data-track-view="thanks_brief_recap_view"
      data-track-label="thanks_brief_recap"
      hidden
    >
      <div>
        <p class="panel-kicker">Brief retenu</p>
        <h2 id="brief-recap-title">Votre contexte est déjà cadré.</h2>
        <p>Sunelys relira ces éléments avant de revenir vers vous, pour éviter de repartir de zéro.</p>
      </div>
      <dl>
        {
          briefFallbackItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd data-brief-field={item.key}>{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div
      class="delivery-card"
      id="checklist-delivery"
      data-track-view="thanks_checklist_delivery_view"
      data-track-label="thanks_checklist_delivery"
      hidden
    >
      <p class="delivery-kicker">Checklist disponible</p>
      <h2>Votre ressource DP est prête.</h2>
      <p>
        Vous pouvez l'ouvrir maintenant, puis l'imprimer ou l'enregistrer en PDF depuis votre navigateur.
      </p>
      <a
        class="btn btn-primary btn-accent"
        href="/checklist-declaration-prealable-solaire?source=merci_checklist"
        data-track="cta_thanks_checklist_download"
      >
        Ouvrir la checklist
      </a>
    </div>

    <div
      class="prep-card"
      aria-labelledby="prep-title"
      data-track-view="thanks_prep_view"
      data-track-label="thanks_prepare_next_step"
    >
      <div>
        <p class="panel-kicker">Pendant ce temps</p>
        <h2 id="prep-title">Si vous voulez accélérer la réponse, préparez simplement ces éléments.</h2>
      </div>
      <ul>
        {
          prepItems.map((item) => (
            <li>
              <span aria-hidden="true">→</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="actions">
      <a class="btn btn-primary btn-accent" href={bookingUrl} target="_blank" rel="noreferrer" data-track="cta_thanks_booking">
        Réserver un créneau optionnel
      </a>
      <a class="thanks-link" href="/services" data-track="cta_thanks_services">
        Découvrir les services <span aria-hidden="true">→</span>
      </a>
      <a class="thanks-link muted" href="mailto:contact@sunelys.fr?subject=Pr%C3%A9cision%20pour%20mon%20diagnostic%20Sunelys" data-track="cta_thanks_email_precision">
        Ajouter une précision <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const source = params.get("source") || "lead_form";
  const checklistDelivery = document.querySelector("#checklist-delivery");
  const briefRecap = document.querySelector("#brief-recap");

  const setBriefValue = (key, value) => {
    if (!(briefRecap instanceof HTMLElement) || !value) return;

    const field = briefRecap.querySelector(`[data-brief-field="${key}"]`);
    if (field instanceof HTMLElement) {
      field.textContent = value;
    }
  };

  if (checklistDelivery instanceof HTMLElement && source.toLowerCase().includes("checklist")) {
    checklistDelivery.hidden = false;
  }

  let pendingLead = null;
  try {
    pendingLead = JSON.parse(sessionStorage.getItem("sunelys_pending_lead") || "null");
  } catch (_error) {
    pendingLead = null;
  }

  if (pendingLead && typeof pendingLead === "object") {
    const serviceInterest = pendingLead.service_interest || pendingLead.need || pendingLead.service || "";
    const blockedStage = pendingLead.blocked_stage || pendingLead.blockedStage || "";
    const volume = pendingLead.volume || "";
    const urgency = pendingLead.urgency || "";

    if (briefRecap instanceof HTMLElement && (serviceInterest || blockedStage || volume || urgency)) {
      setBriefValue("service", serviceInterest || "À confirmer");
      setBriefValue("blocked", blockedStage || "À qualifier");
      setBriefValue("volume", volume || "À préciser");
      setBriefValue("urgency", urgency || "À prioriser");
      briefRecap.hidden = false;
    }

    window.trackLeadSuccess?.({
      ...pendingLead,
      label: pendingLead.label || source,
      source: pendingLead.source || source,
      conversion_type:
        pendingLead.conversion_type ||
        (source.toLowerCase().includes("checklist") ? "checklist_download" : "form_contact"),
      service_interest:
        pendingLead.service_interest ||
        (source.toLowerCase().includes("checklist")
          ? "Déclaration préalable panneaux solaires"
          : "Pilotage administratif photovoltaïque"),
    });
  }
</script>

<style>
  .thanks-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(
        120% 120% at 100% 0%,
        color-mix(in srgb, var(--accent-soft) 60%, transparent),
        transparent 58%
      ),
      linear-gradient(
        170deg,
        color-mix(in srgb, var(--surface-elevated) 96%, white),
        var(--surface)
      );
    box-shadow: var(--shadow-md);
    padding: clamp(1.4rem, 3vw, 3rem);
    display: grid;
    gap: 1rem;
    max-width: 720px;
  }

  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 0.94;
  }

  .intro {
    margin: 0;
    max-width: 60ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .delivery-card {
    display: grid;
    gap: 0.65rem;
    border: 1px solid color-mix(in srgb, var(--line) 68%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    padding: clamp(1rem, 2vw, 1.3rem);
    box-shadow: var(--shadow-sm);
  }

  .delivery-card[hidden] {
    display: none;
  }

  .delivery-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .delivery-card h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    line-height: 1.02;
  }

  .delivery-card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .delivery-card .btn {
    justify-self: start;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 760px) {
    .actions {
      display: grid;
    }

    .actions .btn {
      width: 100%;
      justify-content: center;
    }

    .delivery-card .btn {
      width: 100%;
      justify-self: stretch;
    }
  }

  /* Direction visuelle 2026 */
  .thanks-card {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.62fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
    overflow: hidden;
    max-width: none;
    min-height: min(39rem, calc(100vh - 8rem));
    padding: clamp(2rem, 5vw, 5rem);
    border: 0;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 88% 4%, rgba(54, 98, 227, 0.42), transparent 31%),
      radial-gradient(circle at 5% 100%, rgba(29, 155, 117, 0.23), transparent 32%),
      var(--ink);
    box-shadow: none;
    color: #ffffff;
  }

  .thanks-card::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -13rem;
    width: clamp(20rem, 36vw, 35rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .thanks-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
    background-size: 3rem 3rem;
    mask-image: radial-gradient(64% 70% at 30% 28%, #000 0%, transparent 78%);
    opacity: 0.45;
  }

  .thanks-copy {
    display: grid;
    align-content: start;
    gap: 0.85rem;
  }

  .success-mark {
    width: 3.2rem;
    height: 3.2rem;
    display: grid;
    place-items: center;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 50%;
    background: rgba(29, 155, 117, 0.18);
    color: #7de0bd;
    font-size: 1.3rem;
    font-weight: 850;
  }

  .thanks-card .eyebrow {
    color: #7de0bd;
    font-weight: 850;
    letter-spacing: 0.11em;
  }

  .thanks-card h1 {
    max-width: 12ch;
    color: #ffffff;
    font-size: clamp(2.6rem, 5.5vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .thanks-card .intro {
    max-width: 44rem;
    color: #cbd5e1;
    font-size: clamp(1rem, 1.15vw, 1.18rem);
    line-height: 1.65;
  }

  .confirmation-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .confirmation-strip li {
    display: inline-flex;
    align-items: center;
    gap: 0.46rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.055);
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.7rem;
    font-weight: 760;
  }

  .confirmation-strip i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #7de0bd;
    box-shadow: 0 0 0 3px rgba(125, 224, 189, 0.14);
  }

  .thanks-panel,
  .brief-recap,
  .prep-card {
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.07);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(16px);
  }

  .thanks-panel {
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .brief-recap {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 0.56fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
    padding: clamp(1rem, 2.5vw, 1.45rem);
  }

  .brief-recap[hidden] {
    display: none;
  }

  .panel-kicker {
    margin: 0;
    color: #7de0bd;
    font-size: 0.62rem;
    font-weight: 860;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .thanks-panel h2,
  .brief-recap h2,
  .prep-card h2 {
    margin: 0.55rem 0 0;
    color: #ffffff;
    font-size: clamp(1.25rem, 2.1vw, 1.95rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .brief-recap p:not(.panel-kicker) {
    margin: 0.7rem 0 0;
    color: #cbd5e1;
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .brief-recap dl {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.58rem;
    margin: 0;
  }

  .brief-recap dl div {
    min-width: 0;
    padding: 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.055);
  }

  .brief-recap dt {
    color: #7de0bd;
    font-size: 0.6rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .brief-recap dd {
    margin: 0.38rem 0 0;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 780;
    line-height: 1.25;
  }

  .thanks-steps {
    display: grid;
    gap: 0;
    margin: 1.15rem 0 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    list-style: none;
  }

  .thanks-steps li {
    display: grid;
    grid-template-columns: 2.3rem minmax(0, 1fr);
    gap: 0.8rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .thanks-steps > li > span {
    color: #7da1ff;
    font-size: 0.68rem;
    font-weight: 850;
  }

  .thanks-steps div {
    display: grid;
    gap: 0.3rem;
  }

  .thanks-steps strong {
    color: #ffffff;
    font-size: 0.94rem;
  }

  .thanks-steps p {
    color: #aebbcf;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .prep-card {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 0.74fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: start;
    padding: clamp(1rem, 2.5vw, 1.45rem);
  }

  .prep-card ul {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .prep-card li {
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    gap: 0.55rem;
    align-items: start;
    color: #cbd5e1;
    font-size: 0.82rem;
    line-height: 1.48;
  }

  .prep-card li span {
    color: #7da1ff;
    font-weight: 850;
  }

  .delivery-card {
    grid-column: 1 / -1;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: none;
    backdrop-filter: blur(8px);
  }

  .delivery-card .delivery-kicker {
    color: #7de0bd;
  }

  .delivery-card h2 {
    color: #ffffff;
  }

  .delivery-card p {
    color: #cbd5e1;
  }

  .actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1.2rem;
    padding-top: 0.35rem;
  }

  .thanks-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
  }

  .thanks-link span {
    color: #7da1ff;
    transition: transform 160ms ease;
  }

  .thanks-link.muted {
    color: rgba(255, 255, 255, 0.7);
  }

  .thanks-link:hover span,
  .thanks-link:focus-visible span {
    transform: translateX(0.2rem);
  }

  @media (max-width: 840px) {
    .thanks-card {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .brief-recap,
    .prep-card {
      grid-template-columns: 1fr;
    }

    .brief-recap dl {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .thanks-steps {
      margin-top: 1rem;
    }
  }

  @media (max-width: 640px) {
    .thanks-card {
      margin-inline: calc(var(--container-padding) * -0.35);
      padding: 1.4rem;
      border-radius: var(--radius-md);
    }

    .actions,
    .actions .btn {
      width: 100%;
    }

    .thanks-link {
      justify-content: center;
      width: 100%;
    }

    .confirmation-strip {
      display: grid;
    }

    .confirmation-strip li {
      justify-content: center;
    }

    .brief-recap dl {
      grid-template-columns: 1fr;
    }
  }
</style>
