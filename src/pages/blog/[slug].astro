---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LeadMagnetChecklist from "../../components/LeadMagnetChecklist.astro";
import MediaFrame from "../../components/MediaFrame.astro";

export async function getStaticPaths() {
  const posts = Object.values(import.meta.glob("../../content/blog/*.md", { eager: true }));
  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
const { frontmatter } = post;
const articleUrl = `https://sunelys.fr/blog/${frontmatter.slug}`;
const primaryServiceHref = frontmatter.primaryServiceHref || "/services";
const primaryServiceLabel = frontmatter.primaryServiceLabel || "Voir le service associé";
const secondaryServiceHref =
  frontmatter.secondaryServiceHref || `/contact?source=${frontmatter.contactSource || "blog-article"}#contact-form`;
const secondaryServiceLabel = frontmatter.secondaryServiceLabel || "Recevoir un cadrage";
const articleContactHref = `/contact?source=${frontmatter.contactSource || "blog-article"}#contact-form`;
const relatedLinks = frontmatter.relatedLinks ?? [];
const date = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(frontmatter.pubDate));
const modifiedDate = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(frontmatter.updatedDate ?? frontmatter.pubDate));
const defaultArticleImage = "https://sunelys.fr/images/og/sunelys-og.png";
const socialImage = frontmatter.ogImage || frontmatter.coverImage;
const author = {
  name: "Myriam Zaoui",
  url: "https://sunelys.fr/a-propos",
  linkedin: "https://www.linkedin.com/in/myriam-zaoui-2baa501b9/",
};

const faqSchema = frontmatter.faqItems?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: frontmatter.faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }
  : null;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: frontmatter.title,
    description: frontmatter.description,
    datePublished: frontmatter.pubDate,
    dateModified: frontmatter.updatedDate ?? frontmatter.pubDate,
    author: {
      "@type": "Person",
      name: author.name,
      url: author.url,
      sameAs: [author.linkedin],
      worksFor: {
        "@type": "Organization",
        name: "Sunelys",
        url: "https://sunelys.fr",
      },
    },
    publisher: {
      "@type": "Organization",
      name: "Sunelys",
      logo: {
        "@type": "ImageObject",
        url: "https://sunelys.fr/brand/logo-full.png",
      },
    },
    mainEntityOfPage: articleUrl,
    keywords: frontmatter.keywords,
    image: socialImage ? `https://sunelys.fr${socialImage}` : defaultArticleImage,
    articleSection: frontmatter.category,
    inLanguage: "fr-FR",
  },
  ...(faqSchema ? [faqSchema] : []),
];

const breadcrumbs = [
  { name: "Accueil", item: "https://sunelys.fr/" },
  { name: "Blog", item: "https://sunelys.fr/blog" },
  { name: frontmatter.title, item: articleUrl },
];
---

<BaseLayout
  title={frontmatter.seoTitle ?? frontmatter.title}
  description={frontmatter.description}
  structuredData={structuredData}
  image={socialImage}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <article class="article-shell reveal">
    <header class="article-header">
      <a class="back-link" href="/blog" data-track="cta_article_back_blog">Blog Sunelys</a>
      <div class="article-meta">
        <span>{frontmatter.category}</span>
        <span>{date}</span>
        {frontmatter.updatedDate && frontmatter.updatedDate !== frontmatter.pubDate && <span>Mis à jour le {modifiedDate}</span>}
        <span>{frontmatter.readingTime}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <p>{frontmatter.description}</p>
      <div class="article-actions">
        <a class="btn btn-primary" href={articleContactHref} data-track="cta_article_header_primary" data-track-label={frontmatter.title}>Recevoir un cadrage</a>
        <a class="btn btn-secondary" href={primaryServiceHref} data-track="cta_article_header_services" data-track-label={frontmatter.title}>{primaryServiceLabel}</a>
      </div>
      <div class="article-cover">
        <MediaFrame
          src={frontmatter.coverImage}
          alt={frontmatter.coverAlt || frontmatter.title}
          label="Visuel article Sunelys"
          variant="wide"
          loading="eager"
        />
      </div>
    </header>

    <div class="article-layout">
      <aside class="article-aside" aria-label="Action Sunelys">
        <p class="aside-label">À transformer en action</p>
        <h2>{frontmatter.businessOutcome || "Remettez l'administratif au service de vos délais chantier."}</h2>
        <p>Sunelys prend en charge le flux concerné pour donner plus de visibilité à vos équipes et réduire les retours évitables.</p>
        <div class="aside-actions">
          <a class="btn btn-primary" href={articleContactHref} data-track="cta_article_sticky" data-track-label={frontmatter.title}>Recevoir un cadrage</a>
          <a class="btn btn-secondary" href={primaryServiceHref} data-track="cta_article_sticky_service" data-track-label={frontmatter.title}>{primaryServiceLabel}</a>
        </div>
      </aside>

      <div class="article-content">
        <Content />
      </div>
    </div>

    <section class="article-author" aria-label="Auteur de l'article">
      <img src="/images/myriam-zaoui.jpg" alt="Myriam Zaoui, fondatrice de Sunelys" width="128" height="128" loading="lazy" decoding="async" />
      <div>
        <p class="aside-label">Rédigé par</p>
        <h2>{author.name}</h2>
        <p>
          Fondatrice de Sunelys, Myriam accompagne les installateurs photovoltaïques sur la
          préparation, le suivi et la fiabilisation des démarches administratives solaires.
        </p>
        <a href={author.url} data-track="cta_article_author_about">Voir le profil Sunelys</a>
      </div>
    </section>

    <LeadMagnetChecklist source={`blog_${frontmatter.slug}_checklist_dp`} />

    {
      relatedLinks.length > 0 && (
        <section class="related-guides" aria-labelledby="related-guides-title">
          <p class="aside-label">À lire aussi</p>
          <h2 id="related-guides-title">Continuer dans le même sujet</h2>
          <div class="related-guides-grid">
            {relatedLinks.map((link) => (
              <a href={link.href} data-track="cta_article_related" data-track-label={link.label}>
                <span>{link.label}</span>
                {link.description && <small>{link.description}</small>}
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="article-conclusion">
      <div class="article-conclusion-copy">
        <p class="aside-label">Étape suivante</p>
        <h2>Ne laissez pas le sujet au stade du constat.</h2>
        <p>
          Si cette friction existe déjà dans vos flux, le bon prochain pas est de cadrer le périmètre à déléguer et
          le service Sunelys le plus pertinent pour vos dossiers.
        </p>
      </div>
      <div class="article-conclusion-actions">
        <a class="btn btn-primary" href={secondaryServiceHref} data-track="cta_article_footer_primary" data-track-label={frontmatter.title}>
          {secondaryServiceLabel}
        </a>
        <a class="btn btn-secondary" href={primaryServiceHref} data-track="cta_article_footer_service" data-track-label={frontmatter.title}>
          {primaryServiceLabel}
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.4rem);
  }

  .article-header {
    padding: clamp(1.7rem, 4.6vw, 4.2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 82% 18%, color-mix(in srgb, var(--accent-soft) 68%, transparent), transparent 32%),
      linear-gradient(145deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 86%, white));
    box-shadow: var(--shadow-md);
  }

  .back-link,
  .article-meta {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.85rem;
    margin-bottom: 0.75rem;
  }

  .article-header h1 {
    max-width: 12ch;
    font-size: clamp(2.6rem, 6.5vw, 6.2rem);
    line-height: 0.94;
  }

  .article-header > p {
    max-width: 64rem;
    margin-top: 1.2rem;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 1.1vw, 1.35rem);
    line-height: 1.65;
  }

  .article-actions {
    margin-top: 1.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-cover {
    margin-top: 1.7rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2.35fr);
    gap: clamp(1rem, 2vw, 1.4rem);
    align-items: start;
  }

  .article-aside {
    position: sticky;
    top: 6.3rem;
    display: grid;
    gap: 0.85rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  .aside-label {
    color: var(--text);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .article-aside h2 {
    font-size: clamp(1.35rem, 1.8vw, 1.8rem);
    line-height: 1.08;
  }

  .article-aside p:not(.aside-label) {
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .aside-actions {
    display: grid;
    gap: 0.58rem;
  }

  .article-content {
    padding: clamp(1.4rem, 3.2vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
  }

  .article-content :global(h2) {
    margin-top: 2.2rem;
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    line-height: 1.02;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(h3) {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text-muted);
    font-size: var(--step-0);
    line-height: 1.72;
  }

  .article-content :global(p) {
    margin-top: 0.95rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
  }

  .article-content :global(a) {
    color: var(--text);
    font-weight: 700;
    text-underline-offset: 0.25rem;
  }

  .article-content :global(blockquote) {
    margin: 1.4rem 0;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent-soft) 38%, white);
  }

  .article-author,
  .related-guides {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
    padding: clamp(1.1rem, 2.4vw, 1.8rem);
  }

  .article-author {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
  }

  .article-author img {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--line) 74%, white);
  }

  .article-author div,
  .related-guides {
    display: grid;
    gap: 0.55rem;
  }

  .article-author h2,
  .related-guides h2 {
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    line-height: 1.08;
  }

  .article-author p:not(.aside-label),
  .article-author a,
  .related-guides small {
    color: var(--text-muted);
    line-height: 1.55;
  }

  .article-author a {
    width: fit-content;
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .article-author a:hover,
  .article-author a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .related-guides-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .related-guides-grid a {
    display: grid;
    gap: 0.35rem;
    min-height: 7.6rem;
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    color: var(--text);
    text-decoration: none;
    transition: transform 170ms ease, box-shadow 170ms ease, border-color 170ms ease;
  }

  .related-guides-grid a:hover,
  .related-guides-grid a:focus-visible {
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .related-guides-grid span {
    font-weight: 800;
    line-height: 1.25;
  }

  .article-conclusion {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto;
    gap: 1rem;
    align-items: center;
    padding: clamp(1.4rem, 3vw, 2.2rem);
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent-soft) 44%, transparent), transparent 36%),
      linear-gradient(150deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 88%, white));
    box-shadow: var(--shadow-sm);
  }

  .article-conclusion-copy p:not(.aside-label) {
    margin-top: 0.7rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .article-conclusion-actions {
    display: grid;
    gap: 0.62rem;
    min-width: min(100%, 18rem);
  }

  @media (max-width: 980px) {
    .article-cover {
      margin-top: 1.7rem;
    }

    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      order: 2;
    }

    .article-conclusion {
      grid-template-columns: 1fr;
    }

    .related-guides-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .article-author {
      grid-template-columns: 1fr;
    }
  }
</style>
