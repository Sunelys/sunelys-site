---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { filterVisibleLinks, getPublicBlogPosts, publicBlogSlugs } from "../../lib/blogPublication";

export async function getStaticPaths() {
  const posts = getPublicBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
const { frontmatter } = post;
const articleUrl = `https://sunelys.fr/blog/${frontmatter.slug}`;
const primaryServiceHref = frontmatter.primaryServiceHref || "/services";
const primaryServiceLabel = frontmatter.primaryServiceLabel || "Voir le service associé";
const secondaryServiceHref =
  frontmatter.secondaryServiceHref || `/contact?source=${frontmatter.contactSource || "blog-article"}#contact-form`;
const secondaryServiceLabel = frontmatter.secondaryServiceLabel || "Recevoir un cadrage";
const articleContactHref = `/contact?source=${frontmatter.contactSource || "blog-article"}#contact-form`;
const relatedLinks = filterVisibleLinks(frontmatter.relatedLinks, publicBlogSlugs);
const pricingLinkByService: Record<string, { href: string; label: string; description: string }> = {
  "/declaration-prealable-panneaux-solaires": {
    href: "/tarif-declaration-prealable-photovoltaique",
    label: "Tarif déclaration préalable",
    description: "Comparer le coût par dossier et le niveau de délégation adapté.",
  },
  "/sous-traitance-declaration-prealable-solaire": {
    href: "/tarif-declaration-prealable-photovoltaique",
    label: "Tarif DP photovoltaïque",
    description: "Chiffrer la sous-traitance de vos déclarations préalables solaires.",
  },
};
const defaultPricingLink = {
  href: "/tarifs",
  label: "Voir les offres Sunelys",
  description: "Comparer les périmètres de prise en charge selon votre organisation.",
};
const pricingLink = pricingLinkByService[primaryServiceHref] ?? defaultPricingLink;
const articleBusinessLinks = [
  {
    href: primaryServiceHref,
    label: primaryServiceLabel,
    description: "Transformer le sujet de l'article en flux administratif piloté.",
  },
  pricingLink,
  {
    href: articleContactHref,
    label: "Demander un diagnostic",
    description: "Cadrer votre volume, vos blocages et le bon périmètre à déléguer.",
  },
].filter((link, index, links) => links.findIndex((candidate) => candidate.href === link.href) === index);
const date = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(frontmatter.pubDate));
const modifiedDate = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(frontmatter.updatedDate ?? frontmatter.pubDate));
const defaultArticleImage = "https://sunelys.fr/images/og/sunelys-og.png";
const socialImage = frontmatter.ogImage || frontmatter.coverImage;
const author = {
  name: "Myriam Zaoui",
  url: "https://sunelys.fr/a-propos",
  linkedin: "https://www.linkedin.com/in/myriam-zaoui-2baa501b9/",
};

const faqSchema = frontmatter.faqItems?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: frontmatter.faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    }
  : null;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: frontmatter.title,
    description: frontmatter.description,
    datePublished: frontmatter.pubDate,
    dateModified: frontmatter.updatedDate ?? frontmatter.pubDate,
    author: {
      "@type": "Person",
      name: author.name,
      url: author.url,
      sameAs: [author.linkedin],
      worksFor: {
        "@type": "Organization",
        name: "Sunelys",
        url: "https://sunelys.fr",
      },
    },
    publisher: {
      "@type": "Organization",
      name: "Sunelys",
      logo: {
        "@type": "ImageObject",
        url: "https://sunelys.fr/brand/logo-full.png",
      },
    },
    mainEntityOfPage: articleUrl,
    keywords: frontmatter.keywords,
    image: socialImage ? `https://sunelys.fr${socialImage}` : defaultArticleImage,
    articleSection: frontmatter.category,
    inLanguage: "fr-FR",
  },
  ...(faqSchema ? [faqSchema] : []),
];

const breadcrumbs = [
  { name: "Accueil", item: "https://sunelys.fr/" },
  { name: "Blog", item: "https://sunelys.fr/blog" },
  { name: frontmatter.title, item: articleUrl },
];
---

<BaseLayout
  title={frontmatter.seoTitle ?? frontmatter.title}
  description={frontmatter.description}
  structuredData={structuredData}
  image={socialImage}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <article class="article-shell">
    <header class="article-hero">
      <div class="article-hero-copy" data-reveal-item>
        <a class="back-link" href="/blog" data-track="cta_article_back_blog">
          <span aria-hidden="true">←</span>
          Tous les guides
        </a>
        <div class="article-meta">
          <span>{frontmatter.category}</span>
          <span>{date}</span>
          <span>{frontmatter.readingTime} de lecture</span>
        </div>
        <h1>{frontmatter.title}</h1>
        <p class="article-lead">{frontmatter.description}</p>
        <div class="article-actions">
          <a class="btn btn-primary btn-accent" href={articleContactHref} data-track="cta_article_header_primary" data-track-label={frontmatter.title}>
            Recevoir un cadrage
          </a>
          <a class="article-service-link" href={primaryServiceHref} data-track="cta_article_header_services" data-track-label={frontmatter.title}>
            {primaryServiceLabel}
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <figure class="article-cover" data-reveal-item>
        <img
          src={frontmatter.coverImage}
          alt={frontmatter.coverAlt || frontmatter.title}
          width="1200"
          height="760"
          loading="eager"
          decoding="async"
        />
        <figcaption>
          <span>Guide opérationnel</span>
          <strong>Sunelys — administratif photovoltaïque</strong>
        </figcaption>
      </figure>
    </header>

    <div class="article-reading-layout">
      <aside class="article-aside" aria-label="Repères de lecture">
        <div class="aside-kicker">
          <span aria-hidden="true">01</span>
          <p>À retenir</p>
        </div>
        <p>
          {frontmatter.businessOutcome || "Remettez l'administratif au service de vos délais chantier."}
        </p>
        <dl>
          <div>
            <dt>Publié</dt>
            <dd>{date}</dd>
          </div>
          {
            frontmatter.updatedDate && frontmatter.updatedDate !== frontmatter.pubDate && (
              <div>
                <dt>Actualisé</dt>
                <dd>{modifiedDate}</dd>
              </div>
            )
          }
          <div>
            <dt>Format</dt>
            <dd>{frontmatter.readingTime}</dd>
          </div>
        </dl>
        <a class="aside-link" href={primaryServiceHref} data-track="cta_article_sticky_service" data-track-label={frontmatter.title}>
          Voir le service associé
          <span aria-hidden="true">→</span>
        </a>
      </aside>

      <div class="article-main">
        <div class="article-content">
          <Content />
        </div>

        <section class="article-author" aria-label="Auteur de l'article">
          <img src="/images/myriam-zaoui.jpg" alt="Myriam Zaoui, fondatrice de Sunelys" width="128" height="128" loading="lazy" decoding="async" />
          <div>
            <p class="section-kicker">L’expertise derrière le guide</p>
            <h2>{author.name}</h2>
            <p>
              Fondatrice de Sunelys, Myriam accompagne les installateurs photovoltaïques dans la préparation,
              le suivi et la fiabilisation de leurs démarches administratives.
            </p>
            <a href={author.url} data-track="cta_article_author_about">Découvrir Sunelys <span aria-hidden="true">→</span></a>
          </div>
        </section>
      </div>
    </div>

    <section class="article-resources" aria-labelledby="article-resources-title">
      <div class="resources-heading">
        <p class="section-kicker">Pour aller plus loin</p>
        <h2 id="article-resources-title">Continuez avec la bonne ressource.</h2>
        <p>
          Service, tarifs ou guide complémentaire : choisissez la suite qui correspond à votre niveau de décision.
        </p>
      </div>
      <div class="resource-links">
        {
          articleBusinessLinks.map((link, index) => (
            <a href={link.href} data-track="cta_article_business_path" data-track-label={link.label}>
              <small>{String(index + 1).padStart(2, "0")}</small>
              <span>{link.label}</span>
              <p>{link.description}</p>
              <b aria-hidden="true">↗</b>
            </a>
          ))
        }
      </div>
    </section>

    {
      relatedLinks.length > 0 && (
        <section class="related-guides" aria-labelledby="related-guides-title">
          <div>
            <p class="section-kicker">À lire aussi</p>
            <h2 id="related-guides-title">Continuer dans le même sujet.</h2>
          </div>
          <div class="related-guides-list">
            {relatedLinks.map((link, index) => (
              <a href={link.href} data-track="cta_article_related" data-track-label={link.label}>
                <small>{String(index + 1).padStart(2, "0")}</small>
                <span>
                  <strong>{link.label}</strong>
                  {link.description && <em>{link.description}</em>}
                </span>
                <b aria-hidden="true">→</b>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="article-conclusion">
      <div class="article-conclusion-copy">
        <p class="section-kicker">Passer à l’action</p>
        <h2>Le sujet est clair. Le prochain dossier peut l’être aussi.</h2>
        <p>
          Sunelys cadre le périmètre, le volume et la première étape à déléguer. Vous recevez une réponse exploitable sous 24h.
        </p>
      </div>
      <div class="article-conclusion-actions">
        <a class="btn btn-primary btn-accent" href={secondaryServiceHref} data-track="cta_article_footer_primary" data-track-label={frontmatter.title}>
          {secondaryServiceLabel}
        </a>
        <a class="conclusion-link" href={primaryServiceHref} data-track="cta_article_footer_service" data-track-label={frontmatter.title}>
          {primaryServiceLabel}
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.4rem);
  }

  .article-header {
    padding: clamp(1.7rem, 4.6vw, 4.2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 82% 18%, color-mix(in srgb, var(--accent-soft) 68%, transparent), transparent 32%),
      linear-gradient(145deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 86%, white));
    box-shadow: var(--shadow-md);
  }

  .back-link,
  .article-meta {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.85rem;
    margin-bottom: 0.75rem;
  }

  .article-header h1 {
    max-width: 12ch;
    font-size: clamp(2.6rem, 6.5vw, 6.2rem);
    line-height: 0.94;
  }

  .article-header > p {
    max-width: 64rem;
    margin-top: 1.2rem;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 1.1vw, 1.35rem);
    line-height: 1.65;
  }

  .article-actions {
    margin-top: 1.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-cover {
    margin-top: 1.7rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2.35fr);
    gap: clamp(1rem, 2vw, 1.4rem);
    align-items: start;
  }

  .article-aside {
    position: sticky;
    top: 6.3rem;
    display: grid;
    gap: 0.85rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  .aside-label {
    color: var(--text);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .article-aside h2 {
    font-size: clamp(1.35rem, 1.8vw, 1.8rem);
    line-height: 1.08;
  }

  .article-aside p:not(.aside-label) {
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .aside-actions {
    display: grid;
    gap: 0.58rem;
  }

  .article-content {
    padding: clamp(1.4rem, 3.2vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
  }

  .article-content :global(h2) {
    margin-top: 2.2rem;
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    line-height: 1.02;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(h3) {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text-muted);
    font-size: var(--step-0);
    line-height: 1.72;
  }

  .article-content :global(p) {
    margin-top: 0.95rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
  }

  .article-content :global(a) {
    color: var(--text);
    font-weight: 700;
    text-underline-offset: 0.25rem;
  }

  .article-content :global(blockquote) {
    margin: 1.4rem 0;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent-soft) 38%, white);
  }

  .article-business-path {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(1rem, 2vw, 1.4rem);
    align-items: start;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(110% 140% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    box-shadow: var(--shadow-sm);
    padding: clamp(1.1rem, 2.4vw, 1.7rem);
  }

  .article-business-path h2 {
    margin: 0.45rem 0 0;
    max-width: 15ch;
    font-size: clamp(1.6rem, 3vw, 2.7rem);
    line-height: 1;
  }

  .article-business-path p {
    margin: 0.7rem 0 0;
    max-width: 58ch;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .business-path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .business-path-grid a {
    min-height: 8.2rem;
    display: grid;
    align-content: start;
    gap: 0.38rem;
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    color: var(--text);
    text-decoration: none;
    padding: 0.9rem;
    transition: transform 170ms ease, box-shadow 170ms ease, border-color 170ms ease;
  }

  .business-path-grid a:hover,
  .business-path-grid a:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
  }

  .business-path-grid span {
    font-weight: 800;
    line-height: 1.2;
  }

  .business-path-grid small {
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .article-author,
  .related-guides {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
    padding: clamp(1.1rem, 2.4vw, 1.8rem);
  }

  .article-author {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
  }

  .article-author img {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--line) 74%, white);
  }

  .article-author div,
  .related-guides {
    display: grid;
    gap: 0.55rem;
  }

  .article-author h2,
  .related-guides h2 {
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    line-height: 1.08;
  }

  .article-author p:not(.aside-label),
  .article-author a,
  .related-guides small {
    color: var(--text-muted);
    line-height: 1.55;
  }

  .article-author a {
    width: fit-content;
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .article-author a:hover,
  .article-author a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .related-guides-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .related-guides-grid a {
    display: grid;
    gap: 0.35rem;
    min-height: 7.6rem;
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--line) 82%, white);
    border-radius: calc(var(--radius-md) - 4px);
    background: color-mix(in srgb, var(--surface-elevated) 90%, white);
    color: var(--text);
    text-decoration: none;
    transition: transform 170ms ease, box-shadow 170ms ease, border-color 170ms ease;
  }

  .related-guides-grid a:hover,
  .related-guides-grid a:focus-visible {
    border-color: color-mix(in srgb, var(--line) 58%, var(--accent));
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .related-guides-grid span {
    font-weight: 800;
    line-height: 1.25;
  }

  .article-conclusion {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto;
    gap: 1rem;
    align-items: center;
    padding: clamp(1.4rem, 3vw, 2.2rem);
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent-soft) 44%, transparent), transparent 36%),
      linear-gradient(150deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 88%, white));
    box-shadow: var(--shadow-sm);
  }

  .article-conclusion-copy p:not(.aside-label) {
    margin-top: 0.7rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .article-conclusion-actions {
    display: grid;
    gap: 0.62rem;
    min-width: min(100%, 18rem);
  }

  @media (max-width: 980px) {
    .article-cover {
      margin-top: 1.7rem;
    }

    .article-layout,
    .article-business-path {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      order: 2;
    }

    .article-conclusion {
      grid-template-columns: 1fr;
    }

    .related-guides-grid,
    .business-path-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .article-author {
      grid-template-columns: 1fr;
    }
  }

  /* Direction éditoriale 2026 */
  .article-shell {
    display: grid;
    gap: clamp(3.2rem, 7vw, 6.6rem);
  }

  .article-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.7fr);
    gap: clamp(2rem, 5vw, 5.5rem);
    align-items: center;
    overflow: hidden;
    min-height: min(47rem, calc(100vh - 8rem));
    padding: clamp(2rem, 5vw, 5rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 86% 8%, rgba(54, 98, 227, 0.34), transparent 31%),
      radial-gradient(circle at 10% 100%, rgba(212, 130, 42, 0.24), transparent 34%),
      var(--ink);
    color: #f8fafc;
  }

  .article-hero::after {
    content: "";
    position: absolute;
    z-index: -1;
    width: clamp(16rem, 33vw, 32rem);
    aspect-ratio: 1;
    right: clamp(-9rem, -8vw, -4rem);
    bottom: clamp(-14rem, -12vw, -7rem);
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .article-hero-copy {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 clamp(2.2rem, 5vw, 4.6rem);
    color: #cdd6e4;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .back-link span {
    color: var(--accent);
    font-size: 1rem;
    transition: transform 160ms ease;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: #ffffff;
    text-decoration: none;
  }

  .back-link:hover span,
