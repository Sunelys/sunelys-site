---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MediaFrame from "../../components/MediaFrame.astro";

export async function getStaticPaths() {
  const posts = Object.values(import.meta.glob("../../content/blog/*.md", { eager: true }));
  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
const { frontmatter } = post;
const articleUrl = `https://sunelys.fr/blog/${frontmatter.slug}`;
const date = new Intl.DateTimeFormat("fr-FR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(frontmatter.pubDate));

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: frontmatter.title,
    description: frontmatter.description,
    datePublished: frontmatter.pubDate,
    dateModified: frontmatter.updatedDate ?? frontmatter.pubDate,
    author: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
    publisher: {
      "@type": "Organization",
      name: "Sunelys",
      logo: {
        "@type": "ImageObject",
        url: "https://sunelys.fr/brand/logo-full.svg",
      },
    },
    mainEntityOfPage: articleUrl,
    keywords: frontmatter.keywords,
    image: frontmatter.coverImage ? `https://sunelys.fr${frontmatter.coverImage}` : undefined,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: "https://sunelys.fr" },
      { "@type": "ListItem", position: 2, name: "Blog", item: "https://sunelys.fr/blog" },
      { "@type": "ListItem", position: 3, name: frontmatter.title, item: articleUrl },
    ],
  },
];
---

<BaseLayout title={frontmatter.seoTitle ?? frontmatter.title} description={frontmatter.description} structuredData={structuredData}>
  <article class="article-shell reveal">
    <header class="article-header">
      <a class="back-link" href="/blog" data-track="cta_article_back_blog">Blog Sunelys</a>
      <div class="article-meta">
        <span>{frontmatter.category}</span>
        <span>{date}</span>
        <span>{frontmatter.readingTime}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <p>{frontmatter.description}</p>
      <div class="article-actions">
        <a class="btn btn-primary" href="/contact?source=article-header" data-track="cta_article_header_primary" data-track-label={frontmatter.title}>Planifier un échange</a>
        <a class="btn btn-secondary" href="/services" data-track="cta_article_header_services" data-track-label={frontmatter.title}>Voir les services</a>
      </div>
      <div class="article-cover">
        <MediaFrame
          src={frontmatter.coverImage}
          alt={frontmatter.coverAlt || frontmatter.title}
          label="Image article à remplacer"
          variant="wide"
          loading="eager"
        />
      </div>
    </header>

    <div class="article-layout">
      <aside class="article-aside" aria-label="Action Sunelys">
        <p class="aside-label">Besoin d'externaliser ?</p>
        <p>Sunelys prend en charge DP, Consuel et raccordement pour fluidifier vos dossiers photovoltaïques.</p>
        <a class="btn btn-primary" href="/contact?source=article-sticky" data-track="cta_article_sticky" data-track-label={frontmatter.title}>Parler à Sunelys</a>
      </aside>

      <div class="article-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2.4rem);
  }

  .article-header {
    padding: clamp(1.7rem, 4.6vw, 4.2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 82% 18%, color-mix(in srgb, var(--accent-soft) 68%, transparent), transparent 32%),
      linear-gradient(145deg, color-mix(in srgb, var(--surface-elevated) 94%, white), color-mix(in srgb, var(--surface) 86%, white));
    box-shadow: var(--shadow-md);
  }

  .back-link,
  .article-meta {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.85rem;
    margin-bottom: 0.75rem;
  }

  .article-header h1 {
    max-width: 12ch;
    font-size: clamp(2.6rem, 6.5vw, 6.2rem);
    line-height: 0.94;
  }

  .article-header > p {
    max-width: 64rem;
    margin-top: 1.2rem;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 1.1vw, 1.35rem);
    line-height: 1.65;
  }

  .article-actions {
    margin-top: 1.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-cover {
    margin-top: 1.7rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2.35fr);
    gap: clamp(1rem, 2vw, 1.4rem);
    align-items: start;
  }

  .article-aside {
    position: sticky;
    top: 6.3rem;
    display: grid;
    gap: 0.85rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  .aside-label {
    color: var(--text);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .article-aside p:not(.aside-label) {
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .article-content {
    padding: clamp(1.4rem, 3.2vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--surface-elevated) 94%, white);
    box-shadow: var(--shadow-sm);
  }

  .article-content :global(h2) {
    margin-top: 2.2rem;
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    line-height: 1.02;
  }

  .article-content :global(h2:first-child) {
    margin-top: 0;
  }

  .article-content :global(h3) {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--text-muted);
    font-size: var(--step-0);
    line-height: 1.72;
  }

  .article-content :global(p) {
    margin-top: 0.95rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
  }

  .article-content :global(a) {
    color: var(--text);
    font-weight: 700;
    text-underline-offset: 0.25rem;
  }

  .article-content :global(blockquote) {
    margin: 1.4rem 0;
    padding: 1rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--line) 70%, var(--accent));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent-soft) 38%, white);
  }

  @media (max-width: 980px) {
    .article-cover {
    margin-top: 1.7rem;
  }

  .article-layout {
      grid-template-columns: 1fr;
    }

    .article-aside {
      position: static;
      order: 2;
    }
  }
</style>
