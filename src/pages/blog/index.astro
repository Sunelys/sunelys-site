---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/blog/BlogCard.astro";

const posts = Object.values(import.meta.glob("../../content/blog/*.md", { eager: true })).sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime(),
);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: "Blog Sunelys",
    url: "https://sunelys.fr/blog",
    description:
      "Conseils sur la gestion administrative photovoltaïque, le Consuel, les déclarations préalables et le raccordement Enedis pour les professionnels du solaire.",
    publisher: {
      "@type": "Organization",
      name: "Sunelys",
      url: "https://sunelys.fr",
    },
  },
];
---

<BaseLayout
  title="Blog photovoltaïque administratif | Sunelys"
  description="Guides pratiques pour installateurs photovoltaïques : gestion administrative solaire, déclaration préalable, Consuel, raccordement Enedis et organisation des dossiers."
  structuredData={structuredData}
>
  <section class="blog-hero section-shell reveal">
    <div class="blog-hero-copy">
      <p class="kicker">Ressources photovoltaïques</p>
      <h1>Des guides clairs pour mieux piloter l'administratif solaire.</h1>
      <p>
        Conseils opérationnels pour réduire les retours, mieux préparer les pièces et structurer vos flux DP,
        Consuel et raccordement Enedis.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contact?source=blog-hero" data-track="cta_blog_hero_primary">Parler de vos dossiers</a>
        <a class="btn btn-secondary" href="/services" data-track="cta_blog_hero_services">Voir les services</a>
      </div>
    </div>
    <div class="blog-hero-visual" aria-hidden="true">
      <img src="/images/site/portal-preview-placeholder.svg" alt="" loading="eager" decoding="async" />
    </div>
  </section>

  <section class="blog-grid section-shell" aria-label="Articles Sunelys">
    {posts.map((post) => <BlogCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1rem, 2vw, 1.4rem);
    align-items: center;
    padding: clamp(2rem, 5vw, 4.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 82% 12%, color-mix(in srgb, var(--accent-soft) 70%, transparent), transparent 34%),
      linear-gradient(145deg, color-mix(in srgb, var(--surface-elevated) 92%, white), color-mix(in srgb, var(--bg-soft) 76%, white));
    box-shadow: var(--shadow-md);
  }

  .kicker {
    margin: 0 0 0.7rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .blog-hero h1 {
    max-width: 11ch;
    font-size: clamp(3rem, 7vw, 6.8rem);
    line-height: 0.92;
  }

  .blog-hero p:not(.kicker) {
    max-width: 58rem;
    margin-top: 1.2rem;
    color: var(--text-muted);
    font-size: clamp(1.04rem, 1.1vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-actions {
    margin-top: 1.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .blog-hero-visual {
    border: 1px solid color-mix(in srgb, var(--line) 80%, white);
    border-radius: calc(var(--radius-xl) - 6px);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: color-mix(in srgb, var(--surface-elevated) 96%, white);
  }

  .blog-hero-visual img {
    display: block;
    width: 100%;
    height: auto;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.8rem, 1.4vw, 1.1rem);
  }

  @media (max-width: 980px) {
    .blog-hero {
      grid-template-columns: 1fr;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-hero h1 {
      max-width: 12ch;
    }
  }
</style>
