---
import BaseLayout from "../layouts/BaseLayout.astro";

const checklistGroups = [
  {
    title: "1. Informations projet",
    items: [
      "Adresse exacte du chantier, commune, parcelle et coordonnées du demandeur.",
      "Type de bâtiment concerné : maison individuelle, annexe, local professionnel ou bâtiment agricole.",
      "Puissance envisagée, nombre de panneaux, implantation et orientation de la toiture.",
      "Statut du projet : autoconsommation, revente totale, surplus ou projet en attente de dimensionnement.",
    ],
  },
  {
    title: "2. Contraintes d'urbanisme",
    items: [
      "Vérifier le PLU ou règlement local avant de figer les visuels.",
      "Identifier les zones ABF, sites classés, lotissements ou prescriptions architecturales.",
      "Contrôler les exigences de couleur, de surimposition, d'intégration et de visibilité depuis l'espace public.",
      "Conserver une trace de la règle utilisée pour répondre vite si la mairie demande un complément.",
    ],
  },
  {
    title: "3. Pièces graphiques",
    items: [
      "Plan de situation lisible avec localisation de la parcelle.",
      "Plan de masse avec l'emplacement de la toiture concernée.",
      "Plan ou photographie de la toiture avant projet.",
      "Insertion ou photomontage après projet, cohérent avec la teinte et la disposition des panneaux.",
      "Photo proche et photo lointaine quand elles sont nécessaires pour comprendre l'impact visuel.",
    ],
  },
  {
    title: "4. Cohérence du dossier",
    items: [
      "Même adresse, même nom et même surface sur toutes les pièces.",
      "Nombre de panneaux cohérent entre formulaire, plan et photomontage.",
      "Orientation, pente et emprise visibles sans ambiguïté.",
      "Pièces nommées proprement pour limiter les erreurs lors du dépôt.",
      "Message d'accompagnement court si le projet comporte une particularité.",
    ],
  },
  {
    title: "5. Avant dépôt",
    items: [
      "Relire le dossier comme une mairie le lirait : le projet est-il compréhensible en moins de deux minutes ?",
      "Anticiper les questions probables : visibilité rue, couleur, surimposition, zone protégée.",
      "Sauvegarder une version complète du dossier transmis.",
      "Prévoir le suivi de récépissé, délai d'instruction et demande éventuelle de pièce complémentaire.",
    ],
  },
];

const checklistItemCount = checklistGroups.reduce((total, group) => total + group.items.length, 0);
---

<BaseLayout
  title="Checklist déclaration préalable solaire | Sunelys"
  description="Checklist opérationnelle pour préparer une déclaration préalable panneaux solaires plus lisible et limiter les demandes de complément."
  robots="noindex,nofollow"
>
  <section class="checklist-hero section-shell">
    <div>
      <p class="eyebrow">Ressource Sunelys</p>
      <h1>Checklist déclaration préalable panneaux solaires</h1>
      <p class="intro">
        Une grille de contrôle simple pour repérer les oublis qui ralentissent le plus souvent les dossiers en mairie.
      </p>
    </div>
    <aside class="checklist-toolbox" aria-label="Progression de la checklist">
      <div class="progress-heading">
        <span data-progress-status>Dossier à cadrer</span>
        <strong><span data-progress-count>0</span> / {checklistItemCount}</strong>
      </div>
      <div
        class="progress-track"
        role="progressbar"
        aria-label="Points vérifiés"
        aria-valuemin="0"
        aria-valuemax={checklistItemCount}
        aria-valuenow="0"
        data-progress-track
      >
        <span data-progress-bar></span>
      </div>
      <p>Votre progression reste enregistrée sur cet appareil.</p>
      <div class="toolbox-actions">
        <button class="btn btn-primary btn-accent print-button" type="button" data-track="cta_checklist_print">
          Imprimer / enregistrer en PDF
        </button>
        <button class="reset-button" type="button" data-checklist-reset disabled>
          Réinitialiser
        </button>
      </div>
      <a
        class="checklist-complete-link"
        href="/contact?source=checklist_complete#contact-form"
        data-track="cta_checklist_complete"
        data-checklist-complete
        hidden
      >
        Faire relire ce flux par Sunelys <span aria-hidden="true">→</span>
      </a>
    </aside>
  </section>

  <section class="checklist-grid section-shell" aria-label="Checklist déclaration préalable">
    {checklistGroups.map((group, groupIndex) => (
      <article class="checklist-card">
        <div class="checklist-card-heading">
          <h2>{group.title}</h2>
          <span><strong data-group-count>0</strong> / {group.items.length}</span>
        </div>
        <ul data-checklist-group>
          {group.items.map((item, itemIndex) => (
            <li>
              <label>
                <input
                  class="checklist-input"
                  type="checkbox"
                  name={`checklist-${groupIndex + 1}-${itemIndex + 1}`}
                  data-checklist-item
                />
                <span class="check-control" aria-hidden="true"></span>
                <p>{item}</p>
              </label>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  <section class="checklist-cta section-shell">
    <p class="eyebrow">Besoin d'absorber du volume ?</p>
    <h2>Sunelys peut prendre le relais sur vos dossiers DP, Consuel et raccordement.</h2>
    <p>
      Si vos équipes perdent du temps sur les pièces, relances et dépôts administratifs, envoyez votre contexte.
      Nous cadrons le flux délégable et les priorités de reprise.
    </p>
    <div class="actions">
      <a class="btn btn-primary btn-accent" href="/contact?source=checklist_dp#contact-form" data-track="cta_checklist_contact">
        Recevoir un cadrage
      </a>
      <a class="btn btn-secondary" href="/declaration-prealable-panneaux-solaires" data-track="cta_checklist_dp_service">
        Voir l'accompagnement DP
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const storageKey = "sunelys-dp-checklist-v1";
  const checklistInputs = Array.from(document.querySelectorAll("[data-checklist-item]"));
  const progressCount = document.querySelector("[data-progress-count]");
  const progressStatus = document.querySelector("[data-progress-status]");
  const progressTrack = document.querySelector("[data-progress-track]");
  const progressBar = document.querySelector("[data-progress-bar]");
  const resetButton = document.querySelector("[data-checklist-reset]");
  const completeLink = document.querySelector("[data-checklist-complete]");
  let furthestMilestone = 0;

  try {
    const savedState = JSON.parse(localStorage.getItem(storageKey) || "[]");
    checklistInputs.forEach((input, index) => {
      if (input instanceof HTMLInputElement) input.checked = savedState[index] === true;
    });
  } catch {
    // La checklist reste pleinement utilisable si le stockage local est indisponible.
  }

  const updateChecklist = (trackProgress = false) => {
    const checkedCount = checklistInputs.filter(
      (input) => input instanceof HTMLInputElement && input.checked,
    ).length;
    const totalCount = checklistInputs.length;
    const percentage = totalCount > 0 ? Math.round((checkedCount / totalCount) * 100) : 0;

    if (progressCount) progressCount.textContent = String(checkedCount);
    if (progressBar instanceof HTMLElement) progressBar.style.width = `${percentage}%`;
    if (progressTrack) progressTrack.setAttribute("aria-valuenow", String(checkedCount));
    if (resetButton instanceof HTMLButtonElement) resetButton.disabled = checkedCount === 0;
    if (completeLink instanceof HTMLElement) completeLink.hidden = checkedCount !== totalCount;

    if (progressStatus) {
      progressStatus.textContent =
        percentage === 100
          ? "Prêt pour la relecture finale"
          : percentage >= 70
            ? "Derniers contrôles"
            : percentage >= 30
              ? "Contrôle en cours"
              : "Dossier à cadrer";
    }

    document.querySelectorAll("[data-checklist-group]").forEach((group) => {
      const groupInputs = Array.from(group.querySelectorAll("[data-checklist-item]"));
      const groupChecked = groupInputs.filter(
        (input) => input instanceof HTMLInputElement && input.checked,
      ).length;
      const groupCount = group.closest(".checklist-card")?.querySelector("[data-group-count]");
      if (groupCount) groupCount.textContent = String(groupChecked);
    });

    try {
      localStorage.setItem(
        storageKey,
        JSON.stringify(
          checklistInputs.map((input) => input instanceof HTMLInputElement && input.checked),
        ),
      );
    } catch {
      // Aucun blocage de l'interface si le stockage local est indisponible.
    }

    if (trackProgress) {
      [25, 50, 75, 100].forEach((milestone) => {
        if (percentage >= milestone && milestone > furthestMilestone) {
          furthestMilestone = milestone;
          window.trackEvent?.("checklist_progress", {
            checklist_name: "declaration_prealable_solaire",
            percent: milestone,
            completed_items: checkedCount,
            total_items: totalCount,
          });
        }
      });
    }
  };

  checklistInputs.forEach((input) => {
    input.addEventListener("change", () => updateChecklist(true));
  });

  resetButton?.addEventListener("click", () => {
    checklistInputs.forEach((input) => {
      if (input instanceof HTMLInputElement) input.checked = false;
    });
    furthestMilestone = 0;
    updateChecklist();
    window.trackEvent?.("checklist_reset", {
      checklist_name: "declaration_prealable_solaire",
    });
  });

  document.querySelector(".print-button")?.addEventListener("click", () => {
    window.print();
  });

  updateChecklist();
</script>

<style>
  .checklist-hero,
  .checklist-cta {
    display: grid;
    gap: 1rem;
    border: 1px solid color-mix(in srgb, var(--line) 72%, var(--accent));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(92% 130% at 100% 0%, color-mix(in srgb, var(--accent-soft) 48%, transparent), transparent 58%),
      linear-gradient(170deg, color-mix(in srgb, var(--surface-elevated) 96%, white), var(--surface));
    box-shadow: var(--shadow-md);
    padding: clamp(1.3rem, 3vw, 2.5rem);
  }

  .checklist-hero {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
  }

  .eyebrow {
    margin: 0 0 0.65rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
  }

  h1 {
    max-width: 13ch;
    font-size: clamp(2.1rem, 4.8vw, 4.6rem);
    line-height: 0.95;
  }

  h2 {
    font-size: clamp(1.45rem, 2.4vw, 2.35rem);
    line-height: 1.02;
  }

  .intro,
  .checklist-cta p,
  li p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.58;
  }

  .intro {
    max-width: 56ch;
    margin-top: 0.9rem;
    font-size: clamp(1rem, 0.36vw + 0.94rem, 1.15rem);
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .checklist-card {
    border: 1px solid color-mix(in srgb, var(--line) 78%, white);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface-elevated) 92%, white);
    box-shadow: var(--shadow-sm);
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .checklist-card ul {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .checklist-card li {
    display: grid;
    grid-template-columns: 1.1rem minmax(0, 1fr);
    gap: 0.6rem;
    align-items: start;
  }

  .checklist-card li span {
    width: 1.05rem;
    height: 1.05rem;
    border: 1px solid color-mix(in srgb, var(--line) 65%, var(--accent));
    border-radius: 5px;
    background: #fffdfa;
    margin-top: 0.2rem;
  }

  .checklist-cta {
    max-width: 54rem;
  }

  .checklist-cta h2 {
    max-width: 18ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 780px) {
    .checklist-hero,
    .checklist-grid {
      grid-template-columns: 1fr;
    }

    .print-button,
    .actions .btn {
      width: 100%;
    }
  }

  @media print {
    body {
      background: #ffffff !important;
    }

    :global(header),
    :global(footer),
    .print-button,
    .checklist-cta {
      display: none !important;
    }

    .checklist-hero,
    .checklist-card {
      box-shadow: none;
      break-inside: avoid;
    }

    .checklist-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Direction visuelle 2026 */
  .checklist-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    overflow: hidden;
    padding: clamp(2rem, 5vw, 4.5rem);
    border: 0;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 88% 4%, rgba(54, 98, 227, 0.42), transparent 31%),
      radial-gradient(circle at 5% 100%, rgba(212, 130, 42, 0.24), transparent 32%),
      var(--ink);
    box-shadow: none;
  }

  .checklist-hero::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -8rem;
    bottom: -13rem;
    width: clamp(20rem, 36vw, 35rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(255, 255, 255, 0.025),
      0 0 0 8rem rgba(255, 255, 255, 0.018);
  }

  .checklist-hero .eyebrow {
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .checklist-hero h1 {
    max-width: 13ch;
    color: #ffffff;
    font-size: clamp(2.55rem, 5.4vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .checklist-hero .intro {
    max-width: 48rem;
    color: #cbd5e1;
    line-height: 1.65;
  }

  .print-button {
    position: relative;
    z-index: 1;
    white-space: nowrap;
  }

  .checklist-toolbox {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.8rem;
    width: min(100%, 21rem);
    padding: 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 22px 48px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(16px);
  }

  .progress-heading {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    justify-content: space-between;
  }

  .progress-heading > span {
    color: #ffffff;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .progress-heading strong {
    color: var(--accent);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .progress-track {
    height: 0.4rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
  }

  .progress-track > span {
    display: block;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--accent), #f2b664);
    transition: width 220ms ease;
  }

  .checklist-toolbox > p {
    margin: 0;
    color: #aebdd0;
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .toolbox-actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
  }

  .toolbox-actions .btn {
    min-height: 2.9rem;
    padding-inline: 0.9rem;
    font-size: 0.78rem;
  }

  .reset-button {
    min-height: 2.9rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-sm);
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 750;
    padding-inline: 0.8rem;
  }

  .reset-button:disabled {
    cursor: default;
    opacity: 0.4;
  }

  .checklist-complete-link {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.2rem;
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 800;
    text-decoration: none;
  }

  .checklist-complete-link[hidden] {
    display: none;
  }

  .checklist-complete-link span {
    color: var(--accent);
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
    padding: clamp(1.5rem, 4vw, 3.5rem);
    border-top: 3px solid var(--ink);
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    background: var(--surface);
  }

  .checklist-card {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .checklist-card-heading {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  .checklist-card-heading > span {
    color: var(--system);
    font-size: 0.7rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .checklist-card h2 {
    color: var(--ink);
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    letter-spacing: -0.035em;
  }

  .checklist-card ul {
    gap: 0;
    margin-top: 0;
  }

  .checklist-card li {
    display: block;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }

  .checklist-card label {
    position: relative;
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
    cursor: pointer;
  }

  .checklist-input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .check-control {
    position: relative;
    width: 1.05rem;
    height: 1.05rem;
    margin-top: 0.22rem;
    border: 1.5px solid var(--system);
    border-radius: 3px;
    background: transparent;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .check-control::after {
    content: "";
    position: absolute;
    left: 0.3rem;
    top: 0.08rem;
    width: 0.28rem;
    height: 0.56rem;
    border: solid #ffffff;
    border-width: 0 2px 2px 0;
    opacity: 0;
    transform: rotate(45deg) scale(0.7);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .checklist-input:focus-visible + .check-control {
    outline: 3px solid color-mix(in srgb, var(--system-soft) 88%, transparent);
    outline-offset: 3px;
  }

  .checklist-input:checked + .check-control {
    border-color: var(--system);
    background: var(--system);
    transform: scale(1.04);
  }

  .checklist-input:checked + .check-control::after {
    opacity: 1;
    transform: rotate(45deg) scale(1);
  }

  .checklist-input:checked ~ p {
    color: color-mix(in srgb, var(--text-muted) 72%, white);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--system) 38%, transparent);
  }

  .checklist-card li p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .checklist-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 5vw, 4.5rem);
    align-items: end;
    max-width: none;
    padding: clamp(2.2rem, 5vw, 4.5rem);
    border: 0;
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at 90% 0%, rgba(54, 98, 227, 0.35), transparent 34%),
      var(--ink);
    box-shadow: none;
  }

  .checklist-cta .eyebrow {
    grid-column: 1;
    color: var(--accent);
    letter-spacing: 0.11em;
  }

  .checklist-cta h2 {
    grid-column: 1;
    max-width: 17ch;
    color: #ffffff;
    font-size: clamp(1.85rem, 3.55vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .checklist-cta > p:not(.eyebrow) {
    grid-column: 1;
    max-width: 48ch;
    color: #cbd5e1;
    line-height: 1.6;
  }

  .checklist-cta .actions {
    grid-column: 2;
    grid-row: 1 / 4;
    display: grid;
    gap: 0.75rem;
    align-content: end;
    min-width: min(100%, 18rem);
  }

  .checklist-cta .btn-secondary {
    border-color: rgba(255, 255, 255, 0.28);
    background: transparent;
    color: #ffffff;
  }

  @media (max-width: 820px) {
    .checklist-hero,
    .checklist-cta {
      grid-template-columns: 1fr;
    }

    .checklist-cta .actions {
      grid-column: 1;
      grid-row: auto;
      width: 100%;
    }

    .checklist-toolbox {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .checklist-hero {
      margin-inline: calc(var(--container-padding) * -0.35);
      padding: 1.4rem;
      border-radius: var(--radius-md);
    }

    .checklist-grid {
      grid-template-columns: 1fr;
      padding: 1.3rem;
      border-radius: 0 0 var(--radius-md) var(--radius-md);
    }

    .print-button,
    .checklist-cta .btn {
      width: 100%;
    }

    .toolbox-actions {
      grid-template-columns: 1fr;
    }

    .reset-button {
      width: 100%;
    }

    .checklist-cta {
      padding: 1.4rem;
      border-radius: var(--radius-md);
    }
  }

  @media print {
    .checklist-hero {
      display: block;
      min-height: 0;
      padding: 1rem 0;
      background: #ffffff !important;
      color: #000000;
    }

    .checklist-hero h1,
    .checklist-hero .intro,
    .checklist-hero .eyebrow {
      color: #000000;
    }

    .checklist-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0;
      border-radius: 0;
    }

    .checklist-toolbox {
      display: none !important;
    }
  }
</style>
