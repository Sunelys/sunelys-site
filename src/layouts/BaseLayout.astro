---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Sunelys",
  description = "Sunelys accompagne vos démarches administratives photovoltaïques.",
  structuredData = [],
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const siteUrl = (Astro.site ?? "https://sunelys.fr").toString().replace(/\/$/, "");
const canonical = new URL(path, `${siteUrl}/`).toString();
const ogImage = new URL("/brand/logo-full.svg", `${siteUrl}/`).toString();

const SHAPE_MODE: "subtle" | "visible" = "subtle";

const shapeTokens =
  SHAPE_MODE === "subtle"
    ? "--shape-opacity:0.11; --shape-blur:7px; --shape-scale:1.04; --shape-x:112%;"
    : "--shape-opacity:0.22; --shape-blur:2px; --shape-scale:1.16; --shape-x:106%;";

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/parcours", label: "Parcours" },
  { href: "/services", label: "Services" },
  { href: "/tarifs", label: "Tarifs" },
  { href: "/contact", label: "Contact" },
];

const footerLinks = [
  { href: "/gestion-administrative-photovoltaique", label: "Gestion administrative photovoltaïque" },
  { href: "/dossier-consuel-photovoltaique", label: "Dossier Consuel photovoltaïque" },
  { href: "/raccordement-enedis-photovoltaique", label: "Raccordement Enedis photovoltaïque" },
];

const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Sunelys",
    url: siteUrl,
    logo: ogImage,
    email: "contact@sunelys.fr",
    telephone: "+33 6 95 90 79 19",
    address: {
      "@type": "PostalAddress",
      streetAddress: "49, impasse des lauriers",
      postalCode: "83600",
      addressLocality: "Les Adrets de l'Esterel",
      addressCountry: "FR",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sunelys",
    url: siteUrl,
  },
];

const allSchemas = [...baseSchemas, ...structuredData];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#cbae8d" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sunelys" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body style={shapeTokens} data-shape-mode={SHAPE_MODE}>
    <a class="skip-link" href="#contenu">Aller au contenu</a>

    <Header path={path} navLinks={navLinks} ctaHref="/contact" ctaLabel="Planifier un échange" />

    <main id="contenu" class="container page-content">
      <slot />
    </main>

    <Footer links={footerLinks} />

    <script>
      window.dataLayer = window.dataLayer || [];
      window.trackEvent = (eventName, params = {}) => {
        window.dataLayer.push({
          event: eventName,
          page_path: window.location.pathname,
          page_title: document.title,
          timestamp: Date.now(),
          ...params,
        });
      };

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const element = event.target.closest("[data-track]");
        if (!element || !window.trackEvent) return;
        window.trackEvent(element.dataset.track, {
          label: element.dataset.trackLabel || (element.textContent || "").trim(),
          href: element.getAttribute("href") || "",
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #eceae4;
    --color-bg-elevated: #f0ede7;
    --color-surface: #f6f3ee;
    --color-text: #1d1c1a;
    --color-text-strong: #111111;
    --color-muted: #5a5751;
    --color-accent: #cbae8d;
    --color-cream: #e8ddbc;
    --color-hairline: #d5cebf;

    --radius-sm: 10px;
    --radius-md: 14px;
    --radius-lg: 20px;
    --radius-xl: 30px;
    --radius-pill: 999px;

    --shadow-ultra: 0 1px 2px rgba(18, 17, 15, 0.06);
    --shadow-soft: 0 12px 34px rgba(18, 17, 15, 0.055);
    --shadow-hover: 0 18px 42px rgba(18, 17, 15, 0.09);

    --blur-header: 12px;

    --font-display: "Didot", "Bodoni MT", "Times New Roman", serif;
    --font-sans: "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;

    --step--1: clamp(0.78rem, 0.16vw + 0.74rem, 0.9rem);
    --step-0: clamp(0.98rem, 0.26vw + 0.92rem, 1.1rem);
    --step-1: clamp(1.2rem, 0.48vw + 1.08rem, 1.46rem);
    --step-2: clamp(1.48rem, 0.82vw + 1.28rem, 1.95rem);
    --step-3: clamp(1.8rem, 1.16vw + 1.52rem, 2.6rem);
    --step-4: clamp(2.2rem, 2vw + 1.7rem, 3.6rem);
    --step-5: clamp(2.4rem, 3vw + 1.8rem, 4.7rem);

    /* Backward-compatible aliases for existing pages */
    --bg: var(--color-bg);
    --surface: var(--color-surface);
    --text: var(--color-text);
    --muted: var(--color-muted);
    --primary: var(--color-text-strong);
    --primary-dark: #000000;
    --accent: var(--color-cream);
    --accent-dark: var(--color-accent);
    --border: var(--color-hairline);
    --shadow: var(--shadow-soft);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    font-family: var(--font-sans);
    color: var(--color-text);
    line-height: 1.5;
    background:
      radial-gradient(140% 95% at -10% -30%, color-mix(in srgb, var(--color-cream) 50%, transparent), transparent 62%),
      radial-gradient(95% 80% at 120% 100%, color-mix(in srgb, var(--color-cream) 40%, transparent), transparent 58%),
      var(--color-bg);
    position: relative;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: url("/brand/shape-clean.svg") no-repeat var(--shape-x) 8vh / clamp(420px, 54vw, 900px);
    opacity: var(--shape-opacity);
    transform: scale(var(--shape-scale));
    filter: blur(var(--shape-blur));
    pointer-events: none;
    z-index: -1;
  }

  .container {
    width: min(1120px, 92%);
    margin-inline: auto;
  }

  .page-content {
    padding-top: clamp(0.8rem, 1.2vw, 1.35rem);
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--color-text-strong);
    letter-spacing: -0.012em;
  }

  p {
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    text-decoration: none;
    font-size: var(--step--1);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-weight: 600;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    padding: 0.67rem 1.05rem;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      border-color 170ms ease, color 170ms ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-ultra);
  }

  .btn-primary {
    background: var(--color-text-strong);
    color: #ffffff;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: #060606;
  }

  .btn-secondary {
    border-color: var(--color-hairline);
    background: color-mix(in srgb, var(--color-surface) 88%, white);
    color: var(--color-text-strong);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    border-color: color-mix(in srgb, var(--color-hairline) 72%, var(--color-accent));
    background: color-mix(in srgb, var(--color-cream) 68%, white);
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--color-surface);
    color: var(--color-text-strong);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    text-decoration: none;
  }

  .skip-link:focus-visible {
    left: 1rem;
    top: 1rem;
    z-index: 100;
  }

  :focus-visible {
    outline: 2px solid var(--color-text-strong);
    outline-offset: 2px;
  }

  .reveal {
    animation: reveal-up 420ms ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .reveal,
    * {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
