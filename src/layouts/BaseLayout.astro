---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ExitIntentModal from "../components/ExitIntentModal.astro";
import CookieConsent from "../components/CookieConsent.astro";

interface BreadcrumbItem {
  name: string;
  item?: string;
}

const {
  title = "Sunelys",
  description = "Sunelys accompagne vos démarches administratives photovoltaïques.",
  structuredData = [],
  robots = "index,follow",
  image,
  ogType = "website",
  breadcrumbs,
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const siteUrl = (Astro.site ?? "https://sunelys.fr").toString().replace(/\/$/, "");
const canonical = new URL(path, `${siteUrl}/`).toString();
const defaultOgImage = new URL("/images/og/sunelys-og.jpg", `${siteUrl}/`).toString();
const schemaLogo = new URL("/brand/logo-full.png", `${siteUrl}/`).toString();
const ogImage = image ? new URL(image, `${siteUrl}/`).toString() : defaultOgImage;

const normalizeGoogleAdsConversionId = (value: string) => {
  const trimmed = value.trim();
  return trimmed && !trimmed.startsWith("AW-") ? `AW-${trimmed}` : trimmed;
};

const ga4Id = import.meta.env.PUBLIC_GA4_ID || "";
const googleAdsConversionId = normalizeGoogleAdsConversionId(
  import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_ID || "",
);
const googleAdsLeadConversionLabel = import.meta.env.PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_LABEL || "";
const googleAdsLeadConversionSendTo =
  googleAdsConversionId && googleAdsLeadConversionLabel
    ? `${googleAdsConversionId}/${googleAdsLeadConversionLabel}`
    : "";
const gtagScriptId = ga4Id || googleAdsConversionId;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION || "";
const matomoUrl = (import.meta.env.PUBLIC_MATOMO_URL || "").replace(/\/$/, "");
const matomoSiteId = import.meta.env.PUBLIC_MATOMO_SITE_ID || "";
const hasMatomo = Boolean(matomoUrl && matomoSiteId);
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || "https://calendly.com/contact-sunelys/30min";
const leadFormAction = import.meta.env.PUBLIC_LEAD_FORM_ACTION || "/api/leads";
const isNoindex = robots.includes("noindex");
const isContactPage = path === "/contact";
const isCompliancePage = path === "/mentions-legales" || path === "/politique-confidentialite";
const showLeadCaptureShell = path !== "/merci" && !isNoindex && !isContactPage && !isCompliancePage;
const showExitIntent = showLeadCaptureShell && path !== "/";

const routeLabels: Record<string, string> = {
  "/services": "Services",
  "/parcours": "Parcours",
  "/tarifs": "Tarifs",
  "/contact": "Contact",
  "/blog": "Blog",
  "/sunelys": "Sunelys",
  "/a-propos": "À propos",
  "/mentions-legales": "Mentions légales",
  "/politique-confidentialite": "Politique de confidentialité",
  "/gestion-administrative-photovoltaique": "Gestion administrative photovoltaïque",
  "/declaration-prealable-panneaux-solaires": "Déclaration préalable panneaux solaires",
  "/dossier-consuel-photovoltaique": "Dossier Consuel photovoltaïque",
  "/raccordement-enedis-photovoltaique": "Raccordement Enedis photovoltaïque",
  "/edf-oa": "EDF OA - compte et contrat d'achat",
  "/sous-traitance-declaration-prealable-solaire": "Sous-traitance déclaration préalable solaire",
  "/sous-traitance-administrative-photovoltaique-installateur": "Sous-traitance administrative photovoltaïque",
  "/tarif-declaration-prealable-photovoltaique": "Tarif déclaration préalable photovoltaïque",
};

const formatSegmentLabel = (segment: string) =>
  decodeURIComponent(segment)
    .replace(/-/g, " ")
    .replace(/\b\p{L}/gu, (letter) => letter.toLocaleUpperCase("fr-FR"));

const pathSegments = path.split("/").filter(Boolean);
const automaticBreadcrumbs: BreadcrumbItem[] =
  path === "/" || isNoindex
    ? []
    : [
        { name: "Accueil", item: `${siteUrl}/` },
        ...pathSegments.map((segment, index) => {
          const routePath = `/${pathSegments.slice(0, index + 1).join("/")}`;
          return {
            name: routeLabels[routePath] ?? formatSegmentLabel(segment),
            item: new URL(routePath, `${siteUrl}/`).toString(),
          };
        }),
      ];

const breadcrumbItems: BreadcrumbItem[] = breadcrumbs ?? automaticBreadcrumbs;
const breadcrumbSchema =
  breadcrumbItems.length > 1
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbItems.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          ...(item.item ? { item: item.item } : {}),
        })),
      }
    : null;

const BRANDING_INTENSITY: "subtle" | "bold" = "subtle";
const brandingVars =
  BRANDING_INTENSITY === "subtle"
    ? "--shape-opacity:0.08; --shape-blur:16px; --shape-scale:1.02; --shape-x:110%; --shape-y:10vh; --shape-secondary-opacity:0.05;"
    : "--shape-opacity:0.22; --shape-blur:6px; --shape-scale:1.12; --shape-x:102%; --shape-y:4vh; --shape-secondary-opacity:0.13;";

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/services", label: "Services" },
  { href: "/tarifs", label: "Tarifs" },
  { href: "/parcours", label: "Parcours" },
  { href: "/a-propos", label: "À propos" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const footerLinks = [
  { href: "/a-propos", label: "À propos de Sunelys" },
  { href: "/blog", label: "Blog administratif solaire" },
  { href: "/gestion-administrative-photovoltaique", label: "Gestion administrative photovoltaïque" },
  { href: "/sous-traitance-administrative-photovoltaique-installateur", label: "Sous-traitance administrative PV" },
  { href: "/declaration-prealable-panneaux-solaires", label: "Déclaration préalable panneaux solaires" },
  { href: "/dossier-consuel-photovoltaique", label: "Dossier Consuel photovoltaïque" },
  { href: "/raccordement-enedis-photovoltaique", label: "Raccordement Enedis photovoltaïque" },
  { href: "/edf-oa", label: "EDF OA - compte et contrat d'achat" },
];

const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Sunelys",
    alternateName: ["SUNELYS", "Sunelys SASU"],
    legalName: "SUNELYS",
    url: siteUrl,
    logo: schemaLogo,
    email: "contact@sunelys.fr",
    telephone: "+33695907919",
    foundingDate: "2025-04-15",
    taxID: "FR46943493759",
    identifier: {
      "@type": "PropertyValue",
      propertyID: "SIREN",
      value: "943493759",
    },
    sameAs: [
      "https://www.linkedin.com/company/sunelys/",
      "https://www.linkedin.com/in/myriam-zaoui-2baa501b9/",
      "https://www.pappers.fr/entreprise/sunelys-943493759",
    ],
    address: {
      "@type": "PostalAddress",
      streetAddress: "49, impasse des lauriers",
      postalCode: "83600",
      addressLocality: "Les Adrets de l'Esterel",
      addressCountry: "FR",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sunelys",
    alternateName: "SUNELYS",
    url: siteUrl,
    inLanguage: "fr-FR",
  },
];

const allSchemas = [...baseSchemas, ...(breadcrumbSchema ? [breadcrumbSchema] : []), ...structuredData];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0e1726" />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Sunelys" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <script
      define:vars={{ gtagScriptId, ga4Id, googleAdsConversionId, hasMatomo, matomoUrl, matomoSiteId }}
    >
      const consentStorageKey = "sunelys_consent_v1";
      const consentLifetime = 180 * 24 * 60 * 60 * 1000;
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function gtag(){ window.dataLayer.push(arguments); };
      window.sunelysAnalyticsEnabled = false;

      const deniedConsent = {
        analytics_storage: "denied",
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
      };
      const grantedConsent = {
        analytics_storage: "granted",
        ad_storage: "granted",
        ad_user_data: "granted",
        ad_personalization: "granted",
      };

      window.gtag("consent", "default", {
        ...deniedConsent,
        wait_for_update: 500,
      });

      const readAnalyticsConsent = () => {
        try {
          const savedConsent = JSON.parse(localStorage.getItem(consentStorageKey) || "null");
          if (!savedConsent || typeof savedConsent.analytics !== "boolean" || !savedConsent.updatedAt) return null;

          const updatedAt = new Date(savedConsent.updatedAt).getTime();
          if (!Number.isFinite(updatedAt) || Date.now() - updatedAt > consentLifetime) {
            localStorage.removeItem(consentStorageKey);
            return null;
          }

          return savedConsent;
        } catch (_error) {
          return null;
        }
      };

      const removeAnalyticsCookies = () => {
        const cookieNames = document.cookie
          .split(";")
          .map((cookie) => cookie.split("=")[0]?.trim())
          .filter((name) => name && (name.startsWith("_ga") || name.startsWith("_gcl") || name === "_gid" || name === "_gat"));
        const hostname = window.location.hostname;
        const domains = ["", hostname, `.${hostname}`, ".sunelys.fr"];

        cookieNames.forEach((name) => {
          domains.forEach((domain) => {
            document.cookie = `${name}=; Max-Age=0; path=/; SameSite=Lax${domain ? `; domain=${domain}` : ""}`;
          });
        });
      };

      const initializeGoogleMeasurement = () => {
        if (!gtagScriptId) return;

        window.gtag("consent", "update", grantedConsent);
        if (!window.sunelysGoogleConfigured) {
          window.gtag("js", new Date());
          if (ga4Id) window.gtag("config", ga4Id, { anonymize_ip: true });
          if (googleAdsConversionId) window.gtag("config", googleAdsConversionId);
          window.sunelysGoogleConfigured = true;
        }

        if (!document.querySelector("#sunelys-google-tag")) {
          const googleScript = document.createElement("script");
          googleScript.id = "sunelys-google-tag";
          googleScript.async = true;
          googleScript.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gtagScriptId)}`;
          document.head.appendChild(googleScript);
        }
      };

      const initializeMatomoMeasurement = () => {
        if (!hasMatomo || document.querySelector("#sunelys-matomo-tag")) return;

        window._paq = window._paq || [];
        window._paq.push(["forgetUserOptOut"]);
        window._paq.push(["trackPageView"]);
        window._paq.push(["enableLinkTracking"]);
        window._paq.push(["setTrackerUrl", matomoUrl + "/matomo.php"]);
        window._paq.push(["setSiteId", matomoSiteId]);

        const matomoScript = document.createElement("script");
        matomoScript.id = "sunelys-matomo-tag";
        matomoScript.async = true;
        matomoScript.src = matomoUrl + "/matomo.js";
        document.head.appendChild(matomoScript);
      };

      const disableAnalyticsMeasurement = () => {
        window.sunelysAnalyticsEnabled = false;
        window.gtag("consent", "update", deniedConsent);
        if (Array.isArray(window._paq)) window._paq.push(["optUserOut"]);
        removeAnalyticsCookies();
        try {
          localStorage.removeItem("sunelys_attribution");
        } catch (_error) {
          // Le retrait reste effectif même si le stockage local est indisponible.
        }
      };

      window.getSunelysAnalyticsConsent = readAnalyticsConsent;
      window.setSunelysAnalyticsConsent = (enabled) => {
        const consent = {
          analytics: Boolean(enabled),
          updatedAt: new Date().toISOString(),
        };

        try {
          localStorage.setItem(consentStorageKey, JSON.stringify(consent));
        } catch (_error) {
          // Le choix reste appliqué pour la page courante.
        }

        window.sunelysAnalyticsEnabled = consent.analytics;
        if (consent.analytics) {
          initializeGoogleMeasurement();
          initializeMatomoMeasurement();
        } else {
          disableAnalyticsMeasurement();
        }

        window.dispatchEvent(new CustomEvent("sunelys:consent-change", { detail: consent }));
        return consent;
      };

      const initialConsent = readAnalyticsConsent();
      if (initialConsent?.analytics === true) {
        window.sunelysAnalyticsEnabled = true;
        initializeGoogleMeasurement();
        initializeMatomoMeasurement();
      } else {
        disableAnalyticsMeasurement();
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body
    class:list={[showLeadCaptureShell && "has-sticky-lead"]}
    style={brandingVars}
    data-branding-intensity={BRANDING_INTENSITY}
  >
    <a class="skip-link" href="#contenu">Aller au contenu</a>

    <Header path={path} navLinks={navLinks} ctaHref="/contact?source=header-diagnostic#contact-form" ctaLabel="Diagnostic sous 24h" />

    <main id="contenu" class="layout-main">
      <div class="container page-flow">
        <slot />
      </div>
    </main>

    <Footer links={footerLinks} />
    <CookieConsent />

    {showExitIntent && <ExitIntentModal action={leadFormAction} path={path} />}

    {
      showLeadCaptureShell && (
        <div class="sticky-lead-bar" aria-label="Actions rapides de contact">
          <p class="sticky-lead-context">
            <span>Diagnostic sous 24h</span>
            <strong>1 dossier suffit pour commencer</strong>
          </p>
          <div class="sticky-lead-actions">
            <a class="sticky-lead-secondary" href="tel:+33695907919" data-track="cta_sticky_phone">
              Appeler
            </a>
            <a class="sticky-lead-primary" href="/contact?source=sticky#contact-form" data-track="cta_sticky_form">
              Diagnostic 24h
            </a>
          </div>
        </div>
      )
    }

    <script define:vars={{ ga4Id, googleAdsLeadConversionSendTo, hasMatomo }}>
      window.dataLayer = window.dataLayer || [];

      const attributionKeys = [
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_term",
        "utm_content",
        "gclid",
        "fbclid",
        "msclkid",
      ];

      const readStoredAttribution = () => {
        if (!window.sunelysAnalyticsEnabled) return {};
        try {
          return JSON.parse(localStorage.getItem("sunelys_attribution") || "{}");
        } catch (_error) {
          return {};
        }
      };

      const normalizeText = (value) => String(value || "").trim().toLowerCase();

      const mapConversionType = (value) => {
        const normalized = normalizeText(value);
        if (!normalized) return "form_contact";

        if (normalized.includes("checklist") || normalized.includes("lead_magnet") || normalized.includes("lead-magnet")) {
          return "checklist_download";
        }

        if (normalized.includes("quiz")) {
          return "quiz_submit";
        }

        if (normalized.includes("calendly") || normalized.includes("booking") || normalized.includes("rdv")) {
          return "booking";
        }

        if (normalized.includes("phone") || normalized.includes("telephone") || normalized.includes("call")) {
          return "phone_click";
        }

        if (normalized.includes("email") || normalized.includes("mail")) {
          return "email_click";
        }

        if (normalized.includes("lead") && normalized.includes("form")) {
          return "form_contact";
        }

        if (normalized.includes("form") || normalized.includes("contact") || normalized.includes("diagnostic")) {
          return "form_contact";
        }

        if (normalized.startsWith("unknown") || normalized === "lead_form") {
          return "form_contact";
        }

        return normalized;
      };

      const params = new URLSearchParams(window.location.search);
      const storedAttribution = readStoredAttribution();
      const incomingAttribution = attributionKeys.reduce((acc, key) => {
        const value = params.get(key);
        if (value) acc[key] = value;
        return acc;
      }, {});

      const attribution = {
        landing_page: storedAttribution.landing_page || window.location.pathname,
        first_referrer: storedAttribution.first_referrer || document.referrer || "direct",
        first_seen_at: storedAttribution.first_seen_at || new Date().toISOString(),
        last_page: window.location.pathname,
        last_referrer: document.referrer || storedAttribution.last_referrer || "direct",
        ...storedAttribution,
        ...incomingAttribution,
      };

      if (window.sunelysAnalyticsEnabled) {
        localStorage.setItem("sunelys_attribution", JSON.stringify(attribution));
      }

      window.getSunelysAttribution = () =>
        window.sunelysAnalyticsEnabled ? readStoredAttribution() : attribution;

      window.addEventListener("sunelys:consent-change", (event) => {
        if (!event.detail?.analytics) return;
        try {
          localStorage.setItem("sunelys_attribution", JSON.stringify(attribution));
        } catch (_error) {
          // La mesure reste active même si le stockage local est indisponible.
        }
      });

      const syncSunelysAttributionFields = (root = document) => {
        const currentAttribution = window.getSunelysAttribution();
        const fieldRoot = root instanceof Element || root instanceof Document ? root : document;
        const attributionFieldNames = ["landing_page", "first_referrer", ...attributionKeys];

        attributionFieldNames.forEach((fieldName) => {
          fieldRoot.querySelectorAll(`input[type="hidden"][name="${fieldName}"]`).forEach((field) => {
            if (!(field instanceof HTMLInputElement)) return;
            field.value = currentAttribution[fieldName] || field.value || "";
          });
        });
      };

      window.syncSunelysAttributionFields = syncSunelysAttributionFields;
      syncSunelysAttributionFields();

      const servicePaths = [
        "/gestion-administrative-photovoltaique",
        "/declaration-prealable-panneaux-solaires",
        "/dossier-consuel-photovoltaique",
        "/raccordement-enedis-photovoltaique",
        "/edf-oa",
        "/sous-traitance-declaration-prealable-solaire",
        "/tarif-declaration-prealable-photovoltaique",
        "/tarifs",
        "/contact",
      ];

      const buildAnalyticsPayload = (eventName, params, currentAttribution) => ({
        event_category: params.category || "engagement",
        event_label: params.label || params.href || eventName,
        link_url: params.href || "",
        page_path: window.location.pathname,
        page_title: document.title,
        source: params.source || "",
        volume: params.volume || "",
        need: params.need || "",
        blocked_stage: params.blocked_stage || "",
        conversion_type: params.conversion_type || "",
        lead_stage: params.lead_stage || "",
        service_interest: params.service_interest || "",
        form_id: params.form_id || "",
        form_location: params.form_location || "",
        lead_source_detail: params.lead_source_detail || "",
        field_name: params.field_name || "",
        error_type: params.error_type || "",
        cta_group: params.cta_group || "",
        transport_type: params.transport_type || "",
        utm_source: currentAttribution.utm_source || "",
        utm_medium: currentAttribution.utm_medium || "",
        utm_campaign: currentAttribution.utm_campaign || "",
        first_referrer: currentAttribution.first_referrer || "",
        landing_page: currentAttribution.landing_page || "",
      });

      window.trackEvent = (eventName, params = {}) => {
        if (!window.sunelysAnalyticsEnabled) return;
        const currentAttribution = readStoredAttribution();
        const analyticsPayload = buildAnalyticsPayload(eventName, params, currentAttribution);

        window.dataLayer.push({
          event: eventName,
          page_path: window.location.pathname,
          page_title: document.title,
          attribution: currentAttribution,
          timestamp: Date.now(),
          ...params,
        });

        if (ga4Id && typeof window.gtag === "function") {
          window.gtag("event", eventName, analyticsPayload);
        }

        if (
          eventName === "generate_lead" &&
          googleAdsLeadConversionSendTo &&
          typeof window.gtag === "function"
        ) {
          window.gtag("event", "conversion", {
            send_to: googleAdsLeadConversionSendTo,
            value: Number(params.value || 1),
            currency: params.currency || "EUR",
          });
        }

        if (hasMatomo && Array.isArray(window._paq)) {
          window._paq.push([
            "trackEvent",
            analyticsPayload.event_category,
            eventName,
            analyticsPayload.event_label,
          ]);
        }
      };

      const confirmedLeadKeys = new Set();
      window.trackLeadSuccess = (params = {}) => {
        if (!window.sunelysAnalyticsEnabled) return;

        const successPayload = {
          ...params,
          category: "lead",
          lead_stage: "lead_confirmed",
        };
        const confirmationKey = [
          successPayload.form_id || "",
          successPayload.source || "",
          successPayload.conversion_type || "form_contact",
        ].join("|");

        if (confirmedLeadKeys.has(confirmationKey)) return;
        confirmedLeadKeys.add(confirmationKey);

        window.trackEvent?.("lead_form_success", successPayload);
        window.trackEvent?.("generate_lead", successPayload);
        window.trackEvent?.("lead_converted", successPayload);

        try {
          sessionStorage.setItem("sunelys_form_submitted", "true");
          sessionStorage.removeItem("sunelys_pending_lead");
        } catch (_error) {
          // La confirmation reste mesurée si le stockage de session est indisponible.
        }
      };

      window.trackLeadError = (params = {}) => {
        window.trackEvent?.("form_error", {
          ...params,
          category: "form",
          lead_stage: "submission_error",
        });
      };

      const buildFormInteractionPayload = (form, fallbackStage) => {
        const formData = new FormData(form);
        const conversionType = String(
          formData.get("conversion_type") ||
            form.dataset.conversionType ||
            "lead_form",
        );
        const normalizedConversionType = mapConversionType(conversionType);
        const source = String(formData.get("source_page") || formData.get("source") || "");
        const formLocation = String(
          formData.get("lead_source_detail") ||
            form.dataset.formLocation ||
            form.id ||
            source ||
            "lead_form",
        );

        return {
          category: "form",
          label: formLocation,
          source,
          volume: String(formData.get("volume") || ""),
          need: String(formData.get("need") || ""),
          blocked_stage: String(formData.get("blocked_stage") || ""),
          conversion_type: normalizedConversionType || conversionType,
          lead_stage: String(formData.get("lead_stage") || fallbackStage),
          service_interest: String(formData.get("service_interest") || ""),
          form_id: form.id || formLocation,
          form_location: formLocation,
          lead_source_detail: String(formData.get("lead_source_detail") || formLocation),
        };
      };

      const startedLeadForms = new Set();
      const submittedLeadForms = new Set();
      document.addEventListener("focusin", (event) => {
        if (!(event.target instanceof Element)) return;
        const form = event.target.closest("form[data-lead-form]");
        if (!(form instanceof HTMLFormElement) || startedLeadForms.has(form)) return;
        if (!window.sunelysAnalyticsEnabled) return;

        startedLeadForms.add(form);
        syncSunelysAttributionFields(form);
        window.trackEvent?.("form_start", buildFormInteractionPayload(form, "form_started"));
      });

      const lastValidationErrorAt = new WeakMap();
      document.addEventListener(
        "invalid",
        (event) => {
          const field = event.target;
          if (
            !(
              field instanceof HTMLInputElement ||
              field instanceof HTMLSelectElement ||
              field instanceof HTMLTextAreaElement
            )
          ) {
            return;
          }

          const form = field.closest("form[data-lead-form]");
          if (!(form instanceof HTMLFormElement)) return;

          const now = Date.now();
          const lastTrackedAt = lastValidationErrorAt.get(form) || 0;
          if (now - lastTrackedAt < 800) return;
          lastValidationErrorAt.set(form, now);

          const errorType = field.validity.valueMissing
            ? "required"
            : field.validity.typeMismatch
              ? "format"
              : field.validity.patternMismatch
                ? "pattern"
                : "invalid";

          window.trackEvent?.("form_validation_error", {
            ...buildFormInteractionPayload(form, "validation_error"),
            field_name: field.name || field.type || "unknown",
            error_type: errorType,
            lead_stage: "validation_error",
          });
        },
        true,
      );

      window.addEventListener("pagehide", () => {
        startedLeadForms.forEach((form) => {
          if (submittedLeadForms.has(form)) return;
          window.trackEvent?.("form_abandon", {
            ...buildFormInteractionPayload(form, "form_abandoned"),
            lead_stage: "form_abandoned",
            transport_type: "beacon",
          });
        });
      });

      const trackedViewElements = document.querySelectorAll("[data-track-view]");
      const trackedViews = new WeakSet();
      if (trackedViewElements.length > 0 && "IntersectionObserver" in window) {
        const viewObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting || entry.intersectionRatio < 0.34) return;
              if (!(entry.target instanceof HTMLElement) || trackedViews.has(entry.target)) return;

              trackedViews.add(entry.target);
              window.trackEvent?.(entry.target.dataset.trackView || "section_view", {
                category: "engagement",
                label: entry.target.dataset.trackLabel || entry.target.id || "tracked_section",
                cta_group: entry.target.dataset.trackView || "",
              });
              observer.unobserve(entry.target);
            });
          },
          { threshold: [0.34, 0.5, 0.75] }
        );

        trackedViewElements.forEach((element) => viewObserver.observe(element));
      }

      let scroll50Tracked = false;
      const trackScrollDepth = () => {
        if (scroll50Tracked) return;
        const documentHeight = Math.max(
          document.documentElement.scrollHeight,
          document.body.scrollHeight,
          window.innerHeight,
        );
        const scrollRatio = (window.scrollY + window.innerHeight) / documentHeight;
        if (scrollRatio < 0.5) return;

        scroll50Tracked = true;
        window.trackEvent?.("scroll_50", {
          category: "engagement",
          label: window.location.pathname,
        });
      };

      window.addEventListener("scroll", trackScrollDepth, { passive: true });
      window.addEventListener("resize", trackScrollDepth);
      trackScrollDepth();

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const element = event.target.closest("[data-track]");
        if (!element || !window.trackEvent) return;
        const href = element.getAttribute("href") || "";
        const category = href.startsWith("tel:")
          ? "phone"
          : href.startsWith("mailto:")
            ? "email"
            : element.closest("form")
              ? "form"
              : "cta";
        const label = element.dataset.trackLabel || (element.textContent || "").trim();
        const clickPayload = {
          category,
          label,
          href,
          cta_group: element.dataset.track || "",
        };

        window.trackEvent(element.dataset.track, clickPayload);

        const hrefPath = (() => {
          try {
            return new URL(href, window.location.origin).pathname.replace(/\/$/, "") || "/";
          } catch (_error) {
            return href.replace(/\/$/, "") || "/";
          }
        })();

        if (window.location.pathname.startsWith("/blog/") && servicePaths.includes(hrefPath)) {
          window.trackEvent("blog_to_service_click", {
            ...clickPayload,
            category: "internal_link",
            service_interest: hrefPath,
            source: "blog",
          });
        }

        if (category === "phone") {
          window.trackEvent("phone_click", {
            ...clickPayload,
            category: "lead",
            conversion_type: "phone_click",
            lead_stage: "phone_click",
          });
        }

        if (category === "email") {
          window.trackEvent("email_click", {
            ...clickPayload,
            category: "lead",
            conversion_type: "email_click",
            lead_stage: "email_click",
          });
        }

        if (href.toLowerCase().includes("calendly.com")) {
          window.trackEvent("booking_click", {
            ...clickPayload,
            category: "lead",
            conversion_type: "booking",
            lead_stage: "booking_click",
            source: "calendly",
          });
        }
      });

      const exploredRails = new WeakSet();
      document.querySelectorAll("[data-scroll-rail]").forEach((rail) => {
        rail.addEventListener(
          "scroll",
          () => {
            if (!(rail instanceof HTMLElement) || exploredRails.has(rail) || rail.scrollLeft < 24) return;
            exploredRails.add(rail);
            window.trackEvent?.("mobile_rail_explore", {
              category: "engagement",
              label: rail.dataset.scrollLabel || "horizontal_content",
            });
          },
          { passive: true },
        );
      });

      document.addEventListener("submit", (event) => {
        if (!(event.target instanceof HTMLFormElement)) return;
        const submittedForm = event.target;
        syncSunelysAttributionFields(submittedForm);
        const submittedFormData = new FormData(submittedForm);

        const conversionType = String(
          submittedFormData.get("conversion_type") ||
            submittedForm.dataset.conversionType ||
            "lead_form",
        );
        const normalizedConversionType = mapConversionType(conversionType);
        const sourcePageValue = String(submittedFormData.get("source_page") || submittedFormData.get("source") || "");
        const normalizedFallbackConversionType = mapConversionType([conversionType, sourcePageValue].filter(Boolean).join(" "));
        const finalConversionType = normalizedConversionType || normalizedFallbackConversionType;
        const leadStage = String(submittedFormData.get("lead_stage") || "form_submitted");
        const formPayload = {
          ...buildFormInteractionPayload(submittedForm, leadStage),
          conversion_type: finalConversionType,
          lead_stage: leadStage,
        };

        if (finalConversionType !== conversionType) {
          const conversionInput = submittedForm.querySelector("input[name='conversion_type']");
          if (conversionInput instanceof HTMLInputElement) {
            conversionInput.value = finalConversionType;
          }
        }

        const isLeadForm = submittedForm.hasAttribute("data-lead-form") || submittedFormData.has("email");
        if (isLeadForm) {
          submittedLeadForms.add(submittedForm);
          window.trackEvent?.("form_submit", formPayload);
          window.trackEvent?.("lead_form_submit", {
            ...formPayload,
            category: "lead",
            conversion_type: finalConversionType,
            lead_stage: leadStage,
          });

          if (
            !submittedForm.hasAttribute("data-async-lead-form") &&
            window.sunelysAnalyticsEnabled
          ) {
            try {
              sessionStorage.setItem(
                "sunelys_pending_lead",
                JSON.stringify({
                  ...formPayload,
                  category: "lead",
                  source: sourcePageValue || formPayload.source || "lead_form",
                }),
              );
            } catch (_error) {
              // La redirection reste fonctionnelle si le stockage de session est indisponible.
            }
          }
        }
      });

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealNodes = document.querySelectorAll(".reveal");

      const showNode = (node) => {
        if (!(node instanceof HTMLElement)) return;
        node.classList.add("is-visible");
      };

      document.documentElement.classList.add("reveal-ready");

      if (reducedMotion || !("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => showNode(node));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              showNode(entry.target);
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
        );

        revealNodes.forEach((node) => revealObserver.observe(node));
      }

      const stickyBar = document.querySelector(".sticky-lead-bar");
      const stickyGuardElements = document.querySelectorAll(
        ".page-flow > :first-child, [data-sticky-guard='hero'], [data-lead-form], body > footer",
      );
      const mobileQuery = window.matchMedia("(max-width: 767px)");
      const visibleStickyGuards = new Set();
      let hasEditableFocus = false;

      const syncStickyBar = () => {
        if (!(stickyBar instanceof HTMLElement)) return;

        const isMobile = mobileQuery.matches;
        const hasScrolled = window.scrollY > 80;
        const hasVisibleGuard = visibleStickyGuards.size > 0;
        const interfaceOverlayOpen =
          document.documentElement.classList.contains("menu-open") ||
          document.body.classList.contains("cookie-consent-open");
        const shouldShow =
          isMobile &&
          hasScrolled &&
          !hasVisibleGuard &&
          !hasEditableFocus &&
          !interfaceOverlayOpen;

        document.body.classList.toggle("sticky-bar-hero-hidden", isMobile && hasVisibleGuard);
        document.body.classList.toggle("sticky-bar-visible", shouldShow);
      };

      if (stickyGuardElements.length > 0 && "IntersectionObserver" in window) {
        const stickyGuardObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio > 0.12) {
                visibleStickyGuards.add(entry.target);
              } else {
                visibleStickyGuards.delete(entry.target);
              }
              syncStickyBar();
            });
          },
          { threshold: [0, 0.12, 0.25, 0.5, 0.75] }
        );

        stickyGuardElements.forEach((element) => stickyGuardObserver.observe(element));
      }

      window.addEventListener("scroll", syncStickyBar, { passive: true });
      window.addEventListener("resize", syncStickyBar);
      window.addEventListener("sunelys:cookie-banner-change", syncStickyBar);
      mobileQuery.addEventListener?.("change", syncStickyBar);

      document.addEventListener("focusin", (event) => {
        if (!(event.target instanceof Element)) return;
        hasEditableFocus = Boolean(
          event.target.closest("input, select, textarea, [contenteditable='true']"),
        );
        syncStickyBar();
      });

      document.addEventListener("focusout", () => {
        window.setTimeout(() => {
          const activeElement = document.activeElement;
          hasEditableFocus =
            activeElement instanceof Element &&
            Boolean(activeElement.closest("input, select, textarea, [contenteditable='true']"));
          syncStickyBar();
        }, 80);
      });

      const menuObserver = new MutationObserver(syncStickyBar);
      menuObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });

      syncStickyBar();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f6f2;
    --bg-soft: #fbfbf8;
    --surface: #ffffff;
    --surface-elevated: #ffffff;
    --text: #0e1726;
    --text-muted: #536071;
    --line: #dde3ea;
    --accent: #d4822a;
    --accent-strong: #b96513;
    --accent-deep: #8f490d;
    --accent-soft: #f6e4cf;
    --ink: #0e1726;
    --ink-soft: #152238;
    --system: #3662e3;
    --system-soft: #eef2ff;
    --success: #1d9b75;
    --success-soft: #e9f7f1;

    --shadow-sm: 0 10px 30px rgba(14, 23, 38, 0.055);
    --shadow-md: 0 24px 68px rgba(14, 23, 38, 0.11);
    --shadow-accent: 0 16px 36px rgba(185, 101, 19, 0.24);

    --radius-sm: 10px;
    --radius-md: 16px;
    --radius-xl: 22px;

    --max-width: 1320px;
    --section-gap: clamp(3.2rem, 7vw, 7rem);
    --container-padding: clamp(1rem, 3.2vw, 2.4rem);

    --font-sans: "Avenir Next", "Segoe UI Variable", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    --font-display: var(--font-sans);

    --step--1: clamp(0.78rem, 0.14vw + 0.74rem, 0.9rem);
    --step-0: clamp(0.98rem, 0.24vw + 0.92rem, 1.12rem);
    --step-1: clamp(1.2rem, 0.5vw + 1.08rem, 1.5rem);
    --step-2: clamp(1.45rem, 0.86vw + 1.24rem, 2rem);
    --step-3: clamp(1.82rem, 1.38vw + 1.42rem, 2.8rem);
    --step-4: clamp(2.2rem, 2.3vw + 1.65rem, 3.95rem);

    /* aliases legacy */
    --color-bg: var(--bg);
    --color-bg-elevated: var(--bg-soft);
    --color-surface: var(--surface);
    --color-text: var(--text);
    --color-text-strong: var(--text);
    --color-muted: var(--text-muted);
    --color-accent: var(--accent);
    --color-cream: var(--accent-soft);
    --color-hairline: var(--line);
    --radius-lg: var(--radius-md);
    --radius-pill: 999px;
    --shadow-ultra: var(--shadow-sm);
    --shadow-soft: var(--shadow-sm);
    --shadow-hover: var(--shadow-md);
    --blur-header: 14px;

    --primary: var(--text);
    --primary-dark: #000000;
    --muted: var(--text-muted);
    --border: var(--line);
    --shadow: var(--shadow-md);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    overflow-x: clip;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    line-height: 1.5;
    background:
      radial-gradient(105% 82% at 100% 0%, color-mix(in srgb, var(--system-soft) 62%, transparent), transparent 54%),
      radial-gradient(95% 78% at 0% 100%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 58%),
      linear-gradient(180deg, var(--bg-soft), var(--bg)),
      var(--bg);
    position: relative;
  }

  body::before,
  body::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    min-height: 100vh;
    pointer-events: none;
    z-index: -1;
  }

  body::before {
    background: url("/brand/shape-clean.svg") no-repeat var(--shape-x) var(--shape-y) / clamp(420px, 58vw, 980px);
    opacity: var(--shape-opacity);
    transform: scale(var(--shape-scale));
    filter: blur(var(--shape-blur));
  }

  body::after {
    background: url("/brand/shape-clean.svg") no-repeat -14% 84vh / clamp(240px, 34vw, 620px);
    opacity: var(--shape-secondary-opacity);
    filter: blur(calc(var(--shape-blur) * 1.1));
  }

  .container {
    width: min(var(--max-width), calc(100% - 2 * var(--container-padding)));
    margin-inline: auto;
  }

  .layout-main {
    padding-top: clamp(1rem, 2.1vw, 1.9rem);
  }

  .page-flow {
    display: grid;
    gap: var(--section-gap);
    padding-bottom: var(--section-gap);
  }

  .page-flow > * {
    min-width: 0;
    max-width: 100%;
  }

  .section-shell {
    margin: 0;
    position: relative;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--text);
    letter-spacing: -0.035em;
    line-height: 1.06;
    text-wrap: balance;
  }

  p {
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.72rem;
    padding: 0.74rem 1.22rem;
    border-radius: 12px;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.84rem;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 700;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      color 170ms ease, border-color 170ms ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary {
    background: var(--ink);
    color: #ffffff;
    border-color: var(--ink);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: var(--ink-soft);
  }

  .btn.btn-accent {
    background: var(--accent);
    color: var(--ink);
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }

  .btn.btn-accent:hover,
  .btn.btn-accent:focus-visible {
    background: #e09647;
    color: var(--ink);
    border-color: #e09647;
  }

  .btn-secondary {
    background: color-mix(in srgb, var(--surface) 92%, white);
    border-color: var(--line);
    color: var(--text);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
    border-color: color-mix(in srgb, var(--line) 60%, var(--accent));
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: 0;
    z-index: 120;
    text-decoration: none;
    background: var(--surface-elevated);
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.48rem 0.72rem;
    transform: translateY(-150%);
  }

  .skip-link:focus-visible {
    top: 1rem;
    transform: translateY(0);
  }

  .sticky-lead-bar {
    display: none;
  }

  :focus-visible {
    outline: 2px solid #111111;
    outline-offset: 2px;
  }

  .reveal-ready .reveal {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.36s ease,
      transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  .reveal-ready .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-ready .reveal [data-reveal-item] {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.36s ease,
      transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-ready .reveal.is-visible [data-reveal-item] {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-ready .reveal.is-visible [data-reveal-item]:nth-child(1) {
    transition-delay: 0.04s;
  }

  .reveal-ready .reveal.is-visible [data-reveal-item]:nth-child(2) {
    transition-delay: 0.08s;
  }

  .reveal-ready .reveal.is-visible [data-reveal-item]:nth-child(3) {
    transition-delay: 0.12s;
  }

  .reveal-ready .reveal.is-visible [data-reveal-item]:nth-child(4) {
    transition-delay: 0.16s;
  }

  .reveal-ready .reveal.is-visible [data-reveal-item]:nth-child(5) {
    transition-delay: 0.2s;
  }

  @media (max-width: 760px) {
    body.has-sticky-lead {
      padding-bottom: calc(5.8rem + env(safe-area-inset-bottom, 0px));
    }

    body::before,
    body::after {
      filter: none;
      opacity: calc(var(--shape-opacity) * 0.45);
    }

    .sticky-lead-bar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 130;
      display: grid;
      gap: 0.55rem;
      padding: 0.7rem max(1rem, env(safe-area-inset-right, 0px)) calc(0.7rem + env(safe-area-inset-bottom, 0px))
        max(1rem, env(safe-area-inset-left, 0px));
      border-top: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent));
      background: rgba(255, 253, 248, 0.96);
      backdrop-filter: blur(16px);
      box-shadow: 0 -14px 34px rgba(20, 16, 10, 0.08);
      opacity: 0;
      transform: translateY(110%);
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
    }

    body.sticky-bar-visible .sticky-lead-bar {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    html.menu-open .sticky-lead-bar,
    body.cookie-consent-open .sticky-lead-bar {
      opacity: 0;
      transform: translateY(110%);
      pointer-events: none;
    }

    .sticky-lead-context {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.45rem;
      align-items: center;
      margin: 0;
      min-width: 0;
    }

    .sticky-lead-context span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.35rem;
      padding: 0.28rem 0.5rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--accent-soft) 62%, #ffffff);
      color: var(--ink);
      font-size: 0.58rem;
      font-weight: 850;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .sticky-lead-context strong {
      overflow: hidden;
      color: var(--ink);
      font-size: 0.72rem;
      font-weight: 830;
      letter-spacing: -0.01em;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .sticky-lead-actions {
      display: grid;
      grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
      gap: 0.6rem;
      align-items: center;
    }

    .sticky-lead-primary,
    .sticky-lead-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      border-radius: 13px;
      text-decoration: none;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0;
      text-transform: none;
    }

    .sticky-lead-primary {
      padding: 0.84rem 1rem;
      background: var(--accent);
      color: var(--ink);
      box-shadow: var(--shadow-accent);
    }

    .sticky-lead-secondary {
      padding: 0.84rem 0.95rem;
      border: 1px solid color-mix(in srgb, var(--line) 76%, var(--accent));
      background: #fafaf7;
      color: var(--text);
    }

    @media (max-width: 380px) {
      .sticky-lead-context {
        grid-template-columns: 1fr;
        gap: 0.2rem;
      }

      .sticky-lead-context span {
        justify-self: start;
      }
    }

    input,
    select,
    textarea {
      font-size: 16px !important;
    }

    [data-scroll-rail] > * {
      scroll-snap-stop: always;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    .btn {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }
</style>
