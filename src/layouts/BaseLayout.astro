---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Sunelys",
  description = "Sunelys accompagne vos démarches administratives photovoltaïques.",
  structuredData = [],
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const siteUrl = (Astro.site ?? "https://sunelys.fr").toString().replace(/\/$/, "");
const canonical = new URL(path, `${siteUrl}/`).toString();
const ogImage = new URL("/brand/logo-full.svg", `${siteUrl}/`).toString();

const BRANDING_INTENSITY: "subtle" | "bold" = "subtle";
const brandingVars =
  BRANDING_INTENSITY === "subtle"
    ? "--shape-opacity:0.1; --shape-blur:10px; --shape-scale:1.04; --shape-x:110%; --shape-y:8vh; --shape-secondary-opacity:0.06;"
    : "--shape-opacity:0.2; --shape-blur:4px; --shape-scale:1.16; --shape-x:104%; --shape-y:5vh; --shape-secondary-opacity:0.12;";

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/services", label: "Services" },
  { href: "/parcours", label: "Parcours" },
  { href: "/contact", label: "Contact" },
];

const footerLinks = [
  { href: "/gestion-administrative-photovoltaique", label: "Gestion administrative photovoltaïque" },
  { href: "/dossier-consuel-photovoltaique", label: "Dossier Consuel photovoltaïque" },
  { href: "/raccordement-enedis-photovoltaique", label: "Raccordement Enedis photovoltaïque" },
];

const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Sunelys",
    url: siteUrl,
    logo: ogImage,
    email: "contact@sunelys.fr",
    telephone: "+33 6 95 90 79 19",
    address: {
      "@type": "PostalAddress",
      streetAddress: "49, impasse des lauriers",
      postalCode: "83600",
      addressLocality: "Les Adrets de l'Esterel",
      addressCountry: "FR",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sunelys",
    url: siteUrl,
  },
];

const allSchemas = [...baseSchemas, ...structuredData];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#c9ac85" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sunelys" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body style={brandingVars} data-branding-intensity={BRANDING_INTENSITY}>
    <a class="skip-link" href="#contenu">Aller au contenu</a>

    <Header path={path} navLinks={navLinks} ctaHref="/contact" ctaLabel="Réserver un échange" />

    <main id="contenu" class="layout-main">
      <div class="container page-flow">
        <slot />
      </div>
    </main>

    <Footer links={footerLinks} />

    <script>
      window.dataLayer = window.dataLayer || [];
      window.trackEvent = (eventName, params = {}) => {
        window.dataLayer.push({
          event: eventName,
          page_path: window.location.pathname,
          page_title: document.title,
          timestamp: Date.now(),
          ...params,
        });
      };

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const element = event.target.closest("[data-track]");
        if (!element || !window.trackEvent) return;
        window.trackEvent(element.dataset.track, {
          label: element.dataset.trackLabel || (element.textContent || "").trim(),
          href: element.getAttribute("href") || "",
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #efede7;
    --bg-soft: #f6f3ed;
    --surface: #fcfaf6;
    --surface-elevated: #ffffff;
    --text: #191713;
    --text-muted: #656056;
    --line: #d9d1c2;
    --accent: #c9ac85;
    --accent-soft: #e9dcc2;

    --shadow-sm: 0 6px 20px rgba(22, 19, 15, 0.045);
    --shadow-md: 0 18px 44px rgba(22, 19, 15, 0.075);

    --radius-sm: 12px;
    --radius-md: 20px;
    --radius-xl: 34px;

    --max-width: 1180px;
    --section-gap: clamp(2.8rem, 6vw, 6rem);
    --container-padding: clamp(1rem, 3vw, 2.2rem);

    --font-display: "Didot", "Bodoni MT", "Times New Roman", serif;
    --font-sans: "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;

    --step--1: clamp(0.78rem, 0.14vw + 0.74rem, 0.9rem);
    --step-0: clamp(0.98rem, 0.24vw + 0.92rem, 1.12rem);
    --step-1: clamp(1.2rem, 0.5vw + 1.08rem, 1.5rem);
    --step-2: clamp(1.45rem, 0.86vw + 1.24rem, 2rem);
    --step-3: clamp(1.82rem, 1.38vw + 1.42rem, 2.8rem);
    --step-4: clamp(2.2rem, 2.3vw + 1.65rem, 3.95rem);

    /* aliases legacy */
    --color-bg: var(--bg);
    --color-bg-elevated: var(--bg-soft);
    --color-surface: var(--surface);
    --color-text: var(--text);
    --color-text-strong: var(--text);
    --color-muted: var(--text-muted);
    --color-accent: var(--accent);
    --color-cream: var(--accent-soft);
    --color-hairline: var(--line);
    --radius-lg: var(--radius-md);
    --radius-pill: 999px;
    --shadow-ultra: var(--shadow-sm);
    --shadow-soft: var(--shadow-sm);
    --shadow-hover: var(--shadow-md);
    --blur-header: 14px;

    --primary: var(--text);
    --primary-dark: #000000;
    --muted: var(--text-muted);
    --border: var(--line);
    --shadow: var(--shadow-md);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    line-height: 1.5;
    background:
      radial-gradient(120% 90% at -20% -35%, color-mix(in srgb, var(--accent-soft) 55%, transparent), transparent 62%),
      radial-gradient(100% 84% at 120% 118%, color-mix(in srgb, var(--accent-soft) 42%, transparent), transparent 60%),
      var(--bg);
    position: relative;
  }

  body::before,
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  body::before {
    background: url("/brand/shape-clean.svg") no-repeat var(--shape-x) var(--shape-y) / clamp(420px, 58vw, 980px);
    opacity: var(--shape-opacity);
    transform: scale(var(--shape-scale));
    filter: blur(var(--shape-blur));
  }

  body::after {
    background: url("/brand/shape-clean.svg") no-repeat -14% 84vh / clamp(240px, 34vw, 620px);
    opacity: var(--shape-secondary-opacity);
    filter: blur(calc(var(--shape-blur) * 1.1));
  }

  .container {
    width: min(var(--max-width), calc(100% - 2 * var(--container-padding)));
    margin-inline: auto;
  }

  .layout-main {
    padding-top: clamp(0.9rem, 2vw, 1.6rem);
  }

  .page-flow {
    display: grid;
    gap: var(--section-gap);
    padding-bottom: var(--section-gap);
  }

  .section-shell {
    margin: 0;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--text);
    letter-spacing: -0.014em;
    text-wrap: balance;
  }

  p {
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.45rem;
    padding: 0.64rem 1.08rem;
    border-radius: 999px;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      color 170ms ease, border-color 170ms ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .btn-primary {
    background: #15130f;
    color: #fffdfa;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: #090806;
  }

  .btn-secondary {
    background: color-mix(in srgb, var(--surface) 90%, white);
    border-color: var(--line);
    color: var(--text);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
    border-color: color-mix(in srgb, var(--line) 60%, var(--accent));
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 120;
    text-decoration: none;
    background: var(--surface-elevated);
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.48rem 0.72rem;
  }

  .skip-link:focus-visible {
    left: 1rem;
    top: 1rem;
  }

  :focus-visible {
    outline: 2px solid #111111;
    outline-offset: 2px;
  }

  .reveal {
    animation: reveal-up 420ms ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    .reveal,
    .btn {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
