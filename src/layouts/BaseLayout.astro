---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Sunelys",
  description = "Sunelys accompagne vos démarches administratives photovoltaïques.",
  structuredData = [],
  robots = "index,follow",
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const siteUrl = (Astro.site ?? "https://sunelys.fr").toString().replace(/\/$/, "");
const canonical = new URL(path, `${siteUrl}/`).toString();
const ogImage = new URL("/brand/logo-full.svg", `${siteUrl}/`).toString();

const BRANDING_INTENSITY: "subtle" | "bold" = "bold";
const brandingVars =
  BRANDING_INTENSITY === "subtle"
    ? "--shape-opacity:0.08; --shape-blur:16px; --shape-scale:1.02; --shape-x:110%; --shape-y:10vh; --shape-secondary-opacity:0.05;"
    : "--shape-opacity:0.22; --shape-blur:6px; --shape-scale:1.12; --shape-x:102%; --shape-y:4vh; --shape-secondary-opacity:0.13;";

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/services", label: "Services" },
  { href: "/parcours", label: "Parcours" },
  { href: "/contact", label: "Contact" },
];

const footerLinks = [
  { href: "/gestion-administrative-photovoltaique", label: "Gestion administrative photovoltaïque" },
  { href: "/declaration-prealable-panneaux-solaires", label: "Déclaration préalable panneaux solaires" },
  { href: "/dossier-consuel-photovoltaique", label: "Dossier Consuel photovoltaïque" },
  { href: "/raccordement-enedis-photovoltaique", label: "Raccordement Enedis photovoltaïque" },
];

const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Sunelys",
    url: siteUrl,
    logo: ogImage,
    email: "contact@sunelys.fr",
    telephone: "+33 6 95 90 79 19",
    address: {
      "@type": "PostalAddress",
      streetAddress: "49, impasse des lauriers",
      postalCode: "83600",
      addressLocality: "Les Adrets de l'Esterel",
      addressCountry: "FR",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sunelys",
    url: siteUrl,
  },
];

const allSchemas = [...baseSchemas, ...structuredData];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#c9ac85" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sunelys" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      allSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body style={brandingVars} data-branding-intensity={BRANDING_INTENSITY}>
    <a class="skip-link" href="#contenu">Aller au contenu</a>

    <Header path={path} navLinks={navLinks} ctaHref="/contact?source=header-rdv" ctaLabel="Prendre rendez-vous" />

    <main id="contenu" class="layout-main">
      <div class="container page-flow">
        <slot />
      </div>
    </main>

    <Footer links={footerLinks} />

    <script>
      window.dataLayer = window.dataLayer || [];

      const attributionKeys = [
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_term",
        "utm_content",
        "gclid",
        "fbclid",
        "msclkid",
      ];

      const readStoredAttribution = () => {
        try {
          return JSON.parse(localStorage.getItem("sunelys_attribution") || "{}");
        } catch (_error) {
          return {};
        }
      };

      const params = new URLSearchParams(window.location.search);
      const storedAttribution = readStoredAttribution();
      const incomingAttribution = attributionKeys.reduce((acc, key) => {
        const value = params.get(key);
        if (value) acc[key] = value;
        return acc;
      }, {});

      const attribution = {
        landing_page: storedAttribution.landing_page || window.location.pathname,
        first_referrer: storedAttribution.first_referrer || document.referrer || "direct",
        first_seen_at: storedAttribution.first_seen_at || new Date().toISOString(),
        last_page: window.location.pathname,
        last_referrer: document.referrer || storedAttribution.last_referrer || "direct",
        ...storedAttribution,
        ...incomingAttribution,
      };

      localStorage.setItem("sunelys_attribution", JSON.stringify(attribution));

      window.getSunelysAttribution = () => readStoredAttribution();

      window.trackEvent = (eventName, params = {}) => {
        const currentAttribution = readStoredAttribution();
        window.dataLayer.push({
          event: eventName,
          page_path: window.location.pathname,
          page_title: document.title,
          attribution: currentAttribution,
          timestamp: Date.now(),
          ...params,
        });
      };

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const element = event.target.closest("[data-track]");
        if (!element || !window.trackEvent) return;
        window.trackEvent(element.dataset.track, {
          label: element.dataset.trackLabel || (element.textContent || "").trim(),
          href: element.getAttribute("href") || "",
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f3f0e8;
    --bg-soft: #faf6ef;
    --surface: #fdfbf7;
    --surface-elevated: #ffffff;
    --text: #181510;
    --text-muted: #625b4f;
    --line: #d9d0c1;
    --accent: #c5a56f;
    --accent-soft: #efe3c9;

    --shadow-sm: 0 10px 28px rgba(20, 16, 10, 0.06);
    --shadow-md: 0 24px 70px rgba(20, 16, 10, 0.12);

    --radius-sm: 14px;
    --radius-md: 24px;
    --radius-xl: 40px;

    --max-width: 1320px;
    --section-gap: clamp(3.2rem, 7vw, 7rem);
    --container-padding: clamp(1rem, 3.2vw, 2.4rem);

    --font-display: "Didot", "Bodoni MT", "Times New Roman", serif;
    --font-sans: "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;

    --step--1: clamp(0.78rem, 0.14vw + 0.74rem, 0.9rem);
    --step-0: clamp(0.98rem, 0.24vw + 0.92rem, 1.12rem);
    --step-1: clamp(1.2rem, 0.5vw + 1.08rem, 1.5rem);
    --step-2: clamp(1.45rem, 0.86vw + 1.24rem, 2rem);
    --step-3: clamp(1.82rem, 1.38vw + 1.42rem, 2.8rem);
    --step-4: clamp(2.2rem, 2.3vw + 1.65rem, 3.95rem);

    /* aliases legacy */
    --color-bg: var(--bg);
    --color-bg-elevated: var(--bg-soft);
    --color-surface: var(--surface);
    --color-text: var(--text);
    --color-text-strong: var(--text);
    --color-muted: var(--text-muted);
    --color-accent: var(--accent);
    --color-cream: var(--accent-soft);
    --color-hairline: var(--line);
    --radius-lg: var(--radius-md);
    --radius-pill: 999px;
    --shadow-ultra: var(--shadow-sm);
    --shadow-soft: var(--shadow-sm);
    --shadow-hover: var(--shadow-md);
    --blur-header: 14px;

    --primary: var(--text);
    --primary-dark: #000000;
    --muted: var(--text-muted);
    --border: var(--line);
    --shadow: var(--shadow-md);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    line-height: 1.5;
    background:
      radial-gradient(120% 100% at -18% -35%, color-mix(in srgb, var(--accent-soft) 72%, transparent), transparent 58%),
      radial-gradient(100% 86% at 120% 116%, color-mix(in srgb, var(--accent-soft) 56%, transparent), transparent 58%),
      linear-gradient(180deg, #f6f3eb, var(--bg) 42%, #f4f0e8),
      var(--bg);
    position: relative;
  }

  body::before,
  body::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    min-height: 100vh;
    pointer-events: none;
    z-index: -1;
  }

  body::before {
    background: url("/brand/shape-clean.svg") no-repeat var(--shape-x) var(--shape-y) / clamp(420px, 58vw, 980px);
    opacity: var(--shape-opacity);
    transform: scale(var(--shape-scale));
    filter: blur(var(--shape-blur));
  }

  body::after {
    background: url("/brand/shape-clean.svg") no-repeat -14% 84vh / clamp(240px, 34vw, 620px);
    opacity: var(--shape-secondary-opacity);
    filter: blur(calc(var(--shape-blur) * 1.1));
  }

  .container {
    width: min(var(--max-width), calc(100% - 2 * var(--container-padding)));
    margin-inline: auto;
  }

  .layout-main {
    padding-top: clamp(1rem, 2.1vw, 1.9rem);
  }

  .page-flow {
    display: grid;
    gap: var(--section-gap);
    padding-bottom: var(--section-gap);
  }

  .section-shell {
    margin: 0;
    position: relative;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--text);
    letter-spacing: -0.014em;
    text-wrap: balance;
  }

  p {
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.65rem;
    padding: 0.72rem 1.2rem;
    border-radius: 999px;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 0.77rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    transition: transform 170ms ease, box-shadow 170ms ease, background-color 170ms ease,
      color 170ms ease, border-color 170ms ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary {
    background: linear-gradient(180deg, #12100d, #090806);
    color: #fffdfa;
    border-color: #0f0c09;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: linear-gradient(180deg, #181511, #0c0a08);
  }

  .btn-secondary {
    background: color-mix(in srgb, var(--surface) 92%, white);
    border-color: var(--line);
    color: var(--text);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: color-mix(in srgb, var(--accent-soft) 55%, white);
    border-color: color-mix(in srgb, var(--line) 60%, var(--accent));
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 120;
    text-decoration: none;
    background: var(--surface-elevated);
    color: var(--text);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.48rem 0.72rem;
  }

  .skip-link:focus-visible {
    left: 1rem;
    top: 1rem;
  }

  :focus-visible {
    outline: 2px solid #111111;
    outline-offset: 2px;
  }

  .reveal {
    animation: reveal-up 260ms ease both;
  }

  @media (max-width: 760px) {
    body::before,
    body::after {
      filter: none;
      opacity: calc(var(--shape-opacity) * 0.45);
    }

    .reveal {
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    .reveal,
    .btn {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
